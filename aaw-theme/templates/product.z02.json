            "media_image": "shopify://shop_images/CUSTOM-FITMENT_f1dcb5b7-e588-4d3c-8613-35ad154960c2.jpg",
            "column": 1,
            "row": 4,
            "column_mobile": "2",
            "row_mobile": "2",
            "heading": "CUSTOM FITMENT",
            "heading_size": "h5",
            "seo_heading": "h5",
            "description": "AAW achieves exceptional comfort in custom in-ear monitors by using advanced 3D scanning and editing technology. Each customer's ear impressions are digitally scanned to create precise 3D models, which are then optimized for a secure, ergonomic fit. This process ensures CIEMs conform seamlessly to the ear’s contours, delivering unmatched comfort and sound isolation for superior acoustic performance.",
            "content_position": "center",
            "content_alignment": "center",
            "content_width": "large",
            "button_style": "solid",
            "btn_text": "",
            "btn_link": "",
            "column_background": "#efefef",
            "heading_color": "#ffffff",
            "text_color": "#ffffff",
            "heading_color_hover": "#000000",
            "text_color_hover": "#484848",
            "btn_bg_color": "#000000",
            "btn_text_color": "#ffffff",
            "btn_border_color": "#000000",
            "btn_hover_color": "#ffffff",
            "btn_hover_text_color": "#000000",
            "btn_hover_border_color": "#ffffff",
            "background_color": "#000000",
            "background_opacity": 40
          }
        },
        "grid_WwgDa7": {
          "type": "grid",
          "settings": {
            "image_on_hover": false,
            "media_image": "shopify://shop_images/UIEM-FITTMENT_5f41ad49-86d2-4e8a-adeb-bc2045e79933.jpg",
            "column": 3,
            "row": 3,
            "column_mobile": "2",
            "row_mobile": "2",
            "heading": "IMPECCABLE UNIVERSAL FITMENT",
            "heading_size": "h5",
            "seo_heading": "h5",
            "description": "AAW leverages a vast database of thousands of ear impressions collected over the years to design universal-fit in-ear monitors (IEMs) that emulate the comfort and seal of custom-fit models. By analyzing ear anatomy patterns and using advanced 3D modeling and manufacturing techniques, AAW creates ergonomic shells that fit a wide range of ear shapes. Rigorous user testing ensures a secure fit, optimal comfort, and superior acoustic performance, delivering a near-custom experience for audiophiles and professionals alike.",
            "content_position": "center-left",
            "content_alignment": "left",
            "content_width": "small",
