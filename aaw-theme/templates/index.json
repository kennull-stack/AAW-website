    "aaw_home_service_confidence": {
      "type": "custom-liquid",
      "settings": {
        "section_visibility": "always",
        "custom_liquid": "<div class=\"aaw-home-shell\">\n  <section class=\"aaw-home-service-section\" aria-labelledby=\"aaw-home-service-title\">\n    <div class=\"aaw-home-wrap\">\n      <div class=\"aaw-home-section-head\">\n        <div>\n          <p class=\"aaw-home-kicker\">Owner support</p>\n          <h2 id=\"aaw-home-service-title\">Support after the first listen.</h2>\n        </div>\n        <p>AAW supports the practical side of IEM ownership: impressions, fit checks, refits, warranty questions, repairs, and long-term care for custom and universal monitors.</p>\n      </div>\n      <div class=\"aaw-home-service-grid\">\n        <article><span>Fit first</span><h3>Impressions and CIEM fit</h3><p>Guidance for ear impressions, custom shells, and fit expectations before your order begins.</p></article>\n        <article><span>Aftercare</span><h3>Refit and warranty help</h3><p>Support for seal issues, pressure points, warranty questions, and the right service channel.</p></article>\n        <article><span>Long-term use</span><h3>Repair and service</h3><p>Cable, socket, shell, and monitor service questions can be handled through AAW Singapore and authorized dealers.</p></article>\n      </div>\n      <div class=\"aaw-home-actions\"><a class=\"aaw-home-btn\" href=\"/pages/how-to-take-ear-impression\">Ear impression guide</a><a class=\"aaw-home-btn secondary\" href=\"/pages/warranty-refit\">Warranty & refit</a></div>\n    </div>\n  </section>\n</div>",
