        "custom_liquid": "{% assign home_z07 = all_products['z07-in-ear-monitor'] %}\n{{ 'aaw-home-z07.css' | asset_url | stylesheet_tag }}\n<div class=\"aaw-home-shell\">\n  <section class=\"aaw-home-z07-hero\" aria-labelledby=\"aaw-home-identity-title\">\n    <figure class=\"aaw-home-z07-media\">\n      <picture>\n        <source media=\"(max-width: 767px)\" srcset=\"{{ 'z07-monitors-on-beige-marble.jpg' | asset_img_url: '700x' }}\" width=\"1856\" height=\"2304\">\n        <img src=\"{{ 'z07-model-wearing-universal-fit-over-ear-cable.jpg' | asset_img_url: '1600x' }}\" srcset=\"{{ 'z07-model-wearing-universal-fit-over-ear-cable.jpg' | asset_img_url: '1200x' }} 1200w, {{ 'z07-model-wearing-universal-fit-over-ear-cable.jpg' | asset_img_url: '1600x' }} 1600w, {{ 'z07-model-wearing-universal-fit-over-ear-cable.jpg' | asset_img_url: '2000x' }} 2000w\" sizes=\"100vw\" alt=\"AAW Z07 universal in-ear monitor worn over ear, showing the FitMorph adaptive fit and cable routing\" width=\"2528\" height=\"1696\" loading=\"eager\" fetchpriority=\"high\">\n      </picture>\n    </figure>\n    <div class=\"aaw-home-wrap aaw-home-z07-grid\">\n      <div class=\"aaw-home-z07-copy\">\n        <div class=\"aaw-home-brand-identity\"><h1 id=\"aaw-home-identity-title\" class=\"aaw-home-brand-name\">Advanced AcousticWerkes</h1><p class=\"aaw-home-brand-slogan\">Those who listen will find the way.</p><p class=\"aaw-home-brand-intro\">In-ear monitors from Singapore since 2014. Over 30,000 monitors shipped to musicians, audio engineers, and audiophiles in 65 countries.</p></div>\n        <p class=\"aaw-home-kicker\">New universal</p>\n        <h2 id=\"aaw-home-z07-title\" class=\"aaw-home-z07-product-title\"><span class=\"aaw-home-z07-logo-title\"><img src=\"{{ 'z07-logo.svg' | asset_url }}\" alt=\"Z07\" width=\"514\" height=\"204\"></span><span class=\"aaw-home-z07-subtitle\">Tubeless hybrid. Adaptive fit.</span></h2>\n        <p class=\"aaw-home-z07-lead\">No tube between driver and ear. And a shell you can refit later - without ever changing the tuning.</p>\n        <div class=\"aaw-home-actions\"><a class=\"aaw-home-btn\" href=\"/products/z07-in-ear-monitor\">Explore Z07</a><a class=\"aaw-home-btn secondary\" href=\"/collections/z-series\">See the Z Series</a></div>\n      </div>\n    </div>\n  </section>\n</div>",
