        "section_visibility": "always",
        "custom_liquid": "{% assign home_z07 = all_products['z07-in-ear-monitor'] %}\n{{ 'aaw-home-z07.css' | asset_url | stylesheet_tag }}\n<div class=\"aaw-home-shell\">\n  <section class=\"aaw-home-z07-hero\" aria-labelledby=\"aaw-home-identity-title\">\n    <figure class=\"aaw-home-z07-media\">\n      <picture>\n        <source media=\"(max-width: 767px)\" srcset=\"{{ 'z07-monitors-on-beige-marble.jpg' | asset_url }}\">\n        <img src=\"{{ 'z07-model-wearing-universal-fit-over-ear-cable.jpg' | asset_url }}\" alt=\"AAW Z07 tubeless hybrid in-ear monitor worn with FitMorph fit system\" width=\"2528\" height=\"1696\" loading=\"eager\">\n      </picture>\n    </figure>\n    <div class=\"aaw-home-wrap aaw-home-z07-grid\">\n      <div class=\"aaw-home-z07-copy\">\n        <div class=\"aaw-home-brand-identity\"><h1 id=\"aaw-home-identity-title\" class=\"aaw-home-brand-name\">Advanced AcousticWerkes</h1><p class=\"aaw-home-brand-slogan\">Those who listen will find the way.</p><p class=\"aaw-home-brand-intro\">Singapore IEM specialist founded in 2014 by Kevin Wang, crafting custom and universal in-ear monitors for musicians, engineers, and serious listeners.</p></div>\n        <p class=\"aaw-home-kicker\">Featured universal</p>\n        <h2 id=\"aaw-home-z07-title\" class=\"aaw-home-z07-product-title\"><span class=\"aaw-home-z07-logo-title\"><img src=\"{{ 'z07-logo.svg' | asset_url }}\" alt=\"Z07\" width=\"514\" height=\"204\"></span><span class=\"aaw-home-z07-subtitle\">Tubeless Hybrid Reference Monitor</span></h2>\n        <p class=\"aaw-home-z07-lead\">FitMorph adaptive fit meets AAW's tube-free hybrid acoustic core.</p>\n        <div class=\"aaw-home-actions\">\n          <a class=\"aaw-home-btn\" href=\"{% if home_z07 != blank %}{{ home_z07.url }}{% else %}/products/z07-in-ear-monitor{% endif %}\">Explore Z07</a>\n          <a class=\"aaw-home-btn secondary\" href=\"/collections/z-series\">Compare Z Series</a>\n        </div>\n      </div>\n    </div>\n  </section>\n</div>",
