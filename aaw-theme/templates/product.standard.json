    \"returnFees\": \"https://schema.org/ReturnShippingFees\"\n    }\n  },\n  \"additionalProperty\": [\n    {\"@type\": \"PropertyValue\", \"name\": \"Driver Configuration\", \"value\": \"1 dynamic driver plus 4 balanced armature drivers, 5-driver hybrid architecture\"},\n    {\"@type\": \"PropertyValue\", \"name\": \"Dynamic Driver\", \"value\": \"10mm PET diaphragm dynamic woofer\"},\n    {\"@type\": \"PropertyValue\", \"name\": \"Balanced Armature Drivers\", \"value\": \"2 mid balanced armature drivers and 2 super-high balanced armature drivers\"},\n    {\"@type\": \"PropertyValue\", \"name\": \"Passive Crossover\", \"value\": \"3-way passive crossover\"},\n    {\"@type\": \"PropertyValue\", \"name\": \"Voicing Switch\", \"value\": \"TwinCore is a physical two-position acoustic voicing switch on each earpiece that toggles between Blue mode (warmer, fuller bass) and Red mode (brighter, more detailed treble)\"},\n    {\"@type\": \"PropertyValue\", \"name\": \"Pressure System\", \"value\": \"Bass-Flow vent pressure system\"},\n    {\"@type\": \"PropertyValue\", \"name\": \"Sensitivity\", \"value\": \"110dB at 1kHz\"},\n    {\"@type\": \"PropertyValue\", \"name\": \"Impedance\", \"value\": \"12Ohm at 1kHz\"},\n    {\"@type\": \"PropertyValue\", \"name\": \"Total Harmonic Distortion\", \"value\": \"Less than 0.5% at 1kHz\"},\n    {\"@type\": \"PropertyValue\", \"name\": \"Frequency Response Graph\", \"value\": \"Displayed TwinCore blue and red curves are approximately 114dB at 20Hz, 110dB at 1kHz, 112dB around 3kHz, and below 90dB by 20kHz\"},\n    {\"@type\": \"PropertyValue\", \"name\": \"Recommended Drive Power\", \"value\": \"20mW or higher at 32Ohm is recommended; use low or medium gain for noise control\"},\n    {\"@type\": \"PropertyValue\", \"name\": \"Recommended Source\", \"value\": \"Low-output-impedance source below 1Ohm, such as a quality USB-C dongle, DAP, or compact DAC/amp\"},\n    {\"@type\": \"PropertyValue\", \"name\": \"Approximate Weight\", \"value\": \"Approximately 6g per earpiece, 12g per pair without cable\"},\n    {\"@type\": \"PropertyValue\", \"name\": \"Cable Connector\", \"value\": \"2-pin detachable\"},\n    {\"@type\": \"PropertyValue\", \"name\": \"Included Terminations\", \"value\": \"3.5mm stereo, 4.4mm balanced, and USB Type-C\"},\n    {\"@type\": \"PropertyValue\", \"name\": \"Warranty\", \"value\": \"1-year warranty covering manufacturing defects under normal use\"}\n  ]\n}\n</script>\n\n<script type=\"application/ld+json\">\n{\n  \"@context\": \"https://schema.org\",\n  \"@type\": \"BreadcrumbList\",\n  \"itemListElement\": [\n    {\"@type\": \"ListItem\", \"position\": 1, \"name\": \"Home\", \"item\": \"https://www.aaw.me/\"},\n    {\"@type\": \"ListItem\", \"position\": 2, \"name\": \"Z Series\", \"item\": \"https://www.aaw.me/collections/z-series\"},\n    {\"@type\": \"ListItem\", \"position\": 3, \"name\": \"Z05 AuAg Launch Edition\", \"item\": {{ canonical_url | json }}}\n  ]\n}\n</script>\n\n  <aside class=\"z05-floating-price-card\" aria-label=\"Z05 AuAg price and purchase\">\n    <span class=\"name\">Z05 AuAg</span>\n    <strong class=\"price\">{{ product.price | money }}</strong>\n    <img class=\"z05-floating-product\" src=\"{{ 'z05-auag-forged-carbon-faceplate-hero.jpg' | asset_img_url: '1200x' }}\" alt=\"Z05 AuAg main faceplate hero image\" loading=\"lazy\">\n    <span class=\"note\">3.5 / 4.4 / Type-C kit included</span>\n    <a class=\"z05-btn\" href=\"/cart/add?id={{ product.selected_or_first_available_variant.id }}&quantity=1\">Buy Now</a>\n  </aside>\n\n  <form class=\"z05-hero z05-wrap z05-product-form\" method=\"post\" action=\"/cart/add\" enctype=\"multipart/form-data\" aria-label=\"Buy Z05 AuAg\">\n    <input type=\"hidden\" name=\"id\" value=\"{{ product.selected_or_first_available_variant.id }}\">\n    <input type=\"hidden\" name=\"quantity\" value=\"1\">\n    <div class=\"z05-hero-copy\">\n      <div class=\"z05-eyebrow\">AAW Z Series Universal - AuAg Launch Edition</div>\n      <h1 aria-label=\"AAW Z05 AuAg Launch Edition Universal In-Ear Monitor\"><span class=\"z05-title-row\"><span class=\"z05-ai-summary\">Z05</span><img class=\"z05-hero-logo\" src=\"{{ 'z05-logo-mark.png' | asset_img_url: '360x' }}\" alt=\"\" aria-hidden=\"true\" width=\"209\" height=\"90\"><span class=\"z05-auag-word\">AuAg</span></span><span class=\"z05-launch\">Launch Edition</span></h1>\n      <p class=\"z05-dek\">Z05 AuAg is the small universal you reach for when the playlist keeps changing. It keeps the 10mm dynamic-driver punch, adds armature clarity, and lets TwinCore shift the mood without swapping IEMs.</p>\n      <p class=\"z05-brand-slogan\">Those who listen will find the way.</p>\n      <p class=\"z05-hero-price\"><span>Price</span><strong>{{ product.selected_or_first_available_variant.price | money }}</strong></p>\n      {% render 'aaw-judgeme-badge', class_name: 'z05-judge-stars', label: 'Z05 AuAg customer rating' %}\n      <ul class=\"z05-meta\" aria-label=\"Z05 AuAg highlights\">\n        <li>Two listening moods</li><li>Hand-finished AuAg</li><li>10mm dynamic punch</li><li>3.5 / 4.4 / Type-C</li>\n      </ul>\n      <div class=\"z05-actions\"><button class=\"z05-btn\" type=\"submit\">Buy Z05 AuAg</button><a class=\"z05-btn secondary\" href=\"#z05-twincore\">Hear TwinCore</a></div>\n    </div>\n    <div class=\"z05-hero-media\">\n      <img src=\"{{ 'z05-auag-luxury-portrait-hero.png' | asset_img_url: '1024x' }}\" alt=\"Z05 AuAg Launch Edition in a minimalist gold and silver luxury studio setting\" width=\"1024\" height=\"1280\">\n    </div>\n  </form>\n<aside class=\"z05-hero-facts z05-wrap\" aria-label=\"Z05 AuAg product summary\"><div class=\"z05-fact-rail\"><p><strong>Product summary</strong><span>Z05 AuAg Launch Edition is a SGD $429 universal-fit hybrid in-ear monitor from Singapore-based Advanced AcousticWerkes (AAW), built for listeners who move between albums, playlists, portable sources, and focused listening. It uses a 10mm PET dynamic woofer, four balanced-armature drivers, Bass-Flow venting, and a physical TwinCore two-mode crossover and voicing switch for Blue and Red listening modes. The kit includes a 2-pin detachable cable with 3.5mm stereo, 4.4mm balanced, and USB-C terminations, plus a carry case and LiquidMorph ear tips.</span></p><ul><li>SGD $429</li><li>10mm dynamic + 4 BA</li><li>3.5 / 4.4 balanced / USB-C</li><li>Pop / Rock / Electronic / Jazz / Vocal</li></ul></div></aside>\n    <div class=\"z05-stat-strip\"><div class=\"z05-wrap z05-stats\"><div class=\"z05-stat\"><b>TwinCore</b><span>Blue when you want weight and flow. Red when you want the mix to open up and step forward.</span></div><div class=\"z05-stat\"><b>Dynamic Bass</b><span>Kick drums and bass lines have real skin and pressure, not just a lifted low-end shelf.</span></div><div class=\"z05-stat\"><b>Hybrid Detail</b><span>Armatures bring vocal edges, cymbal air, and room cues without thinning out the body.</span></div><div class=\"z05-stat\"><b>AuAg</b><span>Forged-carbon faceplates carry the gold/silver identity; the shells are finished by hand, pair by pair.</span></div></div></div>\n</div>",
