    "z05_product_card": {
      "type": "custom-liquid",
      "settings": {
        "section_visibility": "always",
        "custom_liquid": "<div class=\"z05-feature-shell\"><section class=\"z05-section dark z05-product-card-section\"><div class=\"z05-wrap\"><p class=\"z05-kicker\">At a glance</p><h2>The build behind the listen</h2><article class=\"z05-spec-card\" aria-labelledby=\"z05-spec-card-title\"><header class=\"z05-spec-card-head\"><img class=\"z05-spec-lockup\" src=\"{{ 'z05-auag-logo-lockup.png' | asset_img_url: '1200x' }}\" alt=\"AAW Z05\" loading=\"lazy\"><div class=\"z05-spec-edition\"><h3 id=\"z05-spec-card-title\">AuAg Launch Edition</h3><p>Forged carbon with gold right shell and silver left shell</p></div></header><div class=\"z05-driver-strip\" aria-label=\"Z05 AuAg driver and tuning architecture\"><div class=\"z05-driver-item\"><span class=\"z05-icon z05-icon-woofer\" aria-hidden=\"true\"></span><b>1 x 10mm</b><small>Dynamic Woofer</small></div><div class=\"z05-driver-item\"><span class=\"z05-icon z05-icon-dual z05-icon-mid-ba\" aria-hidden=\"true\"></span><b>2 x</b><small>Mid BA Drivers</small></div><div class=\"z05-driver-item\"><span class=\"z05-icon z05-icon-dual\" aria-hidden=\"true\"></span><b>2 x</b><small>Super-Hi BA Drivers</small></div><div class=\"z05-driver-item\"><span class=\"z05-icon z05-icon-switch\" aria-hidden=\"true\"><i></i></span><b>TwinCore</b><small>Crossover Switch System</small></div></div><div class=\"z05-feature-panel\"><h3>Key Features</h3><ul><li>10mm Dynamic Woofer</li><li>5 Driver Hybrid Architecture</li><li>3 Way Passive Crossover</li><li>Bass-Flow Vent Pressure System</li><li>TwinCore Crossover Switch System</li></ul><div class=\"z05-measurement-grid\" aria-label=\"Z05 AuAg electrical, acoustic, source, and weight measurements\"><article><span>Sensitivity</span><strong>110dB @ 1kHz</strong></article><article><span>Impedance</span><strong>12Ohm @ 1kHz</strong></article><article><span>Total Harmonic Distortion</span><strong>&lt;0.5% @ 1kHz</strong></article><article><span>Recommended Drive Power</span><strong>20mW+ @ 32Ohm</strong></article><article><span>Recommended Source</span><strong>&lt;1Ohm output impedance</strong></article><article><span>Approx. Weight</span><strong>6g each / 12g pair</strong></article></div></div><figure class=\"z05-fr-graph\"><img src=\"{{ 'z05-auag-frequency-response.png' | asset_img_url: '1200x' }}\" alt=\"AAW Z05 AuAg frequency response graph: TwinCore blue and red curves measure approximately 114dB at 20Hz, 110dB at 1kHz, 112dB around 3kHz, and below 90dB by 20kHz\" loading=\"lazy\"><figcaption><strong>Frequency response graph.</strong> The blue and red TwinCore curves are shown from 20Hz to 20kHz: approximately 114dB at 20Hz, 110dB at 1kHz, 112dB around 3kHz, and below 90dB by 20kHz.</figcaption></figure></article></div></section></div>",
