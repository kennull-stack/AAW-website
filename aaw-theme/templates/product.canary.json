    "multicolumn_yK8L3k": {
      "type": "multicolumn",
      "blocks": {
        "column_YqMwcD": {
          "type": "column",
          "settings": {
            "image": "shopify://shop_images/CanaryPro-Exploded.jpg",
            "heading": "Extreme Multi-Driver Matrix (EMDM)",
            "description": "Canary Pro's 14-driver matrix represents the pinnacle of hybrid in-ear monitoring architecture design. It was developed and enhanced based on our acclaimed hybrid system to address coherence and phasing issues that are common when fusing dynamic driver with armature drivers. To achieve this, Canary Pro's EMDM system features a dedicated 3D-printed acoustic chamber to house the isobaric dual dynamic drivers and reshape their characteristics. In addition, the 5-way passive crossover design configures each driver to perform optimally within its designated frequency range, resulting in minimal scrambled phase shift and interference.",
            "link_label": "",
            "link_url": "",
            "column_background": true,
            "column_background_color": "#f2f2f2",
            "column_text_color": "#000000",
            "column_link_color": "#2877ff"
          }
        },
        "column_GTGPDy": {
          "type": "column",
          "settings": {
            "image": "shopify://shop_images/SLFI.png",
            "heading": "Super-Low Flat Impedance (SLFI)",
            "description": "The Canary Pro boasts a meticulously designed 14-driver matrix, featuring SLFI design, that ensures a flat impedance of around  7ohm across its frequency range. To address a long-standing problem in the industry - the dependence on the output impedance of the sound source for accurate earphone output - the Canary Pro changes the character of its Balanced Armature driver from inductive to resistive. This innovative approach has effectively solved this age-old issue, resulting in a more accurate and consistent sound output regardless of the source.",
            "link_label": "",
            "link_url": "",
            "column_background": true,
            "column_background_color": "#f2f2f2",
            "column_text_color": "#000000",
            "column_link_color": "#2877ff"
          }
        }
      },
