ity\": \"https://schema.org/InStock\",\n        \"itemCondition\": \"https://schema.org/NewCondition\",\n        \"seller\": {\"@id\": \"https://www.aaw.me/#organization\"}\n      },\n      \"termsOfService\": \"https://www.aaw.me/pages/warranty-and-refit\"\n    },\n    {\n      \"@type\": \"WebPage\",\n      \"@id\": {{ canonical_url | append: \"#webpage\" | json }},\n      \"url\": {{ canonical_url | json }},\n      \"name\": \"What are Custom In-Ear Monitors?\",\n      \"description\": \"AAW's guide to custom in-ear monitors, including CIEM fit, isolation, driver architecture, shell design, build process, and how custom monitors compare with universal IEMs.\",\n      \"isPartOf\": {\"@id\": \"https://www.aaw.me/#website\"},\n      \"about\": {\"@id\": {{ canonical_url | append: \"#custom-in-ear-monitor\" | json }}},\n      \"breadcrumb\": {\"@id\": {{ canonical_url | append: \"#breadcrumb\" | json }}},\n      \"primaryImageOfPage\": {\n        \"@type\": \"ImageObject\",\n        \"url\": {{ 'aaw-ins-hero-ciem-2026.jpg' | asset_url | prepend: 'https:' | json }},\n        \"caption\": \"AAW custom in-ear monitors photographed for the custom IEM guide\"\n      },\n      \"mainEntity\": [\n        {\"@id\": {{ canonical_url | append: \"#article\" | json }}},\n        {\"@id\": {{ canonical_url | append: \"#custom-iem-service\" | json }}},\n        {\"@id\": {{ canonical_url | append: \"#faq\" | json }}}\n      ],\n      \"inLanguage\": \"en\"\n    },\n    {\n      \"@type\": \"Article\",\n      \"@id\": {{ canonical_url | append: \"#article\" | json }},\n      \"mainEntityOfPage\": {\"@id\": {{ canonical_url | append: \"#webpage\" | json }}},\n      \"headline\": \"What are Custom In-Ear Monitors?\",\n      \"alternativeHeadline\": \"CIEM fit, isolation, build process, and AAW custom monitor craft\",\n      \"description\": \"A comprehensive guide to custom in-ear monitors: how they work, their benefits over universal IEMs, primary use cases, and why AAW builds them