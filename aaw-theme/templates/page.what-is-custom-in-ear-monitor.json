    "ci_hero": {
      "type": "custom-liquid",
      "settings": {
        "section_visibility": "always",
        "custom_liquid": "<div class=\"ci-feature-shell\">\n  <section class=\"ci-hero ci-wrap\">\n    <div class=\"ci-hero-copy\">\n      <p class=\"ci-kicker\">AAW</p>\n      <h1>What are Custom <em>In-Ear Monitors?</em></h1>\n      <p class=\"ci-dek\">A custom in-ear monitor is a private concert hall, hand-built to the geometry of your ear. The shell is yours alone. The tuning is the work of a Singapore atelier that has spent a decade refining how music should feel. This is where the journey to your first AAW custom begins.</p>\n    </div>\n    <div class=\"ci-hero-media\">\n      <img src=\"{{ 'aaw-ins-hero-ciem-2026.jpg' | asset_img_url: '1024x' }}\" alt=\"AAW custom in-ear monitors — the intersection of precision acoustics and personal fit\" width=\"1024\" height=\"1280\" loading=\"eager\">\n    </div>\n  </section>\n  <div class=\"ci-stat-strip\">\n    <div class=\"ci-wrap ci-stats\">\n      <div class=\"ci-stat\"><b>Made to Your Anatomy</b><span>Every shell is 3D-modeled from your own ear impressions. The fit is yours, and only yours — an intimacy mass-produced earphones can never deliver.</span></div>\n      <div class=\"ci-stat\"><b>Sanctuary-Grade Isolation</b><span>Up to 26 dB of the outside world disappears the moment your monitors seat. No batteries, no algorithms — only the music, and you.</span></div>\n      <div class=\"ci-stat\"><b>Architected for Sound</b><span>Balanced armature, dynamic, electrostatic, and hybrid platforms — each crossover hand-tuned so every driver speaks the same story, perfectly in time.</span></div>\n      <div class=\"ci-stat\"><b>Hand-Built in Singapore</b><span>Each pair is finished at 76 Playfair Road by the same artisans behind our flagship monitors. Your signature, your serial number, our craft.</span></div>\n    </div>\n  </div>\n</div>",
        "content_width": "large",
        "text_alignment": "left",
        "color_scheme": "primary",
        "top_space_desktop": 0,
        "bottom_space_desktop": 0,
        "top_space_mobile": 0,
