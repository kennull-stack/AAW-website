    "z05_hero_story": {
      "type": "custom-liquid",
      "settings": {
        "section_visibility": "always",
        "custom_liquid": "<style>\n  .z05-feature-shell{position:relative;width:100vw;margin-left:calc(50% - 50vw);background:#080808;color:#f5f2ea;font-family:inherit;letter-spacing:0;}\n  .z05-feature-shell *{box-sizing:border-box;}\n  .z05-lang-switch{position:absolute;z-index:20;top:14px;left:max(18px,calc((100vw - 1180px)/2));display:inline-flex;gap:2px;padding:3px;border:1px solid rgba(255,255,255,.18);background:rgba(8,8,8,.72);backdrop-filter:blur(10px);}\n  .z05-lang-switch button{appearance:none;border:0;background:transparent;color:#bdb5aa;min-width:38px;height:28px;padding:0 9px;font:inherit;font-size:11px;font-weight:900;letter-spacing:.08em;text-transform:uppercase;cursor:pointer;}\n  .z05-lang-switch button.is-active{background:#e2b768;color:#080808;}\n  .z05-wrap{width:min(1180px,calc(100vw - 36px));margin:0 auto;}\n  .z05-eyebrow{display:flex;align-items:center;gap:10px;margin:0 0 16px;color:#b8b0a2;font-size:12px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;}\n  .z05-eyebrow:before{content:\"\";width:36px;height:1px;background:#d6a756;display:inline-block;}\n  .z05-hero{min-height:68vh;display:grid;grid-template-columns:minmax(320px,.92fr) minmax(420px,1.08fr);gap:34px;align-items:center;padding:56px 0 30px;}\n  .z05-hero-copy{position:relative;z-index:2;}\n  .z05-hero h1{max-width:620px;margin:0;color:#fff;font-size:clamp(52px,6.4vw,92px);line-height:.9;font-weight:800;text-transform:uppercase;letter-spacing:0;}\n  .z05-hero h1 .z05-title-row{display:flex;align-items:center;gap:.2em;color:#fff;line-height:.9;white-space:nowrap;}\n  .z05-hero-logo{display:inline-block;width:auto;height:.78em;max-height:76px;object-fit:contain;transform:translateY(.04em);}\n  .z05-hero h1 .z05-auag-word{display:inline-block;color:#fff;}\n  .z05-hero h1 .z05-launch{display:block;color:#e2b768;font-size:.42em;line-height:1.05;margin-top:10px;}\n  .z05-hero .z05-dek{max-width:560px;margin:20px 0 0;color:#d8d1c7;font-size:clamp(17px,1.55vw,21px);line-height:1.42;} .z05-brand-slogan{margin:16px 0 0;color:#f4e8d0;font-size:14px;line-height:1.5;font-weight:800;text-transform:uppercase;} .z05-brand-slogan span{display:block;color:#b8b0a2;font-weight:700;text-transform:none;}\n  .z05-meta{display:flex;flex-wrap:wrap;gap:10px;margin:24px 0 0;padding:0;list-style:none;color:#f4e8d0;}\n  .z05-meta li{border:1px solid rgba(255,255,255,.18);background:rgba(255,255,255,.06);padding:9px 12px;font-size:12px;font-weight:700;text-transform:uppercase;}\n  .z05-actions{display:flex;flex-wrap:wrap;gap:12px;margin-top:22px;}\n  .z05-btn{display:inline-flex;align-items:center;justify-content:center;min-height:44px;padding:0 17px;border:1px solid #e2b768;text-decoration:none;font-weight:800;text-transform:uppercase;font-size:12px;color:#090909;background:#e2b768;}\n  .z05-btn.secondary{background:transparent;color:#f2e5c5;}\n  .z05-hero-media{position:relative;aspect-ratio:4/5;min-height:0;align-self:center;display:flex;align-items:center;justify-content:center;overflow:hidden;background:linear-gradient(145deg,#171717,#050505);border:1px solid rgba(255,255,255,.12);}\n  .z05-hero-media:before{content:\"AuAg\";position:absolute;top:22px;right:20px;color:rgba(255,255,255,.08);font-size:clamp(72px,11vw,150px);line-height:.8;font-weight:900;letter-spacing:0;}\n  .z05-hero-media img{position:relative;z-index:1;width:100%;height:100%;object-fit:cover;object-position:center bottom;display:block;filter:contrast(1.04) saturate(.98);}\n  .z05-stat-strip{border-top:1px solid rgba(255,255,255,.12);border-bottom:1px solid rgba(255,255,255,.12);background:#0f0f0f;}\n  .z05-stats{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;padding:0;}\n  .z05-stat{padding:22px 20px;background:#151515;min-height:112px;}\n  .z05-stat b{display:block;color:#fff;font-size:23px;line-height:1.05;}\n  .z05-stat span{display:block;margin-top:10px;color:#bdb5aa;font-size:13px;line-height:1.35;}\n  .z05-section{padding:76px 0;background:#f4f1ea;color:#111;}\n  .z05-section.dark{background:#080808;color:#f5f2ea;}\n  .z05-section h2{margin:0;color:inherit;font-size:clamp(32px,5vw,72px);line-height:.95;text-transform:uppercase;letter-spacing:0;}\n  .z05-section p{font-size:17px;line-height:1.62;color:inherit;}\n  .z05-grid-2{display:grid;grid-template-columns:.82fr 1.18fr;gap:46px;align-items:start;}\n  .z05-kicker{margin:0 0 16px;color:#a87725;font-size:12px;font-weight:800;text-transform:uppercase;letter-spacing:.12em;}\n  .z05-number-cards{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:30px;}\n  .z05-number-card{border-top:2px solid #111;padding-top:16px;}\n  .z05-number-card .num{display:block;color:#a87725;font-size:38px;font-weight:900;line-height:1;}\n  .z05-number-card h3{margin:14px 0 8px;font-size:20px;text-transform:uppercase;letter-spacing:0;}\n  .z05-table{width:100%;border-collapse:collapse;background:#fff;box-shadow:0 16px 42px rgba(0,0,0,.08);}\n  .z05-table th,.z05-table td{padding:16px;border-bottom:1px solid #ded8cd;text-align:left;vertical-align:top;font-size:14px;line-height:1.45;}\n  .z05-table th{width:32%;color:#6d4b16;text-transform:uppercase;font-size:12px;letter-spacing:.08em;}\n  .z05-build-card{background:#111;color:#f4eee4;padding:32px;border:1px solid rgba(255,255,255,.12);}\n  .z05-build-card dl{display:grid;grid-template-columns:150px 1fr;gap:0;margin:24px 0 0;}\n  .z05-build-card dt,.z05-build-card dd{margin:0;padding:13px 0;border-bottom:1px solid rgba(255,255,255,.14);font-size:14px;}\n  .z05-build-card dt{color:#bfa46b;text-transform:uppercase;font-weight:800;letter-spacing:.08em;font-size:11px;}\n  .z05-build-card dd{color:#fff;font-weight:700;}\n  .z05-photo-grid{display:grid;grid-template-columns:1.1fr .9fr;gap:14px;margin-top:34px;}\n  .z05-photo-grid .panel{min-height:320px;background:#161616;border:1px solid rgba(255,255,255,.1);overflow:hidden;position:relative;}\n  .z05-photo-grid .panel img{width:100%;height:100%;object-fit:cover;display:block;}\n  .z05-photo-grid .panel .caption{position:absolute;left:14px;right:14px;bottom:14px;background:rgba(0,0,0,.65);color:#f1e5cc;padding:12px;font-size:12px;line-height:1.35;}\n  .z05-copy-stack{display:grid;grid-template-columns:repeat(2,1fr);gap:22px;margin-top:30px;}\n  .z05-copy-stack article{border:1px solid rgba(255,255,255,.15);padding:24px;background:#111;}\n  .z05-copy-stack h3{margin:0 0 12px;color:#fff;font-size:23px;text-transform:uppercase;letter-spacing:0;}\n  .z05-copy-stack p{color:#cfc7bb;margin:0;}\n  .z05-faq{display:grid;gap:14px;margin-top:26px;}\n  .z05-faq details{background:#fff;border:1px solid #ded8cd;padding:18px;}\n  .z05-faq summary{cursor:pointer;font-weight:900;text-transform:uppercase;}\n  .z05-faq p{margin:12px 0 0;color:#2d2923;}\n  .z05-final{background:#0a0a0a;color:#fff;text-align:center;padding:72px 18px;border-top:1px solid rgba(255,255,255,.12);}\n  .z05-final h2{font-size:clamp(34px,6vw,84px);margin:0;text-transform:uppercase;letter-spacing:0;line-height:.95;}\n  .z05-final p{max-width:720px;margin:18px auto 0;color:#d1c8bd;font-size:18px;line-height:1.55;}\n  @media(max-width:900px){.z05-hero,.z05-grid-2,.z05-photo-grid,.z05-copy-stack{grid-template-columns:1fr}.z05-hero{padding-top:46px;min-height:auto}.z05-hero-media{min-height:0}.z05-stats,.z05-number-cards{grid-template-columns:1fr 1fr}.z05-build-card dl{grid-template-columns:1fr}.z05-build-card dt{border-bottom:0;padding-bottom:2px}.z05-build-card dd{padding-top:2px}}\n  @media(max-width:560px){.z05-lang-switch{left:50%;transform:translateX(-50%);top:10px}.z05-wrap{width:min(100% - 24px,1180px)}.z05-hero h1{font-size:46px}.z05-stats,.z05-number-cards{grid-template-columns:1fr}.z05-section{padding:52px 0}.z05-table th,.z05-table td{display:block;width:100%;padding:12px 14px}.z05-table th{padding-bottom:2px}.z05-table td{padding-top:2px}.z05-actions .z05-btn{width:100%;}}\n</style>\n<div class=\"z05-feature-shell\">\n  <div class=\"z05-lang-switch\" role=\"group\" aria-label=\"Z05 language selector\">\n    <button type=\"button\" data-z05-lang=\"en\" class=\"is-active\">EN</button>\n    <button type=\"button\" data-z05-lang=\"zh\">简</button>\n    <button type=\"button\" data-z05-lang=\"zhHant\">繁</button>\n  </div>\n\n<script>\n(function(){\n  const z05Copy = {\"AAW Z Series Universal - AuAg Launch Edition\":[\"AAW Z 系列通用耳机 - AuAg 首发版\",\"AAW Z 系列通用耳機 - AuAg 首發版\"],\"Launch Edition\":[\"首发版\",\"首發版\"],\"Z05 AuAg is the small universal you reach for when the playlist keeps changing. It keeps the 10mm dynamic-driver punch, adds armature clarity, and lets TwinCore shift the mood without swapping IEMs.\":[\"Z05 AuAg 是那种歌单一直变、你还是会顺手拿起来的小型通用耳机。10mm 动圈保留拳拳到肉的低频，动铁补上清晰度，TwinCore 则让听感换个心情，不用换耳机。\",\"Z05 AuAg 是那種歌單一直變、你還是會順手拿起來的小型通用耳機。10mm 動圈保留拳拳到肉的低頻，動鐵補上清晰度，TwinCore 則讓聽感換個心情，不用換耳機。\"],\"Those who listen will find the way.\":[\"善听者，终能找到道路。\",\"善聽者，終能找到道路。\"],\"善听者，终能找到道路。\":[\"Those who listen will find the way.\",\"Those who listen will find the way.\"],\"Two listening moods\":[\"两种听感心情\",\"兩種聽感心情\"],\"Hand-finished AuAg\":[\"手工完成 AuAg 外观\",\"手工完成 AuAg 外觀\"],\"10mm dynamic punch\":[\"10mm 动圈冲击力\",\"10mm 動圈衝擊力\"],\"3.5 / 4.4 / Type-C\":[\"3.5 / 4.4 / Type-C\",\"3.5 / 4.4 / Type-C\"],\"Buy Z05 AuAg\":[\"购买 Z05 AuAg\",\"購買 Z05 AuAg\"],\"Hear TwinCore\":[\"了解 TwinCore\",\"了解 TwinCore\"],\"Blue when you want weight and flow. Red when you want the mix to open up and step forward.\":[\"想要厚度和流动感时用蓝档；想让声音打开、往前一点时用红档。\",\"想要厚度和流動感時用藍檔；想讓聲音打開、往前一點時用紅檔。\"],\"Dynamic Bass\":[\"动圈低频\",\"動圈低頻\"],\"Kick drums and bass lines have real skin and pressure, not just a lifted low-end shelf.\":[\"鼓点和贝斯线有真实的皮感与压力，不只是把低频架高。\",\"鼓點和貝斯線有真實的皮感與壓力，不只是把低頻架高。\"],\"Hybrid Detail\":[\"混合单元细节\",\"混合單元細節\"],\"Armatures bring vocal edges, cymbal air, and room cues without thinning out the body.\":[\"动铁负责把人声边缘、镲片空气感和空间线索带出来，同时不把声音削薄。\",\"動鐵負責把人聲邊緣、鈸片空氣感和空間線索帶出來，同時不把聲音削薄。\"],\"Forged-carbon faceplates carry the gold/silver identity; the shells are finished by hand, pair by pair.\":[\"锻造碳面板承载金/银识别度；腔体则是一副一副手工完成。\",\"鍛造碳面板承載金/銀識別度；腔體則是一副一副手工完成。\"],\"Same monitor, two listening moods\":[\"同一副耳机，两种听感心情\",\"同一副耳機，兩種聽感心情\"],\"Some albums want warmth and weight. Others ask for cleaner edges and a little more air. TwinCore lets Z05 AuAg move between those moods with a real switch on the shell, large enough to nudge by fingernail while the monitors stay in your ears.\":[\"有些专辑需要温度和厚度，有些则需要更清晰的边缘和一点空气感。TwinCore 让 Z05 AuAg 用腔体上的实体开关切换这两种心情，开关够大，耳机不用摘下来也能直接用指甲拨到位。\",\"有些專輯需要溫度和厚度，有些則需要更清晰的邊緣和一點空氣感。TwinCore 讓 Z05 AuAg 用腔體上的實體開關切換這兩種心情，開關夠大，耳機不用摘下來也能直接用指甲撥到位。\"],\"No tool, no tiny recessed slot, no guessing through a phone app. The action has just enough resistance, only two positions, and is easy to find by touch once you know where it sits. Think of it less like a gimmick and more like choosing the right filter, gain, or cartridge flavor before you settle into the record.\":[\"不用工具，不是那种小到难找的凹槽，也不用在手机 app 里猜。手感阻尼刚好，只有两档，知道位置之后可以盲调。它更像是在正式听一张唱片前，选好滤波、增益，或者唱头味道。\",\"不用工具，不是那種小到難找的凹槽，也不用在手機 app 裡猜。手感阻尼剛好，只有兩檔，知道位置之後可以盲調。它更像是在正式聽一張唱片前，選好濾波、增益，或者唱頭味道。\"],\"Blue Mode\":[\"蓝档\",\"藍檔\"],\"Weight / Flow\":[\"厚度 / 流动感\",\"厚度 / 流動感\"],\"A fuller low end, calmer upper harmonics, and a center image that feels easier to sit with for long albums.\":[\"低频更饱满，上方泛音更放松，中心结像更适合慢慢听完整张专辑。\",\"低頻更飽滿，上方泛音更放鬆，中心結像更適合慢慢聽完整張專輯。\"],\"Red Mode\":[\"红档\",\"紅檔\"],\"Focus / Spark\":[\"聚焦 / 亮度\",\"聚焦 / 亮度\"],\"Tighter bass outlines, more forward clarity, and extra cymbal air when you want the mix to open up.\":[\"低频轮廓更收，人声和细节更靠前，想让混音打开时会多一点镲片空气感。\",\"低頻輪廓更收，人聲和細節更靠前，想讓混音打開時會多一點鈸片空氣感。\"],\"Overview\":[\"总览\",\"總覽\"],\"A compact hybrid for people who rotate music\":[\"给不断换歌的人，一副小巧混合单元\",\"給不斷換歌的人，一副小巧混合單元\"],\"Some IEMs are tuned for one perfect demo track. Z05 AuAg is built for the way most of us listen: albums, playlists, dongles, DAPs, desk chains, and a mood that changes by the hour.\":[\"有些耳机像是为了某一首 demo 曲调出来的。Z05 AuAg 更像是为大多数人的真实听法准备：专辑、歌单、小尾巴、播放器、桌面系统，还有随时会变的心情。\",\"有些耳機像是為了某一首 demo 曲調出來的。Z05 AuAg 更像是為大多數人的真實聽法準備：專輯、歌單、小尾巴、播放器、桌面系統，還有隨時會變的心情。\"],\"What it is\":[\"它是什么\",\"它是什麼\"],\"A compact universal hybrid you can live with daily: easy to carry, easy to drive, and serious enough for focused listening.\":[\"一副可以天天带着走的小型通用混合单元：好收纳、好驱动，也认真到足够坐下来专心听。\",\"一副可以天天帶著走的小型通用混合單元：好收納、好驅動，也認真到足夠坐下來專心聽。\"],\"Why AuAg\":[\"为什么是 AuAg\",\"為什麼是 AuAg\"],\"The gold/silver finish gives the launch pair a bit of ceremony without turning it into a display-only object.\":[\"金/银外观给首发版本一点仪式感，但不会让它变成只能摆着看的东西。\",\"金/銀外觀給首發版本一點儀式感，但不會讓它變成只能擺著看的東西。\"],\"What you get\":[\"盒内有什么\",\"盒內有什麼\"],\"A monitor, cable, 3.5mm, 4.4mm balanced, and Type-C terminations, a carry case, and LiquidMorph tips, all ready to go.\":[\"耳机本体、线材、3.5mm、4.4mm 平衡和 Type-C 插头、收纳盒，以及 LiquidMorph 耳套，开盒就能听。\",\"耳機本體、線材、3.5mm、4.4mm 平衡和 Type-C 插頭、收納盒，以及 LiquidMorph 耳套，開盒就能聽。\"],\"For the listener who changes albums before they change gear\":[\"给那些先换专辑、而不是先换器材的人\",\"給那些先換專輯、而不是先換器材的人\"],\"Run it from a phone dongle on the way out, then plug into a balanced player or desktop chain at home. The point is simple: keep the Z05 character with fewer little compromises.\":[\"出门接手机小尾巴，回家接平衡播放器或桌面系统。重点很简单：尽量少妥协，把 Z05 的性格留住。\",\"出門接手機小尾巴，回家接平衡播放器或桌面系統。重點很簡單：盡量少妥協，把 Z05 的性格留住。\"],\"Fit\":[\"佩戴\",\"佩戴\"],\"No custom mold needed with LiquidMorph tips for a seal you can repeat.\":[\"不需要定制耳模，配合 LiquidMorph 耳套就能得到稳定可重复的密封。\",\"不需要訂製耳模，配合 LiquidMorph 耳套就能得到穩定可重複的密封。\"],\"Driver platform\":[\"单元平台\",\"單元平台\"],\"Dynamic-driver body with armature speed and air layered on top.\":[\"动圈负责身体感，动铁补上速度和空气感。\",\"動圈負責身體感，動鐵補上速度和空氣感。\"],\"Source path\":[\"前端路径\",\"前端路徑\"],\"3.5mm, 4.4mm balanced, and Type-C terminations in the box.\":[\"盒内包含 3.5mm、4.4mm 平衡和 Type-C 插头。\",\"盒內包含 3.5mm、4.4mm 平衡和 Type-C 插頭。\"],\"Finish\":[\"外观工艺\",\"外觀工藝\"],\"Forged-carbon faceplates with Au/Ag foil; 3D-printed shells finished by hand with matching foil lacing.\":[\"锻造碳面板带 Au/Ag 箔片；3D 打印腔体再以匹配的金银箔手工装饰。\",\"鍛造碳面板帶 Au/Ag 箔片；3D 列印腔體再以匹配的金銀箔手工裝飾。\"],\"At a glance\":[\"快速看懂\",\"快速看懂\"],\"The build behind the listen\":[\"听感背后的结构\",\"聽感背後的結構\"],\"Listening Notes\":[\"聆听笔记\",\"聆聽筆記\"],\"What you notice when it is in hand\":[\"拿在手上会先注意到这些\",\"拿在手上會先注意到這些\"],\"A few close looks at the parts that change daily listening: the AuAg faceplates, the physical TwinCore switch, the cable system, and the tips that keep the seal honest.\":[\"近看几个真正影响日常使用的地方：AuAg 面板、实体 TwinCore 开关、线材系统，以及让密封稳定的耳套。\",\"近看幾個真正影響日常使用的地方：AuAg 面板、實體 TwinCore 開關、線材系統，以及讓密封穩定的耳套。\"],\"AuAg faceplates\":[\"AuAg 面板\",\"AuAg 面板\"],\"Gold on one side, silver on the other. It is the kind of finish you keep turning under the light before the first track even starts.\":[\"一边是金，一边是银。第一首歌还没开始前，你大概已经会忍不住在光下转几次。\",\"一邊是金，一邊是銀。第一首歌還沒開始前，你大概已經會忍不住在光下轉幾次。\"],\"TwinCore switch\":[\"TwinCore 开关\",\"TwinCore 開關\"],\"A real switch for real mood changes: more body when you want to sink in, more bite when you want to listen closer.\":[\"真正的实体开关，对应真正的听感心情：想沉进去就多一点厚度，想听细一点就多一点咬合和清晰度。\",\"真正的實體開關，對應真正的聽感心情：想沉進去就多一點厚度，想聽細一點就多一點咬合和清晰度。\"],\"Cable kit\":[\"线材套装\",\"線材套裝\"],\"Phone, dongle, DAP, desktop chain. The included terminations cover the sources most of us actually rotate through.\":[\"手机、小尾巴、播放器、桌面系统。附带插头覆盖了大多数人真的会轮着用的前端。\",\"手機、小尾巴、播放器、桌面系統。附帶插頭覆蓋了大多數人真的會輪著用的前端。\"],\"LiquidMorph tips\":[\"LiquidMorph 耳套\",\"LiquidMorph 耳套\"],\"Tip rolling is not decoration here. A better seal means steadier bass, cleaner center image, and less fiddling mid-album.\":[\"这里的换耳套不是装饰。密封更好，低频更稳，中心结像更干净，听到一半也少一点折腾。\",\"這裡的換耳套不是裝飾。密封更好，低頻更穩，中心結像更乾淨，聽到一半也少一點折騰。\"],\"Fitment\":[\"佩戴\",\"佩戴\"],\"A universal fit that still feels settled\":[\"通用腔体，也要戴得稳\",\"通用腔體，也要戴得穩\"],\"The best tuning falls apart if the shell keeps shifting. Z05 AuAg keeps the body compact, routes the cable over-ear, and lets the tip do the sealing work.\":[\"调音再好，腔体一直跑位也会散掉。Z05 AuAg 保持小巧腔体，线材绕耳走，把密封这件事交给耳套做好。\",\"調音再好，腔體一直跑位也會散掉。Z05 AuAg 保持小巧腔體，線材繞耳走，把密封這件事交給耳套做好。\"],\"Real-world fit check\":[\"实际佩戴参考\",\"實際佩戴參考\"],\"The cable takes the strain, the shell sits close, and the tip keeps the bass from wandering.\":[\"线材负责卸力，腔体贴近耳朵，耳套把低频稳住。\",\"線材負責卸力，腔體貼近耳朵，耳套把低頻穩住。\"],\"Over-ear route\":[\"绕耳走线\",\"繞耳走線\"],\"Cable stays put\":[\"线材更稳\",\"線材更穩\"],\"Less tug at the shell when you move, sit, or swap sources.\":[\"走动、坐下、换前端时，腔体受到的拉扯更少。\",\"走動、坐下、換前端時，腔體受到的拉扯更少。\"],\"Compact body\":[\"小巧腔体\",\"小巧腔體\"],\"No custom mold needed\":[\"不需要定制耳模\",\"不需要訂製耳模\"],\"A small universal body that sits naturally instead of trying to fill the whole ear.\":[\"小型通用腔体自然坐进耳朵，而不是硬把整个耳甲腔填满。\",\"小型通用腔體自然坐進耳朵，而不是硬把整個耳甲腔填滿。\"],\"Seal support\":[\"密封支撑\",\"密封支撐\"],\"LiquidMorph tips help lock in bass pressure and center image.\":[\"LiquidMorph 耳套帮助锁住低频压力和中心结像。\",\"LiquidMorph 耳套幫助鎖住低頻壓力和中心結像。\"],\"Craft & Sound\":[\"工艺与声音\",\"工藝與聲音\"],\"Made to be worn, then looked at twice\":[\"先要戴得住，再值得多看两眼\",\"先要戴得住，再值得多看兩眼\"],\"The shell has to disappear before the finish gets to show off. Z05 AuAg starts with a compact universal fit, repeatable seal, and a driver layout that can stay convincing across long sessions.\":[\"外观要好看，但腔体得先让人忘掉它的存在。Z05 AuAg 从小巧通用佩戴、稳定密封和长时间听也站得住的单元布局开始。\",\"外觀要好看，但腔體得先讓人忘掉它的存在。Z05 AuAg 從小巧通用佩戴、穩定密封和長時間聽也站得住的單元佈局開始。\"],\"The forged-carbon look is on the faceplates. The body is a 3D-printed shell, then each pair is dressed by hand with gold and silver foil work. It takes hours because the finish has to feel intentional, not sprinkled on.\":[\"锻造碳效果在面板上。腔体本身是 3D 打印壳体，再由手工做金银箔装饰。每一副都要花时间，因为这个外观应该像被认真安排过，而不是随手撒上去。\",\"鍛造碳效果在面板上。腔體本身是 3D 列印殼體，再由手工做金銀箔裝飾。每一副都要花時間，因為這個外觀應該像被認真安排過，而不是隨手撒上去。\"],\"Faceplate\":[\"面板\",\"面板\"],\"Forged carbon with Au/Ag foil\":[\"锻造碳配 Au/Ag 箔片\",\"鍛造碳配 Au/Ag 箔片\"],\"Shell body\":[\"腔体\",\"腔體\"],\"3D-printed universal monitor shell\":[\"3D 打印通用耳机腔体\",\"3D 列印通用耳機腔體\"],\"Finish time\":[\"制作时间\",\"製作時間\"],\"Hand-laced over hours per pair\":[\"每副需数小时手工装饰\",\"每副需數小時手工裝飾\"],\"Format\":[\"形式\",\"形式\"],\"Universal-fit hybrid in-ear monitor\":[\"通用佩戴混合单元入耳式耳机\",\"通用佩戴混合單元入耳式耳機\"],\"Low End\":[\"低频\",\"低頻\"],\"10mm PET diaphragm dynamic woofer\":[\"10mm PET 振膜动圈低频单元\",\"10mm PET 振膜動圈低頻單元\"],\"Clarity\":[\"清晰度\",\"清晰度\"],\"Mid and super-high BA drivers for vocal edge and air\":[\"中频与超高频动铁负责人声边缘和空气感\",\"中頻與超高頻動鐵負責人聲邊緣和空氣感\"],\"Voice Control\":[\"声底控制\",\"聲底控制\"],\"TwinCore physical voicing switch\":[\"TwinCore 实体调音开关\",\"TwinCore 實體調音開關\"],\"Pressure Flow\":[\"压力流动\",\"壓力流動\"],\"Bass-Flow vent pressure system\":[\"Bass-Flow 低频泄压系统\",\"Bass-Flow 低頻洩壓系統\"],\"Forged-carbon faceplates; 3D-printed shells with hand-laced gold and silver foil finish\":[\"锻造碳面板；3D 打印腔体配手工金银箔装饰\",\"鍛造碳面板；3D 列印腔體配手工金銀箔裝飾\"],\"In The Box\":[\"盒内配件\",\"盒內配件\"],\"2-pin detachable cable, 3.5mm, 4.4mm balanced, Type-C terminations, carrying case, LiquidMorph eartips\":[\"2-pin 可换线、3.5mm、4.4mm 平衡、Type-C 插头、收纳盒、LiquidMorph 耳套\",\"2-pin 可換線、3.5mm、4.4mm 平衡、Type-C 插頭、收納盒、LiquidMorph 耳套\"],\"Shell form, finish, and fit\":[\"腔体、外观与佩戴\",\"腔體、外觀與佩戴\"],\"The finish catches the eye; the compact shell shape is what lets you keep listening.\":[\"外观先抓住视线，小巧腔体则让你能继续听下去。\",\"外觀先抓住視線，小巧腔體則讓你能繼續聽下去。\"],\"Signal Chain Ready\":[\"前端友好\",\"前端友好\"],\"One cable, the sources most of us actually use\":[\"一条线，接上我们真的会用的前端\",\"一條線，接上我們真的會用的前端\"],\"No one wants to buy a new cable on day one. Z05 AuAg ships with the paths that cover the usual rotation: phone, dongle, DAP, and desktop stack.\":[\"没人想第一天就再买一条线。Z05 AuAg 附带的连接方式覆盖了常见轮换：手机、小尾巴、播放器和桌面系统。\",\"沒人想第一天就再買一條線。Z05 AuAg 附帶的連接方式覆蓋了常見輪換：手機、小尾巴、播放器和桌面系統。\"],\"The usual source rotation\":[\"常用前端轮换\",\"常用前端輪換\"],\"Monitors, cable, and terminations in one kit, so the first listen is not delayed by accessory hunting.\":[\"耳机、线材和插头都在一个套装里，第一耳不用先去找配件。\",\"耳機、線材和插頭都在一個套裝裡，第一耳不用先去找配件。\"],\"Portable\":[\"便携\",\"便攜\"],\"Quick analog or digital listening when the phone or laptop is the source.\":[\"手机或电脑做前端时，可以快速走模拟或数字连接。\",\"手機或電腦做前端時，可以快速走類比或數位連接。\"],\"Balanced\":[\"平衡\",\"平衡\"],\"4.4mm ready\":[\"4.4mm 就绪\",\"4.4mm 就緒\"],\"For DAPs and compact DAC/amps when you want the balanced output.\":[\"想用播放器或小型解码耳放的平衡输出时，直接接上。\",\"想用播放器或小型解碼耳放的平衡輸出時，直接接上。\"],\"Monitor side\":[\"耳机端\",\"耳機端\"],\"2-pin detachable\":[\"2-pin 可换线\",\"2-pin 可換線\"],\"A familiar monitor-side connection for long-term cable flexibility.\":[\"熟悉的耳机端接口，长期换线更自由。\",\"熟悉的耳機端接口，長期換線更自由。\"],\"Buy Now\":[\"立即购买\",\"立即購買\"],\"Seal & Comfort\":[\"密封与舒适\",\"密封與舒適\"],\"The tip is part of the tuning\":[\"耳套也是调音的一部分\",\"耳套也是調音的一部分\"],\"With a dynamic woofer, seal is not a footnote. When the tip sits right, bass weight, vocal center, and left-right balance stop changing every time you move.\":[\"对动圈耳机来说，密封不是注脚。耳套坐对了，低频重量、人声中心和左右平衡才不会一动就变。\",\"對動圈耳機來說，密封不是註腳。耳套坐對了，低頻重量、人聲中心和左右平衡才不會一動就變。\"],\"Clear outer form, teal inner bore\":[\"透明外缘，湖绿色内管\",\"透明外緣，湖綠色內管\"],\"Soft enough for comfort, structured enough to keep the bore stable.\":[\"外层够柔软，内管也有足够支撑，让声音通道保持稳定。\",\"外層夠柔軟，內管也有足夠支撐，讓聲音通道保持穩定。\"],\"Size tray within reach\":[\"尺寸托盘就在手边\",\"尺寸托盤就在手邊\"],\"Because the right tip is often the difference between 'good' and 'there it is.'\":[\"因为合适的耳套，往往就是“还不错”和“对了”的区别。\",\"因為合適的耳套，往往就是「還不錯」和「對了」的區別。\"],\"Clear flange\":[\"透明外缘\",\"透明外緣\"],\"Rounded, transparent silicone that settles without feeling bulky.\":[\"圆润透明的硅胶，贴合但不显得笨重。\",\"圓潤透明的矽膠，貼合但不顯得笨重。\"],\"Teal bore\":[\"湖绿色内管\",\"湖綠色內管\"],\"A steadier inner path so the low end does not collapse when the shell shifts.\":[\"更稳定的内侧通道，让腔体轻微移动时低频不容易塌掉。\",\"更穩定的內側通道，讓腔體輕微移動時低頻不容易塌掉。\"],\"Size tray\":[\"尺寸托盘\",\"尺寸托盤\"],\"Easy tip checks before a long session, not a loose bag of parts.\":[\"长时间听之前快速确认耳套尺寸，而不是在一袋散件里翻找。\",\"長時間聽之前快速確認耳套尺寸，而不是在一袋散件裡翻找。\"],\"FAQ\":[\"常见问题\",\"常見問題\"],\"A few notes before you hit play\":[\"按下播放前，先看几条\",\"按下播放前，先看幾條\"],\"The short version for anyone deciding whether this belongs in the daily rotation.\":[\"如果你在想它适不适合进入日常轮换，先看这个短版。\",\"如果你在想它適不適合進入日常輪換，先看這個短版。\"],\"What does AuAg mean?\":[\"AuAg 是什么意思？\",\"AuAg 是什麼意思？\"],\"Au is gold, Ag is silver. On this launch edition, the identity is split left/right: gold and silver accents over the hand-finished shell work, with forged-carbon faceplates doing the visual heavy lifting.\":[\"Au 是金，Ag 是银。这个首发版把左右耳做成金/银识别，手工完成的腔体上有对应装饰，锻造碳面板负责主要视觉张力。\",\"Au 是金，Ag 是銀。這個首發版把左右耳做成金/銀識別，手工完成的腔體上有對應裝飾，鍛造碳面板負責主要視覺張力。\"],\"Is this only a cosmetic edition?\":[\"它只是外观版本吗？\",\"它只是外觀版本嗎？\"],\"No. The finish gets attention first, but the reason to stay is the Z05 platform: dynamic bass, BA clarity, Bass-Flow pressure control, and TwinCore voicing.\":[\"不是。外观会先抓住注意力，但真正留下来的理由是 Z05 平台：动圈低频、动铁清晰度、Bass-Flow 压力控制和 TwinCore 调音。\",\"不是。外觀會先抓住注意力，但真正留下來的理由是 Z05 平台：動圈低頻、動鐵清晰度、Bass-Flow 壓力控制和 TwinCore 調音。\"],\"What does the TwinCore switch change?\":[\"TwinCore 开关改变什么？\",\"TwinCore 開關改變什麼？\"],\"It changes the overall voicing. Blue leans fuller and easier; red leans cleaner and more awake. It feels broader than a simple bass bump.\":[\"它改变的是整体声底。蓝档更饱满、更放松；红档更干净、更清醒。它不像单纯加一点低频，而是整个听感的变化。\",\"它改變的是整體聲底。藍檔更飽滿、更放鬆；紅檔更乾淨、更清醒。它不像單純加一點低頻，而是整個聽感的變化。\"],\"What cable is included?\":[\"附带什么线材？\",\"附帶什麼線材？\"],\"Z05 AuAg includes a 2-pin detachable cable, 3.5mm stereo, 4.4mm balanced, and Type-C terminations, plus LiquidMorph tips so you can get the seal right from the first session.\":[\"Z05 AuAg 附带 2-pin 可换线、3.5mm 单端、4.4mm 平衡和 Type-C 插头，也包含 LiquidMorph 耳套，让第一耳就更容易找到合适密封。\",\"Z05 AuAg 附帶 2-pin 可換線、3.5mm 單端、4.4mm 平衡和 Type-C 插頭，也包含 LiquidMorph 耳套，讓第一耳就更容易找到合適密封。\"],\"Choose the mood, keep the monitor\":[\"换的是心情，留下的是同一副耳机\",\"換的是心情，留下的是同一副耳機\"],\"A launch-edition Z05 with real low-end body, armature detail, and a physical switch for the way your listening mood actually changes.\":[\"一副首发版 Z05：有真实低频身体感，有动铁细节，也有一个实体开关，跟得上你真正会变化的听歌心情。\",\"一副首發版 Z05：有真實低頻身體感，有動鐵細節，也有一個實體開關，跟得上你真正會變化的聽歌心情。\"]};\n  const langs = {en:0, zh:1, zhHant:2};\n  const storageKey = 'z05ProductLang';\n  const records = [];\n  function ready(fn){document.readyState === 'loading' ? document.addEventListener('DOMContentLoaded', fn) : fn();}\n  function collect(){\n    const roots = document.querySelectorAll('.z05-feature-shell');\n    roots.forEach(function(root){\n      const walker = document.createTreeWalker(root, NodeFilter.SHOW_TEXT, {\n        acceptNode: function(node){\n          const parent = node.parentElement;\n          if(!parent || parent.closest('style,script,.z05-lang-switch')) return NodeFilter.FILTER_REJECT;\n          const trimmed = node.nodeValue.replace(/\\s+/g,' ').trim();\n          return z05Copy[trimmed] ? NodeFilter.FILTER_ACCEPT : NodeFilter.FILTER_SKIP;\n        }\n      });\n      let node;\n      while((node = walker.nextNode())){\n        records.push({node:node,en:node.nodeValue.replace(/\\s+/g,' ').trim()});\n      }\n    });\n  }\n  function applyLang(lang){\n    const index = langs[lang] || 0;\n    records.forEach(function(record){\n      record.node.nodeValue = index === 0 ? record.en : z05Copy[record.en][index - 1];\n    });\n    document.querySelectorAll('[data-z05-lang]').forEach(function(button){\n      const active = button.getAttribute('data-z05-lang') === lang;\n      button.classList.toggle('is-active', active);\n      button.setAttribute('aria-pressed', active ? 'true' : 'false');\n    });\n    document.documentElement.setAttribute('data-z05-lang', lang);\n    try{localStorage.setItem(storageKey, lang);}catch(e){}\n  }\n  ready(function(){\n    collect();\n    document.querySelectorAll('[data-z05-lang]').forEach(function(button){\n      button.addEventListener('click', function(){applyLang(button.getAttribute('data-z05-lang'));});\n    });\n    let saved = 'en';\n    try{saved = localStorage.getItem(storageKey) || 'en';}catch(e){}\n    if(!langs.hasOwnProperty(saved)) saved = 'en';\n    applyLang(saved);\n  });\n})();\n</script>\n\n  <section class=\"z05-hero z05-wrap\">\n    <div class=\"z05-hero-copy\">\n      <div class=\"z05-eyebrow\">AAW Z Series Universal - AuAg Launch Edition</div>\n      <h1><span class=\"z05-title-row\"><img class=\"z05-hero-logo\" src=\"{{ 'z05-logo-mark.png' | asset_url }}\" alt=\"Z05\"><span class=\"z05-auag-word\">AuAg</span></span><span class=\"z05-launch\">Launch Edition</span></h1>\n      <p class=\"z05-dek\">Z05 AuAg is the small universal you reach for when the playlist keeps changing. It keeps the 10mm dynamic-driver punch, adds armature clarity, and lets TwinCore shift the mood without swapping IEMs.</p>\n      <p class=\"z05-brand-slogan\">Those who listen will find the way.<span>善听者，终能找到道路。</span></p>\n      <ul class=\"z05-meta\" aria-label=\"Z05 AuAg highlights\">\n        <li>Two listening moods</li><li>Hand-finished AuAg</li><li>10mm dynamic punch</li><li>3.5 / 4.4 / Type-C</li>\n      </ul>\n      <div class=\"z05-actions\"><a class=\"z05-btn\" href=\"/cart/add?id={{ product.selected_or_first_available_variant.id }}&quantity=1\">Buy Z05 AuAg</a><a class=\"z05-btn secondary\" href=\"#z05-twincore\">Hear TwinCore</a></div>\n    </div>\n    <div class=\"z05-hero-media\">\n      <img src=\"{{ 'z05-auag-luxury-portrait-hero.png' | asset_url }}\" alt=\"Z05 AuAg Launch Edition in a minimalist gold and silver luxury studio setting\">\n    </div>\n  </section>\n  <div class=\"z05-stat-strip\"><div class=\"z05-wrap z05-stats\"><div class=\"z05-stat\"><b>TwinCore</b><span>Blue when you want weight and flow. Red when you want the mix to open up and step forward.</span></div><div class=\"z05-stat\"><b>Dynamic Bass</b><span>Kick drums and bass lines have real skin and pressure, not just a lifted low-end shelf.</span></div><div class=\"z05-stat\"><b>Hybrid Detail</b><span>Armatures bring vocal edges, cymbal air, and room cues without thinning out the body.</span></div><div class=\"z05-stat\"><b>AuAg</b><span>Forged-carbon faceplates carry the gold/silver identity; the shells are finished by hand, pair by pair.</span></div></div></div>\n</div>",
