                                                          "custom_liquid":  "\u003cdiv class=\"z05-feature-shell\"\u003e\u003csection class=\"z05-section dark z05-gallery-section\"\u003e\u003cdiv class=\"z05-wrap\"\u003e\u003cp class=\"z05-kicker\"\u003eLaunch Image Set\u003c/p\u003e\u003ch2\u003eAuAg Launch Edition details\u003c/h2\u003e\u003cp class=\"z05-gallery-lead\"\u003eA closer look at the gold/silver forged carbon finish, TwinCore switch, swappable cable terminations, and LiquidMorph fit system.\u003c/p\u003e\u003cdiv class=\"z05-gallery-grid\"\u003e\u003cfigure\u003e\u003cimg src=\"{{ \u0027z05-auag-forged-carbon-faceplate-hero.jpg\u0027 | asset_url }}\" alt=\"Z05 AuAg faceplate hero image\" loading=\"lazy\"\u003e\u003cfigcaption\u003eAuAg faceplate hero\u003c/figcaption\u003e\u003c/figure\u003e\u003cfigure\u003e\u003cimg src=\"{{ \u0027z05-auag-gold-silver-faceplate-pair.jpg\u0027 | asset_url }}\" alt=\"Z05 AuAg gold and silver faceplates\" loading=\"lazy\"\u003e\u003cfigcaption\u003eGold right, silver left\u003c/figcaption\u003e\u003c/figure\u003e\u003cfigure\u003e\u003cimg src=\"{{ \u0027z05-auag-twincore-switch-closeup.jpg\u0027 | asset_url }}\" alt=\"Z05 AuAg TwinCore switch close-up\" loading=\"lazy\"\u003e\u003cfigcaption\u003eTwinCore switch\u003c/figcaption\u003e\u003c/figure\u003e\u003cfigure\u003e\u003cimg src=\"{{ \u0027z05-auag-angled-shell-profile.jpg\u0027 | asset_url }}\" alt=\"Z05 AuAg angled shell view\" loading=\"lazy\"\u003e\u003cfigcaption\u003eUniversal shell angle\u003c/figcaption\u003e\u003c/figure\u003e\u003cfigure\u003e\u003cimg src=\"{{ \u0027z05-auag-swappable-cable-terminations.jpg\u0027 | asset_url }}\" alt=\"Z05 AuAg cable and swappable terminations\" loading=\"lazy\"\u003e\u003cfigcaption\u003eSwappable terminations\u003c/figcaption\u003e\u003c/figure\u003e\u003cfigure\u003e\u003cimg src=\"{{ \u0027z05-auag-complete-package-flatlay.jpg\u0027 | asset_url }}\" alt=\"Z05 AuAg full package flatlay\" loading=\"lazy\"\u003e\u003cfigcaption\u003eFull package flatlay\u003c/figcaption\u003e\u003c/figure\u003e\u003cfigure\u003e\u003cimg src=\"{{ \u0027z05-auag-package-with-liquidmorph-tray.jpg\u0027 | asset_url }}\" alt=\"Z05 AuAg cable monitors and eartip tray\" loading=\"lazy\"\u003e\u003cfigcaption\u003eAccessories and fit system\u003c/figcaption\u003e\u003c/figure\u003e\u003cfigure\u003e\u003cimg src=\"{{ \u0027z05-auag-liquidmorph-accessory-tray.jpg\u0027 | asset_url }}\" alt=\"Z05 AuAg LiquidMorph eartip tray\" loading=\"lazy\"\u003e\u003cfigcaption\u003eLiquidMorph tray\u003c/figcaption\u003e\u003c/figure\u003e\u003c/div\u003e\u003c/div\u003e\u003c/section\u003e\u003c/div\u003e\u003cstyle\u003e.z05-gallery-section .z05-gallery-lead{max-width:820px;color:#d8d1c7}.z05-gallery-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-top:32px}.z05-gallery-grid figure{margin:0;position:relative;overflow:hidden;background:#111;border:1px solid rgba(255,255,255,.13);min-height:220px}.z05-gallery-grid img{width:100%;height:100%;min-height:220px;object-fit:cover;display:block;transition:transform .35s ease}.z05-gallery-grid figure:hover img{transform:scale(1.025)}.z05-gallery-grid figcaption{position:absolute;left:10px;right:10px;bottom:10px;background:rgba(0,0,0,.66);border:1px solid rgba(255,255,255,.12);color:#f2e5c5;padding:9px 10px;font-size:12px;line-height:1.25;text-transform:uppercase;font-weight:800;letter-spacing:.04em}@media(max-width:980px){.z05-gallery-grid{grid-template-columns:repeat(2,1fr)}}@media(max-width:560px){.z05-gallery-grid{grid-template-columns:1fr}.z05-gallery-grid figure,.z05-gallery-grid img{min-height:260px}}\u003c/style\u003e"
                                                      }
