                     "z05_liquidmorph":  {
                                             "type":  "custom-liquid",
                                             "settings":  {
                                                              "section_visibility":  "always",
                                                              "custom_liquid":  "\u003cdiv class=\"z05-feature-shell\"\u003e\u003csection class=\"z05-section z05-liquidmorph-section\"\u003e\u003cdiv class=\"z05-wrap z05-grid-2\"\u003e\u003cdiv\u003e\u003cp class=\"z05-kicker\"\u003eIncluded Fit System\u003c/p\u003e\u003ch2\u003eLiquidMorph eartips\u003c/h2\u003e\u003cp\u003eZ05 AuAg ships with LiquidMorph eartips: clear, soft-sealing tips chosen to help the monitor keep its bass shape, isolation, and comfort without making the accessory kit feel crowded.\u003c/p\u003e\u003ctable class=\"z05-table\"\u003e\u003ctr\u003e\u003cth\u003eIncluded tip system\u003c/th\u003e\u003ctd\u003eLiquidMorph eartips\u003c/td\u003e\u003c/tr\u003e\u003ctr\u003e\u003cth\u003eWhy it matters\u003c/th\u003e\u003ctd\u003eA stable seal helps bass texture, vocal body, and channel balance stay consistent from session to session.\u003c/td\u003e\u003c/tr\u003e\u003ctr\u003e\u003cth\u003eDaily fit\u003c/th\u003e\u003ctd\u003eSoft universal comfort for portable listening, commuting, and longer album sessions.\u003c/td\u003e\u003c/tr\u003e\u003c/table\u003e\u003c/div\u003e\u003cdiv class=\"z05-liquidmorph-media\"\u003e\u003cimg src=\"{{ \u0027z05-liquidmorph-clear-eartips-closeup.jpg\u0027 | asset_url }}\" alt=\"LiquidMorph eartips included with Z05 AuAg\" loading=\"lazy\"\u003e\u003cdiv class=\"caption\"\u003eThe clear LiquidMorph flange and teal inner bore show the soft-sealing eartip shape included with Z05 AuAg.\u003c/div\u003e\u003c/div\u003e\u003c/div\u003e\u003c/section\u003e\u003c/div\u003e\u003cstyle\u003e.z05-liquidmorph-section{background:#0b0c0b;color:#f5f2ea}.z05-liquidmorph-section h2{max-width:680px}.z05-liquidmorph-section p{color:#d8d1c7}.z05-liquidmorph-section .z05-table{margin-top:24px;background:#141414;box-shadow:none}.z05-liquidmorph-section .z05-table th,.z05-liquidmorph-section .z05-table td{border-bottom:1px solid rgba(255,255,255,.14);color:#f4eee4}.z05-liquidmorph-section .z05-table th{color:#83d9d0}.z05-liquidmorph-media{position:relative;min-height:480px;overflow:hidden;border:1px solid rgba(255,255,255,.14);background:#050505}.z05-liquidmorph-media img{display:block;width:100%;height:100%;min-height:480px;object-fit:cover}.z05-liquidmorph-media .caption{position:absolute;left:16px;right:16px;bottom:16px;background:rgba(0,0,0,.68);border:1px solid rgba(255,255,255,.14);padding:13px;color:#e5f7f5;font-size:13px;line-height:1.4}@media(max-width:900px){.z05-liquidmorph-media,.z05-liquidmorph-media img{min-height:340px}}\u003c/style\u003e",
