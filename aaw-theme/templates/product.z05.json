    "z05_liquidmorph": {
      "type": "custom-liquid",
      "settings": {
        "section_visibility": "always",
        "custom_liquid": "<div class=\"z05-feature-shell\"><section class=\"z05-section z05-liquidmorph-section\"><div class=\"z05-wrap\"><div class=\"z05-liquidmorph-head\"><div><p class=\"z05-kicker\">Seal & Comfort</p><h2>The tip is part of the tuning</h2></div><p>With a dynamic woofer, seal is not a footnote. When the tip sits right, bass weight, vocal center, and left-right balance stop changing every time you move.</p></div><div class=\"z05-liquidmorph-showcase\"><figure class=\"z05-liquidmorph-primary\"><img src=\"{{ 'z05-liquidmorph-clear-eartips-closeup.jpg' | asset_url }}\" alt=\"LiquidMorph clear eartips with teal inner bore\" loading=\"lazy\"><figcaption><b>Clear outer form, teal inner bore</b><span>Soft enough for comfort, structured enough to keep the bore stable.</span></figcaption></figure><figure class=\"z05-liquidmorph-tray\"><img src=\"{{ 'z05-auag-liquidmorph-accessory-tray.jpg' | asset_url }}\" alt=\"Z05 AuAg LiquidMorph eartip tray\" loading=\"lazy\"><figcaption><b>Size tray within reach</b><span>Because the right tip is often the difference between 'good' and 'there it is.'</span></figcaption></figure></div><div class=\"z05-fit-panel\"><article><span>Clear flange</span><b>Rounded, transparent silicone that settles without feeling bulky.</b></article><article><span>Teal bore</span><b>A steadier inner path so the low end does not collapse when the shell shifts.</b></article><article><span>Size tray</span><b>Easy tip checks before a long session, not a loose bag of parts.</b></article></div></div></section></div><style>.z05-liquidmorph-section{background:#0b0c0b;color:#f5f2ea}.z05-liquidmorph-head{display:grid;grid-template-columns:minmax(0,1fr) minmax(360px,.72fr);gap:36px;align-items:end}.z05-liquidmorph-head h2{max-width:900px;font-size:clamp(36px,4.6vw,66px);overflow-wrap:normal;word-break:normal;hyphens:none}.z05-liquidmorph-head>p{margin:0;color:#d8d1c7;font-size:17px;line-height:1.62}.z05-liquidmorph-showcase{display:grid;grid-template-columns:1.08fr .92fr;gap:14px;margin-top:34px}.z05-liquidmorph-showcase figure{margin:0;position:relative;overflow:hidden;background:#060706;border:1px solid rgba(255,255,255,.14);min-height:500px}.z05-liquidmorph-showcase img{display:block;width:100%;height:100%;min-height:500px}.z05-liquidmorph-primary img{object-fit:contain;padding:28px;background:linear-gradient(145deg,#101211,#050505)}.z05-liquidmorph-tray img{object-fit:cover;object-position:center}.z05-liquidmorph-showcase figcaption{position:absolute;left:14px;right:14px;bottom:14px;background:rgba(0,0,0,.74);border:1px solid rgba(255,255,255,.14);padding:13px;color:#e5f7f5}.z05-liquidmorph-showcase b{display:block;font-size:12px;line-height:1.15;text-transform:uppercase;letter-spacing:.06em}.z05-liquidmorph-showcase span{display:block;margin-top:7px;color:#d6e4e1;font-size:12px;line-height:1.38}.z05-fit-panel{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;margin-top:14px;background:rgba(255,255,255,.16);border:1px solid rgba(255,255,255,.16)}.z05-fit-panel article{background:#121313;padding:22px;min-height:128px}.z05-fit-panel span{display:block;margin-bottom:12px;color:#83d9d0;font-size:11px;font-weight:900;text-transform:uppercase;letter-spacing:.08em}.z05-fit-panel b{display:block;color:#fff;font-size:16px;line-height:1.35}@media(max-width:980px){.z05-liquidmorph-head{grid-template-columns:1fr}.z05-liquidmorph-showcase{grid-template-columns:1fr 1fr}.z05-liquidmorph-showcase figure,.z05-liquidmorph-showcase img{min-height:380px}.z05-fit-panel{grid-template-columns:1fr}}@media(max-width:640px){.z05-liquidmorph-showcase{grid-template-columns:1fr}.z05-liquidmorph-showcase figure,.z05-liquidmorph-showcase img{min-height:320px}.z05-liquidmorph-primary img{padding:16px}.z05-liquidmorph-showcase figcaption{position:static;margin:10px;background:#090909}.z05-liquidmorph-head h2{font-size:36px}}</style>",
