
<link  rel="preload" as="style" href="{{ 'slideshow.css' | asset_url }}">
{{ 'slideshow.css' | asset_url | stylesheet_tag }}
 
<div class="section-container {{ section.settings.color_scheme }}-scheme {% if section.settings.enable_full_width == false  and section.settings.enable_compact_width == true %} compact-view {% endif %}" {% if section.settings.enable_block_color %}style="--body-background:{% if section.blocks.first.settings.color_scheme.settings.gradient_bg_color != blank  %}{{  section.blocks.first.settings.color_scheme.settings.gradient_bg_color }}{% else %}{{ section.blocks.first.settings.color_scheme.settings.bg_color}}{% endif %}"{% endif %}>
    {% if section.settings.enable_full_width == false  and section.settings.enable_compact_width == false %}
        <div class="{{ settings.container_width }}">
    {% endif %}
    <div class="slideshow-mainbox {% if section.settings.show_arrow_hover%} arrow-hover{% endif %}">
      <div class="slider slideshow-outer slideshow-outer-{{ section.id }} {% if section.settings.slider_transition == 'fade' %} slider-zoom-out {% endif %}{% if section.settings.enable_block_color %} block-color-enable{% endif %} {% if section.settings.banner_marquee %} slider-marquee-enabled {% endif %}"
          data-slides-length="{{ section.blocks.size }}"
          data-sl-slider
          data-slick='{
              "slidesToShow": 1,
              "lazyLoad": "progressive",
              "fade":{% if section.settings.slider_transition == 'fade' %}true{% else %}false{% endif %},
              "cssEase": "ease-in-out",
              "infinite":true,
              "autoplay": {%- if section.settings.auto_rotate -%}true{%- else -%}false{%- endif -%},
              "autoplaySpeed": {{ section.settings.interval | times: 1000 }},
              {% if section.settings.navigation_type != 'none' %}
              "arrows": {% if section.settings.navigation_type == 'arrow' %}true{% else %}false{% endif %},
              "dots": {% if section.settings.navigation_type == 'dots' %}true{% else %}false{% endif %},
              {% endif %}
              "appendArrows": "#slideshow-arrow-container-{{ section.id }}"
              }'> 
          {% for block in section.blocks %} 
              {% capture slideImage %}
                  {% liquid
                  assign mobileImage = false
              
                  if block.settings.image_mobile != blank
                      assign mobileImage = true
                      assign mobileClass = 'mobile-img d-block d-md-none'
                      if forloop.first
                          assign height = block.settings.image_mobile.width | divided_by: block.settings.image_mobile.aspect_ratio | round
                          assign sizes = '100vw'
                          assign widths = '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
                          if section.index == 1
                              assign fetch_priority = 'high'
                          endif
                              echo block.settings.image_mobile | image_url: width: 3840 | image_tag: height: height,class: mobileClass, sizes: sizes, widths: widths, fetchpriority: fetch_priority

                      else
                      
                          render 'image', image: block.settings.image_mobile, class: mobileClass
                      endif
                  endif
                  assign desktopClass = ''
                  if mobileImage
                      assign desktopClass = 'd-none d-md-block'
                  endif
                  if block.settings.image_desktop != blank

                      if forloop.first
                          assign height = block.settings.image_desktop.width | divided_by: block.settings.image_desktop.aspect_ratio | round
                          assign sizes = '100vw'
                          assign widths = '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
                      
                          if section.index == 1
                              assign fetch_priority = 'high'
                          endif
                          echo block.settings.image_desktop | image_url: width: 3840 | image_tag: height: height,class: desktopClass, sizes: sizes, widths: widths, fetchpriority: fetch_priority
              
                      else
                          render 'image', image: block.settings.image_desktop, class: desktopClass
                      endif
                  elsif block.settings.image_desktop == blank and mobileImage
                      assign placeholderClass = 'placeholder-svg d-none d-md-block'
                      echo   'hero-apparel-2' | placeholder_svg_tag: placeholderClass 
                  else
                      assign placeholderClass = 'placeholder-svg'
                      echo  'hero-apparel-1' | placeholder_svg_tag: placeholderClass
                  endif
                  %}
              {% endcapture %}
              <div class="slideshow-item-wrapper">
                  <div
                  id="slideshow_item_{{ block.id }}"
                  data-slide="{{ forloop.index0 }}"
                  data-id="slideshow_item_{{ block.id }}"
                  class="{{ block.settings.color_scheme }}-scheme  slideshow-item {% if section.settings.desktop_height == 'adapt_image' %}desktop-adapt-height{%- else -%} desktop-fixed-height {% endif %} {% if section.settings.mobile_height == 'adapt_image' %} mobile-adapt-height{%- else -%} mobile-fixed-height{% endif %}"
                  {{ block.shopify_attributes }}
                  {% if section.settings.enable_block_color %} data-color="{% if block.settings.color_scheme.settings.gradient_bg_color != blank  %}{{  block.settings.color_scheme.settings.gradient_bg_color }}{% else %}{{ block.settings.color_scheme.settings.bg_color}}{% endif %}"{% endif %}
                  >
                  <div class="slideshow-media media-box">
                      {% if block.settings.slider_video != blank %}
                      <video id="slider_video-{{ block.id }}" class="videoBackgroundFile" data-autoplay="true" autoplay muted loop playsinline>
                          <source
                          src="{% if block.settings.slider_video.sources[0].url contains 'mp4' %}{{ block.settings.slider_video.sources[0].url -}}{% else %}{{ block.settings.slider_video.sources[1].url -}}  {% endif %}"
                          type="video/mp4"
                          >
                      </video>
                      {%- else -%}
                      {{ slideImage }}
                      {% endif %}
                  </div>

                  {% liquid
                      assign buttonWrapper = false
                      if block.settings.btn_text_1 != blank and block.settings.btn_link_1 != blank
                          assign buttonWrapper = true
                      elsif block.settings.btn_text_2 != blank and block.settings.btn_link_2 != blank
                          assign buttonWrapper = true
                      endif
                  %}
                  {% if block.settings.heading != blank or block.settings.description != blank or buttonWrapper %}
                      <div class="slideshow-content-wrapper container">
                      <div class="slideshow-content {{ block.settings.content_width }}-width {{ block.settings.desktop_content_position }} {{ block.settings.mobile_content_position }} {{ block.settings.desktop_alignment }} {{ block.settings.mobile_alignment }}">
                          {% if block.settings.subheading != blank
                              or block.settings.heading != blank
                              or block.settings.description != blank
                              or buttonWrapper
                          %}
                              <div class="slideshow-content-inner{% if block.settings.enable_background %} background-enabled{% endif %}">
                                  {% if block.settings.subheading != blank %}
                                      <h6 class="slideshow-subheading">
                                          <span class="text-reveal-content">
                                          <span data-aos="hero" data-aos-order="1">  {{- block.settings.subheading -}}</span>
                                          </span>
                                      </h6>
                                  {% endif %}
                                  {% if block.settings.heading != blank %}
                                      {%- capture blockhighlightPrefix -%}
                                          <strong class="highlight-text{% if block.settings.enable_highlight_background %} with-background{% endif %}">
                                      {%- endcapture -%}
                                      <{{ block.settings.seo_heading }} class="hero-slideshow-heading {{ block.settings.heading_size }}">
                                          <span class="text-reveal-content">
                                            <span data-aos="hero" data-aos-order="2">                                             
                                              {%- assign block_heading = block.settings.heading | replace: '<strong> ', ' <strong>' | replace: ' </strong>', '</strong> ' %}
                                              {{ block_heading | replace: "<strong>", blockhighlightPrefix | replace: '++', '<br>' }} 
                                            </span>
                                          </span>
                                      </{{ block.settings.seo_heading }}>
                                  {% endif %}

                                  {% if block.settings.description != blank %}
                                      <p class="slideshow-desc">
                                          <span class="text-reveal-content">
                                          <span data-aos="hero" data-aos-order="3">{{ block.settings.description }}</span>
                                          </span>
                                      </p>
                                  {% endif %}

                                  {% if buttonWrapper %}
                                      <div class="slideshow-button">
                                          {% if block.settings.btn_link_1 != blank and block.settings.btn_text_1 != blank %}
                                              <div class="slideshow-button-item" data-aos="hero" data-aos-order="4">
                                                  {% render 'button', class: 'slideshow-primary-btn', button_link: block.settings.btn_link_1 , button_style: block.settings.button_syle_1 , button_size: block.settings.button_size_1, button_text: block.settings.btn_text_1 %}
                                              </div>
                                          {% endif %}

                                          {% if block.settings.btn_link_2 != blank and block.settings.btn_text_2 != blank %}
                                              <div class="slideshow-button-item" data-aos="hero" data-aos-order="5">
                                              {% render 'button', class: 'slideshow-secondary-btn', button_link: block.settings.btn_link_2 , button_style: block.settings.button_syle_2 , button_size: block.settings.button_size_2, button_text: block.settings.btn_text_2 %}
                                              </div>
                                          {% endif %}
                                      </div>
                                  {% endif %}
                              </div>
                          {% endif %}
                      </div>
                      </div>
                  {% endif %}
                  {% liquid
                      assign buttonLinkStatus = false
                      assign buttonLink = ''
                      if block.settings.btn_text_1 == blank and block.settings.btn_link_1 != blank and block.settings.btn_text_2 == blank
                          assign buttonLinkStatus = true
                          assign buttonLink = block.settings.btn_link_1
                      elsif block.settings.btn_link_1 == blank and block.settings.btn_text_2 == blank and block.settings.btn_link_2 != blank
                          assign buttonLinkStatus = true
                          assign buttonLink = block.settings.btn_link_2
                      endif
                  %}
                  {% if buttonLinkStatus %}
                      <a
                      href="{{ buttonLink }}"
                      class="overlay-link"
                      >
                      </a>
                  {% endif %}
                  </div>
              </div>
          {% endfor %}
      </div>
      {% if section.settings.navigation_type != 'none' %}
      <div id="slideshow-arrow-container-{{ section.id }}" class="slideshow-arrow-container"></div>
      {% endif %}
      {% if section.settings.banner_marquee and section.settings.marquee_text != blank %}
          <div class="slideshow-marquee-box">
              <div class="slideshow-marquee-wrapper">
              <div
                  class="slideshow-marquee-content {% if section.settings.rotation_style != 'onscroll' %} autoplay-infinite {% else %} on-scroll-move{% endif %}  {{ section.settings.direction }}-direction"
                  data-marquee-speed="{{ section.settings.scrolling_speed }}"
                  data-marquee-speed-mobile="{{ section.settings.scrolling_speed_mobile }}"
                  {% if section.settings.rotation_style != 'always' %}
                      data-marquee-on-scroll
                  {% endif %}
                  {% if section.settings.rotation_style != 'onscroll' %}
                      data-marquee-text
                  {% endif %}
              >
                  {% for i in (1..10) %}
                  <div class="slideshow-marquee-item heading-font" data-marque-node aria-hidden="true">
                      <div class="slideshow-marquee-node">
                      <span>{{ section.settings.marquee_text }}</span>
                      </div>
                  </div>
                  {% endfor %}
              </div>
              </div>
          </div>
      {% endif %}
    </div>
    {% if section.settings.enable_full_width == false  and section.settings.enable_compact_width == false %}
        </div>
    {% endif %}
</div>

<style>
  
  #shopify-section-{{ section.id }}.shopify-section{ 
    --top-spacer:{{ section.settings.top_space_desktop }}px;
    --bottom-spacer:{{ section.settings.bottom_space_desktop }}px;
      position:relative;
      --marquee-text-size: {{ section.settings.marquee_text_size }}px;
      --animation-speed: {{ section.settings.marquee_speed }}s;
      --marquee-text-color: {{ section.settings.banner_marquee_color }};
      --outline-thickness:{{ section.settings.outline_thickness }}px;
      --slideshow-marquee-gap: {{ section.settings.item_gap_desktop }}px;
      }
     {% if section.settings.banner_marquee %}
      #shopify-section-{{ section.id }}{
        --marquee-height: calc(var(--marquee-text-size)*1.2 + 10px);
      }
    {% endif %} 
  
  @media screen and (min-width:768px) {
    #shopify-section-{{ section.id }} .slideshow-outer{
      {% if section.settings.desktop_height == '100vh' and section.index == 1 %}
        --slideshow-height: var(--fullHeight,{{ section.settings.desktop_height }});
        {% else %}
        --slideshow-height: {{ section.settings.desktop_height }};
      {%  endif %}
      {% if section.blocks.first.settings.slider_video != blank %}
        --image-ratio: {{- 1 | divided_by : section.blocks.first.settings.slider_video.aspect_ratio | times: 100 -}}%;
      {% elsif section.blocks.first.settings.image_desktop != blank %}
        --image-ratio: {{- 1 | divided_by : section.blocks.first.settings.image_desktop.aspect_ratio | times: 100 -}}%;
      {%- else -%}
        --image-ratio: 50%;
      {% endif %}
    }
  }

  {% for block in section.blocks %}
    .slideshow-item[data-id='slideshow_item_{{ block.id }}']{
      --overlay-bg:{{ block.settings.overlay_color }};
      --overlay-opacity:{{ block.settings.overlay_opacity | divided_by: 100.0 }};
      --content-bg:{{ block.settings.content_overlay_color.red }},{{ block.settings.content_overlay_color.green }},{{ block.settings.content_overlay_color.blue }};
      --content-bg-alpha:{{ block.settings.content_overlay_opacity | divided_by: 100.0 }};
      --highlight-text: {{ block.settings.highlighted_color }};
      {% unless block.settings.highlighted_bg_color == 'rgba(0,0,0,0)' or block.settings.highlighted_bg_color == empty %}
      --highlight-background: {{ block.settings.highlighted_bg_color.red }},{{ block.settings.highlighted_bg_color.green }},{{ block.settings.highlighted_bg_color.blue }};
      --highlight-background-opacity: {{ block.settings.highlighted_bg_opacity | divided_by: 100.0 }};    
      {% else %}
      --highlight-background: 0,0,0;
      --highlight-background-opacity: 0;
      {% endunless %}
    }
  {% endfor %}
  @media screen and (max-width:767px) {
    #shopify-section-{{ section.id }}.shopify-section{
      {% if section.settings.mobile_height == '100vh' and section.index == 1 %}
        --slideshow-height: var(--fullHeight,{{ section.settings.mobile_height }});
        {% else %}
      --slideshow-height: {{ section.settings.mobile_height }};
      {%  endif %}
      {% if section.blocks.first.settings.slider_video != blank %}
        --image-ratio {{- 1 | divided_by : section.blocks.first.settings.slider_video.aspect_ratio | times: 100 -}}%;
      {% elsif section.blocks.first.settings.image_mobile != blank %}
      --image-ratio: {{- 1 | divided_by : section.blocks.first.settings.image_mobile.aspect_ratio | times: 100 -}}%;
      {%- else -%}
      --image-ratio: 100%;
      {% endif %}
      --marquee-text-size: {{ section.settings.marquee_text_size_mobile }}px;
      --slideshow-marquee-gap: {{ section.settings.item_gap_mobile }}px;
    }
  }
  @media only screen and (max-width:767px) {
    #shopify-section-{{ section.id }}.shopify-section{
      --top-spacer:{{ section.settings.top_space_mobile }}px;
      --bottom-spacer:{{ section.settings.bottom_space_mobile }}px;
    }
  }
  {% if section.settings.section_visibility == 'large' %}
    @media (max-width: 767px) {
      #shopify-section-{{ section.id }}{
        display: none !important;
      }
    }
  {% elsif section.settings.section_visibility == 'small' %}
    @media (min-width: 768px) {
      #shopify-section-{{ section.id }}{
        display: none !important;
      }
    }
  {% endif %}
</style>
{% schema %}
{
  "name": "t:sections.slideshow.name",
  "tag": "section",
  "class": "slideshow",
  "disabled_on": {
    "groups": [
      "header",
      "footer"
    ]
  },
  "settings": [
    {
      "type": "select",
      "id": "section_visibility",
      "label": "t:global.common.section_visibility.label",
      "default": "always",
      "options": [
        {
          "label": "t:global.common.section_visibility.options.always",
          "value": "always"
        },
        {
          "label": "t:global.common.section_visibility.options.small",
          "value": "small"
        },
        {
          "label": "t:global.common.section_visibility.options.large",
          "value": "large"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "enable_full_width",
      "label": "t:global.common.enable_full_width.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_compact_width",
      "label": "t:sections.slideshow.settings.enable_compact_width.label",
      "info": "t:sections.slideshow.settings.enable_compact_width.info",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "enable_block_color",
      "label": "t:sections.slideshow.settings.enable_block_color.label",
      "default": false
    },
    {
      "type": "select",
      "id": "desktop_height",
      "label": "t:sections.slideshow.settings.desktop_height.label",
      "default": "750px",
      "options": [
        {
          "value": "550px",
          "label": "550px"
        },
        {
          "value": "650px",
          "label": "650px"
        },
        {
          "value": "750px",
          "label": "750px"
        },
        {
          "value": "100vh",
          "label": "t:sections.slideshow.settings.desktop_height.options.fullscreen"
        },
        {
          "value": "adapt_image",
          "label": "t:sections.slideshow.settings.desktop_height.options.adapt_to_slide"
        }
      ]
    },
    {
      "type": "select",
      "id": "mobile_height",
      "label": "t:sections.slideshow.settings.mobile_height.label",
      "default": "450px",
      "options": [
        {
          "value": "450px",
          "label": "450px"
        },
        {
          "value": "550px",
          "label": "550px"
        },
        {
          "value": "650px",
          "label": "650px"
        },
        {
          "value": "100vh",
          "label": "t:sections.slideshow.settings.mobile_height.options.fullscreen"
        },
        {
          "value": "adapt_image",
          "label": "t:sections.slideshow.settings.mobile_height.options.adapt_to_slide"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "auto_rotate",
      "label": "t:sections.slideshow.settings.auto_rotate.label",
      "default": false
    },
    {
      "type": "range",
      "id": "interval",
      "min": 3,
      "max": 9,
      "step": 2,
      "unit": "s",
      "label": "t:sections.slideshow.settings.change_slides_speed.label",
      "default": 5
    },
    {
      "type": "select",
      "id": "slider_transition",
      "label": "t:sections.slideshow.settings.slider_transition.label",
      "default": "fade",
      "options": [
        {
          "value": "slide",
          "label": "t:sections.slideshow.settings.slider_transition.options.slide"
        },
        {
          "value": "fade",
          "label": "t:sections.slideshow.settings.slider_transition.options.fade"
        }
      ]
    },
    {
      "type": "select",
      "id": "navigation_type",
      "label": "t:sections.slideshow.settings.navigation_type.label",
      "default": "arrow",
      "options": [
        {
          "value": "arrow",
          "label": "t:sections.slideshow.settings.navigation_type.options.arrow"
        },
        {
          "value": "dots",
          "label": "t:sections.slideshow.settings.navigation_type.options.dots"
        },
        {
          "value": "none",
          "label": "t:sections.slideshow.settings.navigation_type.options.none"
        }
      ]
    },
    {
      "type":"checkbox",
      "id":"show_arrow_hover",
      "label":"Show arrow on hover",
      "default":false
    },
    {
      "type": "header",
      "content": "t:global.header.marquee_section.label"
    },
    {
      "type": "checkbox",
      "id": "banner_marquee",
      "label": "t:sections.slideshow.settings.banner_marquee.label",
      "default": false   
    },
    {
      "type": "inline_richtext",
      "id": "marquee_text",
      "label": "t:global.common.general_labels.text",
      "info": "t:global.common.marquee_text_info.info"
    },
    {
      "type": "select",
      "id": "rotation_style",
      "label": "t:global.common.marquee_type.label",
      "default": "always",
      "options": [
        {
          "value": "onscroll",
          "label": "t:global.common.marquee_type.options.onscroll"
        },
        {
          "value": "always",
          "label": "t:global.common.marquee_type.options.always"
        },
        {
          "value": "both",
          "label": "t:global.common.marquee_type.options.both"
        }
      ]
    },
    {
      "type": "select",
      "id": "direction",
      "label": "t:global.common.marquee_direction.label",
      "options": [
        {
          "value": "rtl",
          "label": "t:global.common.marquee_direction.options.rtl"
        },
        {
          "value": "ltr",
          "label": "t:global.common.marquee_direction.options.ltr"
        }
      ],
      "default": "rtl"
    },
    {
      "type": "color",
      "id": "banner_marquee_color",
      "label": "t:sections.slideshow.settings.banner_marquee_color.label",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "scrolling_speed",
      "label": "t:global.common.marquee_speed.desktop.label",
      "min": 5,
      "max": 100,
      "unit": "s",
      "default": 15
    },
    {
      "type": "range",
      "id": "scrolling_speed_mobile",
      "label": "t:global.common.marquee_speed.mobile.label",
      "min": 5,
      "max": 100,
      "unit": "s",
      "default": 15
    },
    {
      "type": "range",
      "id": "outline_thickness",
      "min": 1,
      "max": 4,
      "step": 1,
      "unit": "px",
      "label": "t:global.common.marque_text_outline_thickness.label",
      "default": 2
    },
    {
      "type": "range",
      "id": "marquee_text_size",
      "min": 20,
      "max": 200,
      "step": 2,
      "unit": "px",
      "label": "t:global.common.marquee_text_size.desktop.label",
      "default": 100
    },
    {
      "type": "range",
      "id": "marquee_text_size_mobile",
      "min": 10,
      "max": 150,
      "step": 2,
      "unit": "px",
      "label": "t:global.common.marquee_text_size.mobile.label",
      "default": 80
    },
    {
      "type": "range",
      "id": "item_gap_desktop",
      "label": "t:sections.slideshow.settings.item_gap.desktop.label",
      "min": 0,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "item_gap_mobile",
      "label": "t:sections.slideshow.settings.item_gap.mobile.label",
      "min": 0,
      "max": 50,
      "step": 2,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "t:global.header.color_section.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "primary",
      "label": "t:global.header.color_scheme.label"
    },
    {
      "type": "header",
      "content": "t:sections.slideshow.settings.arrow_header.content"
    },
    {
      "type": "header",
      "content": "t:global.header.space_section.label"
    },
    {
      "type": "range",
      "id": "top_space_desktop",
      "label": "t:global.top_space_desktop.label",
      "default": 0,
      "min": 0,
      "max": 100,
      "step": 5
    },
    {
      "type": "range",
      "id": "bottom_space_desktop",
      "label": "t:global.bottom_space_desktop.label",
      "default": 0,
      "min": 0,
      "max": 100,
      "step": 5
    },
    {
      "type": "range",
      "id": "top_space_mobile",
      "label": "t:global.top_space_mobile.label",
      "default": 0,
      "min": 0,
      "max": 100,
      "step": 5
    },
    {
      "type": "range",
      "id": "bottom_space_mobile",
