{% schema %}
{
  "name": "AAW customer voices",
  "tag": "section",
  "class": "aaw-customer-voices-section",
  "settings": [
    {
      "type": "select",
      "id": "layout_mode",
      "label": "Layout",
      "default": "home",
      "options": [
        { "value": "home", "label": "Homepage compact" },
        { "value": "page", "label": "Full page" }
      ]
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Customer voices"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What listeners remember after the first listen."
    },
    {
      "type": "textarea",
