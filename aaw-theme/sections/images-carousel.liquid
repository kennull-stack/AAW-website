<link rel="preload" as="style" href="{{ 'images-carousel.css' | asset_url }}">
{{ 'images-carousel.css' | asset_url | stylesheet_tag }}
<div class="section-container {{ section.settings.color_scheme }}-scheme {% if section.settings.make_section_rounded %}section-rounded{% endif %}">
  <div class="{{ settings.container_width }}">
    {% if section.settings.heading != blank %}
      {%- capture sectionhighlightPrefix -%}
        <strong class="highlight-text">
      {%- endcapture -%}

      {%- capture sectionhighlightSuffix -%}
        </strong>
      {%- endcapture -%}

      <div class="section-heading-box {{ section.settings.heading_alignment }}" {% if settings.enable_animation %}data-aos="fade-up" data-aos-duration="1000"{% endif %}>
        <{{ section.settings.seo_heading }} class="section-heading {{ section.settings.heading_size }}">
          {{ section.settings.heading | replace: "<strong>", sectionhighlightPrefix | replace: "</strong>", sectionhighlightSuffix | replace: '++', '<br>' }}
        </{{ section.settings.seo_heading }}>
      </div>
    {% endif %}
    {% if section.blocks.size > 0 %}
      <div class="images-carousel-wrapper">
        <div class="images-carousel-image-box">
          <div
            class="images-carousel-images"
            
          >
            {% for block in section.blocks %}
              <div class="images-carousel-img {% if forloop.first %} active{% endif %}"
                data-id="images-carousel-{{ block.id }}"
                {{ block.shopify_attributes }}
                data-slide="{{ forloop.index0 }}"
              >
                <div class="images-carousel-img-item">
                  <div class="media-box media-box-fixed">
                    {% if block.settings.video != blank %}

                      <deferred-media class="deferred-media autoplay-status-true" data-type="mp4">
                        <template>
                          {% if block.settings.video != blank %}
                            <video
                              class="images-carousel-video"
                              autoPlay muted loop playsinline
                              data-autoplay="true"
                              data-video-image-wrapper
                            >

                            <source  src="{% if block.settings.video.sources[0].url contains 'mp4' %}{{ block.settings.video.sources[0].url -}}{% else %}{{ block.settings.video.sources[1].url -}}{% endif %}"
                type="video/mp4">
                            
                            </video>
                            {%- endif -%}
                        </template>
                      </deferred-media>
                      {% comment %} <video class="images-carousel-video" autoPlay muted loop>
                        <source src="{{ block.settings.video.sources[0].url }}" type="video/mp4">
                        <source src="{{ block.settings.video.sources[1].url }}">
                      </video> {% endcomment %}
                    {% elsif block.settings.image != blank %}
                      {% render 'image', image: block.settings.image, class: 'media_image' %}
                    {% else %}
                    {%- assign placeholder_image_index = forloop.index0 | modulo: 4 | plus: 1 -%}
                    {%- assign placeholder_image = 'collection-apparel-' | append: placeholder_image_index -%}
                      {{ placeholder_image | placeholder_svg_tag: 'placeholder-svg' }}
                    {% endif %}
                  </div>
                </div>
              </div>
            {% endfor %}
          </div>
        </div>
        <div class="images-carousel-content-box">
          <div class="images-carousel-content">
            <ul class="images-carousel-content-list">
              {% for block in section.blocks %}
                {% if block.settings.heading != blank %}
                  <li
                    id="images-carousel-{{ block.id }}"
                    class="images-carousel-content-item{% if forloop.index == 1 %} active{% endif %}"
                    data-index="{{ forloop.index0 }}"
                    data-image-carousel
                  >
                    <{{ block.settings.seo_heading }} class="images-carousel-heading heading-font {{ block.settings.heading_size }} cursor-pointer">
                      <span class="images-carousel-heading-text ">{{ block.settings.heading }}</span>
                  
                    </{{ block.settings.seo_heading }}>
                  </li>
                {% endif %}
              {% endfor %}
            </ul>
            <ul class="images-carousel-content-list">
              {% for block in section.blocks %}
                <li
                  class="images-carousel-content-description images-carousel-content-item {% if forloop.first %} active{% endif %}"
                  data-id="images-carousel-{{ block.id }}"
                  {% if forloop.first %}
                    style="display:block"
                  {% endif %}
                >
                  {% if block.settings.description != blank %}
                    <div class="images-carousel-content-text rte">
                      {{ block.settings.description | replace: '<p></p>', '<br>' }}
                    </div>
                  {% endif %}
                </li>
              {% endfor %}
            </ul>
          </div>
        </div>
      </div>
    {% endif %}
  </div>
</div>
<style>
    #shopify-section-{{ section.id }}{
      {% if section.settings.make_section_rounded %}
        background:{{ section.settings.section_background }};
      {% endif %}
      --top-spacer: {{ section.settings.top_space_desktop }}px;
      --bottom-spacer: {{ section.settings.bottom_space_desktop }}px;
      --media-height: {{ section.settings.desktop_height }};
      --highlight-text: {{ section.settings.highlighted_color }};
    }
    @media only screen and (max-width:767px) {
      #shopify-section-{{ section.id }}{
        --top-spacer: {{ section.settings.top_space_mobile }}px !important;
        --bottom-spacer: {{ section.settings.bottom_space_mobile }}px !important;
        --media-height: {{ section.settings.mobile_height }};
      }
  }
    .images-carousel-content-description {
      display:none;
    }

    {% if section.settings.section_visibility == 'large' %}
      @media (max-width: 767px) {
        #shopify-section-{{ section.id }}{
          display: none !important;
        }
      }
    {% elsif section.settings.section_visibility == 'small' %}
      @media (min-width: 768px) {
        #shopify-section-{{ section.id }}{
          display: none !important;
        }
      }
    {% endif %}
</style>
