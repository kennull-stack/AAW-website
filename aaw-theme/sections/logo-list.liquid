<link rel="preload" as="style" href="{{ 'logo-list.css' | asset_url }}">
{{ 'logo-list.css' | asset_url | stylesheet_tag }}
{% if section.blocks.size > 0 %}
  {% capture logoContent %}
    {% for block in section.blocks %}
        {% if block.type == 'logo' %}
          {% assign aosDelay = forloop.index | times: 50 %}
            <{% if block.settings.image_link != blank %}a href="{{ block.settings.image_link }}"{% else %}div{% endif %} class="logo-item" {% if settings.enable_animation %}data-aos="fade-up" data-aos-delay="{{ aosDelay }}"{% endif %}>
              <div id="block-{{ block.id }}" class="logo-item-inner logo-background-{{ section.settings.show_card_background }} logo-border-{{ section.settings.show_card_border }}">
                {% liquid 
                  if block.settings.image_url != blank
                    render 'image', image_url: block.settings.image_url
                  elsif block.settings.image != blank
                    render 'image', image: block.settings.image
                  else
                    echo 'logo' | placeholder_svg_tag: 'placeholder-svg'
                  endif 
                %}
              </div>
            </{% if block.settings.image_link != blank %}a{% else %}div{% endif %}>
        {% endif %}
    {% endfor %}
  {% endcapture %}
  <div class="section-container {{ section.settings.color_scheme }}-scheme border-{{ section.settings.show_borders }} {% if section.settings.make_section_rounded %}section-rounded{% endif %}">
    <div class="{{ settings.container_width }}">
      {% if section.settings.heading != blank %}
        {%- capture sectionhighlightPrefix -%}
          <strong class="highlight-text">
        {%- endcapture -%}

        {%- capture sectionhighlightSuffix -%}
          </strong>
        {%- endcapture -%}

        <div class="section-heading-box {{ section.settings.heading_alignment }}" {% if settings.enable_animation %}data-aos="fade-up" data-aos-duration="1000"{% endif %}>
          <{{ section.settings.seo_heading }} class="section-heading {{ section.settings.heading_size }}">
            {{ section.settings.heading | replace: "<strong>", sectionhighlightPrefix | replace: "</strong>", sectionhighlightSuffix | replace: '++', '<br>' }}
          </{{ section.settings.seo_heading }}>
        </div>
      {% endif %}
      <div
        class="logo-items-wrapper{% if section.settings.layout_type == 'grid' %} stacked{% if section.settings.enable_swipe_mobile %} mobile-swipe{% endif %}{% elsif section.settings.layout_type == 'marquee'  %} marquee autoplay-infinite {{ section.settings.direction }}-direction{% endif %}{% if section.settings.images_height %} images-equal-height{% endif %}"
        {% if section.settings.layout_type == 'marquee' %}
          data-marquee-speed="{{ section.settings.scrolling_speed }}"
          data-marquee-speed-mobile="{{ section.settings.scrolling_speed_mobile }}" data-marquee-text
        {% endif %}
      >
        {% if section.settings.layout_type == 'grid' %}
          {{ logoContent }}
        {% else %}
          {% liquid
            if section.settings.layout_type == 'marquee'
              assign limit = 4
              if section.blocks.size <= 3
                assign limit = 5
              endif
            else
              assign limit = 1
            endif
          %}
          {% for i in (1..limit) %}
            {% if section.settings.layout_type == 'marquee' %}
              <div class="logo-list-marquee" data-marque-node>
                {{ logoContent }}
              </div>
            {% endif %}
          {% endfor %}
        {% endif %}
      </div>
    </div>
  </div>
{% endif %}
<style>
  #shopify-section-{{ section.id }}{
    {% if section.settings.make_section_rounded %}
      background:{{ section.settings.section_background }};
    {% endif %}
    --top-spacer: {{ section.settings.top_space_desktop }}px;
    --bottom-spacer: {{ section.settings.bottom_space_desktop }}px;
    --column-count:{{ section.settings.columns_desktop }};
    --column-space: {{ section.settings.column_spacing }}px;
    --column-background: {{ section.settings.card_color.red }}, {{ section.settings.card_color.green }}, {{ section.settings.card_color.blue }}, {{ section.settings.card_color.alpha }};
    --column-border:{{ section.settings.card_border_color }};
    --highlight-text: {{ section.settings.highlighted_color }};
  }
  @media (max-width:1025px) {
    #shopify-section-{{ section.id }} .logo-items-wrapper.stacked{
      grid-template-columns: repeat(auto-fill,minmax(170px, 1fr));
    }
  }
  @media (max-width:767px) {
    #shopify-section-{{ section.id }} .logo-items-wrapper.stacked{
      grid-template-columns: repeat(auto-fill,minmax(150px, 1fr));
    }
  }

  {% for block in section.blocks %}
    #block-{{ block.id }}{
    --logoWidth: {{ block.settings.image_width }}%;
    }
  {% endfor %}
  @media only screen and (max-width:767px) {
    #shopify-section-{{ section.id }}{
      --top-spacer: {{ section.settings.top_space_mobile }}px !important;
      --bottom-spacer: {{ section.settings.bottom_space_mobile }}px !important;
    }
  }
  {% if section.settings.section_visibility == 'large' %}
    @media (max-width: 767px) {
      #shopify-section-{{ section.id }}{
        display: none !important;
      }
    }
  {% elsif section.settings.section_visibility == 'small' %}
    @media (min-width: 768px) {
      #shopify-section-{{ section.id }}{
        display: none !important;
      }
    }
  {% endif %}
</style>
{% schema %}
{
  "name": "t:sections.logo-list.name",
  "tag": "section",
  "class": "logo-list",
  "disabled_on": {
    "groups": [
      "header",
      "footer"
    ]
  },
  "max_blocks": 12,
  "settings": [
    {
      "type": "select",
      "id": "section_visibility",
      "label": "t:global.common.section_visibility.label",
      "default": "always",
      "options": [
        {
          "label": "t:global.common.section_visibility.options.always",
          "value": "always"
        },
        {
          "label": "t:global.common.section_visibility.options.small",
          "value": "small"
        },
        {
          "label": "t:global.common.section_visibility.options.large",
          "value": "large"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "make_section_rounded",
      "label": "t:global.common.general_labels.make_section_rounded",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_borders",
      "label": "t:sections.logo-list.settings.show_borders.label",
      "default": false
    },
    {
      "type": "header",
      "content": "t:global.header.card.label"
    },
    {
      "type": "checkbox",
      "id": "images_height",
      "label": "t:sections.logo-list.settings.images_height.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_card_background",
      "label": "t:sections.logo-list.settings.show_card_background.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_card_border",
      "label": "t:sections.logo-list.settings.show_card_border.label",
      "default": false
    },
   
    {
      "type": "select",
      "id": "layout_type",
      "label": "t:sections.logo-list.settings.layout_type.label",
      "default": "grid",
      "options": [
        {
          "value": "grid",
          "label": "t:sections.logo-list.settings.layout_type.grid.label"
        },
        {
          "value": "marquee",
          "label": "t:sections.logo-list.settings.layout_type.marquee.label"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "enable_swipe_mobile",
      "label": "t:global.common.swipe_mobile.label",
      "default": false
    },
    {
      "type": "header",
      "content": "t:sections.logo-list.settings.grid.content"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "t:sections.logo-list.settings.columns_desktop.label",
      "default": 8,
      "min": 2,
      "max": 10,
      "step": 1
    },
    {
      "type": "range",
      "id": "column_spacing",
      "label": "t:sections.logo-list.settings.column_spacing.label",
      "min": 0,
      "max": 40,
      "unit": "px",
      "step": 2,
      "default": 20
    },
    {
      "type": "header",
      "content": "t:sections.logo-list.settings.marquee.content"
    },
    {
      "type": "range",
      "id": "scrolling_speed",
      "label": "t:global.common.marquee_speed.desktop.label",
      "min": 1,
      "max": 100,
      "unit": "s",
      "step": 1,
      "default": 15
    },
    {
      "type": "range",
      "id": "scrolling_speed_mobile",
      "label": "t:global.common.marquee_speed.mobile.label",
      "min": 1,
      "max": 100,
      "unit": "s",
      "step": 1,
      "default": 15
    },
    {
      "type": "select",
      "id": "direction",
      "label": "t:global.common.marquee_direction.label",
      "default": "ltr",
      "options": [
        {
          "value": "ltr",
          "label": "t:global.common.marquee_direction.options.ltr"
        },
        {
          "value": "rtl",
          "label": "t:global.common.marquee_direction.options.rtl"
        }
      ]
    },
    {
      "type": "header",
      "content": "t:sections.logo-list.settings.content.content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "t:global.common.general_labels.heading",
      "info": "t:global.common.infos.heading.label",
      "default": "Logo list"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "t:global.common.general_labels.heading_size",
      "default": "h3",
      "options": [
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        },
        {
          "value": "h4",
          "label": "H4"
        },
        {
          "value": "h5",
          "label": "H5"
        },
        {
          "value": "h6",
          "label": "H6"
        }
      ]
    },
    {
      "type": "select",
      "id": "seo_heading",
      "label": "t:global.common.general_labels.heading_tag",
      "info": "t:global.common.infos.seo_heading.label",
      "default": "h3",
      "options": [
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        },
        {
          "value": "h4",
          "label": "H4"
        },
        {
          "value": "h5",
          "label": "H5"
        },
        {
          "value": "h6",
          "label": "H6"
        }
      ]
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "t:global.common.heading_alignment.label",
      "default": "text-center",
      "options": [
        {
          "label": "t:global.common.heading_alignment.options.left.label",
          "value": "text-left"
        },
        {
          "label": "t:global.common.heading_alignment.options.center.label",
          "value": "text-center"
        }
      ]
    },
    {
      "type": "header",
      "content": "t:global.header.color_section.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "primary",
      "label": "t:global.header.color_scheme.label"
    },
    {
      "type": "color",
      "id": "section_background",
      "label": "t:global.common.section_background.label",
      "info": "t:global.common.section_background.info"
    },
    {
