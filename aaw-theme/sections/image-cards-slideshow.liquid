<link rel="preload" as="style" href="{{ 'image-card-slideshow.css' | asset_url }}">
{{ 'image-card-slideshow.css' | asset_url | stylesheet_tag }}
{% liquid
  assign gridImageSize = section.settings.image_size
  if gridImageSize == 'landscape'
    assign promotionalImageRatio = 75
  elsif gridImageSize == 'square'
    assign promotionalImageRatio = 100
  elsif gridImageSize == 'portrait'
    assign promotionalImageRatio = 125
  else
    if section.settings.image != blank
      assign promotionalImageRatio = 1 | divided_by: section.settings.image.aspect_ratio | times: 100
    else
      assign promotionalImageRatio = 100
    endif
  endif
%}
<div class="section-container {{ section.settings.color_scheme }}-scheme {% if section.settings.make_section_rounded %} section-rounded{% endif %}">
  <div class="{{ settings.container_width }}">
    <cards-slider class="cards-slider-content">
        <!-- <div class="cards-pagination">
            <div class="cards-pagination-content">
                <span class="cards-pagination-current">1</span>
                <span>/</span>
                <span class="cards-pagination-total">3</span>
            </div>
        </div> -->
    
        <div class="cards-main-carousel" data-main-carousel>
            <div class="cards-main-carousel-container">
              {%- if section.blocks.size > 1 -%}
                <div class="cards-main-carousel-navigation" data-cards-main-carousel-navigation>
                 
                    <button class="slide-arrow prev-arrow cards-main-carousel-navigation-prev prev" aria-disabled="true">
                     <svg class="slide-arrow-icon1" width="13" height="13" viewBox="0 0 13 13" fill="none"><path fill-rule="evenodd" clip-rule="evenodd" d="M7 0L0.636039 6.36396L7 12.7279L8.17187 11.5561L3.80836 7.19255L12.5018 7.19253L12.5018 5.53528L3.80837 5.53531L8.17184 1.17184L7 0Z" fill="currentColor"></path></svg>
                      <svg class="slide-arrow-icon2" width="13" height="13" viewBox="0 0 13 13" fill="none"><path fill-rule="evenodd" clip-rule="evenodd" d="M7 0L0.636039 6.36396L7 12.7279L8.17187 11.5561L3.80836 7.19255L12.5018 7.19253L12.5018 5.53528L3.80837 5.53531L8.17184 1.17184L7 0Z" fill="currentColor"></path></svg>
                    </button>
                    <button class="slide-arrow next-arrow cards-main-carousel-navigation-next next" aria-disabled="true">
                        <svg class="slide-arrow-icon1" width="13" height="13" viewBox="0 0 13 13" fill="none"><path fill-rule="evenodd" clip-rule="evenodd" d="M6 0L12.364 6.36396L6 12.7279L4.82813 11.5561L9.19164 7.19255L0.498208 7.19253L0.498198 5.53528L9.19163 5.53531L4.82816 1.17184L6 0Z" fill="currentColor"></path></svg>
                        <svg class="slide-arrow-icon2" width="13" height="13" viewBox="0 0 13 13" fill="none"><path fill-rule="evenodd" clip-rule="evenodd" d="M6 0L12.364 6.36396L6 12.7279L4.82813 11.5561L9.19164 7.19255L0.498208 7.19253L0.498198 5.53528L9.19163 5.53531L4.82816 1.17184L6 0Z" fill="currentColor"></path></svg>
                    </button>
                </div>
            {% endif %}
                <ul class="cards-main-carousel-list" data-cards-main-carousel-list>
                    {%- for block in section.blocks -%}
                      <li class="cards-main-carousel-list-item block-card-{{ forloop.index }} {{ block.settings.color_scheme }}-scheme {% if forloop.first %}active{% endif %}" data-cards-main-carousel-list-item>
                          <div class="cards-main-carousel-list-image">
                             <div class="media-box" style="--image-ratio:{{ promotionalImageRatio }}%">
                              {%- liquid 
                                  if block.settings.image != blank
                                    render 'image', image: block.settings.image
                                  else 
                                   assign placeholder_image_index = forloop.index0 | modulo: 4 | plus: 1 
                                    echo 'collection-apparel-' | append: placeholder_image_index | placeholder_svg_tag: 'placeholder-svg'
                                  endif 
                              -%}
                             </div>
                          </div>
                          {%  liquid 
                                assign btn_status = false
                            if block.settings.btn_link != blank and block.settings.btn_text != blank 
                                assign btn_status = true
                            endif
                          %}
                          {% if block.settings.heading != blank or block.settings.description != blank or btn_status == true %}
                          <div class="cards-main-carousel-list-item-details">
                              <div class="cards-main-carousel-list-item-details-inner">
                                {% if block.settings.heading != blank or block.settings.description != blank %}
                                  <div class="cards-content {{ block.settings.content_width }}-width">
                                    {% if block.settings.heading != blank %}
                                        {%- capture blockhighlightPrefix -%}
                                            <strong class="highlight-text">
                                        {%- endcapture -%}
                
                                        {%- capture blockhighlightSuffix -%}
                                            </strong>
                                        {%- endcapture -%}
                                        <{{ block.settings.seo_heading }} class="cards-main-carousel-list-item-heading {{ block.settings.heading_size }}">
                                           <span>{{ block.settings.heading | replace: "<strong>", blockhighlightPrefix | replace: "</strong>", blockhighlightSuffix | replace: '++', '<br>' }}</span>
                                        </{{ block.settings.seo_heading }}>
                                    {% endif %}

                                    {% if block.settings.description != blank %}
                                      <p class="cards-main-carousel-list-item-description">
                                         <span> {{ block.settings.description }} </span>
                                      </p>
                                    {% endif %}
                                  </div>
                                {% endif %}
                                       {% if block.settings.btn_link != blank and block.settings.btn_text != blank %}
                                          {% render 'button', class: 'cards-main-carousel-list-item-button', button_link: block.settings.btn_link , button_style: block.settings.button_syle, button_size: block.settings.button_size, button_text: block.settings.btn_text %}
                                    {% endif %}
                                
                              </div>
                          </div>
                         {% endif %}
                      </li>
      
                    {% endfor %}
                </ul>
            </div>
        </div>
        <div class="cards-secondary-carousel-list" data-secondary-carousel-list>
            <ul class="">
               {%- for block in section.blocks -%}
                <li class="block-card-{{ forloop.index }}">
                   <div class="media-box" style="--image-ratio:{{ promotionalImageRatio }}%">
                    {%- liquid  if block.settings.image != blank
                         render 'image', image: block.settings.image
                      else 
                          assign placeholder_image_index = forloop.index0 | modulo: 4 | plus: 1 
                            echo 'collection-apparel-' | append: placeholder_image_index | placeholder_svg_tag: 'placeholder-svg'
                        endif 
                     -%}
                   </div>
                </li>
              {% endfor %}
           
            </ul>
        </div>
    </cards-slider>
  </div>
</div>

<style>
    #shopify-section-{{ section.id }} {
        {% if section.settings.make_section_rounded %}
          background:{{ section.settings.section_background }};
        {% endif %}
      --top-spacer: {{ section.settings.top_space_desktop }}px;
      --bottom-spacer: {{ section.settings.bottom_space_desktop }}px;
    
    }

    @media only screen and (max-width:767px) {
        #shopify-section-{{ section.id }}{
          --top-spacer: {{ section.settings.top_space_mobile }}px !important;
          --bottom-spacer: {{ section.settings.bottom_space_mobile }}px !important;
        }
    }
    {% if section.settings.section_visibility == 'large' %}
      @media (max-width: 767px) {
        #shopify-section-{{ section.id }}{
          display: none !important;
        }
      }
    {% elsif section.settings.section_visibility == 'small' %}
      @media (min-width: 768px) {
        #shopify-section-{{ section.id }}{
          display: none !important;
        }
      }
    {% endif %}
</style>

{% schema %}
    {
      "name": "t:sections.image-card-slideshow.name",
      "tag": "section",
      "class": "image-card-slideshow",
      "disabled_on": {
        "groups": [
          "header",
          "footer"
        ]
      },
      "settings": [
            {
                "type": "select",
                "id": "section_visibility",
                "label": "t:global.common.section_visibility.label",
                "default": "always",
                "options": [
                    {
                    "label": "t:global.common.section_visibility.options.always",
                    "value": "always"
                    },
                    {
                    "label": "t:global.common.section_visibility.options.small",
                    "value": "small"
                    },
                    {
                    "label": "t:global.common.section_visibility.options.large",
                    "value": "large"
                    }
                ]
            },
            {
                "type": "checkbox",
                "id": "make_section_rounded",
                "label": "t:global.common.general_labels.make_section_rounded",
                "default": false
            },
            {
                "type": "select",
                "id": "image_size",
                "label": "t:global.common.image_ratio.label",
                "default": "square",
                "options": [
                    {
                        "value": "landscape",
                        "label": "t:global.common.image_ratio.options.landscape"
                    },
                    {
                        "value": "portrait",
                        "label": "t:global.common.image_ratio.options.portrait"
                    },
                    {
                        "value": "square",
                        "label": "t:global.common.image_ratio.options.square"
                    }
                ]
            },
            {
                "type": "header",
                "content": "t:global.header.color_section.label"
            },
             {
                "type": "color_scheme",
                "id": "color_scheme",
                "default": "primary",
                "label": "t:global.header.color_scheme.label"
            },
            {
                "type": "color",
                "id": "section_background",
                "label": "t:global.common.section_background.label",
                "info": "t:global.common.section_background.info"
            },
            {
                "type": "header",
                "content": "t:global.header.space_section.label"
            },
            {
                "type": "range",
                "id": "top_space_desktop",
                "label": "t:global.top_space_desktop.label",
                "default": 40,
                "min": 0,
                "max": 100,
                "step": 5
            },
            {
                "type": "range",
                "id": "bottom_space_desktop",
                "label": "t:global.bottom_space_desktop.label",
                "default": 40,
                "min": 0,
                "max": 100,
                "step": 5
            },
            {
                "type": "range",
                "id": "top_space_mobile",
                "label": "t:global.top_space_mobile.label",
                "default": 35,
                "min": 0,
                "max": 100,
                "step": 5
            },
            {
                "type": "range",
                "id": "bottom_space_mobile",
                "label": "t:global.bottom_space_mobile.label",
                "default": 35,
                "min": 0,
                "max": 100,
                "step": 5
            }
        ],
      "blocks": [
        {
          "type": "card",
          "name":"t:sections.image-card-slideshow.blocks.card.name",
          "settings": [
             {
                "type": "color_scheme",
                "id": "color_scheme",
                "default": "primary",
                "label": "t:global.header.color_scheme.label"
            },
            {
              "type": "image_picker",
              "id": "image",
              "label": "t:global.common.general_labels.image"
            },
             {
                    "type": "inline_richtext",
                    "id": "heading",
                    "default": "Heading",
                    "info": "t:global.common.infos.heading.label",
                    "label": "t:global.common.general_labels.heading"
                },
                {
                    "type": "select",
                    "id": "heading_size",
                    "label": "t:global.common.general_labels.heading_size",
                    "default": "h4",
                    "options": [
                        {
                            "value": "h1",
                            "label": "H1"
                        },
                        {
                            "value": "h2",
                            "label": "H2"
                        },
                        {
                            "value": "h3",
                            "label": "H3"
                        },
                        {
                            "value": "h4",
                            "label": "H4"
                        },
                        {
                            "value": "h5",
                            "label": "H5"
                        },
                        {
                            "value": "h6",
                            "label": "H6"
                        }
                    ]
                },
                {
                    "type": "select",
                    "id": "seo_heading",
                    "label": "t:global.common.general_labels.heading_tag",
                    "info": "t:global.common.infos.seo_heading.label",
                    "default": "h4",
                    "options": [
                        {
                            "value": "h1",
                            "label": "H1"
                        },
                        {
                            "value": "h2",
                            "label": "H2"
                        },
                        {
                            "value": "h3",
                            "label": "H3"
                        },
                        {
                            "value": "h4",
                            "label": "H4"
                        },
                        {
                            "value": "h5",
                            "label": "H5"
                        },
                        {
                            "value": "h6",
                            "label": "H6"
                        }
                    ]
                },
                {
                    "type": "textarea",
                    "id": "description",
                    "label": "t:global.common.general_labels.description",
                    "default": "Add short description for this section"
                },
             {
                "type": "header",
                "content": "t:global.header.content_section.label"
              },
              {
                "type": "select",
                "id": "content_width",
                "label": "t:sections.slideshow.blocks.settings.content_width.desktop.label",
                "default": "medium",
                "options": [
                  {
                    "value": "small",
                    "label": "t:global.common.size.value.small"
                  },
                  {
                    "value": "medium",
                    "label": "t:global.common.size.value.medium"
                  },
                  {
                    "value": "large",
                    "label": "t:global.common.size.value.large" 
                  }
                ]
              },
             {
                "type": "header",
                "content": "t:global.header.button_section.label"
            },
            {
                    "type": "text",
                    "id": "btn_text",
                    "label": "t:global.common.general_labels.text",
                    "default": "Button text"
                },
                {
                    "type": "url",
                    "id": "btn_link",
                    "label": "t:global.common.general_labels.link",
                    "default": "/collections/all"
                },
                {
                    "type": "select",
                    "id": "button_syle",
                    "label": "t:global.common.style.label",
                    "default": "solid",
                    "options": [
                      {
                        "value": "solid",
                        "label": "t:global.common.style.value.solid"
                      },
                      {
                        "value": "outline",
                        "label": "t:global.common.style.value.outline"
                      },
                      {
                        "value": "link",
                        "label": "t:global.common.style.value.link"
                      },
                      {
                        "value": "animate",
                        "label":"t:global.common.style.value.animate"
                      }
                    ]
                },
                {
                    "type": "select",
                    "id": "button_size",
                    "label": "t:global.common.size.label",
                    "default": "regular",
                    "options": [
                        {
                            "value": "regular",
                            "label": "t:global.common.size.value.regular"
                        },
                        {
                            "value": "small",
                            "label": "t:global.common.size.value.small"
                        },
                        {
                            "value": "medium",
                            "label": "t:global.common.size.value.medium"
                        },
                        {
                            "value": "large",
                            "label": "t:global.common.size.value.large"
                        }
                    ]
                }
          ]
        }
      ],
      "presets": [ 
        {
          "name":"t:sections.image-card-slideshow.presets.name",
          "blocks": [
            {
              "type": "card"
            },
            {
              "type": "card"
            },
            {
              "type": "card"
            }
          ]
        }
      ]
    }
{% endschema %}