<header
  class="header-main {% if template == 'index' %} transparent-{{ section.settings.desktop_transparent_header }} mobile-transparent-{{ section.settings.mobile_transparent_header }} {% endif %}"
  data-header-sticky="{{ section.settings.enable_sticky_header }}"
  data-header-sticky-type="{{ section.settings.sticky_header_type }}"
  data-header-style="{{section.settings.header_style}}"
  data-header-section
>

  {% comment %} if section.settings.header_style == 'header_8' and section.settings.desktop_transparent_header == false and template == 'index'
    assign mainheaderClass = 'tabbed_menu'
  elsif template != 'index'
     assign mainheaderClass = 'tabbed_menu'
  elsif section.settings.header_style == 'header_8' and section.settings.desktop_transparent_header == true
     assign mainheaderClass = ''
  endif {% endcomment %}
{%  liquid  
  if section.settings.header_style == 'header_8'
    assign mainheaderClass = 'tabbed_menu'
  endif  
%}
  <div class="container">
    <header-icons>
      <div class="header-inner 
      {{ section.settings.header_style }}{% if section.settings.header_style == 'header_8' %} tabbed-menus-{{ section.settings.tabbed_menus_style }}{% endif %}{% if section.settings.header_style == 'header_8' and section.settings.tabbed_menus_style == 'center' %} logo-left{% elsif section.settings.header_style != 'header_3' and section.settings.header_style != 'header_5' and section.settings.header_style != 'header_8' %} logo-left{% else %} logo-center{% endif %}
       {% if section.settings.header_style == 'header_2' or section.settings.header_style == 'header_3' or section.settings.header_style == 'header_6' or section.settings.header_style == 'header_7' %} menu-left
       {% elsif section.settings.header_style == 'header_8' and section.settings.tabbed_menus_style == 'left' %} menu-left
       {% elsif section.settings.header_style == 'header_4' or   section.settings.header_style == 'header_5' %} hamburger-left{% else %} menu-center{% endif %} {% if section.settings.header_style == 'header_6' or section.settings.header_style == 'header_7' %} searchbar-enabled{% endif %} {{ mainheaderClass }}">
        {% capture logo %}
          {% if section.settings.header_style == 'header_7' %}
           <div class="logo-left-searchbar-wrapper">
          {% endif %}
            <a class="header-logo" href="{{ routes.root_url }}" aria-label="{{ shop.name }}"> 
              {%- if section.settings.logo != blank -%}
                {%- assign image_2x_size = section.settings.logo_width | times: 2 | at_most: 2560 -%}
                  <img class="header-logo-img"
                    srcset="{{ section.settings.logo | image_url: width: section.settings.logo_width }} 1x, {{ section.settings.logo | image_url: width: image_2x_size }} 2x"
                    src="{{ section.settings.logo | image_url: width: section.settings.logo_width }}"
                    loading="lazy"
                    width="{{ section.settings.logo_width }}"
                    height="{{ section.settings.logo_width | divided_by : section.settings.logo.aspect_ratio | round }}"
                    alt=""
                    aria-hidden="true" >
                    {% if section.settings.desktop_transparent_header %}
                    {%liquid
                      if section.settings.transparent_logo != blank 
                      assign transparent_image = section.settings.transparent_logo
                      else 
                      assign transparent_image =  section.settings.logo
                    endif
                    %}
                      {%- assign image_2x_size = section.settings.logo_width | times: 2 | at_most: 2560 -%}
                        <img class="header-logo-img header-logo-img-transparent"
                          srcset="{{ transparent_image | image_url: width: section.settings.logo_width }} 1x, {{ transparent_image | image_url: width: image_2x_size }} 2x"
                          src="{{ transparent_image | image_url: width: section.settings.logo_width }}"
                          loading="lazy"
                          width="{{ section.settings.logo_width }}"
                          height="{{ section.settings.logo_width | divided_by : transparent_image.aspect_ratio | round }}"
                          alt=""
                          aria-hidden="true" >
                    {% endif %}
                {% else %}
                  <span class="logo-text">{{ shop.name }}</span>
              {% endif %}
            </a>
          {% if section.settings.header_style == 'header_7' %}
            {% render 'header-search-group' %}
            </div>
          {% endif %}
        {% endcapture %}
        {% if section.settings.menu != blank %}
        <button class="hamburger-toggler" type="button" data-mobile-hamburger aria-label="Mobile hamburger">
          <div class="hamburger-toggler-icon">
            <span class="line"></span>
            <span class="line"></span>
          </div>
        </button>
      {% endif %}
        {%- if section.settings.menu != blank -%}
          {%- if section.settings.header_style == 'header_4' or section.settings.header_style == 'header_5' or section.settings.header_style == 'header_7' -%}
            <hamburger-menu
              class="hamburger-toggler hamburger-menu cursor-pointer"
              type="button"
              data-hamburger-menu
              aria-label="Hamburger menu"
              tabindex="0"
            >
              <div class="hamburger-toggler-icon">
                <span class="line"></span>
                <span class="line"></span>
              </div>
            </hamburger-menu>
          {% endif %}
        {% endif %}
        {% liquid
          if section.settings.header_style != 'header_3'
            echo logo
          endif
          if section.settings.menu != blank
          if section.settings.header_style == 'header_8'
            render 'tabbed-nav-items', section: section
          elsif section.settings.header_style != 'header_4' and section.settings.header_style != 'header_5'
              render 'nav-items', section: section
            endif
          endif
          if section.settings.header_style == 'header_3'
            echo logo
          endif
        %}
        <div class="header-icons-box">
          {% render 'header-icons', section: section %}
        </div>
      </div>
    </header-icons>
   
  </div>
      
  {% liquid
    render 'mobile-menu', section: section
    if section.settings.header_style == 'header_4' or section.settings.header_style == 'header_5' or section.settings.header_style == 'header_7'
      render 'hamburger-menu', section: section
    endif
  %}
  {% if section.settings.header_style == 'header_8' %}
  <div class="header-bottom {{ section.settings.header_style }} menu-tabbed" data-header-bottom
>
    {% if section.settings.menu != blank %}
      <div class="menu-list-box" data-menu-list-box {% if template == 'index' %}data-transparent="{{ section.settings.desktop_transparent_header }}"{% endif %}> 
          <div class="menu-list-topheader menu-list-bottom menu-list-level-2" data-menu-level="2">
            <div class="container">
          {%- for link in linklists[section.settings.menu].links -%}
          {% if link.current and link.links.size > 0 %}
            {% assign activeCls = 'active' %} 
          {% else %}
          {% assign activeCls = 'd-md-none' %}  
          {% endif %}
          {% comment %} 
          {% if section.settings.desktop_transparent_header and template == 'index' %}
            {% assign activeCls = 'd-md-none' %}
          {% endif %} {% endcomment %}
              {% if link.links.size > 0 %}
                  <ul class="list-inline menu-list menu-list-bottom {{ activeCls }}" data-index="{{ forloop.index }}" data-menu-list-bottom>
                      {%- for childlink in link.links -%}
                          <li class="menu-item {% if childlink.links.size > 0 %} has-children {% endif %}">
                              <a href="{{ childlink.url }}" class="menu-link {{ section.settings.sub_menu_font }}-font"
                              aria-label="{{ childlink.title }}">{{- childlink.title }}
                              {% if childlink.links.size > 0 %}
                              <svg width="10" height="6" viewBox="0 0 10 6" fill="none">
                                  <path d="M1.00006 0.999871L4.99994 5L9.00006 1.00013" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                              </svg>
                              {% endif %}
                              </a>
                          
                          {% if childlink.links.size > 0 %}
                              <ul class="nav-submenu">
                                  {% for grandchild in childlink.links %}
                                      <li class="nav-submenu-item">
                                          <a
                                          class="focus-inside nav-submenu-link"
                                          href="{{ grandchild.url }}"
                                          >
                                          {{- grandchild.title }}
                                          </a>
                                      </li>
                                  {% endfor %}
                                </ul>
                          {% endif %}
                          </li>
                      {% endfor %}
                    </ul>
              {% endif %}
          {% endfor %}
          </div>
</div>
      </div>
      {% endif %}
  </div>
  {% endif %}
</header>
<style>
  .header {
    --menu-font-size:{{ section.settings.menu_font_size }}px;
    --submenu-font-size:{{ section.settings.submenu_font_size }}px;
    --transparent-text-color:{{ section.settings.transparent_color }};
    --header-logo-width: {{ section.settings.logo_width }}px;
  }
  @media (max-width: 767px) {
    .header {
      --header-logo-width: {{ section.settings.logo_width_mobile }}px;
      --mobile-menu-font-size:{{ section.settings.mobile_menu_font_size }}px;
    }
  }
</style>
<script>
  function stickyHeaderInit() {
    var windowScrollTop = window.scrollY;
    let scrollHeight = 100;
    var headerElement = document.querySelector('#shopify-section-{{- section.id -}}');
    let headerTag = document.querySelector('header');
    if(headerTag){
      let stickyHeader = headerTag.getAttribute('data-header-sticky');
      let stickyHeaderType = headerTag.getAttribute('data-header-sticky-type');
      console.log('stickyHeaderType',stickyHeaderType);
      if(stickyHeaderType == 'always'){
        document.querySelector('body').classList.add("sticky-always")
      }
      else{
        document.querySelector('body').classList.remove("sticky-always")
      }
      if (stickyHeader == 'true') {
        headerElement.classList.add('sticky-active');
      }
      {% if template == 'index' %}
        if(headerTag.classList.contains("transparent-true")){
          headerElement.classList.add('transparent-header')
        }
      {% endif %}
  
        if (headerElement.querySelector('[data-header-section]')) {
          var headerHeight = headerElement.querySelector('[data-header-section]').getBoundingClientRect().height.toFixed(2);
          document.querySelector('body').style.setProperty('--header-height', `${headerHeight}px`);  
          if(stickyHeader ==  'false'){
            document.querySelector('body').style.setProperty('--dynamic-header-height', `0px`);
          }else{
            document.querySelector('body').style.setProperty('--dynamic-header-height', `${headerHeight}px`);
          }
          scrollHeight = scrollHeight ;
          var outerheight = headerHeight + 50;
          if(document.querySelector('.announcement-bar')){
            let announcementSection = document.querySelector('.announcement-bar');
            let annoucementHeight = announcementSection.getBoundingClientRect().height.toFixed(2);
            document.querySelector('body').style.setProperty('--announcement-height', `${annoucementHeight}px`);
          }
    
        if (window.innerWidth > 991) {
          if (headerElement.querySelector('.transparent-true')) {
            document.querySelector('body').style.setProperty('--transparent-header-height', `${headerHeight}px`);
          } 
        }  
        if (window.innerWidth < 991) {
          if (headerElement.querySelector('.mobile-transparent-true')) {
            document.querySelector('body').style.setProperty('--transparent-header-height', `${headerHeight}px`);
          } 
        } 
        window.addEventListener('scroll', function () {
          let mainHeader = document.querySelector('header');
          if(mainHeader){
              let stickyHeader = mainHeader.getAttribute('data-header-sticky');
              if (stickyHeader == 'false') {
                return false;
              }
              if (stickyHeader == 'true') {
                  if (window.scrollY > scrollHeight) {
                    headerElement.classList.add('is-sticky');
                  } else {
                    headerElement.classList.remove('is-sticky');
                  }
                  if(stickyHeaderType == 'on_scroll'){
                    if (mainHeader && stickyHeader == 'true') {
                      if (window.scrollY > scrollHeight) {
                        if (windowScrollTop > window.scrollY) {
                          headerElement.classList.remove('is-hidden');
                        } else {
                          if (!document.querySelector('body').classList.contains('menu-open')) {
                            headerElement.classList.add('is-hidden');
                          }
                        }
                      } else {
                        headerElement.classList.remove('is-hidden');
                      }
                    } 
                  }
                if(headerElement.classList.contains("is-hidden")){
                  document.querySelector('body').style.setProperty('--dynamic-header-height', `0px`);
                }else{

                  if( stickyHeader ==  'false'){
                    document.querySelector('body').style.setProperty('--dynamic-header-height', `0px`);
                  }else{
                    let headerHeight = headerElement.querySelector('[data-header-section]').getBoundingClientRect().height.toFixed(2);
                    document.querySelector('body').style.setProperty('--dynamic-header-height', `${headerHeight}px`);
                  }
                 
                }
              }
            
          }
          windowScrollTop = window.scrollY;
        });
        window.addEventListener('resize', function () {

          setTimeout(function () {
            let headerHeight = headerElement.querySelector('[data-header-section]').getBoundingClientRect().height.toFixed(2);
            let stickyHeadercheck = headerTag.getAttribute('data-header-sticky');
            document.querySelector('body').style.setProperty('--header-height', `${headerHeight}px`);
            if(stickyHeadercheck ==  'false'){
              document.querySelector('body').style.setProperty('--dynamic-header-height', `0px`); 
            }else{
              document.querySelector('body').style.setProperty('--dynamic-header-height', `${headerHeight}px`);
            }
            
            
            if(document.querySelector('.announcement-bar')){
              let announcementSection = document.querySelector('.announcement-bar');
              let annoucementHeight = announcementSection.getBoundingClientRect().height.toFixed(2);
              document.querySelector('body').style.setProperty('--announcement-height', `${annoucementHeight}px`);          
            }
            if (window.innerWidth > 991) {
              if (headerElement.querySelector('.transparent-true')) {
                document.querySelector('body').style.setProperty('--transparent-header-height', `${headerHeight}px`);
              }
            } 
            if (window.innerWidth < 991) {
              if (headerElement.querySelector('.mobile-transparent-true')) {
                document.querySelector('body').style.setProperty('--transparent-header-height', `${headerHeight}px`);
              } 
            } 
          }, 500);
        });
      }
      
     
    }
    else{
      document.querySelector('body').style.setProperty('--header-height', `0px`);   
      document.querySelector('body').style.setProperty('--dynamic-header-height', `0px`);
    }
  }
</script>


