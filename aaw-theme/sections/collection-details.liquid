<link rel="preload" as="style" href="{{ 'collection-details.css' | asset_url }}">
{{ 'collection-details.css' | asset_url | stylesheet_tag }}

<div class="section-container {{ section.settings.color_scheme }}-scheme{% if section.settings.make_section_rounded %} section-rounded{% endif %}">
  <div class="{{ settings.container_width }}">
    {% if section.settings.heading != blank %}

        {%- capture sectionhighlightPrefix -%}
        <strong class="highlight-text">
        {%- endcapture -%}

        {%- capture sectionhighlightSuffix -%}
        </strong>
        {%- endcapture -%}

        <div class="section-heading-box {{ section.settings.heading_alignment }}" {% if settings.enable_animation %}data-aos="fade-up" data-aos-duration="1000"{% endif %}>
            <{{ section.settings.seo_heading }} class="section-heading {{ section.settings.heading_size }}">
                {{ section.settings.heading | replace: "<strong>", sectionhighlightPrefix | replace: "</strong>", sectionhighlightSuffix | replace: '++', '<br>' }}
            </{{ section.settings.seo_heading }}>
        </div>
    {% endif %}

    <div class="collection-details-wrapper">
      {% assign infinite = false %}
    {% if section.settings.autoslide == true %}
      {% assign infinite = true %}
    {% endif %}
      <div class="slider collection-details-slider" id="collection-details-{{ section.id }}"
        {% if section.blocks.size > 1 %}
          data-slides-length="{{ section.blocks.size }}"
            data-slick='
            {
              "infinite": {{ infinite }},
              "autoplay": {{ section.settings.autoslide }},
              "slidesToShow": 1.5,
              "slidesToScroll": 1,
              "autoplaySpeed": {{ section.settings.interval | times: 1000 }},
              "arrows": true,
              "responsive": [
                {
                  "breakpoint": 991,
                  "settings": {
                    "slidesToShow":1.1
                  }
                }
              ]
            }
          '
        {% endif %}
      >
        {%- for block in section.blocks -%}
          {% liquid
            assign imageContent = ''
            assign collection = block.settings.collection

            if block.settings.image != blank
              assign imageContent = block.settings.image
            elsif collection.featured_image != blank
              assign imageContent = collection.featured_image
            endif
          -%}
          <div class="collection-details-card-item" data-slide="{{ forloop.index0 }}" {{ block.shopify_attributes }} id="collection-details-block-{{ block.id }}">
            <div class="collection-details-card">
              <div class="collection-details-card-image animate-hvr">
                <div class="media-box media-box-fixed">
                  {%- if imageContent != blank -%}
                    {%- render 'image', image: imageContent, class: 'collection-block-image' -%}
                  {%- else -%}
                    {%- assign placeholder_image_index = forloop.index0 | modulo: 4 | plus: 1 -%}
                    {%- assign placeholder_image = 'collection-apparel-' | append: placeholder_image_index -%}
                    {{ placeholder_image | placeholder_svg_tag: 'placeholder-svg' }}
                  {%- endif -%}
                </div>
              </div>
              <div class="collection-details-card-content">
                <div class="collection-details-card-text">
                  <{{block.settings.seo_heading}} class="collection-details-card-title {{block.settings.heading_size}} " >
                    {%- if block.settings.heading != blank -%}
                      {{ block.settings.heading -}}
                    {% elsif collection != blank %}
                      {{- collection.title | strip_html -}}
                    {%- else -%}
                      {{ 'sections.collection_details.collection_name' | t }}
                    {%- endif %}
                  </{{block.settings.seo_heading}}>

                  {% if block.settings.show_description %}
                    <div class="collection-details-card-desc rte"  >
                      {%- if block.settings.description != blank -%}
                        {{  block.settings.description | replace:'<p></p>','<br>'}}
                      {% elsif collection.description != blank %}
                        {{ collection.description  | replace: '<table', '<div class="table-main"><table' | replace: '</table>', '</table></div>' }}
                      {% else %}
                      {{ 'sections.collection_details.collection_description' | t }}
                      {% endif %}
                    </div>
                  {% endif %}

                  {% if collection != blank and  block.settings.btn_text != blank %}
                    <div class="collection-details-card-button" >
                        {% render 'button',
                          button_link: collection.url ,
                          button_style: block.settings.button_style,
                          button_size: block.settings.button_size,
                          button_text: block.settings.btn_text
                        %}
                    </div>
                {% endif %}
                </div>
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</div>
<style>
  #shopify-section-{{ section.id }}.shopify-section {
    --top-spacer:{{ section.settings.top_space_desktop }}px;
    --bottom-spacer:{{ section.settings.bottom_space_desktop }}px;
    --highlight-text: {{ section.settings.highlighted_color }};
    --image-fit:{{ section.settings.image_fit }};
    --media-height: {{ section.settings.desktop_height }};
    {% if section.settings.make_section_rounded %}
      background:{{ section.settings.section_background }};
    {% endif %}
  }


  @media screen and (max-width:767px){
    #shopify-section-{{ section.id }}.shopify-section {
    --top-spacer:{{ section.settings.top_space_mobile }}px;
    --bottom-spacer:{{ section.settings.bottom_space_mobile }}px;
    --media-height: {{ section.settings.mobile_height }};
    }

  }

  {% if section.settings.section_visibility == 'large' %}
    @media (max-width: 767px) {
      #shopify-section-{{ section.id }}{
        display: none !important;
      }
    }
  {% elsif section.settings.section_visibility == 'small' %}
    @media (min-width: 768px) {
      #shopify-section-{{ section.id }}{
        display: none !important;
      }
    }
  {% endif %}
</style>
