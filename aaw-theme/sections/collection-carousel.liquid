<link rel="preload" as="style" href="{{ 'collection-carousel.css' | asset_url }}">
{{ 'collection-carousel.css' | asset_url | stylesheet_tag }}

{% capture button %}
{%- if section.settings.btntext != blank and section.settings.btnlink != blank -%}
  <div class="view-all-link">
    <a href="{{ section.settings.btnlink }}" class="view-all-text text-underline"><span>{{ section.settings.btntext }}</span>
    </a>
  </div>
{%- endif -%}
{% endcapture %}

{%- capture textContent -%}

{%- capture sectionhighlightPrefix -%}
   <strong class="highlight-text">
{%- endcapture -%}

{%- capture sectionhighlightSuffix -%}
   </strong>
{%- endcapture -%}
{%- if section.settings.heading != blank -%}
    <{{ section.settings.seo_heading }} class="section-heading {{ section.settings.heading_size }}">
        {{- section.settings.heading | replace: "<strong>", sectionhighlightPrefix | replace: "</strong>", sectionhighlightSuffix | replace: '++', '<br>' -}}
    </{{ section.settings.seo_heading }}>
{%- endif -%}
{%- if section.settings.description != blank -%}
    <div class="section-description rte">
      {{ section.settings.description | replace: '<p></p>', '<br>' | replace: '<h1></h1>', '<br>' | replace: '<h2></h2>', '<br>' | replace: '<h3></h3>', '<br>' | replace: '<h4></h4>', '<br>' | replace: '<h5></h5>', '<br>' | replace: '<h6></h6>', '<br>' }}
    </div>
  {%- endif -%}
{%- endcapture -%}
<div class="section-container {{ section.settings.color_scheme }}-scheme {% if section.settings.make_section_rounded %}section-rounded{% endif %}">
  <div class="{{ settings.container_width }}">
      {% if textContent != blank %}
        <div class="section-heading-box{% if section.settings.description != blank %} desc-enabled{% endif %} {{ section.settings.content_alignment }}" {% if settings.enable_animation %}data-aos="fade-up" data-aos-duration="1000"{% endif %}>
          {{ textContent }}
          {% if button != blank %}
            {{ button }}
          {% endif %}
        </div>
      {% endif %}
    {% assign infinite = false %}
    {% if section.settings.autoslide == true %}
      {% assign infinite = true %}
    {% endif %}
    <div class="collection-carousel-wrapper">
      <div
        class="slider collection-carousel-slider"
        id="collection-slider-{{ section.id }}"
        {% if section.blocks.size > 2 %}
          data-slides-length="{{ section.blocks.size }}"
          data-slick='
            {
              "infinite": {{ infinite }},
              "autoplay": {{ section.settings.autoslide }},
              "slidesToShow": 2.5,
              "slidesToScroll": 1,
              "autoplaySpeed": {{ section.settings.interval | times: 1000 }},
              "arrows": true,
              "responsive": [
                {
                  "breakpoint": 991,
                  "settings": {
                    "slidesToShow":2.5
                  }
                },
                {
                  "breakpoint": 767,
                  "settings": {
                      "slidesToShow": 1.5

                  }
                },
                {
                  "breakpoint": 575,
                  "settings": {
                      "slidesToShow":1.5

                  }
                }
              ]
            }
          '
        {% endif %}
      >
        {%- for block in section.blocks -%}
          {% liquid
            assign imageContent = ''
            assign collection = block.settings.collection

            if block.settings.image != blank
              assign imageContent = block.settings.image
            elsif collection.featured_image != blank
              assign imageContent = collection.featured_image
            endif
            if section.settings.grid_image_size == 'landscape'
              assign imageRatio = 75
            elsif section.settings.grid_image_size == 'square'
              assign imageRatio = 100
            elsif section.settings.grid_image_size == 'portrait'
              assign imageRatio = 125
            else
              if block.settings.image != blank
                assign imageRatio = 1 | divided_by: block.settings.image.aspect_ratio | times: 100 | plus: 1
              elsif collection.featured_image
                assign imageRatio = 1 | divided_by: collection.featured_image.aspect_ratio | times: 100 | plus: 1
              else
                assign imageRatio = 100
              endif
            endif
          -%}
          {% assign aosDelay = forloop.index | times: 100 %}
          <a
            data-slide="{{ forloop.index0 }}"
            {{ block.shopify_attributes }}
            {% if collection.url == blank %}
              role="link"aria-disabled="true"
            {% else %}
              href="{{ collection.url | default : '#' }}"
            {% endif %}
            id="collection-block-{{ block.id }}"
            class="collection-card-item {% if section.settings.heading_overlay %}content-overlay{% endif %}"
            {% if settings.enable_animation %}data-aos="fade-up" data-aos-delay="{{ aosDelay }}"{% endif %}
          >
         
            <div class="collection-card-img animate-hvr">
              <div class="media-box" style="--image-ratio:{{ imageRatio }}%;">
                {%- if imageContent != blank -%}
                  {%- render 'image', image: imageContent, class: 'collection-block-image' -%}
                {%- else -%}
                  {%- assign placeholder_image_index = forloop.index0 | modulo: 4 | plus: 1 -%}
                  {%- assign placeholder_image = 'collection-apparel-' | append: placeholder_image_index -%}
                  {{ placeholder_image | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
              </div>
              <div class="collection-card-overlay-content">
                <div class="collection-card-overlay-head">
                  {% if section.settings.heading_overlay %}
                    <h4 class="collection-card-heading">
                      {%- if block.settings.heading != blank -%}
                        {{ block.settings.heading -}}
                      {% elsif collection != blank %}
                        {{- collection.title | strip_html -}}
                      {%- else -%}
                        {{ 'sections.collection_carousel.collection' | t }}
                      {%- endif %}
                    </h4>
                  {% endif %}
                  <div class="collection-card-overlay-btn">
                    <span class="arrow-btn">
                      <svg class="arrow-btn-icon" width="15" height="15" viewBox="0 0 15 15" fill="none" >
                        <path fill-rule="evenodd" clip-rule="evenodd" d="M7.07031 0L14.1414 7.07107L7.07031 14.1421L5.76824 12.8401L10.6166 7.99173L0.95721 7.9917L0.957199 6.15032L10.6166 6.15035L5.76827 1.30205L7.07031 0Z" fill="currentColor"/>
                        </svg>                        
                    </span>
                  </div>
                </div>
                <div class="collection-card-overlay-footer">
                  <h4 class="collection-card-count">
                    {% if forloop.index < 10 %}
                    0{{ forloop.index }}
                    {% else %}
                        {{ forloop.index }}
                    {% endif %}
                  </h4>
                </div>
              </div>
            </div>
            <div class="collection-card-content text-{{ section.settings.title_postion }}">
              <h4 class="collection-card-heading">
                {%- if block.settings.heading != blank -%}
                  {{ block.settings.heading -}}
                {% elsif collection != blank %}
                  {{- collection.title | strip_html -}}
                {%- else -%}
                  {{ 'sections.collection_carousel.collection' | t }}
                {%- endif %}
              </h4>
            </div>

          </a>
        {% endfor %}
      </div>
    </div>

 
  </div>
</div>
<style>
  #shopify-section-{{ section.id }}.shopify-section {
    --top-spacer:{{ section.settings.top_space_desktop }}px;
    --bottom-spacer:{{ section.settings.bottom_space_desktop }}px;
    --card-overlay-background:{{ section.settings.overlay_color.red }},{{ section.settings.overlay_color.green }},{{ section.settings.overlay_color.blue }};
    --card-overlay-opacity:{{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --image-fit:{{ section.settings.image_fit }};
    --card-overlay-color:{{ section.settings.heading_overlay_color }};
    --highlight-text: {{ section.settings.highlighted_color }};
    {% if section.settings.make_section_rounded %}
      background:{{ section.settings.section_background }};
    {% endif %}
  }

  #shopify-section-{{ section.id }}.shopify-section .collection-carousel-wrapper{
    --button-background:{{ section.settings.button_background_color }};
    --button-text-color:{{ section.settings.button_text_color }};
    --button-border:{{ section.settings.button_border_color }};
  }


  @media only screen and (max-width:767px) {
    #shopify-section-{{ section.id }}.shopify-section{
      --top-spacer:{{ section.settings.top_space_mobile }}px;
      --bottom-spacer:{{ section.settings.bottom_space_mobile }}px;
    }
  }
  {% if section.settings.section_visibility == 'large' %}
    @media (max-width: 767px) {
      #shopify-section-{{ section.id }}{
        display: none !important;
      }
    }
  {% elsif section.settings.section_visibility == 'small' %}
    @media (min-width: 768px) {
      #shopify-section-{{ section.id }}{
        display: none !important;
      }
    }
  {% endif %}
</style>

{% schema %}
{
  "name": "t:sections.collection-carousel.name",
  "tag": "section",
  "max_blocks": 10,
  "class": "collection-carousel",
  "disabled_on": {
    "groups": [
      "header",
      "footer"
    ]
  },
  "settings": [
    {
      "type": "select",
      "id": "section_visibility",
      "label": "t:global.common.section_visibility.label",
      "default": "always",
      "options": [
        {
          "label": "t:global.common.section_visibility.options.always",
          "value": "always"
        },
        {
          "label": "t:global.common.section_visibility.options.small",
          "value": "small"
        },
        {
          "label": "t:global.common.section_visibility.options.large",
          "value": "large"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "make_section_rounded",
      "label": "t:global.common.general_labels.make_section_rounded",
      "default": false
    },
    {
      "type": "select",
      "id": "grid_image_size",
      "label": "t:global.common.image_ratio.label",
      "default": "portrait",
      "options": [
        {
          "value": "auto",
          "label": "t:global.common.image_ratio.options.auto"
        },
        {
          "value": "landscape",
          "label": "t:global.common.image_ratio.options.landscape"
        },
        {
          "value": "portrait",
          "label": "t:global.common.image_ratio.options.portrait"
        },
        {
          "value": "square",
          "label": "t:global.common.image_ratio.options.square"
        }
      ]
    },
    {
      "type": "select",
      "id": "image_fit",
      "label": "t:global.common.image_fit.label",
      "default": "cover",
      "options": [
        {
          "value": "cover",
          "label": "t:global.common.image_fit.options.cover.label"
        },
        {
          "value": "contain",
          "label": "t:global.common.image_fit.options.contain.label"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "autoslide",
      "label": "t:sections.collection-carousel.settings.autoslide.label",
      "default": true
    },
    {
      "type": "range",
      "id": "interval",
      "min": 1.5,
      "max": 5,
      "step": 0.5,
      "unit": "s",
      "label": "t:sections.collection-carousel.settings.interval.label",
      "default": 2.5
    },
    {
      "type": "header",
      "content": "t:global.header.content_section.label"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "Collection carousel",
      "label": "t:global.common.general_labels.heading",
      "info": "t:global.common.infos.heading.label"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "t:global.common.general_labels.heading_size",
      "default": "h3",
      "options": [
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        },
        {
          "value": "h4",
          "label": "H4"
        },
        {
          "value": "h5",
          "label": "H5"
        },
        {
          "value": "h6",
          "label": "H6"
        }
      ]
    },
    {
      "type": "select",
      "id": "seo_heading",
      "label": "t:global.common.general_labels.heading_tag",
      "info": "t:global.common.infos.seo_heading.label",
      "default": "h3",
      "options": [
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        },
        {
          "value": "h4",
          "label": "H4"
        },
        {
          "value": "h5",
          "label": "H5"
        },
        {
          "value": "h6",
          "label": "H6"
        }
      ]
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "t:sections.collection-carousel.settings.content_alignment.label",
      "default": "text-left",
      "options": [
        {
          "label": "t:global.common.alignments.left",
          "value": "text-left"
        },
        {
          "label": "t:global.common.alignments.center",
          "value": "text-center"
        }
      ]
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "t:global.common.general_labels.description"
    },
    {
      "type": "header",
      "content": "t:global.common.general_labels.link"
    },
    {
      "type": "text",
      "id": "btntext",
      "label": "t:global.common.general_labels.text"
    },
    {
      "type": "url",
      "id": "btnlink",
      "label": "t:global.common.general_labels.link"
    },
    {
      "type": "header",
      "content": "t:global.common.general_labels.collection_grid"
    },
    {
      "type": "checkbox",
      "id": "heading_overlay",
      "default": true,
      "label": "t:sections.collection-carousel.settings.heading_overlay.label"
    },
    {
      "type": "select",
      "id": "title_postion",
      "label": "t:sections.collection-carousel.settings.title_postion.label",
      "info":"t:sections.collection-carousel.settings.title_postion.info",
      "default": "left",
      "options": [
        {
          "value": "left",
          "label": "t:global.common.alignments.left"
        },
        {
          "value": "center",
          "label": "t:global.common.alignments.center"
        },
        {
          "value": "right",
          "label": "t:global.common.alignments.right"
        }
      ]
    },
    {
      "type": "paragraph",
      "content": "t:global.header.color_section.label"
    },
    {
      "type": "color",
      "id": "heading_overlay_color",
      "label": "t:sections.collection-carousel.settings.heading_overlay_color.label",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "t:sections.collection-carousel.settings.overlay_color.label",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "t:sections.collection-carousel.settings.overlay_opacity.label",
      "default": 15,
      "max": 100,
      "min": 0,
      "step": 1,
      "unit": "%"
    },
    {
      "type": "paragraph",
      "content": "t:global.common.general_labels.card_arrow"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "t:global.common.general_labels.arrow",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "button_background_color",
      "label": "t:global.common.general_labels.background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_border_color",
      "label": "t:global.common.general_labels.border",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "t:global.header.color_section.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "primary",
      "label": "t:global.header.color_scheme.label"
    },
    {
      "type": "color",
      "id": "highlighted_color",
      "default": "#EFF341",
      "label": "t:global.common.general_labels.highlight_color"
    },
    {
      "type": "color",
      "id": "section_background",
      "label": "t:global.common.section_background.label",
      "info": "t:global.common.section_background.info"
    },
    {
      "type": "header",
      "content": "t:global.header.space_section.label"
    },
    {
      "type": "range",
      "id": "top_space_desktop",
      "label": "t:global.top_space_desktop.label",
      "default": 60,
      "min": 0,
      "max": 100,
      "step": 5
    },
    {
      "type": "range",
      "id": "bottom_space_desktop",
      "label": "t:global.bottom_space_desktop.label",
      "default": 40,
      "min": 0,
      "max": 100,
      "step": 5
    },
    {
      "type": "range",
      "id": "top_space_mobile",
      "label": "t:global.top_space_mobile.label",
      "default": 35,
      "min": 0,
      "max": 100,
      "step": 5
    },
    {
      "type": "range",
      "id": "bottom_space_mobile",
      "label": "t:global.bottom_space_mobile.label",
      "default": 35,
      "min": 0,
      "max": 100,
      "step": 5
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "t:sections.featured-collections-list.blocks.collection.name",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "t:sections.featured-collections-list.blocks.collection.settings.collection.label"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.featured-collections-list.blocks.collection.settings.image.label"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "t:sections.featured-collections-list.blocks.collection.settings.heading.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.featured-collections-list.presets.name",
      "blocks": [
        {
          "type": "collection"
        },
        {
          "type": "collection"
        },
        {
          "type": "collection"
        },
        {
          "type": "collection"
        },
        {
          "type": "collection"
        },
        {
          "type": "collection"
        }
      ]
    }
  ]
}
{% endschema %}
