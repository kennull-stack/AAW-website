<link rel="preload" as="style" href="{{ 'account.css' | asset_url }}">
{{ 'account.css' | asset_url | stylesheet_tag }}
{%- if section.settings.enable_shop_login_button == false -%}
  {%- assign hide_shop_login_button = true -%}
{%- endif -%}
<div class="section-container {{ section.settings.color_scheme }}-scheme">
  {% if section.settings.image != blank %}
  <div class="account-background-img d-none d-md-block">
    {% render 'image', image: section.settings.image %}
  </div>
  {% endif %}
  <div class="container-fullwidth">
    <div class="row no-gutters">
      <div class="col-12 col-sm-12{% if section.settings.heading != blank or section.settings.description != blank or section.settings.image != blank  %} col-md-6 col-lg-6{% else %} col-md-12 col-lg-12{% endif %}">
        <div class="left-side-content">
          <div class="account-card" id="recover">
            <h3 class="account-heading {{ section.settings.heading_size }}">{{ 'customer.login_page.reset_password' | t }}</h3>
            {%- form 'recover_customer_password', class: 'account-form' -%}
              {% if form.errors %}
                <p class="error-message"> {{ form.errors.messages.form }} </p>
              {%- endif -%}
              {% assign recover_success = form.posted_successfully? %}
              <div class="no-form-group">
                <label class="hidden" for="RecoverEmail">{{ 'customer.login_page.email' | t }}</label>
                <input
                  type="email"
                  class="form-control input-md"
                  name="email"
                  id="RecoverEmail"
                  autocomplete="email"
                  autocapitalize="off"
                  {% if form.errors %}
                    aria-invalid="true"
                    aria-describedby="RecoverEmail-email-error"
                  {% endif %}
                  placeholder="{{ 'customer.login_page.email' | t }}"
                  pattern="^([a-zA-Z0-9_\-\.]+)@((\[[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.)|(([a-zA-Z0-9\-]+\.)*[a-zA-Z]{2,}))$"
                >
              </div> 
              {% liquid
                assign buttonText ='customer.login_page.submit' | t
                render 'button' type: 'button', button_size: section.settings.btn_size, button_text: buttonText
              %}
              <div class="account-info-text text-small" >
                  <a href="#login" class="text-underline" data-target-login>{{ 'customer.login_page.cancel' | t }}</a>
              </div>
            {%- endform -%}
          </div>
          <div class="account-card" id="login">
            <{{ section.settings.seo_heading }} class="account-heading {{ section.settings.heading_size }}">{{ 'customer.login_page.title' | t }}</{{ section.settings.seo_heading }}>
            {%- form 'customer_login', novalidate: 'novalidate', class: 'account-form' -%}
              {%- if recover_success == true -%}
                <p class="success-message">{{ 'customer.recover_password.success' | t }}</p>
              {%- endif -%}
              {%- if form.errors -%}
                <div class="error-message">{{ form.errors | default_errors }}</div>
              {%- endif -%}
              <div class="signin__with-shop">
                {%- if shop.features.login_with_shop_classic_customer_accounts? -%}
                  <section name="sign-in-with-shop-provider">
                    {{ shop | login_button: hide_button: hide_shop_login_button }}
                    {%- unless hide_shop_login_button -%}
                      <p>
                        {{ 'customer.login_page.alternate_provider_separator' | t }}
                      </p>
                    {%- endunless -%}
                  </section>
                {%- endif -%}
                </div>
              <div class="form-group">
                <label for="CustomerEmail" class="hidden">{{ 'customer.login_page.email' | t }}</label>
                <input class="form-control input-md" type="email" 
                  name="customer[email]"
                  autocomplete="email" 
                  id="CustomerEmail"
                  placeholder="{{ 'customer.login_page.email' | t }}" 
                  {% if form.errors contains 'form' %}
                  aria-invalid="true"
                  {% endif %}  
                  autocapitalize="off" 
                  required="">
              </div>
              <div class="form-group">
                <label for="customerPassword" class="hidden">{{ 'customer.login_page.password' | t }}</label>
                <input class="form-control input-md"
                  name="customer[password]"
                  type="password" 
                  {% if form.errors contains 'password' %}
                  aria-invalid="true"
                  {% endif %}
                  placeholder="{{ 'customer.login_page.password' | t }}" 
                  autocapitalize="off" 
                  required="">  
              </div>
              <div class="form-group">
                <a href="#recover" class="forgot-password text-underline text-small" data-target-forgot>{{ 'customer.login_page.forgot_password' | t }}</a>
              </div>
              {% liquid
                assign buttonText = 'customer.login_page.submit' | t
                render 'button' type: 'button', button_size: section.settings.btn_size, button_text: buttonText
              %}
              <p class="account-info-text text-small">{{ 'customer.login_page.login_heading' | t }} <a href="{{ routes.account_register_url }}" class="text-underline">{{ 'customer.login_page.signup_text' | t }}</a></p>
            {%- endform -%}
          </div>
        </div>
      </div>
      {% if section.settings.heading != blank or section.settings.description != blank or section.settings.image != blank %}
      <div class="col-12 col-sm-12 col-md-6 col-lg-6">
        {% if section.settings.image != blank %}
          <div class="account-background-img d-block d-md-none">
            {% render 'image', image: section.settings.image %}
          </div>
          {% endif %}
          {% if section.settings.heading != blank or section.settings.description != blank %}
          <div class="right-side-content">
            <div class="customer-page-content text-{{ section.settings.content_alignment }}">
              {%- if section.settings.heading != blank -%} 
              {%- capture sectionhighlightPrefix -%}
                <strong class="highlight-text">
              {%- endcapture -%}
      
              {%- capture sectionhighlightSuffix -%}
                </strong>
              {%- endcapture -%}
                <{{ section.settings.content_seo_heading }} class="customer-page-title {{ section.settings.content_heading_size }}">
                  {{- section.settings.heading | replace: "<strong>", sectionhighlightPrefix | replace: "</strong>", sectionhighlightSuffix -}}
                </{{ section.settings.content_seo_heading }}>
            {% endif %}
            {%- if section.settings.description != blank -%} 
              <p class="customer-page-desc">
                {{ section.settings.description | newline_to_br }}
              </p>
            {% endif %}
            </div>
          </div>
        {% endif %}
      </div>
    {% endif %}
    </div>

  </div>
</div>
<style>
  #shopify-section-{{ section.id }} .section-container {
    --top-spacer: {{ section.settings.top_space_desktop }}px;
    --bottom-spacer: {{ section.settings.bottom_space_desktop }}px;
    --overlay-background:{{ section.settings.overlay_color }};
    --overlay-opacity:{{ section.settings.overlay_opacity | divided_by:100.0 }};
    --overlay-heading:{{ section.settings.overlay_heading_color }};
    --overlay-text:{{ section.settings.overlay_description_color }};
  }
  @media only screen and (max-width:767px) {
    #shopify-section-{{ section.id }} .section-container{
      --top-spacer:{{ section.settings.top_space_mobile }}px;
      --bottom-spacer:{{ section.settings.bottom_space_mobile }}px;
    }
  }
</style>
<script>
  var url = window.location.href;
 let forgetPasswordElement =document.querySelector('[data-target-forgot]');
 let loginElement =document.querySelector('[data-target-login]');
 let loginSection=document.getElementById('login');
 var recoverSection = document.getElementById('recover');
 if (url.indexOf('#recover') > -1) {
  loginSection.style.display = 'none';
  recoverSection.style.display = 'flex';
} else {
  recoverSection.style.display = 'none';
  loginSection.style.display = 'flex';
}
 forgetPasswordElement.addEventListener("click",function(event){
  event.preventDefault();
  loginSection.style.display = 'none';
  recoverSection.style.display = 'flex';
  var url = window.location.pathname + '#recover';
  history.pushState({}, null, url);
  
})
loginElement.addEventListener("click",function(event){
  event.preventDefault();
  recoverSection.style.display = 'none';
  loginSection.style.display = 'flex';
  var url = window.location.pathname;
  history.pushState({}, null, url);
})
</script>
