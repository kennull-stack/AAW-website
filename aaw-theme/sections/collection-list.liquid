<link rel="preload" as="style" href="{{ 'collection-list.css' | asset_url }}">
{{ 'collection-list.css' | asset_url | stylesheet_tag }}

{%- capture textContent -%}
{%- if section.settings.heading != blank -%}

  {%- capture sectionhighlightPrefix -%}
    <strong class="highlight-text">
  {%- endcapture -%}

  {%- capture sectionhighlightSuffix -%}
    </strong>
  {%- endcapture -%}


    <{{ section.settings.seo_heading }} class="section-heading {{ section.settings.heading_size }}">
        {{- section.settings.heading | replace: "<strong>", sectionhighlightPrefix | replace: "</strong>", sectionhighlightSuffix | replace: '++', '<br>' -}}
    </{{ section.settings.seo_heading }}>
{%- endif -%}
{%- if section.settings.description != blank -%}
    <div class="section-description rte">
      {{ section.settings.description | replace: '<p></p>', '<br>' | replace: '<h1></h1>', '<br>' | replace: '<h2></h2>', '<br>' | replace: '<h3></h3>', '<br>' | replace: '<h4></h4>', '<br>' | replace: '<h5></h5>', '<br>' | replace: '<h6></h6>', '<br>' }}
    </div>
  {%- endif -%}
{%- endcapture -%}
<div class="section-container  {{ section.settings.color_scheme }}-scheme {% if section.settings.make_section_rounded %}section-rounded{% endif %}">
  <div class="{{ settings.container_width }}">
      {% if textContent != blank %}
        <div class="section-heading-box{% if section.settings.description != blank %} desc-enabled{% endif %} {{ section.settings.content_alignment }}">
          {{ textContent }}
        </div>
      {% endif %}
      {%liquid
        
        if section.settings.columns_desktop == 2 
        assign columnsValue = 'col-lg-6'
       elsif section.settings.columns_desktop == 3
        assign columnsValue = 'col-lg-4'
       else
        assign columnsValue = 'col-lg-3'
       endif
   
      if section.settings.column_mobile == '1'
        assign columnsValueMobile = 'col-12'
        else 
        assign columnsValueMobile = 'col-6'
      endif 
  

       %}
   <div class="collection-list-main {% if section.settings.enable_swipe_mobile %} mobile-swipe{% endif %}">
    <div class="row">
      {% for block in section.blocks %}
        {% assign aosDelay = forloop.index | times: 100 %}
        {%- assign placeholder_image_index = forloop.index0 | modulo: 4 | plus: 1 -%}
        {%- assign placeholder_image = 'collection-apparel-' | append: placeholder_image_index -%}
        {% render 'card-collection',
          collection: block.settings.collection,
          section: section,
          aosDelay:aosDelay,
          placeholder_image: placeholder_image,
          gridImageSize: section.settings.grid_image_size,
          columnsValue:columnsValue,
          columnsValueMobile:columnsValueMobile
        %}
      {% endfor %}
    </div>
  </div>
  </div>
</div>
<style>

    #shopify-section-{{ section.id }}.shopify-section {
      --top-spacer:{{ section.settings.top_space_desktop }}px;
      --bottom-spacer:{{ section.settings.bottom_space_desktop }}px;
      --highlight-text: {{ section.settings.highlighted_color }};
      {% if section.settings.make_section_rounded %}
        background:{{ section.settings.section_background }};
      {% endif %}
    }

     #shopify-section-{{ section.id }} .parallex-content.text-left{
      align-items:flex-start;
      text-align:left
    }
    @media screen and (max-width:767px){
      #shopify-section-{{ section.id }}.shopify-section {
      --top-spacer:{{ section.settings.top_space_mobile }}px;
      --bottom-spacer:{{ section.settings.bottom_space_mobile }}px;
      }

    }

    {% if section.settings.section_visibility == 'large' %}
      @media (max-width: 767px) {
        #shopify-section-{{ section.id }}{
          display: none !important;
        }
      }
    {% elsif section.settings.section_visibility == 'small' %}
      @media (min-width: 768px) {
        #shopify-section-{{ section.id }}{
          display: none !important;
        }
      }
  {% endif %}
</style>
{% schema %}
{
  "name": "t:sections.collection-list.name",
  "tag": "section",
  "class": "collection-list",
  "max_blocks": 15,
  "disabled_on": {
    "groups": [
      "header",
      "footer"
    ]
  },
  "settings": [
    {
      "type": "select",
      "id": "section_visibility",
      "label": "t:global.common.section_visibility.label",
      "default": "always",
      "options": [
        {
          "label": "t:global.common.section_visibility.options.always",
          "value": "always"
        },
        {
          "label": "t:global.common.section_visibility.options.small",
          "value": "small"
        },
        {
          "label": "t:global.common.section_visibility.options.large",
          "value": "large"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "make_section_rounded",
      "label": "t:global.common.general_labels.make_section_rounded",
      "default": false
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "t:sections.collection-list.settings.columns_desktop.label",
      "default": 4,
      "min": 2,
      "max": 4,
      "step": 1
    },
    {
      "type": "radio",
      "id": "column_mobile",
      "label": "t:sections.collection-list.settings.column_mobile.label",
      "default": "2",
      "options": [
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "2",
          "label": "2"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "enable_swipe_mobile",
      "label": "t:global.common.swipe_mobile.label",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.collection-list.settings.header.label"
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "t:sections.collection-list.settings.content_alignment.label",
      "default": "text-left",
      "options": [
        {
          "label": "t:global.common.alignments.left",
          "value": "text-left"
        },
        {
          "label": "t:global.common.alignments.center",
          "value": "text-center"
        }
      ]
    },
    {
      "label": "t:global.common.general_labels.heading",
      "id": "heading",
      "type": "inline_richtext",
      "default": "Collections list",
      "info": "t:global.common.infos.heading.label"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "t:global.common.general_labels.heading_size",
      "default": "h3",
      "options": [
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        },
        {
          "value": "h4",
          "label": "H4"
        },
        {
          "value": "h5",
          "label": "H5"
        },
        {
          "value": "h6",
          "label": "H6"
        }
      ]
    },
    {
      "type": "select",
      "id": "seo_heading",
      "label": "t:global.common.general_labels.heading_tag",
      "info": "t:global.common.infos.seo_heading.label",
      "default": "h3",
      "options": [
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        },
        {
          "value": "h4",
          "label": "H4"
        },
        {
          "value": "h5",
          "label": "H5"
        },
        {
          "value": "h6",
          "label": "H6"
        }
      ]
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "t:global.common.general_labels.description"
    },
    {
      "type": "select",
      "id": "grid_image_size",
      "label": "t:global.common.image_ratio.label",
      "default": "auto",
      "options": [
        {
          "value": "auto",
          "label": "t:global.common.image_ratio.options.auto"
        },
        {
          "value": "landscape",
          "label": "t:global.common.image_ratio.options.landscape"
        },
        {
          "value": "portrait",
          "label": "t:global.common.image_ratio.options.portrait"
        },
        {
          "value": "square",
          "label": "t:global.common.image_ratio.options.square"
        }
      ]
    },
    {
      "type": "header",
      "content": "t:global.header.color_section.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "primary",
      "label": "t:global.header.color_scheme.label"
    },
    {
      "type": "color",
      "id": "highlighted_color",
      "default": "#EFF341",
      "label": "t:global.common.general_labels.highlight_color"
    },
    {
      "type": "color",
      "id": "section_background",
      "label": "t:global.common.section_background.label",
      "info": "t:global.common.section_background.info"
    },
    {
      "type": "header",
      "content": "t:global.header.space_section.label"
    },
    {
      "type": "range",
      "id": "top_space_desktop",
      "label": "t:global.top_space_desktop.label",
      "default": 40,
      "min": 0,
      "max": 100,
      "step": 5
    },
    {
      "type": "range",
      "id": "bottom_space_desktop",
      "label": "t:global.bottom_space_desktop.label",
      "default": 40,
      "min": 0,
      "max": 100,
      "step": 5
    },
    {
      "type": "range",
      "id": "top_space_mobile",
      "label": "t:global.top_space_mobile.label",
      "default": 35,
      "min": 0,
      "max": 100,
      "step": 5
    },
    {
      "type": "range",
      "id": "bottom_space_mobile",
      "label": "t:global.bottom_space_mobile.label",
      "default": 35,
      "min": 0,
      "max": 100,
      "step": 5
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "t:sections.collection-list.blocks.name",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "t:sections.collection-list.blocks.settings.collection.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.collection-list.presets.name",
      "blocks": [
        {
          "type": "collection"
        },
        {
          "type": "collection"
        },
        {
          "type": "collection"
        },
        {
          "type": "collection"
        },
        {
          "type": "collection"
        },
        {
          "type": "collection"
        },
        {
          "type": "collection"
        },
        {
          "type": "collection"
        }
      ]
    }
  ]
}
{% endschema %}
