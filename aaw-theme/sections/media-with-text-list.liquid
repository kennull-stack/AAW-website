<link rel="preload" as="style" href="{{ 'media-with-text-list.css' | asset_url }}">
{{ 'media-with-text-list.css' | asset_url | stylesheet_tag }}

{%liquid

  if section.settings.image_size == 'landscape'
      assign imageRatio = 50
  elsif section.settings.image_size == 'square'
      assign imageRatio = 100
  elsif section.settings.image_size == 'portrait'
      assign imageRatio = 115
  endif
%}
{%- if section.blocks.size > 0 -%}
  <div class="section-container {{ section.settings.color_scheme }}-scheme {% if section.settings.make_section_rounded %}section-rounded{% endif %}" >
      <div class="media-with-text-list-wrapper">
          {%- for block in section.blocks -%}
            <div class="media-with-text-list-item" id="media-with-text-list-item-{{ block.id }}" data-media-item {{ block.shopify_attributes }}>
              <div class="container">
                  {% if block.settings.heading != blank %}
                    {% assign aosDelay = forloop.index | times: 50  %}
                    <{% if block.settings.link_to != blank %}a href="{{ block.settings.link_to }}"{% else %}div{% endif %} class="media-with-text-list-content" >
                    
                        <{{ block.settings.seo_heading }} class="media-with-text-list-heading {{ block.settings.heading_size }}" {% if settings.enable_animation %}data-aos="fade-up" data-aos-delay="{{aosDelay}}"{% endif %}>
                          <span class="media-with-text-list-heading-highlight">{% unless forloop.index > 9 %}{{ 0 }}{% endunless %}{{ forloop.index }}</span>
                          {{ block.settings.heading }}
                        </{{ block.settings.seo_heading }}>

                        <div class="media-with-text-list-img hidden d-md-block">
                            <div class="media-with-text-list-img-inner">
                                <div class="media-box" style="--image-ratio:{{ imageRatio | append: "%" }}">
                                  {%- liquid 
                                    if block.settings.image != blank
                                      render 'image', image: block.settings.image
                                    else 
                                      echo 'detailed-apparel-1' | placeholder_svg_tag: 'placeholder-svg'
                                    endif 
                                  -%}
                                </div>
                            </div>
                        </div>
                        <div class="media-with-text-list-arrow" >
                            <span class="arrow-btn no-bg">
                              <svg class="arrow-btn-icon1" width="15" height="15" viewBox="0 0 15 15" fill="none">
                                <path fill-rule="evenodd" clip-rule="evenodd" d="M7.07031 0L14.1414 7.07107L7.07031 14.1421L5.76824 12.8401L10.6166 7.99173L0.95721 7.9917L0.957199 6.15032L10.6166 6.15035L5.76827 1.30205L7.07031 0Z" fill="currentColor"></path>
                            </svg>
                            <svg class="arrow-btn-icon2" width="15" height="15" viewBox="0 0 15 15" fill="none">
                              <path fill-rule="evenodd" clip-rule="evenodd" d="M7.07031 0L14.1414 7.07107L7.07031 14.1421L5.76824 12.8401L10.6166 7.99173L0.95721 7.9917L0.957199 6.15032L10.6166 6.15035L5.76827 1.30205L7.07031 0Z" fill="currentColor"></path>
                          </svg>                       
                            </span>                          
                        </div>
                        <div class="media-with-text-list-img d-md-none">
                          <div class="media-with-text-list-img-inner">
                              <div class="media-box" style="--image-ratio:{{ imageRatio | append: "%" }}">
                                {%- liquid 
                                  if block.settings.image != blank
                                    render 'image', image: block.settings.image
                                  else 
                                    echo 'detailed-apparel-1' | placeholder_svg_tag: 'placeholder-svg'
                                  endif 
                                -%}
                              </div>
                          </div>
                      </div>
                        
                      </{% if block.settings.link_to != blank %}a{% else %}div{% endif %}>
                        
                  {% endif %}
              </div>
          </div>
          {%- endfor -%}
      </div>
  </div>
{%- endif -%}
<style>
    #shopify-section-{{ section.id }} {
      {% if section.settings.make_section_rounded %}
        background:{{ section.settings.section_background }};
      {% endif %}
      --top-spacer:{{ section.settings.top_space_desktop }}px;
      --bottom-spacer:{{ section.settings.bottom_space_desktop }}px;
      --active-background:{{ section.settings.active_background }}; 
    }
    #shopify-section-{{ section.id }} .media-with-text-list-wrapper .active{
      --heading-color:{{ section.settings.active_color }}; 
    }
    @media only screen and (max-width:767px) {
        #shopify-section-{{ section.id }}{
          --top-spacer:{{ section.settings.top_space_mobile }}px !important;
          --bottom-spacer:{{ section.settings.bottom_space_mobile }}px !important;
        }
    }
    {% if section.settings.section_visibility == 'large' %}
      @media (max-width: 767px) {
        #shopify-section-{{ section.id }}{
          display: none !important;
        }
      }
    {% elsif section.settings.section_visibility == 'small' %}
      @media (min-width: 768px) {
        #shopify-section-{{ section.id }}{
          display: none !important;
        }
      }
    {% endif %}

    
</style>
{% schema %}
{
  "name": "t:sections.media-with-text-list.name",
  "tag": "section",
  "class": "media-with-text-list",
  "disabled_on": {
    "groups": [
      "header",
      "footer"
    ]
  },
  "settings": [
    {
      "type": "select",
      "id": "section_visibility",
      "label": "t:global.common.section_visibility.label",
      "default": "always",
      "options": [
        {
          "label": "t:global.common.section_visibility.options.always",
          "value": "always"
        },
        {
          "label": "t:global.common.section_visibility.options.small",
          "value": "small"
        },
        {
          "label": "t:global.common.section_visibility.options.large",
          "value": "large"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "make_section_rounded",
      "label": "t:global.common.general_labels.make_section_rounded",
      "default": true
    },
    {
      "type": "select",
      "id": "image_size",
      "label": "t:global.common.image_ratio.label",
      "default": "portrait",
      "options": [
        {
          "value": "landscape",
          "label": "t:global.common.image_ratio.options.landscape"
        },
        {
          "value": "portrait",
          "label": "t:global.common.image_ratio.options.portrait"
        },
        {
          "value": "square",
          "label": "t:global.common.image_ratio.options.square"
        }
      ]
    },
    {
      "type": "header",
      "content": "t:global.header.color_section.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "tertiary",
      "label": "t:global.header.color_scheme.label"
    },
    {
      "type": "color",
      "id": "section_background",
      "label": "t:global.common.section_background.label",
      "info": "t:global.common.section_background.info"
    },
    {
      "type": "color",
      "id": "active_color",
      "label": "t:sections.media-with-text-list.settings.active_color.label",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "active_background",
      "label": "t:sections.media-with-text-list.settings.active_background.label",
      "default": "#757575"
    },
    {
      "type": "header",
      "content": "t:global.header.space_section.label"
    },
    {
      "type": "range",
      "id": "top_space_desktop",
      "label": "t:global.top_space_desktop.label",
      "default": 40,
      "min": 0,
      "max": 100,
      "step": 5
    },
    {
      "type": "range",
      "id": "bottom_space_desktop",
      "label": "t:global.bottom_space_desktop.label",
      "default": 40,
      "min": 0,
      "max": 100,
      "step": 5
    },
    {
      "type": "range",
      "id": "top_space_mobile",
      "label": "t:global.top_space_mobile.label",
      "default": 35,
      "min": 0,
      "max": 100,
      "step": 5
    },
    {
      "type": "range",
      "id": "bottom_space_mobile",
      "label": "t:global.bottom_space_mobile.label",
      "default": 35,
      "min": 0,
      "max": 100,
      "step": 5
    }
  ],
  "blocks": [
    {
      "type": "text_list",
      "name": "t:sections.media-with-text-list.blocks.name",
      "limit": 10,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "default": "Heading",
          "label": "t:global.common.general_labels.heading"
        },
        {
          "type": "select",
          "id": "heading_size",
          "label": "t:global.common.general_labels.heading_size",
          "default": "h2",
          "options": [
            {
              "value": "h1",
              "label": "H1"
            },
            {
              "value": "h2",
              "label": "H2"
            },
            {
              "value": "h3",
              "label": "H3"
            },
            {
              "value": "h4",
              "label": "H4"
            },
            {
              "value": "h5",
              "label": "H5"
            },
            {
              "value": "h6",
              "label": "H6"
            }
          ]
        },
        {
          "type": "select",
          "id": "seo_heading",
          "label": "t:global.common.general_labels.heading_tag",
          "info": "t:global.common.infos.seo_heading.label",
          "default": "h2",
          "options": [
            {
              "value": "h1",
              "label": "H1"
            },
            {
              "value": "h2",
              "label": "H2"
            },
            {
              "value": "h3",
              "label": "H3"
            },
            {
              "value": "h4",
              "label": "H4"
            },
            {
              "value": "h5",
              "label": "H5"
            },
            {
              "value": "h6",
              "label": "H6"
            }
          ]
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:global.common.general_labels.image"
        },
        {
          "type": "url",
          "id": "link_to",
          "label": "t:global.common.general_labels.link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.media-with-text-list.presets.name",
      "blocks": [
        {
          "type": "text_list"
        },
        {
          "type": "text_list"
        },
        {
          "type": "text_list"
        },
        {
          "type": "text_list"
        }
      ]
    }
  ]
}
{% endschema %}