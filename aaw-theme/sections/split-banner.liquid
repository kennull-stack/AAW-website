      "tag": "section",
      "class": "split-banner",
      "disabled_on": {
        "groups": [
            "header",
            "footer"
        ]
      },
      "settings": [
        {
            "type": "select",
            "id": "section_visibility",
            "label": "t:global.common.section_visibility.label",
            "default": "always",
            "options": [
                {
                    "label": "t:global.common.section_visibility.options.always",
                    "value": "always"
                },
                {
                    "label": "t:global.common.section_visibility.options.small",
                    "value": "small"
                },
                {
                    "label": "t:global.common.section_visibility.options.large",
                    "value": "large"
                }
            ]
        },
        {
            "type": "checkbox",
            "id": "make_section_rounded",
            "label": "t:global.common.general_labels.make_section_rounded",
            "default": false
        },
        {
            "type": "select",
            "id": "desktop_height",
            "label": "t:sections.slideshow.settings.desktop_height.label",
            "default": "550px",
            "options": [
                {
                    "value": "550px",
                    "label": "550px"
                },
                {
                    "value": "650px",
                    "label": "650px"
                },
                {
                    "value": "750px",
                    "label": "750px"
                },
                {
                    "value": "100vh",
                    "label": "t:sections.slideshow.settings.desktop_height.options.fullscreen"
                }
            ]
            },
            {
            "type": "select",
            "id": "mobile_height",
            "label": "t:sections.slideshow.settings.mobile_height.label",
            "default": "450px",
            "options": [
                {
                    "value": "450px",
                    "label": "450px"
                },
                {
                    "value": "550px",
                    "label": "550px"
                },
                {
                    "value": "650px",
                    "label": "650px"
                },
                {
                    "value": "100vh",
                    "label": "t:sections.slideshow.settings.mobile_height.options.fullscreen"
                }
            ]
        },
        {
            "type": "header",
            "content": "t:global.header.color_section.label"
        },
        {
            "type": "color_scheme",
            "id": "color_scheme",
            "default": "primary",
            "label": "t:global.header.color_scheme.label"
        },
        {
          "type": "color",
          "id": "section_background",
          "label": "t:global.common.section_background.label",
          "info": "t:global.common.section_background.info"
        },
        {
            "type": "header",
            "content": "t:global.header.space_section.label"
        },
        {
            "type": "range",
            "id": "top_space_desktop",
            "label": "t:global.top_space_desktop.label",
            "default": 40,
            "min": 0,
            "max": 100,
            "step": 5
        },
        {
            "type": "range",
            "id": "bottom_space_desktop",
            "label": "t:global.bottom_space_desktop.label",
            "default": 40,
            "min": 0,
            "max": 100,
            "step": 5
        },
        {
            "type": "range",
            "id": "top_space_mobile",
            "label": "t:global.top_space_mobile.label",
            "default": 35,
            "min": 0,
            "max": 100,
            "step": 5
        },
        {
            "type": "range",
            "id": "bottom_space_mobile",
            "label": "t:global.bottom_space_mobile.label",
            "default": 35,
            "min": 0,
            "max": 100,
            "step": 5
        }
      ],
      "blocks": [
        {
            "type": "split_banner",
            "name": "t:sections.split-banner.blocks.name",
            "limit": 3,
            "settings":[
                {
                    "type": "image_picker",
                    "id": "image",
                    "label": "t:global.common.general_labels.image"
                },
                {
                    "type": "inline_richtext",
                    "id": "heading",
                    "default": "Heading",
                    "info": "t:global.common.infos.heading.label",
                    "label": "t:global.common.general_labels.heading"
                },
                {
                    "type": "select",
                    "id": "heading_size",
                    "label": "t:global.common.general_labels.heading_size",
                    "default": "h4",
                    "options": [
                        {
                            "value": "h1",
                            "label": "H1"
                        },
                        {
                            "value": "h2",
                            "label": "H2"
                        },
                        {
                            "value": "h3",
                            "label": "H3"
                        },
                        {
                            "value": "h4",
                            "label": "H4"
                        },
                        {
                            "value": "h5",
                            "label": "H5"
                        },
                        {
                            "value": "h6",
                            "label": "H6"
                        }
