<link rel="preload" as="style" href="{{ 'split-banner.css' | asset_url }}">
{{ 'split-banner.css' | asset_url | stylesheet_tag }}

{%- if section.blocks.size > 0 -%}
<div class="section-container {{ section.settings.color_scheme }}-scheme{% if section.settings.make_section_rounded %} section-rounded{% endif %}">
    <div class="split-banner-wrapper">
        {%- for block in section.blocks -%}
            <div class="split-banner-item" id="split-banner-item-{{ block.id }}" {{ block.shopify_attributes }}>
                <div class="split-banner-image">
                    <div class="media-box media-fixed">
                        {%- liquid 
                            if block.settings.image != blank
                              render 'image', image: block.settings.image
                            else 
                             assign placeholder_image_index = forloop.index0 | modulo: 4 | plus: 1 
                              echo 'collection-apparel-' | append: placeholder_image_index | placeholder_svg_tag: 'placeholder-svg'
                            endif 
                        -%}
                    </div>
                </div>
                <div class="split-banner-content {{ block.settings.desktop_content_position }} {{ block.settings.mobile_content_position }}" {% if settings.enable_animation %}data-aos="fade-up" data-aos-duration="1000"{% endif %}>
                    {% if block.settings.heading != blank %}
                        {%- capture blockhighlightPrefix -%}
                            <strong class="highlight-text">
                        {%- endcapture -%}

                        {%- capture blockhighlightSuffix -%}
                            </strong>
                        {%- endcapture -%}
                        <{{ block.settings.seo_heading }} class="split-banner-heading {{ block.settings.heading_size }}">
                            {{ block.settings.heading | replace: "<strong>", blockhighlightPrefix | replace: "</strong>", blockhighlightSuffix | replace: '++', '<br>' }}
                        </{{ block.settings.seo_heading }}>
                    {% endif %}
                    {% if block.settings.description != blank %}
                        <p class="split-banner-desc">{{ block.settings.description | newline_to_br }}</p>
                    {% endif %}

                    {% if block.settings.btn_link != blank and block.settings.btn_text != blank %}
                        <div class="split-banner-button-item" data-aos="hero" data-aos-order="4">
                          {% render 'button', class: 'split-banner-primary-btn', button_link: block.settings.btn_link , button_style: block.settings.button_syle, button_size: block.settings.button_size, button_text: block.settings.btn_text %}
                        </div>
                    {% endif %}

                </div>
            </div>
        {%- endfor -%}
    </div>
</div>
{%- endif -%}
<style>
    #shopify-section-{{ section.id }} {
        {% if section.settings.make_section_rounded %}
          background:{{ section.settings.section_background }};
        {% endif %}
      --top-spacer: {{ section.settings.top_space_desktop }}px;
      --bottom-spacer: {{ section.settings.bottom_space_desktop }}px;
      --media-height: {{ section.settings.desktop_height }};
    }

    @media only screen and (max-width:767px) {
        #shopify-section-{{ section.id }}{
          --top-spacer: {{ section.settings.top_space_mobile }}px !important;
          --bottom-spacer: {{ section.settings.bottom_space_mobile }}px !important;
          --media-height: {{ section.settings.mobile_height }};
        }
    }
    {% if section.settings.section_visibility == 'large' %}
      @media (max-width: 767px) {
        #shopify-section-{{ section.id }}{
          display: none !important;
        }
      }
    {% elsif section.settings.section_visibility == 'small' %}
      @media (min-width: 768px) {
        #shopify-section-{{ section.id }}{
          display: none !important;
        }
      }
    {% endif %}

    {%- for block in section.blocks -%}
        
        #split-banner-item-{{ block.id }} {
            --overlay-heading-color: {{ block.settings.heading_color }};
            --highlight-text: {{ block.settings.highlighted_color }};
            --overlay-text-color: {{ block.settings.description_color }};
            --overlay-opacity: {{ block.settings.overlay_opacity }};
            --overlay-bg: {{ block.settings.overlay_bgcolor }};


            --button-background: {{ block.settings.btn_bg_color }};
            --button-text-color: {{ block.settings.btn_text_color }};
            --button-border: {{ block.settings.btn_border_color }};
            --button-background-hover:{{ block.settings.btn_hover_color }};
            --button-text-color-hover:{{ block.settings.btn_hover_text_color }};
            --button-border-hover:{{ block.settings.btn_hover_border_color }};
            --link-color:{{ block.settings.btn_text_color }};
        }
    {%- endfor -%}
</style>

{% schema %}
