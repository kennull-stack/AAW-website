<link rel="preload" as="style" href="{{ 'testimonials.css' | asset_url }}">
{{ 'testimonials.css' | asset_url | stylesheet_tag }}
<div class="section-container image-enabled {{ section.settings.color_scheme }}-scheme {% if section.settings.make_section_rounded %}section-rounded{% endif %}">
  {% if section.settings.image != blank %}
  <div class="section-image{% if section.settings.background_blur %} background-blur{% endif %}">
    {% render 'image', image: section.settings.image %}
  </div>
  {% endif %}
  <div class="{{ settings.container_width }}">
    {% if section.settings.heading != blank %}

      {%- capture sectionhighlightPrefix -%}
        <strong class="highlight-text">
      {%- endcapture -%}

      {%- capture sectionhighlightSuffix -%}
        </strong>
      {%- endcapture -%}

      <div class="section-heading-box {{ section.settings.heading_alignment }}" {% if settings.enable_animation %}data-aos="fade-up" data-aos-duration="1000"{% endif %}>
        <{{ section.settings.seo_heading }} class="section-heading {{ section.settings.heading_size }}">
          {{ section.settings.heading | replace: "<strong>", sectionhighlightPrefix | replace: "</strong>", sectionhighlightSuffix | replace: '++', '<br>' }}
        </{{ section.settings.seo_heading }}>
      </div>
    {% endif %}
    <div class="testimonials-wrapper">
      {% if section.settings.style_type == 'carousel' %}
      {%- if section.blocks.size > 0 -%}
        <div
          id="testimonials-{{ section.id }}"
          class="{% if section.settings.style_type == 'carousel' %}slider{% endif %} testimonials-slider column{{ section.settings.column_count }}"
          data-slides-length="{{ section.blocks.size }}"
          data-sl-slider
          data-slick='
            {
            "slidesToShow": {{ section.settings.column_count }},
            "lazyLoad": "progressive",
            "infinite":true,
            "dots": false,
            "arrows": true,
            "responsive": [
              {
                "breakpoint": 767,
                "settings": {
                    "slidesToShow": 1
                }
              }
             ]
            }
          '
          tabindex="0">
          {%- for block in section.blocks -%}
            {%- capture reviewStars -%}
              <ul class="testimonials-reviews" >
                {%- for i in (1..block.settings.rating) -%}
                  <li>
                    <svg viewBox="0 0 380 362" width="20" height="19">
                      <path data-id="Layer_10" fill-rule="evenodd"   d="m204.7 10.5l37.5 116.1l122-0.3c15.4 0 21.2 19.1 7.7 28.9l-97.5 70.5l37.9 115.9c4.9 14.8-12.9 26.5-24.6 16.5l-97.6-71.2l-98.6 71.9c-13.4 9.7-28.2-3.4-22.6-20.4l36.9-112.7l-98.8-71.5c-12.6-9.1-5.2-28.9 10.1-27.9l120.9 0.3l37.5-116.1c4.5-14.2 24.7-14.1 29.2 0z" />
                    </svg>
                  </li>
                {%- endfor -%}
              </ul>
            {%- endcapture -%}
            <div class="slideshow__slide--{{ block.id }} testimonials-slider-item"
              data-slide="{{ forloop.index0 }}"
              {{ block.shopify_attributes }}>
              <div class="testimonials-slide text-{{ section.settings.content_alignment }}">
                {{- reviewStars -}}
                {% if block.settings.heading != blank %}
                  <h5 class="testimonials-heading">{{ block.settings.heading }}</h5>
                {% endif %}
                {% if block.settings.message != blank %}
                  <div class="testimonials-desc rte">{{ block.settings.message | replace: '<p></p>', '<br>' }}</div>
                {% endif %}
                {% if block.settings.author != blank  or block.settings.image != blank %}
                  <div class="testimonials-author-box">
                    {% if block.settings.image != blank %}
                      <div class="author-img">
                        <img src="{{ block.settings.image | image_url: width: 40 }}" 
                          width="{{ block.settings.image.width }}"
                          height="{{ block.settings.image.height }}"
                          loading="lazy"
                          alt="{{ block.settings.image.alt | default: shop.name | escape }}">
                      </div>
                    {% endif %}
                    {% if block.settings.author != blank %}
                      <p class="testimonials-author">
                        <strong> {{ block.settings.author -}}</strong>
                      </p>
                    {% endif %}
                  </div>
                {% endif %}
              </div>
            </div>
          {% endfor %}
        </div>
      {%- endif -%}
      {% else %}
      {%- if section.blocks.size > 0 -%}
        <div class="testimonials-grid d-none d-md-grid">
            {% if section.blocks.size < 4 %}
              {% assign columCount = section.blocks.size %}
              {% else %}
              {% assign columCount = 4 %}
            {% endif %}
            {% for i in (1..columCount) %}
              {% assign mainIndex = forloop.index %}
              {% assign itemCount = columCount %}
                <div class="testimonials-items">
                  {% for block in section.blocks %}
                    {% capture blockContent %}
                      {%- capture reviewStars -%}
                          <ul class="testimonials-reviews">
                            {%- for i in (1..block.settings.rating) -%}
                              <li>
                                <svg viewBox="0 0 380 362" width="20" height="19">
                                  <path data-id="Layer_10" fill-rule="evenodd"   d="m204.7 10.5l37.5 116.1l122-0.3c15.4 0 21.2 19.1 7.7 28.9l-97.5 70.5l37.9 115.9c4.9 14.8-12.9 26.5-24.6 16.5l-97.6-71.2l-98.6 71.9c-13.4 9.7-28.2-3.4-22.6-20.4l36.9-112.7l-98.8-71.5c-12.6-9.1-5.2-28.9 10.1-27.9l120.9 0.3l37.5-116.1c4.5-14.2 24.7-14.1 29.2 0z" />
                                </svg>
                              </li>
                            {%- endfor -%}
                          </ul>
                        {%- endcapture -%}
                        <div class="slideshow__slide--{{ block.id }} testimonials-slider-item {% if forloop.index > 8  and section.settings.load_more %}hidden-items{% endif %}"
                          data-slide="{{ forloop.index0 }}"
                          {{ block.shopify_attributes }}>
                          <div class="testimonials-slide text-{{ section.settings.content_alignment }}">
                            {{- reviewStars -}}
                            {% if block.settings.heading != blank %}
                              <h5 class="testimonials-heading">{{ block.settings.heading }}</h5>
                            {% endif %}
                            {% if block.settings.message != blank %}
                              <div class="testimonials-desc rte">{{ block.settings.message | replace: '<p></p>', '<br>' }}</div>
                            {% endif %}
                            {% if block.settings.author != blank or block.settings.image != blank %}
                              <div class="testimonials-author-box">
                                {% if block.settings.image != blank %}
                                  <div class="author-img">
                                    <img src="{{ block.settings.image | image_url: width: 40 }}" 
                                      width="{{ block.settings.image.width }}"
                                      height="{{ block.settings.image.height }}"
                                      loading="lazy"
                                      alt="{{ block.settings.image.alt | default: shop.name | escape }}">
                                  </div>
                                {% endif %}
                                {% if block.settings.author != blank %}
                                  <p class="testimonials-author">
                                    <strong> {{ block.settings.author -}}</strong>
                                  </p>
                                {% endif %}
                             </div>
                            {% endif %}
                          </div>
                        </div>  
                      {% endcapture %}
                    {% assign  moduloValue  = forloop.index | modulo: itemCount %}
                    {% if moduloValue == mainIndex %}
                    {{ blockContent }}
                    {% elsif mainIndex == columCount and moduloValue == 0 %}
                    {{ blockContent }}
                      {% endif %}
                  {% endfor %}
                </div>
            {% endfor %}
        </div>
        {%- if section.blocks.size > 8  and section.settings.load_more -%}
          <div class="testimonials-load-more text-center d-none d-md-grid">
            {% liquid
              assign buttonText = 'general.testimonial.load_more'| t
              assign buttonAttributes = 'aria-label="Load more" data-testimonial-load-more'
              render 'button' type: 'button',class:'testimonials-load-more-btn button ', button_size: 'small', button_text: buttonText,buttonAttributes:buttonAttributes
            %}
          </div>
        {% endif %}
        <div class="testimonials-grid d-grid d-md-none {% if section.settings.enable_swipe %} mobile-swipe{% else %} mobile-column-{{ section.settings.mobile_layout }}{% endif %}">
          {%- for block in section.blocks -%}
            {%- capture reviewStars -%}
              <ul class="testimonials-reviews" >
                {%- for i in (1..block.settings.rating) -%}
                  <li>
                    <svg viewBox="0 0 380 362" width="20" height="19">
                      <path data-id="Layer_10" fill-rule="evenodd"   d="m204.7 10.5l37.5 116.1l122-0.3c15.4 0 21.2 19.1 7.7 28.9l-97.5 70.5l37.9 115.9c4.9 14.8-12.9 26.5-24.6 16.5l-97.6-71.2l-98.6 71.9c-13.4 9.7-28.2-3.4-22.6-20.4l36.9-112.7l-98.8-71.5c-12.6-9.1-5.2-28.9 10.1-27.9l120.9 0.3l37.5-116.1c4.5-14.2 24.7-14.1 29.2 0z" />
                    </svg>
                  </li>
                {%- endfor -%}
              </ul>
            {%- endcapture -%}
            <div class="slideshow__slide--{{ block.id }} testimonials-slider-item"
              data-slide="{{ forloop.index0 }}"
              {{ block.shopify_attributes }}>
              <div class="testimonials-slide text-{{ section.settings.content_alignment }}">
                {{- reviewStars -}}
                {% if block.settings.heading != blank %}
                  <h5 class="testimonials-heading">{{ block.settings.heading }}</h5>
                {% endif %}
                {% if block.settings.message != blank %}
                  <div class="testimonials-desc rte">{{ block.settings.message | replace: '<p></p>', '<br>' }}</div>
                {% endif %}
                {% if block.settings.author != blank  or block.settings.image != blank %}
                  <div class="testimonials-author-box">
                    {% if block.settings.image != blank %}
                      <div class="author-img">
                        <img src="{{ block.settings.image | image_url: width: 40 }}" 
                          width="{{ block.settings.image.width }}"
                          height="{{ block.settings.image.height }}"
                          loading="lazy"
                          alt="{{ block.settings.image.alt | default: shop.name | escape }}">
                      </div>
                    {% endif %}
                    {% if block.settings.author != blank %}
                      <p class="testimonials-author">
                        <strong> {{ block.settings.author -}}</strong>
                      </p>
                    {% endif %}
                  </div>
                {% endif %}
              </div>
            </div>
          {% endfor %}

       </div>
      {% endif  %}
      {% endif %}
    </div>
  </div>
</div>
<style>
  #shopify-section-{{ section.id }}{
    {% if section.settings.make_section_rounded %}
      background:{{ section.settings.section_background }};
    {% endif %}
    --top-spacer:{{ section.settings.top_space_desktop }}px;
    --bottom-spacer:{{ section.settings.bottom_space_desktop }}px;
    --highlight-text: {{ section.settings.highlighted_color }};
    --section-image-overlay:{{ section.settings.overlay_background.red }},{{section.settings.overlay_background.green}},{{section.settings.overlay_background.blue}};
    --section-image-overlay-opacity:{{ section.settings.overlay_opacity | divided_by: 100.0 }};
  }
  @media only screen and (max-width:767px) {
    #shopify-section-{{ section.id }}.shopify-section{
      --top-spacer:{{ section.settings.top_space_mobile }}px;
      --bottom-spacer:{{ section.settings.bottom_space_mobile }}px;
    }
  }
  {% if section.settings.section_visibility == 'large' %}
    @media (max-width: 767px) {
      #shopify-section-{{ section.id }}{
        display: none !important;
      }
    }
  {% elsif section.settings.section_visibility == 'small' %}
    @media (min-width: 768px) {
      #shopify-section-{{ section.id }}{
        display: none !important;
      }
    }
  {% endif %}
  .hidden-items{
    display:none;
    opacity:0;
    transform: translate3d(0, 15%, 0);
    transition: .6s ;
  }
</style>

{% schema %}
{
  "name": "t:sections.testimonials.name",
  "tag": "section",
  "class": "testimonials",
  "max_blocks": 16,
  "disabled_on": {
    "groups": [
      "header",
      "footer"
    ]
  },
  "settings": [
    {
      "type": "select",
      "id": "section_visibility",
      "label": "t:global.common.section_visibility.label",
      "default": "always",
      "options": [
        {
          "label": "t:global.common.section_visibility.options.always",
          "value": "always"
        },
        {
          "label": "t:global.common.section_visibility.options.small",
          "value": "small"
        },
        {
          "label": "t:global.common.section_visibility.options.large",
          "value": "large"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "make_section_rounded",
      "label": "t:global.common.general_labels.make_section_rounded",
      "default": false
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.testimonials.settings.background_image.label"
    },
    {
      "type":"checkbox",
      "id":"background_blur",
      "label":"t:sections.testimonials.settings.background_blur.label",
      "default":false
    },
    {
      "type":"header",
      "content":"t:global.header.content_section.label"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "Testimonials",
      "info": "t:global.common.infos.heading.label",
      "label": "t:global.common.general_labels.heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "t:global.common.general_labels.heading_size",
      "default": "h3",
      "options": [
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        },
        {
          "value": "h4",
          "label": "H4"
        },
        {
          "value": "h5",
          "label": "H5"
        },
        {
          "value": "h6",
          "label": "H6"
        }
      ]
    },
    {
      "type": "select",
      "id": "seo_heading",
      "label": "t:global.common.general_labels.heading_tag",
      "info": "t:global.common.infos.seo_heading.label",
      "default": "h3",
      "options": [
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        },
        {
          "value": "h4",
          "label": "H4"
        },
        {
          "value": "h5",
          "label": "H5"
        },
        {
          "value": "h6",
          "label": "H6"
        }
      ]
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "t:global.common.heading_alignment.label",
      "default": "text-center",
      "options": [
        {
          "label": "t:global.common.heading_alignment.options.left.label",
          "value": "text-left"
        },
        {
          "label": "t:global.common.heading_alignment.options.center.label",
          "value": "text-center"
        }
      ]
    },
    {
      "type": "header",
      "content": "t:global.header.layout.label"
    },
    {
      "type": "select",
      "id": "style_type",
      "label": "t:sections.testimonials.settings.layout_type.label",
      "default": "grid",
      "options": [
        {
          "value": "grid",
          "label": "t:sections.testimonials.settings.layout_type.grid.label"
        },
        {
          "value": "carousel",
          "label": "t:sections.testimonials.settings.layout_type.carousel.label"
        }
      ]
    },
    {
      "type": "select",
      "label": "t:global.header.content_alignment_section.label",
      "id": "content_alignment",
      "default": "center",
      "options": [
        {
          "value": "left",
          "label": "t:global.common.alignments.left"
        },
        {
          "value": "center",
          "label": "t:global.common.alignments.center"
        },
        {
          "value": "right",
          "label": "t:global.common.alignments.right"
        }
      ]
    },
    {
      "type": "paragraph",
      "content": "t:global.header.carousel.label"
    },
    {
      "type": "range",
      "id": "column_count",
      "min": 1,
      "max": 3,
      "step": 1,
      "label": "t:sections.testimonials.settings.column_count.label",
      "default": 3
    },
    {
      "type": "paragraph",
      "content": "t:global.header.grid.label"
    },
    {
      "type": "checkbox",
      "id": "load_more",
      "label": "t:sections.testimonials.settings.load_more.label",
      "info": "t:sections.testimonials.settings.load_more.info",
      "default": false
    },
    {
      "type": "select",
      "id": "mobile_layout",
      "label": "t:sections.testimonials.settings.mobile_layout.label",
      "default": "1",
      "options": [
        {
          "value": "1",
          "label": "t:sections.testimonials.settings.mobile_layout.options.1-column.label"
        },
        {
          "value": "2",
          "label": "t:sections.testimonials.settings.mobile_layout.options.2-column.label"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "enable_swipe",
      "label": "t:sections.testimonials.settings.swipe_mobile.label",
      "default": true
    },
    {
      "type": "header",
      "content": "t:global.header.color_section.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "secondary",
      "label": "t:global.header.color_scheme.label"
    },
    {
      "type": "color",
      "id": "section_background",
      "label": "t:global.common.section_background.label",
      "info": "t:global.common.section_background.info"
    },
    {
      "type": "color",
      "id": "highlighted_color",
      "default": "#EFF341",
      "label": "t:global.common.general_labels.highlight_color"
    },
    {
      "type": "color",
      "id": "overlay_background",
      "label": "t:global.common.general_labels.overlay",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "t:global.common.general_labels.overlay_opacity",
      "default": 0,
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%"
    },
    {
      "type": "header",
      "content": "t:global.header.space_section.label"
    },
    {
      "type": "range",
      "id": "top_space_desktop",
      "label": "t:global.top_space_desktop.label",
      "default": 60,
      "min": 0,
      "max": 100,
      "step": 5
    },
    {
      "type": "range",
      "id": "bottom_space_desktop",
      "label": "t:global.bottom_space_desktop.label",
      "default": 60,
      "min": 0,
      "max": 100,
      "step": 5
    },
    {
      "type": "range",
      "id": "top_space_mobile",
      "label": "t:global.top_space_mobile.label",
      "default": 35,
      "min": 0,
      "max": 100,
      "step": 5
    },
    {
      "type": "range",
      "id": "bottom_space_mobile",
      "label": "t:global.bottom_space_mobile.label",
      "default": 35,
      "min": 0,
      "max": 100,
      "step": 5
    }
  ],
  "blocks": [
    {
      "type": "quote",
      "name": "t:sections.testimonials.blocks.quote.name",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:global.common.general_labels.image"
        },
        {
          "type": "range",
          "id": "rating",
          "label": "t:sections.testimonials.blocks.quote.settings.rating.label",
          "default": 5,
          "min": 1,
          "max": 5,
          "step": 1
        },
        {
          "type": "inline_richtext",
          "id": "heading",
          "label": "t:sections.testimonials.blocks.quote.settings.heading.label",
          "default": "Review heading"
        },
        {
          "type": "richtext",
          "id": "message",
          "default": "<p>Add client reviews & testimonials to showcase your store’s happy clients.</p>",
          "label": "t:sections.testimonials.blocks.quote.settings.message.label"
        },
        {
          "type": "text",
          "id": "author",
          "default": "Author name",
          "label": "t:sections.testimonials.blocks.quote.settings.author.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.testimonials.presets.name",
      "blocks": [
        {
          "type": "quote"
        },
        {
          "type": "quote"
        },
        {
          "type": "quote"
        },
        {
          "type": "quote"
        }
      ]
    }
  ]
}
{% endschema %}
