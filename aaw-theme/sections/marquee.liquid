<link rel="preload" as="style" href="{{ 'marque-text.css' | asset_url }}">
  {{ 'marque-text.css' | asset_url | stylesheet_tag }}
  {% liquid
    if section.settings.enable_autoplay
      assign limit = 8
    else
      assign limit = 12
    endif
  %}
<div class="marque-text-box">
  <div class="marque-text-inner-box">
   
      <div class="marque-text-wrapper" >
        <div class="marque-text-content {% if section.settings.rotation_style != 'onscroll' %} autoplay-infinite {% else %} on-scroll-move{% endif %} {{ section.settings.direction }}-direction"
            data-marquee-speed="{{ section.settings.scrolling_speed }}"
            data-marquee-speed-mobile="{{ section.settings.scrolling_speed_mobile }}"
          {% if section.settings.rotation_style != 'always' %}
            data-marquee-on-scroll
          {% endif %}
          {% if section.settings.rotation_style != 'onscroll' %}
            data-marquee-text
          {% endif %}
        >
          {% for i in (1..limit) %}

            <div data-id="marquee-text-{{ i }}" class="marque-text-node" data-marque-node >
            {% for block in section.blocks %}
                {% case block.type %}
                    {% when "text" %}
                        
                        <div class="marque-text-item {% if block.settings.small_icon %} small-icon{% endif %}" id="marque-text-{{ i }}-{{ block.id }}" {{ block.shopify_attributes }}>
                            {% if block.settings.text != blank %}
                            <span class="marqueeNode-{{ block.id }} rte {{ block.settings.font_family }}-font {{ block.settings.text_style }}-text" style="--outline-thickness:{{ block.settings.outline_thickness }}px" >
                                {{- block.settings.text -}}
                            </span>
                            {% endif %}
                            {% if block.settings.custom_icon != blank %}
                            <span class="marqueeNode-{{ block.id }} marquee-icon" >
                                {{- block.settings.custom_icon -}}
                            </span>
                            {% endif %}
                        </div>
                    {% endcase %}
                        
            {% endfor %}
        </div>

          {% endfor %}
        </div>
      </div>
    
  </div>
</div>
 <style>
#shopify-section-{{ section.id }} {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  --top-spacer:{{ section.settings.top_space_desktop }}px;
  --bottom-spacer:{{ section.settings.bottom_space_desktop }}px;
  background:{{ section.settings.bgcolor }};
}
#shopify-section-{{ section.id }} .marque-text-wrapper{
  transform:rotate({{ section.settings.text_angle }}deg);
  z-index:1
}
{% if section.blocks.size > 0 %}
{% for i in (1..limit) %}
  {% for block in section.blocks %}
   
  #marque-text-{{ i }}-{{ block.id }}{
    {% if block.settings.text_gradient_color != blank and block.settings.text_style == 'gradient' %}
        --node-color: {{ block.settings.text_gradient_color }};
    {% else %}
        --node-color: {{ block.settings.color }};
    {% endif %}

    {% if block.settings.text_style == 'outline-filled' or block.settings.text_style == 'outline' %}
      --node-outline-color: {{ block.settings.outline_color }};
    {% endif %}
    
    --node-size: {{ block.settings.mobile_font }}px;
    --marquee-gap:{{ block.settings.text_gap }}px;
    --marquee-icon-gap:{{ block.settings.text_icon_gap }}px;
  }

{%- comment -%}   
  #marque-text-{{ i }}-{{ block.id }} .marquee-icon:not(.default-color),
  #marque-text-{{ i }}-{{ block.id }} .marquee-icon:not(.default-color) *{
    color:{{ block.settings.icon_color }};
  }
  #marque-text-{{ i }}-{{ block.id }} .marquee-icon:not(.default-color) svg{
    fill:{{ block.settings.icon_color }};
  }
   {%- endcomment -%}

  {% endfor %}
  @media only screen and (min-width:768px) {
    {% for block in section.blocks %}
    #marque-text-{{ i }}-{{ block.id }}{
      --node-size: calc({{ block.settings.desktop_font }}px * 0.8);
    }
    {% endfor %}
  }
  @media only screen and (min-width:1200px) {
        {% for block in section.blocks %}
        #marque-text-{{ i }}-{{ block.id }}{
        --node-size: {{ block.settings.desktop_font }}px;
        }
    {% endfor %}
  }
{% endfor %}
{% endif %}
@media only screen and (max-width:767px) {
  #shopify-section-{{ section.id }}{
    --top-spacer:{{ section.settings.top_space_mobile }}px;
    --bottom-spacer:{{ section.settings.bottom_space_mobile }}px;
  }
}
{% if section.settings.section_visibility == 'large' %}
  @media (max-width: 767px) {
    #shopify-section-{{ section.id }}{
      display: none !important;
    }
  }
{% elsif section.settings.section_visibility == 'small' %}
  @media (min-width: 768px) {
    #shopify-section-{{ section.id }}{
      display: none !important;
    }
  }
{% endif %}
</style> 
{% schema %}
{
  "name": "t:sections.marquee-text.name",
  "tag": "section",
  "class": "marque-text",
  "disabled_on": {
    "groups": [
      "header"
    ]
  },
  "settings": [
    {
      "type": "select",
      "id": "section_visibility",
      "label": "t:global.common.section_visibility.label",
      "default": "always",
      "options": [
        {
          "label": "t:global.common.section_visibility.options.always",
          "value": "always"
        },
        {
          "label": "t:global.common.section_visibility.options.small",
          "value": "small"
        },
        {
          "label": "t:global.common.section_visibility.options.large",
          "value": "large"
        }
      ]
    },
    {
      "type": "select",
      "id": "rotation_style",
      "label": "t:global.common.marquee_type.label",
      "default": "both",
      "options": [
        {
          "value": "onscroll",
          "label": "t:global.common.marquee_type.options.onscroll"
        },
        {
          "value": "always",
          "label": "t:global.common.marquee_type.options.always"
        },
        {
          "value": "both",
          "label": "t:global.common.marquee_type.options.both"
        }
      ]
    },
    {
      "type": "select",
      "id": "direction",
      "label": "t:global.common.marquee_direction.label",
      "options": [
        {
          "value": "rtl",
          "label": "t:global.common.marquee_direction.options.rtl"
        },
        {
          "value": "ltr",
          "label": "t:global.common.marquee_direction.options.ltr"
        }
      ],
      "default": "rtl"
    },
    {
      "type": "range",
      "id": "scrolling_speed",
      "label": "t:global.common.marquee_speed.desktop.label",
      "min": 5,
      "max": 100,
      "unit": "s",
      "default": 15
    },
    {
      "type": "range",
      "id": "scrolling_speed_mobile",
      "label": "t:global.common.marquee_speed.mobile.label",
      "min": 5,
      "max": 100,
      "unit": "s",
      "default": 15
    },
    {
      "type": "range",
      "id": "text_angle",
      "label": "t:sections.marquee-text.settings.text_angle.label",
      "default": 0,
      "unit": "°",
      "min": -5,
      "max": 5,
      "step": 1
    },
    {
      "type": "header",
      "content": "t:global.header.color_section.label"
    },
    {
      "type": "color",
      "id": "bgcolor",
      "label": "t:sections.marquee-text.settings.bgcolor.label",
      "default":"#F2F2F2"
    },
    {
      "type": "header",
      "content": "t:global.header.space_section.label"
    },
    {
      "type": "range",
      "id": "top_space_desktop",
      "label": "t:global.top_space_desktop.label",
      "default": 20,
      "min": 0,
      "max": 100,
      "step": 5
    },
    {
      "type": "range",
      "id": "bottom_space_desktop",
      "label": "t:global.bottom_space_desktop.label",
      "default": 20,
      "min": 0,
      "max": 100,
      "step": 5
    },
    {
      "type": "range",
      "id": "top_space_mobile",
      "label": "t:global.top_space_mobile.label",
      "default": 10,
      "min": 0,
      "max": 100,
      "step": 5
    },
    {
      "type": "range",
      "id": "bottom_space_mobile",
      "label": "t:global.bottom_space_mobile.label",
      "default": 10,
      "min": 0,
      "max": 100,
      "step": 5
    }
  ],
  "blocks": [
    {
      "type": "text",
      "name": "t:sections.marquee-text.blocks.name",
      "settings": [
        {
          "type": "inline_richtext",
          "id": "text",
          "label": "t:global.common.general_labels.text",
          "default": "MARQUEE TEXT HERE"
        },
        {
          "type": "range",
          "id": "text_gap",
          "label": "t:sections.marquee-text.blocks.settings.text_gap.label",
          "min": 5,
          "max": 100,
          "unit": "px",
          "default": 50
        },
        {
          "type": "select",
          "id": "text_style",
          "label": "t:sections.marquee-text.blocks.settings.text_style.label",
          "default": "solid",
          "options": [
            {
              "label": "t:sections.marquee-text.blocks.settings.text_style.solid.label",
              "value": "solid"
            },
            {
              "label": "t:sections.marquee-text.blocks.settings.text_style.outlined.label",
              "value": "outline"
            },
            {
              "label": "t:sections.marquee-text.blocks.settings.text_style.gradient.label",
              "value": "gradient"
            },
            {
              "label": "t:sections.marquee-text.blocks.settings.text_style.outline-filled.label",
              "value": "outline-filled"
            }
          ]
        },
        {
          "type": "header",
          "content": "t:global.header.font.label"
        },
        {
          "type": "select",
          "id": "font_family",
          "label": "t:global.common.font_family.label",
          "options": [
            {
              "value": "heading",
              "label": "t:global.common.font_family.options.heading"
            },
            {
              "value": "body",
              "label": "t:global.common.font_family.options.body"
            }
          ],
          "default": "heading"
        },
        {
          "type": "range",
          "id": "desktop_font",
          "label": "t:global.common.marquee_text_size.desktop.label",
          "min": 20,
          "max": 130,
          "step": 2,
          "unit": "px",
          "default": 80
        },
        {
          "type": "range",
          "id": "mobile_font",
          "label": "t:global.common.marquee_text_size.mobile.label",
          "min": 14,
          "max": 80,
          "step": 2,
          "unit": "px",
          "default": 40
        },
        {
          "type": "range",
          "id": "outline_thickness",
          "min": 1,
          "max": 4,
          "step": 1,
          "unit": "px",
          "label": "t:global.common.marque_text_outline_thickness.label",
          "default": 1
        },
        {
          "type": "header",
          "content": "t:global.header.color_section.label"
        },
        {
          "type": "color",
          "id": "color",
          "label": "t:sections.marquee-text.blocks.settings.color.label",
          "default":"#898989"
        },
        {
          "type": "color",
          "id": "outline_color",
          "label": "t:global.common.outline.label"
        },
        {
          "type": "color_background",
          "id": "text_gradient_color",
          "label": "t:global.common.gradient.label"
        },
        {
          "type": "textarea",
          "id": "custom_icon",
          "label": "t:sections.marquee-text.blocks.settings.custom_icon.label"
        },
        {
          "type": "checkbox",
          "id": "small_icon",
          "label": "t:sections.marquee-text.blocks.settings.small_icon.label",
          "default": false
        },
        {
          "type": "range",
          "id": "text_icon_gap",
          "label": "t:sections.marquee-text.blocks.settings.text_icon_gap.label",
          "min": 5,
          "max": 100,
          "unit": "px",
          "default": 15
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.marquee-text.presets.name",
      "blocks": [
        {
          "type": "text"
        },
        {
          "type": "text"
        }
      ]
    }
  ]
}
{% endschema %}
