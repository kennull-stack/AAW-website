        <p>Outside Singapore: Hong Kong, Macau, Japan, China, South Korea, Thailand. Dealers include DMA, Fine Up Computer, Let's Go Audio, Music Movie Driver, e-earphone, Step Sound, Sorishop, and SoundProofBros.</p>
      </div>
      <a class="bm-btn bm-btn--ghost" href="/pages/store-locator">Find a listening room</a>
    </div>
  </section>

  <section class="bm-final">
    <div class="bm-wrap">
      <p class="bm-kicker">Z02</p>
      <h2>Planar speed. Graphene low end. Hybrid clarity.</h2>
      <form class="bm-actions bm-actions--center" method="post" action="/cart/add">
        <input type="hidden" name="id" value="{{ current_variant.id }}">
        <input type="hidden" name="quantity" value="1">
        <button class="bm-btn" type="submit"{% unless current_variant.available %} disabled{% endunless %}>{% if current_variant.available %}Buy Z02{% else %}Sold Out{% endif %}</button>
      </form>
    </div>
  </section>
</div>

