{% if section.settings.section_visibility == 'large' %}
  <style>
    @media (max-width: 767px) {
      #shopify-section-{{ section.id }} {
        display: none !important;
      }
    }
  </style>
{% elsif section.settings.section_visibility == 'small' %}
  <style>
    @media (min-width: 768px) {
      #shopify-section-{{ section.id }} {
        display: none !important;
      }
    }
  </style>
{% endif %}

{% assign current_variant = product.selected_or_first_available_variant %}
{% assign product_price = current_variant.price | money %}
{% assign jm_badge = product.metafields.judgeme.badge | default: '' %}
{% assign jm_widget = product.metafields.judgeme.widget | default: '' %}

<script type="application/ld+json">
{
  "@context": "https://schema.org/",
  "@type": "Product",
  "@id": {{ canonical_url | append: "#product" | json }},
  "name": "AAW Z02 Planar Magnetic Universal In-Ear Monitor",
  "image": [
    {{ 'z02-hero-wide.jpg' | asset_url | prepend: 'https:' | json }},
    {{ 'z02-driver-diagram.jpg' | asset_url | prepend: 'https:' | json }},
    {{ 'Z02-FR_5fb85fc0-6b97-46e2-a9d5-0031f8aa6a25.jpg' | file_url | json }}
  ],
  "description": "Z02 is a dynamic-planar hybrid in-ear monitor from Advanced AcousticWerkes. It combines a miniature planar magnetic tweeter, 10mm graphene dynamic driver, 2-way crossover, and 3D-printed acoustic chamber for a lively, coherent, and fatigue-free sound signature.",
  "sku": {{ current_variant.sku | default: "Z02" | json }},
  "mpn": "AAW Z02",
  "brand": {"@id": "https://www.aaw.me/#organization"},
  "category": "Universal In-Ear Monitor",
  "offers": {
    "@type": "Offer",
    "url": {{ canonical_url | json }},
    "priceCurrency": {{ cart.currency.iso_code | default: shop.currency | json }},
    "price": {{ current_variant.price | money_without_currency | remove: ',' | json }},
    "availability": "https://schema.org/{% if current_variant.available %}InStock{% else %}OutOfStock{% endif %}",
    "itemCondition": "https://schema.org/NewCondition",
    "seller": {"@id": "https://www.aaw.me/#organization"},
    "hasMerchantReturnPolicy": {
      "@type": "MerchantReturnPolicy",
      "url": "https://www.aaw.me/pages/shipping-return",
      "applicableCountry": "SG",
      "returnPolicyCategory": "https://schema.org/MerchantReturnFiniteReturnWindow",
      "merchantReturnDays": 7,
      "returnMethod": "https://schema.org/ReturnByMail",
      "returnFees": "https://schema.org/ReturnShippingFees"
    }
  },
  "additionalProperty": [
    {"@type": "PropertyValue", "name": "Driver Configuration", "value": "2-driver dynamic-planar hybrid"},
    {"@type": "PropertyValue", "name": "Planar Tweeter", "value": "Miniature planar magnetic tweeter embedded in a 3D-printed shell"},
    {"@type": "PropertyValue", "name": "Dynamic Driver", "value": "10mm graphene dynamic driver with physical low-pass filtering"},
    {"@type": "PropertyValue", "name": "Crossover", "value": "Physical 2-way crossover"},
    {"@type": "PropertyValue", "name": "Internal Wire", "value": "OCC copper internal wire"},
    {"@type": "PropertyValue", "name": "Sensitivity", "value": "105dB"},
    {"@type": "PropertyValue", "name": "Impedance", "value": "18 Ohm"},
    {"@type": "PropertyValue", "name": "Frequency Response", "value": "10Hz to 40kHz"},
    {"@type": "PropertyValue", "name": "Total Harmonic Distortion", "value": "<=1%"},
    {"@type": "PropertyValue", "name": "Enclosure", "value": "AAW third-generation 3D-printed digital enclosure and acoustic chamber"},
    {"@type": "PropertyValue", "name": "Warranty", "value": "1-year limited warranty"}
  ]
}
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the Z02 driver configuration?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Z02 uses a 2-driver dynamic-planar hybrid configuration: a 10mm graphene dynamic driver for low frequencies and a miniature planar magnetic tweeter for vocal, treble, and upper-frequency detail."
      }
    },
    {
      "@type": "Question",
      "name": "What does the miniature planar magnetic tweeter do?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The planar magnetic tweeter is embedded in the 3D-printed shell to reduce sound pressure decay and unwanted resonance typical of tubed balanced armature layouts. It is designed for extended high-frequency response, low distortion, fast transient response, and consistent soundstage reproduction."
      }
    },
    {
      "@type": "Question",
      "name": "What does the graphene dynamic driver add?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The 10mm graphene dynamic driver uses an ultra-thin rigid diaphragm and physical low-pass filtering so it can handle bass and lower-frequency energy with minimal overlap against the planar tweeter."
      }
    },
    {
      "@type": "Question",
      "name": "How is the Z02 enclosure made?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Z02 uses AAW's third-generation digital enclosure and acoustic chamber process. Driver and nozzle placements are simulated through many iterations, then 3D printed for precision and production consistency."
      }
    },
    {
      "@type": "Question",
      "name": "What comes in the box?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "48 inch Brevity OCC copper detachable cable, AAW carrying case, assorted ear tips, and a 1-year limited warranty."
      }
    }
  ]
}
</script>

