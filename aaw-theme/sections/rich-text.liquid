              "label": "t:global.common.style.value.link"
            },
            {
              "value": "animate",
              "label":"t:global.common.style.value.animate"
            }
          ]
        },
        {
          "type": "text",
          "id": "text",
          "label": "t:global.common.general_labels.text",
          "default": "Button"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:global.common.general_labels.link"
        },
        {
          "type": "select",
          "id": "button_size",
          "label": "t:sections.rich_text.settings.button_size.label",
          "default": "medium",
          "options": [
            {
              "value": "regular",
              "label": "t:global.common.size.value.regular"
            },
            {
              "value": "small",
              "label": "t:global.common.size.value.small"
            },
            {
              "value": "medium",
              "label": "t:global.common.size.value.medium"
            },
            {
              "value": "large",
              "label": "t:global.common.size.value.large"
            }
          ]
        }
      ]
    },
    {
      "type": "divider",
      "name": "t:sections.rich_text.settings.divider.label"
    },
    {
      "type": "image",
      "name": "t:global.common.general_labels.image",
      "limit": 3,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:global.common.general_labels.image"
        },
        {
          "type": "range",
          "id": "image_size",
          "label": "t:sections.rich_text.settings.image_size.label",
          "default": 40,
          "min": 20,
          "max": 100,
          "unit": "%",
          "step": 1
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.rich_text.presets.name",
      "blocks": [
        {
          "type": "heading"
        },
        {
          "type": "text"
        }
      ]
    }
  ]
}
{% endschema %}
