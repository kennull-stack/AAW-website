<link rel="preload" as="style" href="{{ 'contact.css' | asset_url }}">
{{ 'contact.css' | asset_url | stylesheet_tag }}
<div class="section-container {{ section.settings.color_scheme }}-scheme {% if section.settings.make_section_rounded %}section-rounded{% endif %}">
  <div class="{{ settings.container_width }}">
    {% if section.settings.heading != blank %}

      {%- capture sectionhighlightPrefix -%}
        <strong class="highlight-text">
      {%- endcapture -%}

      {%- capture sectionhighlightSuffix -%}
        </strong>
      {%- endcapture -%}


      <div class="section-heading-box {{ section.settings.heading_alignment }}" {% if settings.enable_animation %}data-aos="fade-up" data-aos-duration="1000"{% endif %}>
        <{{ section.settings.seo_heading }} class="section-heading {{ section.settings.heading_size }}">
          {{ section.settings.heading | replace: "<strong>", sectionhighlightPrefix | replace: "</strong>", sectionhighlightSuffix | replace: '++', '<br>' }}
        </{{ section.settings.seo_heading }}>
      </div>
    {% endif %}
    <div class="contact-form-wrapper {{ section.settings.content_width }}-width">
      {%- form 'contact', id: 'ContactForm', class: 'get-in-touch-form' -%}
        <div class="form-group">
          <label class="hidden" for="ContactName">{{ 'templates.contact.form.name' | t }}</label>
          <input
            type="text"
            class="form-control"
            name="contact[name]"
            id="ContactName"
            autocomplete="name"
            autocapitalize="off"
            placeholder="{{ 'templates.contact.form.name' | t }}"
            required
          >
        </div>
        <div class="form-group">
          <label class="hidden" for="ContactEmail">{{ 'templates.contact.form.email' | t }}</label>
          <input
            type="email"
            class="form-control"
            name="contact[email]"
            id="ContactEmail"
            autocomplete="email"
            autocapitalize="off"
            value="{% if form.email %}{{ form.email }}{% elsif customer %}{{ customer.email }}{% endif %}"
            aria-required="true"
            spellcheck="false"
            {% if form.errors contains 'email' %}
              aria-invalid="true"
              aria-describedby="ContactForm-email-error"
            {% endif %}
            placeholder="{{ 'templates.contact.form.email' | t }}"
            pattern="^([a-zA-Z0-9_\\-\\.]+)@((\\[[0-9]{1,3}\\.[0-9]{1,3}\\.[0-9]{1,3}\\.)|(([a-zA-Z0-9\\-]+\\.)+))([a-zA-Z]{2,4}|[0-9]{1,3})(\\]?)$"
            required
          >
        </div>
        {% if section.settings.enable_phone_number %}
        <div class="form-group">
          <label class="hidden" for="ContactPhone">{{ 'templates.contact.form.phone' | t }}</label>
          <input
            type="text"
            class="form-control"
            name="contact[phone]"
            id="ContactPhone"
            autocomplete="phone"
            autocapitalize="off"
            placeholder="{{ 'templates.contact.form.phone' | t }}"
            required
          >
        </div>
      {% endif %}
        <div class="form-group">
          <label class="hidden" for="ContactSubject">{{ 'templates.contact.form.subject' | t }}</label>
          <input
            type="text"
            class="form-control"
            name="contact[subject]"
            id="ContactSubject"
            autocomplete="subject"
            autocapitalize="off"
            placeholder="{{ 'templates.contact.form.subject' | t }}"
            required
          >
        </div>
        <div class="form-group">
          <label class="hidden" for="ContactForm-body">{{ 'templates.contact.form.comment' | t }}</label>
          <textarea
            id="ContactForm-body"
            name="contact[Message]"
            rows="6"
            placeholder="{{ 'templates.contact.form.comment' | t }}"
            class="form-control"
            required
          ></textarea>
        </div>
        {% liquid
          assign buttonText = 'templates.contact.form.send' | t
          render 'button', type:'button', class:'button', buttonAttributes:'type="submit"', button_size: 'default', button_text: buttonText
          %}
        {%- if form.errors -%}
          <p class="error-message" id="form-message__error-{{ section.id }}" autofocus>
            {{ form.errors.translated_fields.email | capitalize }}
            {{ form.errors.messages.email }}
          </p>
        {%- endif -%}
        {%- if form.posted_successfully? -%}
          <p class="success-message" id="form-message__success-{{ section.id }}" tabindex="-1" role="status" autofocus>
            {{- 'templates.contact.form.post_success' | t -}}
          </p>
        {%- endif -%}
      {% endform %}
    </div>
  </div>
</div>
<style>
  #shopify-section-{{ section.id }}.shopify-section {
    --top-spacer:{{ section.settings.top_space_desktop }}px;
    --bottom-spacer:{{ section.settings.bottom_space_desktop }}px;
    --highlight-text: {{ section.settings.highlighted_color }};
    {% if section.settings.make_section_rounded %}
      background:{{ section.settings.section_background }};
    {% endif %}
  }
  @media only screen and (max-width:767px) {
    #shopify-section-{{ section.id }}.shopify-section{
      --top-spacer:{{ section.settings.top_space_mobile }}px;
      --bottom-spacer:{{ section.settings.bottom_space_mobile }}px;
    }
  }
  {% if section.settings.section_visibility == 'large' %}
    @media (max-width: 767px) {
      #shopify-section-{{ section.id }}{
        display: none !important;
      }
    }
  {% elsif section.settings.section_visibility == 'small' %}
    @media (min-width: 768px) {
      #shopify-section-{{ section.id }}{
        display: none !important;
      }
    }
  {% endif %}
</style>

{% schema %}
{
  "name": "t:sections.contact-form.name",
  "tag": "section",
  "class": "contact-form",
  "disabled_on": {
    "groups": [
      "header",
      "footer"
    ]
  },
  "settings": [
    {
      "type": "select",
      "id": "section_visibility",
      "label": "t:global.common.section_visibility.label",
      "default": "always",
      "options": [
        {
          "label": "t:global.common.section_visibility.options.always",
          "value": "always"
        },
        {
          "label": "t:global.common.section_visibility.options.small",
          "value": "small"
        },
        {
          "label": "t:global.common.section_visibility.options.large",
          "value": "large"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "make_section_rounded",
      "label": "t:global.common.general_labels.make_section_rounded",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "enable_phone_number",
      "label": "t:sections.contact-form.settings.enable_phone_number.label",
      "default": false
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "Contact form",
      "label": "t:global.common.general_labels.heading",
      "info": "t:global.common.infos.heading.label"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "t:global.common.general_labels.heading_size",
      "default": "h3",
      "options": [
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        },
        {
          "value": "h4",
          "label": "H4"
        },
        {
          "value": "h5",
          "label": "H5"
        },
        {
          "value": "h6",
          "label": "H6"
        }
      ]
    },
    {
      "type": "select",
      "id": "seo_heading",
      "label": "t:global.common.general_labels.heading_tag",
      "info": "t:global.common.infos.seo_heading.label",
      "default": "h3",
      "options": [
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        },
        {
          "value": "h4",
          "label": "H4"
        },
        {
          "value": "h5",
          "label": "H5"
        },
        {
          "value": "h6",
          "label": "H6"
        }
      ]
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "t:global.common.heading_alignment.label",
      "default": "text-center",
      "options": [
        {
          "label": "t:global.common.heading_alignment.options.left.label",
          "value": "text-left"
        },
        {
          "label": "t:global.common.heading_alignment.options.center.label",
          "value": "text-center"
        }
      ]
    },
    {
      "type": "header",
      "content": "t:sections.contact-form.settings.header.label"
    },
    {
      "type": "select",
      "id": "content_width",
      "label": "t:sections.contact-form.settings.content_width.label",
      "default": "medium",
      "options": [
        {
          "value": "small",
          "label": "t:global.common.size.value.small"
        },
        {
          "value": "medium",
          "label": "t:global.common.size.value.medium"
        },
        {
          "value": "large",
          "label": "t:global.common.size.value.large"
        }
      ]
    },
    {
      "type": "header",
      "content": "t:global.header.color_singular_section.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "primary",
      "label": "t:global.header.color_scheme.label"
    },
    {
      "type": "color",
      "id": "highlighted_color",
      "default": "#EFF341",
      "label": "t:global.common.general_labels.highlight_color"
    },
    {
      "type": "color",
      "id": "section_background",
      "label": "t:global.common.section_background.label",
      "info": "t:global.common.section_background.info"
    },
    {
      "type": "header",
      "content": "t:global.header.space_section.label"
    },
    {
      "type": "range",
      "id": "top_space_desktop",
      "label": "t:global.top_space_desktop.label",
      "default": 40,
      "min": 0,
      "max": 100,
      "step": 5
    },
    {
      "type": "range",
      "id": "bottom_space_desktop",
      "label": "t:global.bottom_space_desktop.label",
      "default": 40,
      "min": 0,
      "max": 100,
      "step": 5
    },
    {
      "type": "range",
      "id": "top_space_mobile",
      "label": "t:global.top_space_mobile.label",
      "default": 35,
      "min": 0,
      "max": 100,
      "step": 5
    },
    {
      "type": "range",
      "id": "bottom_space_mobile",
      "label": "t:global.bottom_space_mobile.label",
      "default": 35,
      "min": 0,
      "max": 100,
      "step": 5
    }
  ],
  "presets": [
    {
      "name": "t:sections.contact-form.presets.name"
    }
  ]
}
{% endschema %}
