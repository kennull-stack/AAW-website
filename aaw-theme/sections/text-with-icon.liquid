<link rel="preload" as="style" href="{{ 'text-with-icon.css' | asset_url }}">
{{ 'text-with-icon.css' | asset_url | stylesheet_tag }}
{% if section.blocks.size > 0 %}
  <div class="section-container {{ section.settings.color_scheme }}-scheme {% if section.settings.make_section_rounded %}section-rounded{% endif %}">
    <div class="{{ settings.container_width }}">
      {% if section.settings.heading != blank %}

        {%- capture sectionhighlightPrefix -%}
            <strong class="highlight-text">
        {%- endcapture -%}

        {%- capture sectionhighlightSuffix -%}
            </strong>
        {%- endcapture -%}

        
        <div class="section-heading-box {{ section.settings.heading_alignment }}" {% if settings.enable_animation %}data-aos="fade-up" data-aos-duration="1000"{% endif %}>
          <{{ section.settings.seo_heading }} class="section-heading {{ section.settings.heading_size }}">
            {{ section.settings.heading | replace: "<strong>", sectionhighlightPrefix | replace: "</strong>", sectionhighlightSuffix | replace: '++', '<br>' }}
          </{{ section.settings.seo_heading }}>
        </div>
      {% endif %}
      <div class="text-with-icon-wrapper{% if section.settings.mobile_swipe %} mobile-swipe{% endif %}">
        {% for block in section.blocks %}
          {% assign aosDelay = forloop.index | times: 50 %}
          <div id="block-{{ block.id }}" class="text-with-icon-item" {{ block.shopify_attributes }} {% if settings.enable_animation %}data-aos="fade-up" data-aos-delay="{{ aosDelay }}"{% endif %}>
            <div class="text-with-icon-item-inner icon-position-{{ section.settings.icon_position }} {{ section.settings.content_alignment }} {% if section.settings.cards_background %}bg-enabled{% endif %}">
              {% if block.settings.icon != blank or block.settings.icon_list %}
                <div class="text-with-icon-icon {% if section.settings.icon_background %}icon-background-enabled{% endif %} icon-{{ section.settings.icon_size }}">
                  {% if block.settings.icon != blank %}
                    {{ block.settings.icon }}
                  {% else %}
                    {% render 'icons', icon: block.settings.icon_list %}
                  {% endif %}
                </div>
              {% endif %}
              {% if block.settings.heading != blank or block.settings.description %}
                <div class="text-with-icon-content">


                  {%- capture highlightPrefix -%}
                      <strong class="highlight-text">
                  {%- endcapture -%}

                  {%- capture highlightSuffix -%}
                      </strong>
                  {%- endcapture -%}
                  

                  <{{ block.settings.seo_heading }} class="text-with-icon-heading {{ block.settings.heading_size }}">
                    {{ block.settings.heading | replace: "<strong>", highlightPrefix | replace: "</strong>", highlightSuffix | replace: '++', '<br>' }}
                  </{{ block.settings.seo_heading }}>
                  {% if block.settings.description != blank %}
                    <p class="text-with-icon-desc">{{ block.settings.description }}</p>
                  {% endif %}
                </div>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
{% endif %}
<style>
  #shopify-section-{{ section.id }}{
    {% if section.settings.make_section_rounded %}
      background:{{ section.settings.section_background }};
    {% endif %}
    --top-spacer:{{ section.settings.top_space_desktop }}px;
    --bottom-spacer:{{ section.settings.bottom_space_desktop }}px;
    --column-count: {{ section.settings.column_count }};
    --highlight-text: {{ section.settings.highlighted_color }};
  }
  {% for block in section.blocks %}
    #block-{{ block.id }}{
      --column-background: {{ block.settings.column_background_color }};
      --icon-background: {{ block.settings.icon_background_color }};
      --column-border: {{ block.settings.column_border_color }};
      --column-textColor: {{ block.settings.text_color }};
      --highlight-text: {{ block.settings.highlight_color }};
    }
  {% endfor %}
  @media only screen and (max-width:767px) {
    #shopify-section-{{ section.id }}{
      --top-spacer: {{ section.settings.top_space_mobile }}px;
      --bottom-spacer: {{ section.settings.bottom_space_mobile }}px;
      --column-count: {{ section.settings.column_count_mobile }}
    }
  }
  {% if section.settings.section_visibility == 'large' %}
    @media (max-width: 767px) {
      #shopify-section-{{ section.id }}{
        display: none !important;
      }
    }
  {% elsif section.settings.section_visibility == 'small' %}
    @media (min-width: 768px) {
      #shopify-section-{{ section.id }}{
        display: none !important;
      }
    }
  {% endif %}
</style>

