<link rel="preload" as="style" href="{{ 'tabbed-content.css' | asset_url }}">
{{ 'tabbed-content.css' | asset_url | stylesheet_tag }}
<div class="section-container {{ section.settings.color_scheme }}-scheme {% if section.settings.make_section_rounded %}section-rounded{% endif %}">
  <div class="{{ settings.container_width }}">
    {% if section.settings.heading != blank %}

      {%- capture sectionhighlightPrefix -%}
        <strong class="highlight-text">
      {%- endcapture -%}

      {%- capture sectionhighlightSuffix -%}
        </strong>
      {%- endcapture -%}

      <div class="section-heading-box {{ section.settings.content_alignment }}" {% if settings.enable_animation %}data-aos="fade-up" data-aos-duration="1000"{% endif %}>
        <{{ section.settings.seo_heading }} class="section-heading  {{ section.settings.heading_size }}">
          {{- section.settings.heading | replace: "<strong>", sectionhighlightPrefix | replace: "</strong>", sectionhighlightSuffix | replace: '++', '<br>' -}}
        </{{ section.settings.seo_heading }}>
      </div>
    {% endif %}
    {% if section.blocks.size > 0 %}
      <div class="tabbed-content-wrapper">
        <ul class="tabbed-content-list">
          {% for block in section.blocks %}
            {% if block.settings.tab_heading != blank %}
              <li class="tabbed-content-list-item">
                <a href="#tabbed-{{ block.id }}" class="tabbed-content-link heading-font h5 {% if forloop.first %}active {% endif %}" data-tabs-main-head {{ block.shopify_attributes }}>
                  {{- block.settings.tab_heading -}}
                </a>
              </li>
            {% endif %}
          {% endfor %}
        </ul>
        <div class="tabbed-content-body">
          {% for block in section.blocks %}
            <div id="tabbed-{{ block.id }}" class="tabbed-content-body-item {% if forloop.first %}active {% endif %}"  data-tabs-content {{ block.shopify_attributes }}>
              <div class="tabbed-content-inner">
                {% case block.type %}
                  {% when 'collection_list', 'product_list' %}
                  {% if block.settings.heading != blank %}
                    <h6 class="tabbed-content-block-heading">{{ block.settings.heading }}</h6>
                  {% endif %}
                  {% if block.settings.description != blank %}
                    <p class="tabbed-content-block-desc">{{ block.settings.description | newline_to_br  }}</p>
                  {% endif %}
                {% endcase %}
                {% assign noImageClass = '' %}
                {% if block.type == 'collection_list' and block.settings.image == blank %} 
                  {% assign noImageClass = 'no-image' %}
                {% elsif block.type == 'product_list' and block.settings.image == blank  %}
                  {% assign noImageClass = 'no-image' %}
                {% elsif  block.type == 'media' %}
                  {% if  block.settings.heading == blank and block.settings.description == blank and block.settings.btn_text == blank and block.settings.btn_url == blank %}
                    {% assign noImageClass = 'no-content' %} 
                  {% endif %}
                {% endif %}
                
                <div class="tabbed-content-block{% if block.type == 'collection_list' %} collections-block{% elsif block.type == 'product_list' %} products-block{% else %} media-block{% endif %} {{ noImageClass }}">
                  {% case block.type %}
                    {% when 'collection_list', 'product_list' %}
                      {% if block.settings.image != blank %}
                        <div class="tabbed-content-block-item tabbed-content-block-left">
                          <div class="tabbed-content-block-img">
                            <div
                              class="media-box"
                              style="--image-ratio:{{ 1 | divided_by : block.settings.image.aspect_ratio | times: 100 }}%"
                            >
                              {%- render 'image', image: block.settings.image -%}
                            </div>
                          </div>
                        </div>
                      {% endif %}
                  {% endcase %}
                  {% case block.type %}
                    {% when 'collection_list' %}
                      <div class="tabbed-content-block-item tabbed-content-block-right">
                        <div class="tabbled-content-collections-list{% if section.settings.enable_swipe_mobile %} mobile-swipe{% endif %}">
                          {% if block.settings.collection != blank %}
                            {% liquid
                              for collection in block.settings.collection
                                assign placeholder_image_index = forloop.index0 | modulo: 4 | plus: 1
                                assign placeholder_image = 'collection-apparel-' | append: placeholder_image_index
                                echo '<div class="collection-card text-center" tabindex="0">'
                                render 'card-collection', collection: collection, section: section, placeholder_image: placeholder_image, collectionClass: 'text-small', collectionSearch: true, gridImageSize: block.settings.grid_image_size
                                echo '</div>'
                              endfor
                            %}
                          {% else %}

                          {%- liquid
                          
                            assign gridImageSize = block.settings.grid_image_size
                            if gridImageSize == 'landscape'
                              assign collectionImageRatio = 75
                            elsif gridImageSize == 'square'
                              assign collectionImageRatio = 100
                            elsif gridImageSize == 'portrait'
                              assign collectionImageRatio = 125 
                            else
                                assign collectionImageRatio = 100
                              
                            endif
                          -%}
                            {%- for i in (1..8) -%}
                              {% assign placeholder_image_index = forloop.index0 | modulo: 4 | plus: 1 %}
                              {% assign placeholder_image = 'collection-apparel-' | append: placeholder_image_index %}
                              <div class="collection-card " tabindex="0">
                                <div class="collection-image">
                                  <div class="media-box" style="--image-ratio:{{ collectionImageRatio }}%">
                                    {{ placeholder_image | placeholder_svg_tag: 'placeholder-svg' }}
                                  </div>
                                </div>
                                <div class="collection-content text-center">
                                  <h5 class="collection-title text-small">
                                    {{ 'sections.collection_template.title' | t }}
                                  </h5>
                                </div>
                              </div>
                            {% endfor %}
                          {% endif %}
                        </div>
                      </div>
                    {% when 'product_list' %}
                      <div class="tabbed-content-block-item tabbed-content-block-right">
                        <div class="tabbled-content-collections-list{% if section.settings.enable_swipe_mobile %} mobile-swipe{% endif %}">
                          {% if block.settings.product_list != blank %}
                            {% liquid
                              for cProduct in block.settings.product_list
                                assign productFormId = 'product-form-' | append: section.id | append: forloop.index | append: '-' | append: cProduct.handle
                                capture current
                                  cycle section.id: 1
                                endcapture
                                assign placeholder_image = 'product-apparel-' | append: current
                                echo '<div class="product-card" tabindex="0">'
                                render 'card-product', placeholder_image: placeholder_image, cProduct: cProduct, section: section, productFormId: productFormId, tabquickView: 'hide', gridImageSize: block.settings.grid_image_size
                                echo '</div>'
                              endfor
                            %}
                          {% else %} 
                            {%- for i in (1..8) -%}
                              {%- liquid
                          
                                assign gridImageSize = block.settings.grid_image_size
                                if gridImageSize == 'landscape'
                                  assign productImageRatio = 75
                                elsif gridImageSize == 'square'
                                  assign productImageRatio = 100
                                elsif gridImageSize == 'portrait'
                                  assign productImageRatio = 125 
                                else
                                    assign productImageRatio = 100
                                  
                                endif
                              -%}
                              <div class="product-card {% if settings.image_border %} border-enabled {% endif %}{% if settings.image_background %} background-enabled {% endif %}">
                                <div class="product-card-img">
                                  <div class="media-box no-product-image" style="--image-ratio:{{  productImageRatio }}%">
                                    {%- capture current -%}{% cycle 1, 2, 3, 4 %}{%- endcapture -%}
                                    {{ 'product-apparel-' | append: current | placeholder_svg_tag: 'placeholder-svg' }}
                                  </div>
                                </div>
                                <div class="product-card-detail">
                                  <div class="product-card-detail-info">
                                    <span class="product-title heading-font">
                                      {{- 'products.product.onboarding.title' | t -}}
                                    </span>
                                    {% if settings.show_price %}
                                    <div class="product-pricing">
                                      <span class="product-actual-price">{{ 1999 | money }}</span>
                                    </div>
                                  {% endif %}
                                  </div>
                                </div>
                              </div>
                            {% endfor %}
                          {% endif %}
                        </div>
                      </div>
                    {% when 'media' %}

                    
                          <div class="tabbed-content-block-item tabbed-content-block-left">
                            <div class="tabbed-content-media-block-img ">
                              {% if block.settings.video != blank %}                              
                                <deferred-media class="deferred-media " data-type="video"> 
                                  <template>
                                    <div class="media-box" style="--image-ratio: {{ 1 | divided_by : block.settings.video.preview_image.aspect_ratio | times: 100 }}%">
                                        {{ block.settings.video | video_tag:  image_size: '1100x',
                                            class: 'videoBackgroundFile tabbed-collage-video', 
                                            autoplay: true,
                                            loop: true,
                                            controls: false,
                                            muted: true
                                        }}
                                    </div>
                                  </template>
                                </deferred-media>
                              {% elsif block.settings.image != blank %}
                                <div
                                  class="media-box"
                                  style="--image-ratio:{{ 1 | divided_by : block.settings.image.aspect_ratio | times: 100 }}%"
                                >
                                  {%- render 'image', image: block.settings.image -%}
                                </div>
                              {% else %}
                                <div class="media-box" style="--image-ratio:50%">
                                  {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
                                </div>
                              {% endif %}
                            </div>
                          </div>
                          {% if block.settings.heading != blank or block.settings.description != blank or block.settings.btn_text != blank and block.settings.btn_url != blank %}
                          <div class="tabbed-content-block-item tabbed-content-block-right">
                            <div class="tabbed-content-media-block-content ">
                              {% if block.settings.heading != blank %}
                                <{{  block.settings.seo_heading }} class="tabbed-content-media-block-heading {{  block.settings.heading_size }}">{{ block.settings.heading }}</{{  block.settings.seo_heading }}>
                              {% endif %}
                              {% if block.settings.description != blank %}
                                <div class="tabbed-content-media-block-desc">{{ block.settings.description | newline_to_br }}</div>
                              {% endif %}
                              {% if block.settings.btn_text != blank and block.settings.btn_url != blank %}
                                <div class="tabbed-content-media-block-button">
                                  {% render 'button', button_link: block.settings.btn_url, button_size: block.settings.button_size, button_text: block.settings.btn_text %}
                                </div>
                              {% endif %}
                            </div>
                          </div>
                         {% endif %}
                  {% endcase %}
                </div>
              </div>
            </div>
          {% endfor %}
        </div>
      </div>
    {% endif %}
  </div>
</div>
<style>
  #shopify-section-{{ section.id }}.shopify-section {
    --top-spacer:{{ section.settings.top_space_desktop }}px;
    --bottom-spacer:{{ section.settings.bottom_space_desktop }}px;
    --active-tab-color:{{ section.settings.tab_highlight }};
    --highlight-text: {{ section.settings.highlighted_color }};
    {% if section.settings.make_section_rounded %}
      background:{{ section.settings.section_background }};
    {% endif %}
  }
  @media only screen and (max-width:767px) {
    #shopify-section-{{ section.id }}.shopify-section{
      --top-spacer:{{ section.settings.top_space_mobile }}px;
      --bottom-spacer:{{ section.settings.bottom_space_mobile }}px;
    }
  }
  {% if section.settings.section_visibility == 'large' %}
    @media (max-width: 767px) {
      #shopify-section-{{ section.id }}{
        display: none !important;
      } 
    }
  {% elsif section.settings.section_visibility == 'small' %}
    @media (min-width: 768px) {
      #shopify-section-{{ section.id }}{
        display: none !important;
      }
    }
  {% endif %}
</style>

