<link rel="preload" as="style" href="{{ 'collapsible-content.css' | asset_url }}">
<link rel="preload" as="style" href="{{ 'store-locator.css' | asset_url }}">
{{ 'collapsible-content.css' | asset_url | stylesheet_tag }}
{{ 'store-locator.css' | asset_url | stylesheet_tag }}
<div class="section-container {{ section.settings.color_scheme }}-scheme {% if section.settings.make_section_rounded %}section-rounded{% endif %}">
  <div class="{{ settings.container_width }}">
    {% if section.settings.heading != blank %}

      {%- capture sectionhighlightPrefix -%}
        <strong class="highlight-text">
      {%- endcapture -%}

      {%- capture sectionhighlightSuffix -%}
        </strong>
      {%- endcapture -%}

      <div class="section-heading-box {{ section.settings.heading_alignment }}" {% if settings.enable_animation %}data-aos="fade-up" data-aos-duration="1000"{% endif %}>
        <{{ section.settings.seo_heading }} class="section-heading {{ section.settings.heading_size }}">
          {{ section.settings.heading | replace: "<strong>", sectionhighlightPrefix | replace: "</strong>", sectionhighlightSuffix | replace: '++', '<br>' }}
        </{{ section.settings.seo_heading }}>
      </div>
    {% endif %}
    <div class="store-locator-box">
      <div class="store-locator-content-box">
        {% if section.blocks.size > 0 %}
          <div class="store-locator-content">
            {% assign firstBlock = false %}
            {% for block in section.blocks %}
              <div
                class="store-locator-content-item cursor-pointer{% if forloop.first %} active{% endif %}"
                data-store-details
                data-map="{{ block.settings.location }}"
                data-media="media-{{ block.id }}"
                {{ block.shopify_attributes }}
              >
                {% if block.settings.store_image != blank %}
                  <div class="store-locator-content-img">
                    <div class="media-box" style="--image-ratio:100%">
                      {%- render 'image', image: block.settings.store_image -%}
                    </div>
                  </div>
                {% endif %}
                <div class="store-locator-content-body">
                  <h6 class="store-locator-content-heading h5">
                    {% if block.settings.store_name != blank -%}
                      {{- block.settings.store_name -}}
                    {%- else %}
                      {{ 'store_locator.store_name' | t -}}
                    {%- endif %}
                  </h6>
                  <div class="store-locator-content-desc rte">
                    {{ block.settings.store_detail | replace: '<p></p>', '<br>' }}
                  </div>
                </div>
              </div>
              {% liquid
                if firstBlock == false
                  assign firstBlock = true
                endif
              %}
            {% endfor %}
          </div>
        {% endif %}
      </div>
      {% if section.blocks.size > 0 %}
        <div class="store-locator-image-box">
          {% assign firstBlock = false %}
          {% assign firstBlockContent = '' %}
          {% for block in section.blocks %}
            {% liquid
              if firstBlock == false
                assign firstBlock = true 
                assign firstBlockContent = block
              endif
            %}
            <div
              id="media-{{ block.id }}"
              class="store-locator-img{% if block.id == firstBlockContent.id %} active{% else %} hidden{% endif %}"
            >
              <div class="media-box media-box-fixed">
                {% if block.settings.loaction_image != blank %}
                  {%- render 'image', image: block.settings.loaction_image -%}
                {% else %}
                  {{ 'hero-apparel-3' | placeholder_svg_tag: 'placeholder-svg' }}
                {% endif %}
              </div>
            </div>
          {% endfor %}
          <div class="store-locator-map{% if firstBlockContent.settings.location == blank %} hidden{% endif %}">
            <div
              class="store-locator-map-content"
              data-location="{{ firstBlockContent.settings.location }}"
              data-map-style="roadmap"
              data-store-locator-map
             
                data-map-container
              
            ></div>
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</div>
<style>
  #shopify-section-{{ section.id }} {
    {% if section.settings.make_section_rounded %}
      background:{{ section.settings.section_background }};
    {% endif %}
  	--top-spacer:{{ section.settings.top_space_desktop }}px;
  	--bottom-spacer:{{ section.settings.bottom_space_desktop }}px;
  	--media-height:{{ section.settings.image_height }};
    --highlight-text: {{ section.settings.highlighted_color }};
  }
  @media (max-width:767px) {
  	#shopify-section-{{ section.id }}.shopify-section{
  		--top-spacer:{{ section.settings.top_space_mobile }}px;
  		--bottom-spacer:{{ section.settings.bottom_space_mobile }}px;
  		--media-height:{{ section.settings.mobile_image_height }};
  	}
  }
  {% if section.settings.section_visibility == 'large' %}
  	@media (max-width: 767px) {
  	  #shopify-section-{{ section.id }}{
  		display: none !important;
  	  }
  	}
    {% elsif section.settings.section_visibility == 'small' %}
  	@media (min-width: 768px) {
  	  #shopify-section-{{ section.id }}{
  		display: none !important;
  	  }
  	}
    {% endif %}
</style>
{% schema %}
{
  "name": "t:sections.store_locator.name",
  "class": "store-locator",
  "tag": "section",
  "disabled_on": {
    "groups": [
      "header",
      "footer"
    ]
  },
  "settings": [
    {
      "type": "select",
      "id": "section_visibility",
      "label": "t:global.common.section_visibility.label",
      "default": "always",
      "options": [
        {
          "label": "t:global.common.section_visibility.options.always",
          "value": "always"
        },
        {
          "label": "t:global.common.section_visibility.options.small",
          "value": "small"
        },
        {
          "label": "t:global.common.section_visibility.options.large",
          "value": "large"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "make_section_rounded",
      "label": "t:global.common.general_labels.make_section_rounded",
      "default": false
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "t:global.common.general_labels.heading",
      "info": "t:global.common.infos.heading.label",
      "default": "Store locator"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "t:global.common.general_labels.heading_size",
      "default": "h3",
      "options": [
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        },
        {
          "value": "h4",
          "label": "H4"
        },
        {
          "value": "h5",
          "label": "H5"
        },
        {
          "value": "h6",
          "label": "H6"
        }
      ]
    },
    {
      "type": "select",
      "id": "seo_heading",
      "default": "h3",
      "label": "t:global.common.general_labels.heading_tag",
      "info": "t:global.common.infos.seo_heading.label",
      "options": [
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        },
        {
          "value": "h4",
          "label": "H4"
        },
        {
          "value": "h5",
          "label": "H5"
        },
        {
          "value": "h6",
          "label": "H6"
        }
      ]
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "t:global.common.heading_alignment.label",
      "default": "text-left",
      "options": [
        {
          "value": "text-left",
          "label": "t:global.common.heading_alignment.options.left.label"
        },
        {
          "value": "text-center",
          "label": "t:global.common.heading_alignment.options.center.label"
        }
      ]
    },
    {
      "type": "header",
      "content": "t:sections.store_locator.settings.map.content"
    },
    {
      "type": "select",
      "id": "image_height",
      "label": "t:sections.store_locator.settings.image_height.label",
      "default": "400px",
      "options": [
        {
          "value": "400px",
          "label": "400px"
        },
        {
          "value": "500px",
          "label": "500px"
        },
        {
          "value": "600px",
          "label": "600px"
        }
      ]
    },
    {
      "type": "select",
      "id": "mobile_image_height",
      "label": "t:sections.store_locator.settings.mobile_image_height.label",
      "default": "300px",
      "options": [
        {
          "value": "200px",
          "label": "200px"
        },
        {
          "value": "300px",
          "label": "300px"
        },
        {
          "value": "400px",
          "label": "400px"
        }
      ]
    },
    {
      "type": "header",
      "content": "t:global.header.color_section.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "primary",
      "label": "t:global.header.color_scheme.label"
    },
    {
      "type": "color",
      "id": "section_background",
      "label": "t:global.common.section_background.label",
      "info": "t:global.common.section_background.info"
    },
    {
      "type": "color",
      "id": "highlighted_color",
      "default": "#EFF341",
      "label": "t:global.common.general_labels.highlight_color"
    },
    {
      "type": "header",
      "content": "t:global.header.space_section.label"
    },
    {
      "type": "range",
      "id": "top_space_desktop",
      "label": "t:global.top_space_desktop.label",
      "default": 60,
      "min": 0,
      "max": 100,
      "step": 5
    },
    {
      "type": "range",
      "id": "bottom_space_desktop",
      "label": "t:global.bottom_space_desktop.label",
      "default": 60,
      "min": 0,
      "max": 100,
      "step": 5
    },
    {
      "type": "range",
      "id": "top_space_mobile",
      "label": "t:global.top_space_mobile.label",
      "default": 35,
      "min": 0,
      "max": 100,
      "step": 5
    },
    {
      "type": "range",
      "id": "bottom_space_mobile",
      "label": "t:global.bottom_space_mobile.label",
      "default": 35,
      "min": 0,
      "max": 100,
      "step": 5
    }
  ],
  "blocks": [
    {
      "type": "store",
      "name": "t:sections.store_locator.blocks.store.name",
      "settings": [
        {
          "type": "text",
          "label": "t:sections.store_locator.blocks.store.settings.store_name.label",
          "id": "store_name"
        },
        {
          "type": "richtext",
          "label": "t:sections.store_locator.blocks.store.settings.store_detail.label",
          "id": "store_detail",
          "default": "<p>Add store details here</p>"
        },
        {
          "type": "image_picker",
          "label": "t:sections.store_locator.blocks.store.settings.store_image.label",
          "id": "store_image"
        },
        {
          "type": "text",
          "label": "t:sections.store_locator.blocks.store.settings.location.label",
          "id": "location",
          "info": "t:sections.store_locator.blocks.store.settings.location.info"
        },
        {
          "type": "image_picker",
          "label": "t:sections.store_locator.blocks.store.settings.loaction_image.label",
          "id": "loaction_image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.store_locator.presets.name",
      "blocks": [
        {
          "type": "store"
        },
        {
          "type": "store"
        },
        {
          "type": "store"
        }
      ]
    }
  ]
}
{% endschema %}
