<link rel="preload" as="style" href="{{ 'categories.css' | asset_url }}">
{{ 'categories.css' | asset_url | stylesheet_tag }}
<div class="section-container {{ section.settings.color_scheme }}-scheme {% if section.settings.make_section_rounded %}section-rounded{% endif %}">
    <div class="{{ settings.container_width }}">
        {% if section.settings.heading != blank %}
            {%- capture sectionhighlightPrefix -%}
              <strong class="highlight-text">
            {%- endcapture -%}
            {%- capture sectionhighlightSuffix -%}
              </strong>
            {%- endcapture -%}
            <div class="section-heading-box {{ section.settings.heading_alignment }}" {% if settings.enable_animation %}data-aos="fade-up" data-aos-duration="1000"{% endif %}>
              <{{ section.settings.seo_heading }} class="section-heading {{ section.settings.heading_size }}">
                {{ section.settings.heading | replace: "<strong>", sectionhighlightPrefix | replace: "</strong>", sectionhighlightSuffix | replace: '++', '<br>' }}
              </{{ section.settings.seo_heading }}>
            </div>
        {% endif %}
        <div class="categories-wrapper">
            <div class="categories-box-list {% if section.settings.enable_swipe_mobile %} mobile-swipe{% endif %} {{ section.settings.card_hover_style }}-hover">
              {%- for block in section.blocks -%}
                {% liquid
                  assign columnImageContent = ''
                  assign collection = block.settings.collection
      
                  if block.settings.image != blank
                    assign columnImageContent = block.settings.image
                  elsif collection.featured_image != blank
                    assign columnImageContent = collection.featured_image
                  endif
                  assign columnImageAlt = block.settings.heading | default: collection.title | default: shop.name
                -%}
              <{% if collection != blank  %}a href="{{ collection.url }}"{% else %}div{% endif %} class="categories-box-item {{ section.settings.column_style }}">
                    <div class="categories-box-image">
                      {%  if section.settings.card_hover_style == "rotate-border" %}
                        <span class="rotating-border"></span>
                      {% endif %}
                        <div class="media-box" style="--image-ratio:100%;">
                          {%- if columnImageContent != blank -%}
                            {%- render 'image', image: columnImageContent, image_alt: columnImageAlt -%}
                          {%- else -%}
                            {%- assign placeholder_image_index = forloop.index0 | modulo: 4 | plus: 1 -%}
                            {%- assign placeholder_image = 'collection-apparel-' | append: placeholder_image_index -%}
                            {{ placeholder_image | placeholder_svg_tag: 'placeholder-svg' }}
                          {%- endif -%}
                        </div>
                    </div>
                    <div class="categories-box-content">
                        <h6 class="categories-box-heading text-medium text-center">
                          {%- if block.settings.heading != blank -%}
                            {{ block.settings.heading -}}
                          {% elsif collection != blank %}
                            {{- collection.title | strip_html -}}
                          {%- else -%}
                            {{ 'sections.collection_carousel.collection' | t }}
                          {%- endif %}</h6>
                    </div>
                    {% comment %} {% if collection != blank  %}
                    <a href="{{ collection.url }}" aria-label="{{ collection.title }}" class="categories-box-link"></a>
                    {% endif %} {% endcomment %}
                <{% if collection != blank  %}/a{% else %}/div{% endif %}>
              {%- endfor -%}
            </div>
        </div>
    </div>
</div>
<style>
    #shopify-section-{{ section.id }}.shopify-section {
      --top-spacer:{{ section.settings.top_space_desktop }}px;
      --bottom-spacer:{{ section.settings.bottom_space_desktop }}px;
      --highlight-text: {{ section.settings.highlighted_color }};

      {% if section.settings.make_section_rounded %}
        background:{{ section.settings.section_background }};
      {% endif %}
    }
    @media only screen and (min-width:768px) {
      #shopify-section-{{ section.id }}.shopify-section{
        --columnCount: 4;
        --columnGap: {{ section.settings.desktop_column_gap }}px;
        --columnWidth: {{ section.settings.desktop_column_width }};
      }
    }
    @media only screen and (min-width:992px) {
      #shopify-section-{{ section.id }}.shopify-section{
        --columnCount: 8;
      }
    }
    @media only screen and (min-width:1200px) {
      #shopify-section-{{ section.id }}.shopify-section{
        --columnCount: {{ section.settings.desktop_column_count }};
      }
    }
    @media only screen and (max-width:767px) {
      #shopify-section-{{ section.id }}.shopify-section{
        --top-spacer:{{ section.settings.top_space_mobile }}px;
        --bottom-spacer:{{ section.settings.bottom_space_mobile }}px;
        --columnCount: {{ section.settings.mobile_column_count }};
        --columnGap: {{ section.settings.mobile_column_gap }}px;
        --columnWidth: {{ section.settings.mobile_column_width }};
      }
    }
    {% if section.settings.section_visibility == 'large' %}
      @media (max-width: 767px) {
        #shopify-section-{{ section.id }}{
          display: none !important;
        }
      }
    {% elsif section.settings.section_visibility == 'small' %}
      @media (min-width: 768px) {
        #shopify-section-{{ section.id }}{
          display: none !important;
        }
      }
    {% endif %}
  </style>
