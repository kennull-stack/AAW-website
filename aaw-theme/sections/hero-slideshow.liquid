{{ 'hero-slideshow.css' | asset_url | stylesheet_tag }}
<div class="section-container {{ section.settings.color_scheme }}-scheme {% if section.settings.enable_full_width == false  and section.settings.enable_compact_width == true %} compact-view {% endif %}">
    {% if section.settings.enable_full_width == false  and section.settings.enable_compact_width == false %}
        <div class="{{ settings.container_width }}">
    {% endif %}
   <div class="hero-slideshow-mainbox">
        <div class="hero-slideshow-outer hero-slideshow-outer-{{ section.id }} {% if section.settings.slider_transition == 'fade' %} slider-zoom-out {% endif %}"
            data-hero-section-id = "{{ section.id }}"
            data-slides-length="{{ section.blocks.size }}"
            data-sl-slider
            data-slick='{
              "slidesToShow": 1,
              "lazyLoad": "progressive",
              "fade":{% if section.settings.slider_transition == 'fade' %}true{% else %}false{% endif %},
              "cssEase": "ease-in-out",
              "infinite":true,
              "autoplay": {%- if section.settings.auto_rotate -%}true{%- else -%}false{%- endif -%},
              "autoplaySpeed": {{ section.settings.interval | times: 1000 }},
              {% if section.settings.navigation_type != 'none' %}
              "arrows": {% if section.settings.navigation_type == 'arrow' %}true{% else %}false{% endif %},
              "dots": {% if section.settings.navigation_type == 'dots' %}true{% else %}false{% endif %},
              {% endif %}
              "appendArrows": "#hero-slideshow-arrow-container-{{ section.id }}",
              "appendDots": "#hero-slideshow-arrow-container-{{ section.id }}"
              }'>
              {% for block in section.blocks %}
                {% capture slideImage %}
                    {% liquid
                    assign mobileImage = false
                
                    if block.settings.image_mobile != blank
                        assign mobileImage = true
                        assign mobileClass = 'mobile-img d-block d-md-none'
                        if forloop.first
                            assign height = block.settings.image_mobile.width | divided_by: block.settings.image_mobile.aspect_ratio | round
                            assign sizes = '100vw'
                            assign widths = '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
                            if section.index == 1
                                assign fetch_priority = 'high'
                            endif
                                echo block.settings.image_mobile | image_url: width: 3840 | image_tag: height: height,class: mobileClass, sizes: sizes, widths: widths, fetchpriority: fetch_priority
                        else                        
                            render 'image', image: block.settings.image_mobile, class: mobileClass
                        endif
                    endif
                    assign desktopClass = ''
                    if mobileImage
                        assign desktopClass = 'd-none d-md-block'
                    endif
                    if block.settings.image_desktop != blank
  
                        if forloop.first
                            assign height = block.settings.image_desktop.width | divided_by: block.settings.image_desktop.aspect_ratio | round
                            assign sizes = '100vw'
                            assign widths = '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
                        
                            if section.index == 1
                                assign fetch_priority = 'high'
                            endif
                            echo block.settings.image_desktop | image_url: width: 3840 | image_tag: height: height,class: desktopClass, sizes: sizes, widths: widths, fetchpriority: fetch_priority
                
                        else
                            render 'image', image: block.settings.image_desktop, class: desktopClass
                        endif
                    elsif block.settings.image_desktop == blank and mobileImage
                        assign placeholderClass = 'placeholder-svg d-none d-md-block'
                        echo   'hero-apparel-2' | placeholder_svg_tag: placeholderClass 
                    else
                        assign placeholderClass = 'placeholder-svg'
                        echo  'hero-apparel-1' | placeholder_svg_tag: placeholderClass
                    endif
                    %}
                {% endcapture %}
            <div class="hero-slideshow-item-wrapper">
              
                    <div
                        id="hero-slideshow_item_{{ block.id }}"
                        data-slide="{{ forloop.index0 }}"
                        data-id="hero-slideshow_item_{{ block.id }}"
                        class="hero-slideshow-item {{ block.settings.color_scheme }}-scheme  slideshow-item {% if section.settings.desktop_height == 'adapt_image' %} desktop-adapt-height {%- else -%} desktop-fixed-height {% endif %} {% if section.settings.mobile_height == 'adapt_image' %} mobile-adapt-height {%- else -%} mobile-fixed-height{% endif %}"
                        {{ block.shopify_attributes }}
                    >
                        <div class="hero-slideshow-media media-box">
                            {% if block.settings.slider_video != blank %}
                                <video id="slider_video-{{ block.id }}" class="videoBackgroundFile" data-autoplay="true" autoplay muted loop playsinline>
                                    <source
                                    src="{% if block.settings.slider_video.sources[0].url contains 'mp4' %}{{ block.settings.slider_video.sources[0].url -}}{% else %}{{ block.settings.slider_video.sources[1].url -}}  {% endif %}"
                                    type="video/mp4"
                                    >
                                </video>
                            {%- else -%}
                                {{ slideImage }}
                            {% endif %}
                        </div>
                        {% liquid
                            assign buttonWrapper = false
                            if block.settings.btn_text != blank and block.settings.btn_link != blank
                                assign buttonWrapper = true
                            endif
                        %}
                        {% if block.settings.heading != blank or block.settings.description != blank or buttonWrapper %}
                            <div class="hero-slideshow-content-wrapper container {% if section.settings.desktop_height == 'adapt_image' %} desktop-adapt-height {%- else -%} desktop-fixed-height {% endif %}{% if section.settings.mobile_height == 'adapt_image' %} mobile-adapt-height{%- else -%} mobile-fixed-height{% endif %}">
                                <div class="hero-slideshow-content">
                                    <div class="hero-slideshow-heading-wrapper">
                                        <div class="hero-slideshow-heading-outer">
                                            {% comment %} {% if block.settings.heading != blank %}                                             
                                               <h2 class="hero-slideshow-heading h2">URBAN SNEAKERS</h2>
                                            {% endif %} {% endcomment %}
                                            {% if block.settings.heading != blank %}
                                                {%- capture blockhighlightPrefix -%}
                                                    <strong class="highlight-text {% if block.settings.enable_highlight_background %}with-background{% endif %}">
                                                {%- endcapture -%}    
                                                <{{ block.settings.seo_heading }} class="hero-slideshow-heading {{ block.settings.heading_size }}">
                                                    <span class="text-reveal-content">
                                                    <span data-aos="hero" data-aos-order="2">
                                                      {%- assign block_heading = block.settings.heading | replace: '<strong> ', ' <strong>' | replace: ' </strong>', '</strong> ' %}
                                                      {{ block_heading | replace: "<strong>", blockhighlightPrefix | replace: '++', '<br>' }}
                                                    </span>
                                                    </span>
                                                </{{ block.settings.seo_heading }}>
                                            {% endif %}
                                            {% if block.settings.subheading != blank %}
                                              <p class="hero-slideshow-subheading text-large">{{ block.settings.subheading }}</p>
                                            {% endif %}
                                        </div>
                                        {% comment %} {% if forloop.first and section.blocks.size > 1 %}
                                          <div id="hero-slideshow-arrow-container-{{ section.id }}" class="hero-slideshow-arrow"></div>
                                        {% endif %} {% endcomment %}
                                         {% comment %}<div class="hero-slideshow-arrow">
                                            <button class="slide-arrow prev-arrow slick-arrow" aria-label="previous arrow" style="">
                                                <svg class="slide-arrow-icon1" width="13" height="13" viewBox="0 0 13 13" fill="none"><path fill-rule="evenodd" clip-rule="evenodd" d="M7 0L0.636039 6.36396L7 12.7279L8.17187 11.5561L3.80836 7.19255L12.5018 7.19253L12.5018 5.53528L3.80837 5.53531L8.17184 1.17184L7 0Z" fill="currentColor"></path></svg>
                                                <svg class="slide-arrow-icon2" width="13" height="13" viewBox="0 0 13 13" fill="none"><path fill-rule="evenodd" clip-rule="evenodd" d="M7 0L0.636039 6.36396L7 12.7279L8.17187 11.5561L3.80836 7.19255L12.5018 7.19253L12.5018 5.53528L3.80837 5.53531L8.17184 1.17184L7 0Z" fill="currentColor"></path></svg>
                                            </button>
                                            <button class="slide-arrow next-arrow slick-arrow" aria-label="next arrow" style="">
                                                <svg class="slide-arrow-icon1" width="13" height="13" viewBox="0 0 13 13" fill="none"><path fill-rule="evenodd" clip-rule="evenodd" d="M6 0L12.364 6.36396L6 12.7279L4.82813 11.5561L9.19164 7.19255L0.498208 7.19253L0.498198 5.53528L9.19163 5.53531L4.82816 1.17184L6 0Z" fill="currentColor"></path></svg>
                                                <svg class="slide-arrow-icon2" width="13" height="13" viewBox="0 0 13 13" fill="none"><path fill-rule="evenodd" clip-rule="evenodd" d="M6 0L12.364 6.36396L6 12.7279L4.82813 11.5561L9.19164 7.19255L0.498208 7.19253L0.498198 5.53528L9.19163 5.53531L4.82816 1.17184L6 0Z" fill="currentColor"></path></svg>
                                            </button> 
                                        </div>{% endcomment %}
                                    </div>
                                    <div class="hero-slideshow-desc-outer">
                                        {% if block.settings.description != blank %}<p>{{ block.settings.description }}</p>{% endif %}
                                        {% if buttonWrapper %}
                                            <div class="hero-slideshow-btn">
                                                {% render 'button', button_link: block.settings.btn_link, button_style: block.settings.button_syle, button_size: block.settings.button_size, button_text: block.settings.btn_text %}
                                                {% comment %} <a href="#" class="animate-button button  regular-btn">
                                                    <span>Shop Now</span>
                                                    <span class="animate-button-icon">
                                                    <svg width="17" height="17" viewBox="0 0 17 17" fill="none">
                                                    <path fill-rule="evenodd" clip-rule="evenodd" d="M8.38465 0.53125L16.2173 8.36382L8.38465 16.1964L6.94235 14.7541L12.3128 9.38362L-0.0534545 9.3836L-0.0534668 7.3439L12.3128 7.34394L6.94239 1.97351L8.38465 0.53125Z" fill="currentColor"></path>
                                                    </svg>
                                                    </span>
                                                </a> {% endcomment %}
                                            </div> 
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                        {% endif %}
            </div> 
            </div> 
          {% endfor %}    
        </div>
        {% if section.settings.navigation_type != 'none' %}
            <div id="hero-slideshow-arrow-container-{{ section.id }}" class="hero-slideshow-arrow"></div>
          {% endif %}
    {% if section.settings.enable_full_width == false  and section.settings.enable_compact_width == false %}
        </div>
    {% endif %}
</div>

<style>
    #shopify-section-{{ section.id }}.shopify-section{ 
        --top-spacer:{{ section.settings.top_space_desktop }}px;
        --bottom-spacer:{{ section.settings.bottom_space_desktop }}px;
    }
     
  @media screen and (min-width:768px) {
    #shopify-section-{{ section.id }} .hero-slideshow-outer{
      {% if section.settings.desktop_height == '100vh' and section.index == 1 %}
        --slideshow-height: var(--fullHeight,{{ section.settings.desktop_height }});
        {% else %}
        --slideshow-height: {{ section.settings.desktop_height }};
      {%  endif %}
      {% if section.blocks.first.settings.slider_video != blank %}
        --image-ratio: {{- 1 | divided_by : section.blocks.first.settings.slider_video.aspect_ratio | times: 100 -}}%;
      {% elsif section.blocks.first.settings.image_desktop != blank %}
        --image-ratio: {{- 1 | divided_by : section.blocks.first.settings.image_desktop.aspect_ratio | times: 100 -}}%;
      {%- else -%}
        --image-ratio: 50%;
      {% endif %}
    }
  }

  {% for block in section.blocks %}
    .hero-slideshow-item[data-id='hero-slideshow_item_{{ block.id }}']{
      --overlay-bg:{{ block.settings.overlay_color }};
      --overlay-opacity:{{ block.settings.overlay_opacity | divided_by: 100.0 }};
      --highlight-text: {{ block.settings.highlighted_color }};
      {% unless block.settings.highlighted_bg_color == 'rgba(0,0,0,0)' or block.settings.highlighted_bg_color == empty %}
      --highlight-background: {{ block.settings.highlighted_bg_color.red }},{{ block.settings.highlighted_bg_color.green }},{{ block.settings.highlighted_bg_color.blue }};
      --highlight-background-opacity: {{ block.settings.highlighted_bg_opacity | divided_by: 100.0 }};    
      {% else %}
      --highlight-background: 0,0,0;
      --highlight-background-opacity: 0;
      {% endunless %}
    }
  {% endfor %} 
  @media screen and (max-width:767px) {
    #shopify-section-{{ section.id }}.shopify-section{
      {% if section.settings.mobile_height == '100vh' and section.index == 1 %}
        --slideshow-height: var(--fullHeight,{{ section.settings.mobile_height }});
        {% else %}
      --slideshow-height: {{ section.settings.mobile_height }};
      {%  endif %}
      {% if section.blocks.first.settings.slider_video != blank %}
        --image-ratio {{- 1 | divided_by : section.blocks.first.settings.slider_video.aspect_ratio | times: 100 -}}%;
      {% elsif section.blocks.first.settings.image_mobile != blank %}
      --image-ratio: {{- 1 | divided_by : section.blocks.first.settings.image_mobile.aspect_ratio | times: 100 -}}%;
      {%- else -%}
      --image-ratio: 100%;
      {% endif %}   
    }
  }
  @media only screen and (max-width:767px) {
    #shopify-section-{{ section.id }}.shopify-section{
      --top-spacer:{{ section.settings.top_space_mobile }}px;
      --bottom-spacer:{{ section.settings.bottom_space_mobile }}px;
    }
  }
  {% if section.settings.section_visibility == 'large' %}
    @media (max-width: 767px) {
      #shopify-section-{{ section.id }}{
        display: none !important;
      }
    }
  {% elsif section.settings.section_visibility == 'small' %}
    @media (min-width: 768px) {
      #shopify-section-{{ section.id }}{
        display: none !important;
      }
    }
  {% endif %}
</style>

{% schema %}
    {
      "name": "t:sections.hero_slideshow.name",
      "tag": "section",
      "class": "hero-slideshow",
      "disabled_on": {
        "groups": [
          "header",
          "footer"
        ] 
      },
      "settings": [   
        {
            "type": "select",
            "id": "section_visibility",
            "label": "t:global.common.section_visibility.label",
            "default": "always",
            "options": [
                {
                "label": "t:global.common.section_visibility.options.always",
                "value": "always"
                },
                {
                "label": "t:global.common.section_visibility.options.small",
                "value": "small"
                },
                {
                "label": "t:global.common.section_visibility.options.large",
                "value": "large"
                }
            ]
        },
        {
            "type": "checkbox",
            "id": "enable_full_width",
            "label": "t:global.common.enable_full_width.label",
            "default": true
        },
        {
            "type": "checkbox",
            "id": "enable_compact_width",
            "label": "t:sections.slideshow.settings.enable_compact_width.label",
            "info": "t:sections.slideshow.settings.enable_compact_width.info",
            "default": false
        },
        {
            "type": "header",
            "content": "t:global.header.color_section.label"
        },
        {
            "type": "color_scheme",
            "id": "color_scheme",
            "default": "primary",
            "label": "t:global.header.color_scheme.label"
        },
        {
            "type": "select",
            "id": "desktop_height",
            "label": "t:sections.slideshow.settings.desktop_height.label",
            "default": "750px",
            "options": [
                {
                "value": "550px",
                "label": "550px"
                },
                {
                "value": "650px",
                "label": "650px"
                },
                {
                "value": "750px",
                "label": "750px"
                },
                {
                "value": "100vh",
                "label": "t:sections.slideshow.settings.desktop_height.options.fullscreen"
                },
                {
                "value": "adapt_image",
                "label": "t:sections.slideshow.settings.desktop_height.options.adapt_to_slide"
                }
            ]
            },
            {
            "type": "select",
            "id": "mobile_height",
            "label": "t:sections.slideshow.settings.mobile_height.label",
            "default": "450px",
            "options": [
                {
                "value": "450px",
                "label": "450px"
                },
                {
                "value": "550px",
                "label": "550px"
                },
                {
                "value": "650px",
                "label": "650px"
                },
                {
                "value": "100vh",
                "label": "t:sections.slideshow.settings.mobile_height.options.fullscreen"
                },
                {
                "value": "adapt_image",
                "label": "t:sections.slideshow.settings.mobile_height.options.adapt_to_slide"
                }
            ]
            },
            {
                "type": "checkbox",
                "id": "auto_rotate",
                "label": "t:sections.slideshow.settings.auto_rotate.label",
                "default": false
            },
            {
                "type": "range",
                "id": "interval",
                "min": 3,
                "max": 9,
                "step": 2,
                "unit": "s",
                "label": "t:sections.slideshow.settings.change_slides_speed.label",
                "default": 5
            },
            {
                "type": "select",
                "id": "slider_transition",
                "label": "t:sections.slideshow.settings.slider_transition.label",
                "default": "fade",
                "options": [
                    {
                    "value": "slide",
                    "label": "t:sections.slideshow.settings.slider_transition.options.slide"
                    },
                    {
                    "value": "fade",
                    "label": "t:sections.slideshow.settings.slider_transition.options.fade"
                    }
                ]
            },
            {
                "type": "select",
                "id": "navigation_type",
                "label": "t:sections.slideshow.settings.navigation_type.label",
                "default": "arrow",
                "options": [
                    {
                    "value": "arrow",
                    "label": "t:sections.slideshow.settings.navigation_type.options.arrow"
                    },
                    {
                    "value": "dots",
                    "label": "t:sections.slideshow.settings.navigation_type.options.dots"
                    },
                    {
                    "value": "none",
                    "label": "t:sections.slideshow.settings.navigation_type.options.none"
                    }
                ]
            },
            {
                "type": "header",
                "content": "t:global.header.space_section.label"
            },
            {
                "type": "range",
                "id": "top_space_desktop",
                "label": "t:global.top_space_desktop.label",
                "default": 0,
                "min": 0,
                "max": 100,
                "step": 5
            },
            {
                "type": "range",
                "id": "bottom_space_desktop",
                "label": "t:global.bottom_space_desktop.label",
                "default": 0,
                "min": 0,
                "max": 100,
                "step": 5
            },
            {
                "type": "range",
                "id": "top_space_mobile",
                "label": "t:global.top_space_mobile.label",
                "default": 0,
                "min": 0,
                "max": 100,
                "step": 5
            },
            {
                "type": "range",
                "id": "bottom_space_mobile",
                "label": "t:global.bottom_space_mobile.label",
                "default": 0,
                "min": 0,
                "max": 100,
                "step": 5
            }
       ],
       "blocks": [
    {
      "type": "slide",
      "name": "t:sections.slideshow.blocks.name.label",
      "settings": [
        {
          "type": "image_picker",
          "id": "image_desktop",
          "label": "t:sections.slideshow.blocks.settings.slide_image.desktop.label"
        },
        {
          "type": "image_picker",
          "id": "image_mobile",
          "label": "t:sections.slideshow.blocks.settings.slide_image.mobile.label"
        },
        {
          "type": "video",
          "id": "slider_video",
          "label": "t:sections.slideshow.blocks.settings.slide_video.label",
          "info": "t:sections.slideshow.blocks.settings.slide_video.info"
        },
        {
          "type": "header",
          "content": "t:global.header.text_section.label"
        },
        {
          "type": "inline_richtext",
          "id": "subheading",
          "label": "t:global.common.general_labels.subheading"
        },
        {
          "type": "inline_richtext",
          "id": "heading",
          "label": "t:global.common.general_labels.heading",
          "info": "t:global.common.infos.heading.label",
          "default": "Slide title"
        },
        {
          "type":"checkbox",
          "id":"enable_highlight_background",
          "label":"t:sections.slideshow.blocks.settings.enable_highlight_background.label",
          "default":false
        },
        {
          "type": "select",
          "id": "heading_size",
          "label": "t:global.common.general_labels.heading_size",
          "default": "h1",
          "options": [
            {
              "value": "h1",
              "label": "H1"
            },
            {
              "value": "h2",
              "label": "H2"
            },
            {
              "value": "h3",
              "label": "H3"
            },
            {
              "value": "h4",
              "label": "H4"
            },
            {
              "value": "h5",
              "label": "H5"
            },
            {
              "value": "h6",
              "label": "H6"
            }
          ]
        },
        {
          "type": "select",
          "id": "seo_heading",
          "label": "t:global.common.general_labels.heading_tag",
          "info": "t:global.common.infos.seo_heading.label",
          "default": "h1",
          "options": [
            {
              "value": "h1",
              "label": "H1"
            },
            {
              "value": "h2",
              "label": "H2"
            },
            {
              "value": "h3",
              "label": "H3"
            },
            {
              "value": "h4",
              "label": "H4"
            },
            {
              "value": "h5",
              "label": "H5"
            },
            {
              "value": "h6",
              "label": "H6"
            }
          ]
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "t:global.common.general_labels.description",
          "default": "Use this text to share information about your brand with your customers."
        },
        {
          "type": "header",
          "content": "t:global.header.button_section.label",
          "info": "t:sections.slideshow.blocks.settings.slide_button_info"
        },
        {
          "type": "paragraph",
          "content": "t:global.common.paragraph.primary"
        },
        {
          "type": "text",
          "id": "btn_text",
          "label": "t:global.common.general_labels.text",
          "default": "Button"
        },
        {
          "type": "url",
          "id": "btn_link",
          "label": "t:global.common.general_labels.link",
          "default": "/collections/all"
        },
        {
          "type": "select",
          "id": "button_syle",
          "label": "t:global.common.style.label",
          "default": "animate",
          "options": [
            {
              "value": "solid",
              "label": "t:global.common.style.value.solid"
            },
            {
              "value": "outline",
              "label": "t:global.common.style.value.outline"
            },
            {
              "value": "link",
              "label": "t:global.common.style.value.link"
            },
            {
              "value": "animate",
              "label":"t:global.common.style.value.animate"
            }
          ]
        },
        {
          "type": "select",
          "id": "button_size",
          "label": "t:global.common.size.label",
          "default": "regular",
          "options": [
            {
              "value": "regular",
              "label": "t:global.common.size.value.regular"
            },
            {
              "value": "small",
              "label": "t:global.common.size.value.small"
            },
            {
              "value": "medium",
              "label": "t:global.common.size.value.medium"
            },
            {
              "value": "large",
              "label": "t:global.common.size.value.large"
            }
          ]
        },    
        {
          "type": "header",
          "content": "t:global.header.color_section.label"
        },
        {
          "type": "color_scheme",
          "id": "color_scheme",
          "default": "primary",
          "label": "t:global.header.color_scheme.label"
        },
        {
          "type": "color",
