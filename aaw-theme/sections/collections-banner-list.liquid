<link rel="preload" as="style" href="{{ 'collections-banner-list.css' | asset_url }}">
{{ 'collections-banner-list.css' | asset_url | stylesheet_tag }}
{% if section.blocks.size>0 %}
  <div class="section-container {{ section.settings.color_scheme }}-scheme{% if section.settings.make_section_rounded %} section-rounded{% endif %}">
      <div class="collections-banner-list-wrapper">
        {% if section.blocks.size>0 %}
        <div class="collections-banner-list-images-wrapper">
          {% for block in section.blocks %}
            {% liquid
              assign imageContent = ''
              assign collection = block.settings.collection
              if block.settings.image != blank
                assign imageContent = block.settings.image
              elsif collection.featured_image != blank
                assign imageContent = collection.featured_image
              endif
            %}
              <div class="collections-banner-list-image{% if forloop.first %} active{% endif %}" data-bg-id="collections-banner-list-{{ block.id }}">
                <div class="media-box media-box-fixed"> 
                {% if imageContent != blank%}
                {%- render 'image', image: imageContent -%}
                {% else %}
                  {%- assign placeholder_image_index = forloop.index0 | modulo: 4 | plus: 1 -%}
                  {%- assign placeholder_image = 'collection-apparel-' | append: placeholder_image_index -%}
                  {{ placeholder_image | placeholder_svg_tag: 'placeholder-svg' }}
                {% endif %}
                </div>
              </div>
          {% endfor %}
        </div>
      {% endif %}
        {% if section.blocks.size>0 %}
        <collection-banner class="collections-banner-list-content-wrapper">
          {% for block in section.blocks %}
            {% assign collection = block.settings.collection %}
            <div id="collections-banner-list-{{ block.id }}" class="collections-banner-list-content-item{% if forloop.first %} active{% endif %}" data-coll-banner>

              {% liquid
                assign imageContents = ''
                assign collection = block.settings.collection
                if block.settings.image != blank
                  assign imageContents = block.settings.image
                elsif collection.featured_image != blank
                  assign imageContents = collection.featured_image
                endif
              %}

              <div class="collections-banner-list-image{% if forloop.first %} active{% endif %}" data-bg-id="collections-banner-list-{{ block.id }}">
                <div class="media-box media-box-fixed"> 
                {% if imageContents != blank%}
                {%- render 'image', image: imageContents -%}
                {% else %}
                  {%- assign placeholder_image_index = forloop.index0 | modulo: 4 | plus: 1 -%}
                  {%- assign placeholder_image = 'collection-apparel-' | append: placeholder_image_index -%}
                  {{ placeholder_image | placeholder_svg_tag: 'placeholder-svg' }}
                {% endif %}
                </div>
              </div>
              
              <div class="collections-banner-list-content-item-main">
                  <div class="collections-banner-list-content-item-inner">
                    <div class="collections-banner-list-content-head">
                      <{{ section.settings.seo_heading }} class="collections-banner-list-content-heading {{ section.settings.heading_size }}">
                        {% if block.settings.heading != blank %}
                          {{ block.settings.heading -}}
                        {% elsif collection != blank %}
                          {{- collection.title | strip_html -}}
                        {% else %}
                          {{ 'sections.collection_carousel.collection' | t }}
                        {% endif %}
                      </{{ section.settings.seo_heading }}>

                      {% if block.settings.description != blank %}
                        <p class="collections-banner-list-content-desc" data-coll-desc>{{ block.settings.description }}</p>
                      {% endif %}
                    </div>
                      {% if block.settings.btn_text != blank and  collection.url != blank %}
                      <div class="collections-banner-list-content-button" data-coll-button>
                        {% render 'button', button_link: collection.url , button_style: section.settings.button_style , button_size: section.settings.btn_size, button_text: block.settings.btn_text %}
                      </div>
                    {% endif %}
                  </div>
                </div>
            </div>
          {% endfor %}
        </collection-banner>
        {% endif %}
      </div>
  </div>
{% endif %}
<style>

  {% assign text_alignment = section.settings.content_alignment | split: '_' %}
  #shopify-section-{{ section.id }}.shopify-section {
    --top-spacer:{{ section.settings.top_space_desktop }}px;
    --bottom-spacer:{{ section.settings.bottom_space_desktop }}px;
    --column-count:{{ section.blocks.size }};
    --media-height:{{ section.settings.media_height }};
    --content-position: {{ section.settings.content_position }};
    --text-alignment1: {{ text_alignment[0] }};
    --text-alignment2: {{ text_alignment[1] }};
    --overlay-background:{{ section.settings.overlay_background.red }},{{ section.settings.overlay_background.green }},{{ section.settings.overlay_background.blue }};
    --overlay-opacity:{{ section.settings.overlay_opacity | divided_by: 100.0 }};
    {% if section.settings.make_section_rounded %}
      background:{{ section.settings.section_background }};
    {% endif %}
  }
  @media only screen and (max-width:1024px){
    #shopify-section-{{ section.id }}.shopify-section {
      --media-height:{{ section.settings.mobile_height }};
    }
  }
  @media only screen and (max-width:767px) {
    #shopify-section-{{ section.id }}.shopify-section{
      --top-spacer:{{ section.settings.top_space_mobile }}px;
      --bottom-spacer:{{ section.settings.bottom_space_mobile }}px;
    }
  }


  {% if section.settings.section_visibility == 'large' %}
    @media (max-width: 767px) {
      #shopify-section-{{ section.id }}{
        display: none !important;
      }
    }
  {% elsif section.settings.section_visibility == 'small' %}
    @media (min-width: 768px) {
      #shopify-section-{{ section.id }}{
        display: none !important;
      }
    }
  {% endif %}
</style>

