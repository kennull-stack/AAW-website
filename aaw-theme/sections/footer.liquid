          "label": "t:sections.footer.blocks.text.settings.image.label"
        },
        {
          "type": "url",
          "id": "image_url",
          "label": "t:sections.footer.blocks.text.settings.image_url.label"
        },
        {
          "type": "richtext",
          "id": "description",
          "default": "<p>Share  your store specific description over here.</p>",
          "label": "t:sections.footer.blocks.text.settings.description.label"
        },
        {
          "type": "checkbox",
          "id": "show_social",
          "default": true,
          "label": "t:sections.footer.blocks.text.settings.show_social.label"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "newsletter"
      },
      {
        "type": "link_list"
      },
      {
        "type": "link_list"
      },
      {
        "type": "link_list"
      },
      {
        "type": "link_list"
      }
    ]
  }
}
{% endschema %}
