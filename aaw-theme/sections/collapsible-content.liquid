<link rel="preload" as="style" href="{{ 'collapsible-content.css' | asset_url }}">
{{ 'collapsible-content.css' | asset_url | stylesheet_tag }}
<div class="section-container {{ section.settings.color_scheme }}-scheme {% if section.settings.make_section_rounded %}section-rounded{% endif %}">
  <div class="container-sm">
    {% if section.settings.heading != blank %}

    {%- capture sectionhighlightPrefix -%}
    <strong class="highlight-text">
    {%- endcapture -%}

    {%- capture sectionhighlightSuffix -%}
    </strong>
    {%- endcapture -%}


      <div class="section-heading-box {{ section.settings.heading_alignment }}" {% if settings.enable_animation %}data-aos="fade-up" data-aos-duration="1000"{% endif %}>
        <{{ section.settings.seo_heading }} class="section-heading {{ section.settings.heading_size }}">
          {{ section.settings.heading | replace: "<strong>", sectionhighlightPrefix | replace: "</strong>", sectionhighlightSuffix | replace: '++', '<br>' }}
        </{{ section.settings.seo_heading }}>
      </div>
    {% endif %}
    {%- if section.blocks.size > 0 -%}
      <div class="accordion-wrapper details-box-outer">
        {% for block in section.blocks %}
          {% if block.settings.heading != blank %}
            {% comment %} fullwidth-content class add below for full width  {% endcomment %}
            <details
              class="accordion-item"
              {% if section.settings.show_first_default and forloop.first %}
                open
              {% endif %}
              data-detail-button
              {{ block.shopify_attributes }}
            >
              <summary class="accordion-heading detail-summary focus-inside">
                <h5 class="accordion-heading-text">{{ block.settings.heading }}</h5>
                <span class="accordion-icon">
                  <svg width="16" height="15" viewBox="0 0 16 15" fill="none">
                    <path fill-rule="evenodd" clip-rule="evenodd" d="M7.99219 0L15.0633 7.07107L7.99219 14.1421L6.69011 12.8401L11.5384 7.99173L1.87908 7.9917L1.87907 6.15032L11.5384 6.15035L6.69014 1.30205L7.99219 0Z" fill="currentColor"/>
                  </svg>
                </span>
              </summary>
              <div class="accordion-content" detail-expand>
                <div class="accordion-content-body rte">
                  {{
                    block.settings.content
                    | replace: '<p></p>', '<br>'
                    | replace: '<h1></h1>', '<br>'
                    | replace: '<h2></h2>', '<br>'
                    | replace: '<h3></h3>', '<br>'
                    | replace: '<h4></h4>', '<br>'
                    | replace: '<h5></h5>', '<br>'
                    | replace: '<h6></h6>', '<br>'
                  }}
                </div>
              </div>
            </details>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}
  </div>
</div>
<style>
  #shopify-section-{{ section.id }} {
    --top-spacer:{{ section.settings.top_space_desktop }}px;
    --bottom-spacer:{{ section.settings.bottom_space_desktop }}px;
    --highlight-text: {{ section.settings.highlighted_color }};
    {% if section.settings.make_section_rounded %}
      background:{{ section.settings.section_background }};
    {% endif %}
  }
  @media only screen and (max-width:767px) {
      #shopify-section-{{ section.id }}{
        --top-spacer:{{ section.settings.top_space_mobile }}px;
        --bottom-spacer:{{ section.settings.bottom_space_mobile }}px;
      }
  }
  {% if section.settings.section_visibility == 'large' %}
    @media (max-width: 767px) {
      #shopify-section-{{ section.id }}{
        display: none !important;
      }
    }
  {% elsif section.settings.section_visibility == 'small' %}
    @media (min-width: 768px) {
      #shopify-section-{{ section.id }}{
        display: none !important;
      }
    }
  {% endif %}
</style>
{% schema %}
{
  "name": "t:sections.collapsible-content.name",
  "tag": "section",
  "class": "collapsible-content",
  "disabled_on": {
    "groups": [
      "header"
    ]
  },
  "settings": [
    {
      "type": "select",
      "id": "section_visibility",
      "label": "t:global.common.section_visibility.label",
      "default": "always",
      "options": [
        {
          "label": "t:global.common.section_visibility.options.always",
          "value": "always"
        },
        {
          "label": "t:global.common.section_visibility.options.small",
          "value": "small"
        },
        {
          "label": "t:global.common.section_visibility.options.large",
          "value": "large"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "make_section_rounded",
      "label": "t:global.common.general_labels.make_section_rounded",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_first_default",
      "label": "t:sections.collapsible-content.settings.show_first_default.label",
      "default": true
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "Collapsible content",
      "label": "t:sections.collapsible-content.settings.inline_richtext.label",
      "info": "t:global.common.infos.heading.label"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "t:global.common.general_labels.heading_size",
      "default": "h3",
      "options": [
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        },
        {
          "value": "h4",
          "label": "H4"
        },
        {
          "value": "h5",
          "label": "H5"
        },
        {
          "value": "h6",
          "label": "H6"
        }
      ]
    },
    {
      "type": "select",
      "id": "seo_heading",
      "label": "t:global.common.general_labels.heading_tag",
      "default": "h3",
      "info": "t:global.common.infos.seo_heading.label",
      "options": [
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        },
        {
          "value": "h4",
          "label": "H4"
        },
        {
          "value": "h5",
          "label": "H5"
        },
        {
          "value": "h6",
          "label": "H6"
        }
      ]
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "t:global.common.heading_alignment.label",
      "default": "text-center",
      "options": [
        {
          "label": "t:global.common.heading_alignment.options.left.label",
          "value": "text-left"
        },
        {
          "label": "t:global.common.heading_alignment.options.center.label",
          "value": "text-center"
        }
      ]
    },
    {
      "type": "header",
      "content": "t:global.header.color_section.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "primary",
      "label": "t:global.header.color_scheme.label"
    },
    {
      "type": "color",
      "id": "highlighted_color",
      "default": "#EFF341",
      "label": "t:global.common.general_labels.highlight_color"
    },
    {
      "type": "color",
      "id": "section_background",
      "label": "t:global.common.section_background.label",
      "info": "t:global.common.section_background.info"
    },
    {
      "type": "header",
      "content": "t:global.header.space_section.label"
    },
    {
      "type": "range",
      "id": "top_space_desktop",
      "label": "t:global.top_space_desktop.label",
      "default": 40,
      "min": 0,
      "max": 100,
      "step": 5
    },
    {
      "type": "range",
      "id": "bottom_space_desktop",
      "label": "t:global.bottom_space_desktop.label",
      "default": 40,
      "min": 0,
      "max": 100,
      "step": 5
    },
    {
      "type": "range",
      "id": "top_space_mobile",
      "label": "t:global.top_space_mobile.label",
      "default": 35,
      "min": 0,
      "max": 100,
      "step": 5
    },
    {
      "type": "range",
      "id": "bottom_space_mobile",
      "label": "t:global.bottom_space_mobile.label",
      "default": 35,
      "min": 0,
      "max": 100,
      "step": 5
    }
  ],
  "blocks": [
    {
      "type": "content",
      "name": "t:sections.collapsible-content.blocks.name",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "default": "Frequently asked question",
          "label": "t:global.common.general_labels.heading"
        },
        {
          "type": "richtext",
          "id": "content",
          "default": "<p>Use this text to answer questions in as much detail as possible for your customers.</p>",
          "label": "t:global.common.general_labels.description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.collapsible-content.presets.name",
      "blocks": [
        {
          "type": "content"
        },
        {
          "type": "content"
        },
        {
          "type": "content"
        },
        {
          "type": "content"
        },
        {
          "type": "content"
        }
      ]
    }
  ]
}
{% endschema %}


