<link rel="preload" as="style" href="{{ 'before-after-image.css' | asset_url }}">
{{ 'before-after-image.css' | asset_url | stylesheet_tag }}
<div class="section-container {{ section.settings.color_scheme }}-scheme {% if section.settings.make_section_rounded %}section-rounded{% endif %}" >
  <div class="{{ settings.container_width }}">
    {% if section.settings.heading != blank %}
        {%- capture sectionhighlightPrefix -%}
            <strong class="highlight-text">
        {%- endcapture -%}

        {%- capture sectionhighlightSuffix -%}
            </strong>
        {%- endcapture -%}


      <div class="section-heading-box {{ section.settings.heading_alignment }}" {% if settings.enable_animation %}data-aos="fade-up" data-aos-duration="1000"{% endif %}>
        <{{ section.settings.seo_heading }} class="section-heading {{ section.settings.heading_size }}">
          {{ section.settings.heading | replace: "<strong>", sectionhighlightPrefix | replace: "</strong>", sectionhighlightSuffix | replace: '++', '<br>' }}
        </{{ section.settings.seo_heading }}>
      </div>
    {% endif %}
    {% if section.blocks.size > 0 %}
      <div class="image-comparison-wrapper{% if section.settings.desktop_height != "adapt_to_first" %} desktop-media-fixed{% else %} desktop-media-adapt{% endif %} {% if section.settings.mobile_height == "adapt_to_first" %} mobile-media-adapt{% else %} mobile-media-fixed{% endif %}" data-layout="horizontal">
          {% for block in section.blocks %}
            <div class="{% if forloop.first %}image-comparison-main{% else %}image-comparison-overlay{% endif %}">
              {% if block.settings.text %}
                <h6 class="image-comparison-label position-{{ block.settings.text_position }}">
                  {{ block.settings.text }}
                </h6>
              {% endif %}            
              {%- if block.settings.image != blank -%}
                <div class="media-box">
                  {%- render 'image', image: block.settings.image -%}
                </div>
              {%- else -%}
              <div class="media-box">
                {{ 'hero-apparel-' | append: forloop.index | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
              {%- endif %}
            </div>
        {% endfor %}
        <div class="image-comparison-button" data-image-comparison-button>
          <span class="image-comparison-button-cursor">
            <svg viewBox="0 0 12 17" stroke="currentColor" fill="none" xmlns="
              http://www.w3.org/2000/svg"
              >
              <path stroke-linecap="round" stroke-width="1.5" d="M1 1L0.999999 16"></path>
              <path stroke-linecap="round" stroke-width="1.5" d="M6 1L6 16"></path>
              <path stroke-linecap="round" stroke-width="1.5" d="M11 1L11 16"></path>
              </svg>
          </span>
        </div>
      </div>
    {% endif %}
  </div>
</div>
<style>
  .image-comparison-wrapper{
    overflow: hidden;
  }
    #shopify-section-{{ section.id }} {
      --top-spacer:{{ section.settings.top_space_desktop }}px;
      --bottom-spacer:{{ section.settings.bottom_space_desktop }}px;
      --image-clip-position: 0px;
        overflow: hidden;
        {% if section.blocks.first.settings.image != blank and section.settings.desktop_height == 'adapt_to_first' %}
        --image-ratio: {{- 1 | divided_by: section.blocks.first.settings.image.aspect_ratio  | times: 100 | plus: 1 -}}%;
    
        {%- elsif section.blocks.first.settings.image == blank and section.settings.desktop_height == 'adapt_to_first' -%}
        --image-ratio: 50%;
        {% endif %}
       --media-height:{{ section.settings.desktop_height }};
       --highlight-text: {{ section.settings.highlighted_color }};

       {% if section.settings.make_section_rounded %}
        background:{{ section.settings.section_background }};
      {% endif %}
    }
    
    @media only screen and (max-width:767px) {
        #shopify-section-{{ section.id }}{
          --top-spacer:{{ section.settings.top_space_mobile }}px !important;
          --bottom-spacer:{{ section.settings.bottom_space_mobile }}px !important;
          {% if section.blocks.first.settings.image != blank and section.settings.mobile_height == 'adapt_to_first' %}
            --image-ratio: {{-  1 | divided_by: section.blocks.first.settings.image.aspect_ratio  | times: 100 | plus: 1 -}}%;

            {%- elsif section.blocks.first.settings.image == blank and section.settings.mobile_height == 'adapt_to_first' -%}
            --image-ratio: 50%;
            {% endif %}
            --media-height:{{ section.settings.mobile_height }};
        }
    }
    {% if section.settings.section_visibility == 'large' %}
      @media (max-width: 767px) {
        #shopify-section-{{ section.id }}{
          display: none !important;
        }
      }
    {% elsif section.settings.section_visibility == 'small' %}
      @media (min-width: 768px) {
        #shopify-section-{{ section.id }}{
          display: none !important;
        }
      }
  {% endif %}
</style>
{% schema %}
{
  "name": "t:sections.before-after-image.name",
  "tag": "section",
  "class": "before-after",
  "max_blocks": 2,
  "disabled_on": {
    "groups": [
      "header",
      "footer"
    ]
  },
  "settings": [
    {
      "type": "select",
      "id": "section_visibility",
      "label": "t:global.common.section_visibility.label",
      "default": "always",
      "options": [
        {
          "label": "t:global.common.section_visibility.options.always",
          "value": "always"
        },
        {
          "label": "t:global.common.section_visibility.options.small",
          "value": "small"
        },
        {
          "label": "t:global.common.section_visibility.options.large",
          "value": "large"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "make_section_rounded",
      "label": "t:global.common.general_labels.make_section_rounded",
      "default": false
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "t:global.header.heading_section.label",
      "default": "Before/After",
      "info": "t:global.common.infos.heading.label"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "t:global.common.general_labels.heading_size",
      "default": "h3",
      "options": [
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        },
        {
          "value": "h4",
          "label": "H4"
        },
        {
          "value": "h5",
          "label": "H5"
        },
        {
          "value": "h6",
          "label": "H6"
        }
      ]
    },
    {
      "type": "select",
      "id": "seo_heading",
      "label": "t:global.common.general_labels.heading_tag",
      "default": "h3",
      "info": "t:global.common.infos.seo_heading.label",
      "options": [
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        },
        {
          "value": "h4",
          "label": "H4"
        },
        {
          "value": "h5",
          "label": "H5"
        },
        {
          "value": "h6",
          "label": "H6"
        }
      ]
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "t:global.common.heading_alignment.label",
      "default": "text-center",
      "options": [
        {
          "value": "text-left",
          "label": "t:global.common.heading_alignment.options.left.label"
        },
        {
          "value": "text-center",
          "label": "t:global.common.heading_alignment.options.center.label"
        }
      ]
    },
    {
      "type": "select",
      "id": "desktop_height",
      "label": "t:global.common.desktop_height.label",
      "default": "600px",
      "options": [
        {
          "value": "500px",
          "label": "500px"
        },
        {
          "value": "600px",
          "label": "600px"
        },
        {
          "value": "700px",
          "label": "700px"
        },
        {
          "value": "adapt_to_first",
          "label": "t:global.common.adapt_to_first.label"
        }
      ]
    },
    {
      "type": "select",
      "id": "mobile_height",
      "label": "t:global.common.mobile_height.label",
      "default": "400px",
      "options": [
        {
          "value": "300px",
          "label": "300px"
        },
        {
          "value": "400px",
          "label": "400px"
        },
        {
          "value": "500px",
          "label": "500px"
        },
        {
          "value": "adapt_to_first",
          "label": "t:global.common.adapt_to_first.label"
        }
      ]
    },
    {
      "type": "header",
      "content": "t:global.header.color_section.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "primary",
      "label": "t:global.header.color_scheme.label"
    },
    {
      "type": "color",
      "id": "highlighted_color",
      "default": "#EFF341",
      "label": "t:global.common.general_labels.highlight_color"
    },
    {
      "type": "color",
      "id": "section_background",
      "label": "t:global.common.section_background.label",
      "info": "t:global.common.section_background.info"
    },
    {
      "type": "header",
      "content": "t:global.header.space_section.label"
    },
    {
      "type": "range",
      "id": "top_space_desktop",
      "label": "t:global.top_space_desktop.label",
      "default": 40,
      "min": 0,
      "max": 100,
      "step": 5
    },
    {
      "type": "range",
      "id": "bottom_space_desktop",
      "label": "t:global.bottom_space_desktop.label",
      "default": 40,
      "min": 0,
      "max": 100,
      "step": 5
    },
    {
      "type": "range",
      "id": "top_space_mobile",
      "label": "t:global.top_space_mobile.label",
      "default": 35,
      "min": 0,
      "max": 100,
      "step": 5
    },
    {
      "type": "range",
      "id": "bottom_space_mobile",
      "label": "t:global.bottom_space_mobile.label",
      "default": 35,
      "min": 0,
      "max": 100,
      "step": 5
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:global.common.general_labels.image"
        },
        {
          "type": "text",
          "id": "text",
          "label": "t:global.common.general_labels.text",
          "default": "Heading"
        },
        {
          "type": "select",
          "id": "text_position",
          "label": "t:global.common.content_position.label",
          "options": [
            {
              "value": "start",
              "label": "t:global.common.content_position.options.start.label"
            },
            {
              "value": "center",
              "label": "t:global.common.content_position.options.center.label"
            },
            {
              "value": "end",
              "label": "t:global.common.content_position.options.end.label"
            }
          ],
          "default": "center"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.before-after-image.presets.name",
      "blocks": [
        {
          "type": "image"
        },
        {
          "type": "image"
        }
      ]
    }
  ]
}
{% endschema %}
