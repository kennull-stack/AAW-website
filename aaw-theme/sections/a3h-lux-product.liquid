{{ 'black-malus-product.css' | asset_url | stylesheet_tag }}
{{ 'a3h-lux-product.css' | asset_url | stylesheet_tag }}

{% if section.settings.section_visibility == 'large' %}
  <style>
    @media (max-width: 767px) {
      #shopify-section-{{ section.id }} {
        display: none !important;
      }
    }
  </style>
{% elsif section.settings.section_visibility == 'small' %}
  <style>
    @media (min-width: 768px) {
      #shopify-section-{{ section.id }} {
        display: none !important;
      }
    }
  </style>
{% endif %}

{% assign current_variant = product.selected_or_first_available_variant %}
{% assign product_price = current_variant.price | money %}
{% assign jm_badge = product.metafields.judgeme.badge | default: '' %}
{% assign jm_widget = product.metafields.judgeme.widget | default: '' %}

<script type="application/ld+json">
{
  "@context": "https://schema.org/",
  "@type": "Product",
  "@id": {{ canonical_url | append: "#product" | json }},
  "name": "AAW A3H+ Lux Edition In-Ear Monitor",
  "image": [
    {{ 'a3h-lux-hero.jpg' | asset_url | prepend: 'https:' | json }},
    {{ 'a3h-lux-closeup.jpg' | asset_url | prepend: 'https:' | json }},
    {{ 'a3h-lux-cable-wide.jpg' | asset_url | prepend: 'https:' | json }}
  ],
  "description": "A3H+ Lux Edition is a three-driver hybrid in-ear monitor from Singapore-based Advanced AcousticWerkes. NOVA open-vented armature, precision balanced armature, 10mm graphene dynamic woofer, 3-way crossover, four-position tuning switch. Universal and custom fit.",
  "sku": {{ current_variant.sku | default: "A3H-LUX" | json }},
  "mpn": "A3H+ Lux",
  "brand": {"@id": "https://www.aaw.me/#organization"},
  "designer": {
    "@type": "Person",
    "name": "Kevin Wang",
    "jobTitle": "Founder & Tuning Engineer",
    "description": "Founder and tuning engineer of Advanced AcousticWerkes, responsible for the acoustic design and tuning of AAW in-ear monitors.",
    "knowsAbout": ["in-ear monitor tuning", "hybrid IEM design", "balanced armature drivers", "dynamic driver integration", "graphene diaphragm design", "custom in-ear monitors", "universal in-ear monitors"],
    "worksFor": {"@id": "https://www.aaw.me/#organization"}
  },
  "category": "Universal In-Ear Monitor",
  "offers": {
    "@type": "Offer",
    "url": {{ canonical_url | json }},
    "priceCurrency": {{ cart.currency.iso_code | default: shop.currency | json }},
    "price": {{ current_variant.price | money_without_currency | remove: ',' | json }},
    "availability": "https://schema.org/{% if current_variant.available %}InStock{% else %}OutOfStock{% endif %}",
    "itemCondition": "https://schema.org/NewCondition",
    "seller": {"@id": "https://www.aaw.me/#organization"},
    "hasMerchantReturnPolicy": {
      "@type": "MerchantReturnPolicy",
      "url": "https://www.aaw.me/pages/shipping-return",
      "applicableCountry": "SG",
      "returnPolicyCategory": "https://schema.org/MerchantReturnFiniteReturnWindow",
      "merchantReturnDays": 7,
      "returnMethod": "https://schema.org/ReturnByMail",
      "returnFees": "https://schema.org/ReturnShippingFees"
    }
  },
  "additionalProperty": [
    {"@type": "PropertyValue", "name": "Driver Configuration", "value": "3-driver hybrid: NOVA open-vented armature, precision balanced armature, 10mm graphene diaphragm woofer"},
    {"@type": "PropertyValue", "name": "NOVA Driver", "value": "Nozzle-less open-vented armature for reduced pressure decay"},
    {"@type": "PropertyValue", "name": "Crossover", "value": "3-way passive and acoustic crossover"},
    {"@type": "PropertyValue", "name": "Sound Tuning", "value": "4-step adjustable sound signature"},
    {"@type": "PropertyValue", "name": "Sensitivity", "value": "105dB"},
    {"@type": "PropertyValue", "name": "Impedance", "value": "12 Ohm"},
    {"@type": "PropertyValue", "name": "Frequency Response", "value": "10Hz to 40kHz"},
    {"@type": "PropertyValue", "name": "Total Harmonic Distortion", "value": "\u22640.5%"},
    {"@type": "PropertyValue", "name": "Enclosure", "value": "Precision CNC aluminium"},
    {"@type": "PropertyValue", "name": "Fit Options", "value": "Universal fit and custom fit"},
    {"@type": "PropertyValue", "name": "Warranty", "value": "1-year limited warranty"}
  ]
}
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the A3H+ Lux driver configuration?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Three-driver hybrid. One NOVA open-vented armature for vocals and treble. One precision balanced armature for upper mids. One 10mm graphene dynamic woofer for bass."
      }
    },
    {
      "@type": "Question",
      "name": "What does the tuning switch do?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Four positions: Vocal, Normal, Vocal+, Bass. The switch changes the crossover load between the woofer and armature paths — across genres, stage use, and everyday listening. No cables to swap, no EQ to set."
      }
    },
    {
      "@type": "Question",
      "name": "Is A3H+ Lux available as universal and custom fit?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Universal-fit units ship with LiquidMorph tips. Custom-fit units are built from ear impressions. Both use the same three-driver hybrid platform."
      }
    },
    {
      "@type": "Question",
      "name": "Who is A3H+ Lux for?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Working musicians, worship bands, emerging artists, and listeners who want a hybrid IEM with switchable voicing at a practical price. The four tuning modes cover stage monitoring and daily listening."
      }
    },
    {
      "@type": "Question",
      "name": "What comes in the box?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "48 inch Null Audio Epsilon UPOCC copper detachable cable, AAW carry case, LiquidMorph tips, AAW foam tips, assorted silicone tips. One-year limited warranty."
      }
    }
  ]
}
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.aaw.me/"},
    {"@type": "ListItem", "position": 2, "name": "Universal IEM", "item": "https://www.aaw.me/collections/universal-in-ear"},
    {"@type": "ListItem", "position": 3, "name": "A3H+ Lux"}
  ]
}
</script>

<div class="bm-product a3h-product">
  <nav class="bm-topbar bm-wrap" aria-label="Breadcrumb">
    <a href="/">Home</a>
    <span aria-hidden="true">/</span>
    <a href="/collections/universal-in-ear">Universal In-Ear</a>
    <span aria-hidden="true">/</span>
    <span aria-current="page">A3H+ Lux</span>
  </nav>

  <aside class="bm-floating-buy" aria-label="A3H+ Lux price and purchase">
    <span class="bm-floating-buy__label">A3H+ Lux</span>
    <strong>{{ product_price }}</strong>
    {% if current_variant.available %}
      <a href="/cart/add?id={{ current_variant.id }}&quantity=1">Buy</a>
    {% else %}
      <span class="a3h-review-count">Sold out</span>
    {% endif %}
  </aside>

  <section class="bm-hero bm-wrap" aria-labelledby="a3h-title">
    <div class="bm-hero__copy">
      <p class="bm-kicker">Triple-driver hybrid in-ear monitor</p>
      <h1 id="a3h-title">A3H+ Lux</h1>
      <p class="bm-hero__lead">Three-driver hybrid with a 10mm graphene dynamic woofer, AAW&rsquo;s NOVA open-vented armature, and a precision balanced armature. Four tuning positions on the shell. Universal or custom fit.</p>
      <p class="bm-price"><span>Price</span><strong>{{ product_price }}</strong></p>
      <div class="bm-judge-stars" aria-label="A3H+ Lux customer rating">
        <div class="jdgm-widget jdgm-preview-badge" data-id="{{ product.id }}" data-auto-install="false">
          {{ jm_badge }}
        </div>
        {% if jm_badge == blank or jm_badge contains 'No reviews' %}
          <span class="bm-rating-fallback" aria-label="Customer review archive">
            <span aria-hidden="true">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
            <span>57-review archive</span>
          </span>
        {% endif %}
      </div>
      <ul class="bm-pill-list" aria-label="A3H+ Lux highlights">
        <li>3-driver hybrid</li>
        <li>NOVA driver</li>
        <li>4-step tuning</li>
        <li>Universal/custom</li>
      </ul>
      <form class="bm-actions" method="post" action="/cart/add" enctype="multipart/form-data">
        <input type="hidden" name="id" value="{{ current_variant.id }}">
        <input type="hidden" name="quantity" value="1">
        <button class="bm-btn" type="submit"{% unless current_variant.available %} disabled{% endunless %}>{% if current_variant.available %}Buy A3H+ Lux{% else %}Sold Out{% endif %}</button>
        <a class="bm-btn bm-btn--ghost" href="#a3h-nova">Explore the build</a>
      </form>
    </div>
    <figure class="bm-hero__media">
      {% render 'aaw-responsive-asset-image', file: 'a3h-lux-hero.jpg', alt: 'A3H+ Lux silver universal in-ear monitors with detachable black cable and faceplates', width: '2000', height: '1334', loading: 'eager', sizes: '100vw' %}
    </figure>
  </section>

  <section class="bm-stat-band" aria-label="A3H+ Lux specification highlights">
    <div class="bm-wrap bm-stats">
      <article><b>3</b><span>Hybrid drivers. Universal or custom fit.</span></article>
      <article><b>4</b><span>Voicing positions on one switch.</span></article>
      <article><b>10Hz-40kHz</b><span>Frequency response.</span></article>
      <article><b>12 Ohm</b><span>Impedance. Drives from any source.</span></article>
    </div>
  </section>

  <section class="bm-section bm-story">
    <div class="bm-wrap bm-story__grid">
      <div>
        <p class="bm-kicker">Design Story</p>
        <h2>Small shell. Serious intent.</h2>
      </div>
      <div class="bm-prose">
        <p>A3H+ Lux is a machined-aluminium hybrid priced for working musicians and daily listeners. The enclosure is CNC aluminium. The faceplates are replaceable.</p>
        <p>The tuning is forward: natural sub-bass, clean vocal projection, controlled treble. No upper-register glare.</p>
        <p>Built for stage monitoring and daily listening. Same driver platform, same crossover, same four-mode switch &mdash; universal or custom.</p>
      </div>
    </div>
  </section>

  <section class="bm-section bm-section--dark a3h-vantage" aria-labelledby="a3h-vantage-title">
    <div class="bm-wrap bm-section-head">
      <p class="bm-kicker">The AAW Vantage</p>
      <h2 id="a3h-vantage-title">Built around the A3H+ Lux platform.</h2>
      <p>Fit, materials, and tuning are treated as one system: a compact hybrid shell, stable seal, skin-safe finish, and four switchable voicings without changing cables or source gear.</p>
    </div>
    <div class="bm-wrap a3h-vantage__grid">
      <article class="a3h-vantage__card a3h-vantage__card--tall a3h-vantage__card--fitment">
        {% render 'aaw-responsive-asset-image', file: 'a3h-lux-musician-fitment-optimized.jpg', alt: 'A3H+ Lux universal in-ear monitor worn by a musician with over-ear cable fit', width: '1535', height: '1024', loading: 'lazy' %}
        <div>
          <span>01</span>
          <h3>Universal Comfort</h3>
          <p>The universal shell is shaped from AAW&rsquo;s custom-fit experience and pairs with LiquidMorph tips for a stable seal, quick sizing, and consistent bass response.</p>
        </div>
      </article>
      <article class="a3h-vantage__card a3h-vantage__card--wide">
        {% render 'aaw-responsive-asset-image', file: 'a3h-lux-switch-back.jpg', alt: 'A3H+ Lux rear shell showing four-position tuning switch', width: '2000', height: '1334', loading: 'lazy' %}
        <div>
          <span>02</span>
          <h3>Switchable Hybrid Tuning</h3>
          <p>Vocal, Normal, Vocal+, and Bass modes alter the crossover load between the armature and 10mm graphene woofer paths, giving A3H+ Lux four practical signatures on one monitor.</p>
        </div>
      </article>
      <article class="a3h-vantage__card">
        {% render 'aaw-responsive-asset-image', file: 'a3h-lux-closeup.jpg', alt: 'A3H+ Lux CNC aluminium shells and faceplate close-up', width: '2000', height: '1334', loading: 'lazy' %}
        <div>
          <span>03</span>
          <h3>Skin-Safe Aluminium</h3>
          <p>Precision CNC aluminium keeps the shell dense and durable while the smooth finish is made for long sessions against the ear.</p>
        </div>
      </article>
      <article class="a3h-vantage__card">
        {% render 'aaw-responsive-asset-image', file: 'aaw-ins-hero-ciem-2026.jpg', alt: 'AAW custom-fit in-ear monitors with personalized shell and faceplate finish', width: '1200', height: '900', loading: 'lazy' %}
        <div>
          <span>04</span>
          <h3>Custom-Fit Path</h3>
          <p>Choose custom fit when you want impression-built isolation and personalized shells. The A3H+ Lux driver platform and four-mode tuning remain the same.</p>
        </div>
      </article>
    </div>
  </section>

  <section class="bm-section bm-section--dark bm-explosion" aria-labelledby="a3h-switch-title">
    <div class="bm-wrap bm-explosion__frame">
      <figure class="bm-explosion__media a3h-explosion__fitment">
        {% render 'aaw-responsive-asset-image', file: 'a3h-lux-musician-fitment-optimized.jpg', alt: 'A3H+ Lux universal in-ear monitor worn by a musician with over-ear cable fit', width: '1535', height: '1024', loading: 'lazy' %}
      </figure>
      <div class="bm-explosion__copy">
        <p class="bm-kicker">Selectable Signature</p>
        <h2 id="a3h-switch-title">Four tunings. One monitor.</h2>
        <p>Four voicings on a single shell. The switch changes the crossover load between the woofer and armature paths. No apps, no cables to swap, no EQ. Vocal pushes the midrange forward. Normal is the balanced reference. Vocal+ adds presence. Bass shifts weight to the woofer.</p>
      </div>
    </div>
  </section>

  <section class="bm-section bm-section--dark" id="a3h-nova">
    <div class="bm-wrap bm-section-head">
      <p class="bm-kicker">Acoustic Architecture</p>
      <h2>NOVA up front. Graphene down low.</h2>
      <p>Each driver covers a specific band. The NOVA open-vented armature sits close to the nozzle for vocal and treble. The 10mm graphene dynamic handles bass. A precision armature fills the upper mids. Three drivers, three bands, one 3-way crossover.</p>
    </div>
    <div class="bm-wrap bm-architecture__grid">
      <figure class="bm-render-card bm-render-card--large">
        {% render 'aaw-responsive-asset-image', file: 'a3h-lux-closeup.jpg', alt: 'Close-up of A3H+ Lux faceplates and cable showing the aluminium enclosure', width: '2000', height: '1334', loading: 'lazy' %}
        <figcaption>Driver and nozzle geometry is digitally modeled to keep phase and handoff consistent between universal and custom-fit builds.</figcaption>
      </figure>
      <div class="bm-driver-map" aria-label="A3H+ Lux driver layout">
        <article><span>01</span><b>NOVA driver</b><p>Open-vented armature placed close to the nozzle. Reduces pressure decay and tube resonance that conventional tubed layouts introduce.</p></article>
        <article><span>02</span><b>Balanced armature</b><p>Handles upper-mid detail and control. Keeps vocal edges clear without over-brightening.</p></article>
        <article><span>03</span><b>Graphene woofer</b><p>10mm dynamic diaphragm filtered for the low band. Natural sub-bass and punch with minimal midrange overlap.</p></article>
        <article><span>04</span><b>3-way crossover</b><p>Passive and acoustic filtering separate the drivers so timing, phase, and handoff stay consistent.</p></article>
      </div>
    </div>
  </section>

  <section class="bm-section bm-build">
    <div class="bm-wrap bm-build__grid">
      <div class="bm-build__copy">
        <p class="bm-kicker">Precision Enclosure Design</p>
        <h2>Built for consistent fit and sound.</h2>
        <p>Driver, nozzle, and chamber geometry is modeled digitally so universal and custom-fit units share the same phase and frequency response. Universal uses a compact CNC aluminium profile. Custom-fit units translate the same platform into an impression-built shell.</p>
      </div>
      <figure class="bm-build__photo">
        {% render 'aaw-responsive-asset-image', file: 'a3h-lux-paper-wide.jpg', alt: 'A3H+ Lux monitors on sculpted white paper with silver aluminium shells', width: '2000', height: '1334', loading: 'lazy' %}
      </figure>
      <div class="bm-build__renders">
        {% render 'aaw-responsive-asset-image', file: 'a3h-lux-pair-wide.jpg', alt: 'A3H+ Lux universal monitors and cable on a neutral studio surface', width: '2000', height: '1334', loading: 'lazy' %}
        {% render 'aaw-responsive-asset-image', file: 'a3h-lux-portrait.jpg', alt: 'Portrait studio photo of A3H+ Lux silver faceplates', width: '1334', height: '2000', loading: 'lazy' %}
      </div>
    </div>
  </section>

  <section class="bm-section bm-section--dark">
    <div class="bm-wrap bm-section-head">
      <p class="bm-kicker">Tuning Modes</p>
      <h2>Adapt without changing the rig.</h2>
      <p>The switch changes how the crossover loads the woofer and armature paths. Four positions. One shell. No cables, no sources, no apps.</p>
    </div>
    <div class="bm-wrap a3h-switch-grid" aria-label="A3H+ Lux tuning modes">
      <article><span>01</span><h3>Vocal</h3><p>Midrange forward. For speech, worship, and vocal monitors.</p></article>
      <article><span>02</span><h3>Normal</h3><p>Balanced reference. Mixed libraries, stage work, daily listening.</p></article>
      <article><span>03</span><h3>Vocal+</h3><p>Added presence and articulation. Detail-forward without sharpness.</p></article>
      <article><span>04</span><h3>Bass</h3><p>Fuller low end. More woofer weight, less armature prominence.</p></article>
    </div>
    <div class="bm-wrap a3h-image-strip">
      <figure>{% render 'aaw-responsive-asset-image', file: 'a3h-lux-cable-wide.jpg', alt: 'A3H+ Lux monitors with detachable cable arranged on a grey studio surface', width: '2000', height: '1334', loading: 'lazy' %}</figure>
      <figure>{% render 'aaw-responsive-asset-image', file: 'a3h-lux-gallery-pair.jpg', alt: 'A3H+ Lux faceplate close-up showing grille pattern and cable loops', width: '2000', height: '1334', loading: 'lazy' %}</figure>
    </div>
  </section>

  <section class="bm-section bm-accessories">
    <div class="bm-wrap bm-section-head">
      <p class="bm-kicker">Cabling and Accessories</p>
      <h2>The everyday kit.</h2>
    </div>
    <div class="bm-wrap bm-accessory-grid">
      <article>
        {% render 'aaw-responsive-asset-image', file: 'a3h-lux-cable-wide.jpg', alt: 'A3H+ Lux detachable cable and universal monitors', width: '2000', height: '1334', loading: 'lazy' %}
        <div><span>01</span><h3>Epsilon cable</h3><p>48&quot; Null Audio Epsilon UPOCC copper cable. Low microphonics. Detachable 2-pin.</p></div>
      </article>
      <article>
        {% render 'aaw-responsive-asset-image', file: 'z05-liquidmorph-clear-eartips-closeup.jpg', alt: 'LiquidMorph clear ear tips with teal inner bore', width: '2048', height: '2048', loading: 'lazy' %}
        <div><span>02</span><h3>LiquidMorph tips</h3><p>Silicone tips with a teal inner bore. Keeps the dynamic woofer sealed for consistent bass and center image.</p></div>
      </article>
      <article>
        {% render 'aaw-responsive-asset-image', file: 'z05-auag-liquidmorph-accessory-tray.jpg', alt: 'LiquidMorph ear tip accessory tray with multiple sizes', width: '2048', height: '2048', loading: 'lazy' %}
        <div><span>03</span><h3>Size tray</h3><p>Multiple sizes in one tray. Faster fit checks before a show or session.</p></div>
      </article>
    </div>
  </section>

  <section class="bm-section bm-section--dark bm-specs">
    <div class="bm-wrap bm-specs__grid">
      <div>
        <p class="bm-kicker">Specifications</p>
        <h2>Compact hybrid numbers.</h2>
        <p>Three drivers. 3-way crossover. 10Hz to 40kHz. 12 Ohm.</p>
      </div>
      <dl class="bm-spec-table">
        <div><dt>Driver count</dt><dd>3 driver hybrid design</dd></div>
        <div><dt>Driver system</dt><dd>NOVA open-vented armature / precision balanced armature / 10mm graphene diaphragm woofer</dd></div>
        <div><dt>Crossover</dt><dd>3-way passive and acoustic crossover</dd></div>
        <div><dt>Sensitivity</dt><dd>105dB</dd></div>
        <div><dt>Impedance</dt><dd>12 Ohm</dd></div>
        <div><dt>Frequency response</dt><dd>10Hz to 40kHz</dd></div>
        <div><dt>Distortion</dt><dd>&le;0.5%</dd></div>
        <div><dt>Enclosure</dt><dd>Precision CNC aluminium</dd></div>
        <div><dt>Tuning</dt><dd>4-step adjustable sound signature</dd></div>
        <div><dt>Warranty</dt><dd>1-year limited warranty</dd></div>
      </dl>
    </div>
  </section>

  <section class="bm-section bm-faq">
    <div class="bm-wrap bm-faq__grid">
      <div>
        <p class="bm-kicker">FAQ</p>
        <h2>Before you choose A3H+ Lux</h2>
      </div>
      <div class="bm-faq__list">
        <details open>
          <summary><span>What is the A3H+ Lux driver configuration?</span></summary>
          <p>Three-driver hybrid. One NOVA open-vented armature for vocals and treble. One precision balanced armature for upper mids. One 10mm graphene dynamic woofer for bass.</p>
        </details>
        <details>
          <summary><span>What does the tuning switch do?</span></summary>
          <p>Four positions: Vocal, Normal, Vocal+, Bass. The switch changes the crossover load between the woofer and armature paths — across genres, stage use, and everyday listening. No cables to swap, no EQ to set.</p>
        </details>
        <details>
          <summary><span>Is A3H+ Lux available as universal and custom fit?</span></summary>
          <p>Yes. Universal-fit units ship with LiquidMorph tips. Custom-fit units are built from ear impressions. Both use the same three-driver hybrid platform.</p>
        </details>
        <details>
          <summary><span>Who is A3H+ Lux for?</span></summary>
          <p>Working musicians, worship bands, emerging artists, and listeners who want a hybrid IEM with switchable voicing at a practical price. The four tuning modes cover stage monitoring and daily listening.</p>
        </details>
        <details>
          <summary><span>What comes in the box?</span></summary>
          <p>48&quot; Null Audio Epsilon UPOCC copper detachable cable, AAW carry case, LiquidMorph tips, AAW foam tips, assorted silicone tips. One-year limited warranty.</p>
        </details>
      </div>
    </div>
  </section>

  <section id="a3h-reviews" class="bm-section bm-section--dark z05-reviews-section">
    <div class="bm-wrap">
      <div class="z05-reviews-head">
        <p class="bm-kicker">Owner Reviews</p>
        <h2>A3H+ Lux listening impressions</h2>
        <p class="z05-reviews-note"><strong>Customer review archive</strong>Read owner impressions from the Judge.me review archive.</p>
      </div>
      <div class="z05-reviews-widget-shell">
        <div style="clear:both"></div>
        <div id="judgeme_product_reviews" class="jdgm-widget jdgm-review-widget" data-id="{{ product.id }}" data-auto-install="false">
          {% if jm_widget != blank %}
            {{ jm_widget }}
          {% else %}
            <div class="jdgm-rev-widg" data-number-of-reviews="57" data-average-rating="4.86">
              <div class="jdgm-rev-widg__header">
                <h2 class="jdgm-rev-widg__title">Customer Reviews</h2>
                <div class="jdgm-rev-widg__summary">
                  <div class="jdgm-rev-widg__summary-text">Based on 57 reviews</div>
                </div>
                <a class="jdgm-write-rev-link" href="#" role="button">Write a Review</a>
              </div>
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  </section>

  <section class="bm-section bm-section--dark bm-brand">
    <div class="bm-wrap bm-brand__inner">
      <div class="bm-brand__lead">
        <p class="bm-kicker">Built by Advanced AcousticWerkes</p>
        <h2>Singapore IEM craft, shaped by listening.</h2>
