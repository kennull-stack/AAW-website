{% if section.settings.section_visibility == 'large' %}
  <style>
    @media (max-width: 767px) {
      #shopify-section-{{ section.id }} {
        display: none !important;
      }
    }
  </style>
{% elsif section.settings.section_visibility == 'small' %}
  <style>
    @media (min-width: 768px) {
      #shopify-section-{{ section.id }} {
        display: none !important;
      }
    }
  </style>
{% endif %}

{% assign current_variant = product.selected_or_first_available_variant %}
{% assign product_price = current_variant.price | money %}
{% assign jm_badge = product.metafields.judgeme.badge | default: '' %}
{% assign jm_widget = product.metafields.judgeme.widget | default: '' %}

<script type="application/ld+json">
{
  "@context": "https://schema.org/",
  "@type": "Product",
  "@id": {{ canonical_url | append: "#product" | json }},
  "name": "AAW Mockingbird Nine-Driver Hybrid In-Ear Monitor",
  "image": [
    {{ 'mockingbird-hero.png' | asset_url | prepend: 'https:' | json }},
    {{ 'mockingbird-frequency-response-graph.png' | asset_url | prepend: 'https:' | json }}
  ],
  "description": "Mockingbird is a nine-driver hybrid reference in-ear monitor from Singapore-based Advanced AcousticWerkes. Successor to the acclaimed W900. Proprietary tuned dynamic driver, bespoke super tweeter balanced armatures, TrueXross 4-way crossover for phase-coherent hybrid performance. Universal and custom fit.",
  "sku": {{ current_variant.sku | default: "MOCKINGBIRD" | json }},
  "mpn": "AAW Mockingbird",
  "brand": {"@id": "https://www.aaw.me/#organization"},
  "designer": {
    "@type": "Person",
    "name": "Kevin Wang",
    "jobTitle": "Founder & Tuning Engineer",
    "description": "Founder and tuning engineer of Advanced AcousticWerkes, responsible for the acoustic design and tuning of AAW in-ear monitors.",
    "knowsAbout": ["in-ear monitor tuning", "hybrid IEM design", "balanced armature drivers", "dynamic driver integration", "crossover network design", "custom in-ear monitors", "universal in-ear monitors", "reference IEM tuning"],
    "worksFor": {"@id": "https://www.aaw.me/#organization"}
  },
  "category": "Universal In-Ear Monitor",
  "offers": {
    "@type": "Offer",
    "url": {{ canonical_url | json }},
    "priceCurrency": {{ cart.currency.iso_code | default: shop.currency | json }},
    "price": {{ current_variant.price | money_without_currency | remove: ',' | json }},
    "availability": "https://schema.org/{% if current_variant.available %}InStock{% else %}OutOfStock{% endif %}",
    "itemCondition": "https://schema.org/NewCondition",
    "seller": {"@id": "https://www.aaw.me/#organization"},
    "hasMerchantReturnPolicy": {
      "@type": "MerchantReturnPolicy",
      "url": "https://www.aaw.me/pages/shipping-return",
      "applicableCountry": "SG",
      "returnPolicyCategory": "https://schema.org/MerchantReturnFiniteReturnWindow",
      "merchantReturnDays": 7,
      "returnMethod": "https://schema.org/ReturnByMail",
      "returnFees": "https://schema.org/ReturnShippingFees"
    }
  },
  "additionalProperty": [
    {"@type": "PropertyValue", "name": "Driver Configuration", "value": "Nine-driver hybrid: proprietary tuned dynamic woofer plus eight balanced armature drivers"},
    {"@type": "PropertyValue", "name": "Dynamic Woofer", "value": "Proprietary tuned dynamic driver with physical low-pass filter for minimal frequency overlap"},
    {"@type": "PropertyValue", "name": "Super Tweeter", "value": "Bespoke balanced armature super tweeter drivers developed with world-class BA manufacturer. Sustained SPL to 20kHz, extends to 40kHz"},
    {"@type": "PropertyValue", "name": "Crossover", "value": "TrueXross 4-way crossover network: dedicated woofer, mid, treble, and super tweeter paths"},
    {"@type": "PropertyValue", "name": "TrueXross Technology", "value": "Eliminates high-order RC crossover networks. Physical low-pass filtering on dynamic driver plus positional arrangement and front acoustic chamber design for improved coherence, minimized phase shift, and optimized arrival timing"},
    {"@type": "PropertyValue", "name": "Sensitivity", "value": "108dB"},
    {"@type": "PropertyValue", "name": "Impedance", "value": "15 Ohm"},
    {"@type": "PropertyValue", "name": "Frequency Response", "value": "10Hz to 40kHz"},
    {"@type": "PropertyValue", "name": "Total Harmonic Distortion", "value": "\u22640.5%"},
    {"@type": "PropertyValue", "name": "Enclosure", "value": "Precision-engineered acoustic chambers with advanced digital modeling"},
    {"@type": "PropertyValue", "name": "Fit Options", "value": "Universal fit and custom fit"},
    {"@type": "PropertyValue", "name": "Warranty", "value": "1-year limited warranty"}
  ]
}
</script>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the Mockingbird driver configuration?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Nine-driver hybrid reference monitor. One proprietary tuned dynamic woofer with physical low-pass filter for natural sub-bass. Eight balanced armature drivers including bespoke super tweeters covering mids, treble, and ultra-high frequencies. TrueXross 4-way crossover network."
      }
    },
    {
      "@type": "Question",
      "name": "What is TrueXross?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "TrueXross is AAW's proprietary approach to solving the classic coherence issue in hybrid earphones. Instead of using high-order RC crossover networks that cause chaotic phase shift and scrambled arrival timing, TrueXross uses a physical low-pass filter on the dynamic driver so it operates in a minimal overlapping frequency range relative to the balanced armature drivers. Combined with precise positional arrangement and front acoustic chamber design, this achieves improved coherence, minimized phase shift, and optimized arrival timing."
      }
    },
    {
      "@type": "Question",
      "name": "What are the bespoke super tweeter drivers?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "AAW worked with the world's leading balanced armature manufacturer to develop custom super tweeter drivers exclusively for Mockingbird. These bespoke drivers sustain sound pressure level all the way to 20kHz and extend to 40kHz, delivering extended treble and superior detail retrieval that gives Mockingbird its high-end speaker-like performance."
      }
    },
    {
      "@type": "Question",
      "name": "Is Mockingbird available as universal and custom fit?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Universal-fit units ship with LiquidMorph tips, AAW foam tips, and assorted silicone tips. Custom-fit units are built from ear impressions. Both use the same nine-driver hybrid reference platform."
      }
    },
    {
      "@type": "Question",
      "name": "What sound signature does Mockingbird have?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "True reference signature. Powerful yet natural sub-bass that full BA IEMs cannot reproduce. Inherits AAW's highly praised musical imaging, instrument separation, and realistic sound stage. The bespoke super tweeters deliver extended treble and superior detail retrieval. The end result is high-end speaker-like performance in an IEM footprint."
      }
    },
    {
      "@type": "Question",
      "name": "What comes in the box?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "48 inch Null Audio Symphonym Tiburon UPOCC copper detachable cable, wooden AAW carry case, LiquidMorph tips, AAW short-stem foam tips (S/M/L), AAW assorted silicone tips (S/M/L x2). One-year limited warranty."
      }
    }
  ]
}
</script>

