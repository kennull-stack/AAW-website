<link rel="stylesheet" href="{{ 'recently-viewed-product.css' | asset_url }}">
<div class="section-container  {{ section.settings.color_scheme }}-scheme {% if section.settings.make_section_rounded %}section-rounded{% endif %}">
  <div class="{{ settings.container_width }}">
    {% if section.settings.heading != blank %}
      {%- capture sectionhighlightPrefix -%}
        <strong class="highlight-text">
        {%- endcapture -%}

        {%- capture sectionhighlightSuffix -%}
        </strong>
        {%- endcapture -%}


      <div class="section-heading-box {{ section.settings.heading_alignment }}" {% if settings.enable_animation %}data-aos="fade-up" data-aos-duration="1000"{% endif %}>
        <{{ section.settings.seo_heading }} class="section-heading {{ section.settings.heading_size }}">
          {{ section.settings.heading | replace: "<strong>", sectionhighlightPrefix | replace: "</strong>", sectionhighlightSuffix | replace: '++', '<br>' }}
        </{{ section.settings.seo_heading }}>
      </div>
    {% endif %}
    <div
      class="recently-viewed-wrapper"
      data-section="{{ routes.search_url }}.json?section_id={{ section.id }}&type=product&q="
      data-product="{{ product.id }}"
      data-recent-viewed-products
    >
      {% if search.performed and search.results.size > 0 %}
        {% paginate search.results by 28 %}
          <div
            id="recently-viewed-products-{{ section.id }}"
            class="recently-viewed__slider product-card-slider slider"

            data-slick='
              {
                    "infinite": true,"slidesToShow":4,
                     "slidesToScroll": 1, "autoplay":false,
                      "arrows": true, "responsive": [
                    {
                      "breakpoint": 1024,
                      "settings": {
                        "slidesToShow": 3
                      }
                    },
                    {
                      "breakpoint": 767,
                      "settings": {
                          "slidesToShow": 2

                      }
                    }
              ]}
            '
          >
            {%- liquid
              for item in search.results limit: section.settings.products_count
               assign aosDelay = forloop.index | times: 50
                case item.object_type
                  when 'product'
                    assign productFormId = 'product-form-' | append: section.id | append: forloop.index
                    echo '<div class="product-card-item">'
                    capture current 
                    cycle section.id: 1
                    endcapture
                  
                    assign placeholder_image = 'product-apparel-' | append: current 
                    render 'card-product', cProduct: item, section: section, productFormId: productFormId, gridImageSize: settings.grid_image_size, placeholder_image: placeholder_image, aosDelay: aosDelay
                    echo '</div>'
                endcase
              endfor
            -%}
          </div>
        {% endpaginate %}
      {% endif %}
    </div>
  </div>
</div>
<style>
  #shopify-section-{{ section.id }} {
    {% if section.settings.make_section_rounded %}
      background:{{ section.settings.section_background }};
    {% endif %}
      --top-spacer:{{ section.settings.top_space_desktop }}px;
      --bottom-spacer:{{ section.settings.bottom_space_desktop }}px;
      --image-fit:{{ settings.image_fit }};
      --highlight-text: {{ section.settings.highlighted_color }};
  }
  }
  #shopify-section-{{ section.id }} .recently-viewed-wrapper .slick-track{
    margin-left:0;
  }
  @media only screen and (max-width:767px) {
    #shopify-section-{{ section.id }}.shopify-section{
      --top-spacer:{{ section.settings.top_space_mobile }}px;
      --bottom-spacer:{{ section.settings.bottom_space_mobile }}px;
    }

  }
  {% if section.settings.section_visibility == 'large' %}
    @media (max-width: 767px) {
      #shopify-section-{{ section.id }}{
        display: none !important;
      }
    }
  {% elsif section.settings.section_visibility == 'small' %}
    @media (min-width: 768px) {
      #shopify-section-{{ section.id }}{
        display: none !important;
      }
    }
  {% endif %}
</style>
{% schema %}
{
  "name": "t:sections.recently-viewed-product.name",
  "tag": "section",
  "class": "recent-viewed-product-section hidden",
  "disabled_on": {
    "groups": [
      "header"
    ]
  },
  "settings": [
    {
      "type": "paragraph",
      "content": "t:sections.recently-viewed-product.settings.paragraph.content"
    },
    {
      "type": "select",
      "id": "section_visibility",
      "label": "t:global.common.section_visibility.label",
      "default": "always",
      "options": [
        {
          "label": "t:global.common.section_visibility.options.always",
          "value": "always"
        },
        {
          "label": "t:global.common.section_visibility.options.small",
          "value": "small"
        },
        {
          "label": "t:global.common.section_visibility.options.large",
          "value": "large"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "make_section_rounded",
      "label": "t:global.common.general_labels.make_section_rounded",
      "default": false
    },
    {
      "id": "heading",
      "type": "inline_richtext",
      "label": "t:global.common.general_labels.heading",
      "info": "t:global.common.infos.heading.label",
      "default": "Recently view products"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "t:global.common.general_labels.heading_size",
      "default": "h2",
      "options": [
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        },
        {
          "value": "h4",
          "label": "H4"
        },
        {
          "value": "h5",
          "label": "H5"
        },
        {
          "value": "h6",
          "label": "H6"
        }
      ]
    },
    {
      "type": "select",
      "id": "seo_heading",
      "label": "t:global.common.general_labels.heading_tag",
      "info": "t:global.common.infos.seo_heading.label",
      "default": "h2",
      "options": [
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        },
        {
          "value": "h4",
          "label": "H4"
        },
        {
          "value": "h5",
          "label": "H5"
        },
        {
          "value": "h6",
          "label": "H6"
        }
      ]
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "t:global.common.heading_alignment.label",
      "default": "text-left",
      "options": [
        {
          "label": "t:global.common.heading_alignment.options.left.label",
          "value": "text-left"
        },
        {
          "label": "t:global.common.heading_alignment.options.center.label",
          "value": "text-center"
        }
      ]
    },
    {
      "type": "range",
      "id": "products_count",
      "min": 4,
      "max": 12,
      "step": 1,
      "label": "t:sections.recently-viewed-product.settings.products_count.label",
      "default": 8
    },
    {
      "type": "paragraph",
      "content": "t:global.header.color_section.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "primary",
      "label": "t:global.header.color_scheme.label"
    },
    {
      "type": "color",
      "id": "section_background",
      "label": "t:global.common.section_background.label",
      "info": "t:global.common.section_background.info"
    },
    {
      "type": "color",
      "id": "highlighted_color",
      "default": "#EFF341",
      "label": "t:global.common.general_labels.highlight_color"
    },
    {
      "type": "header",
      "content": "t:global.header.space_section.label"
    },
    {
      "type": "range",
      "id": "top_space_desktop",
      "label": "t:global.top_space_desktop.label",
      "default": 85,
      "min": 0,
      "max": 100,
      "step": 5
    },
    {
      "type": "range",
      "id": "bottom_space_desktop",
      "label": "t:global.bottom_space_desktop.label",
      "default": 40,
      "min": 0,
      "max": 100,
      "step": 5
    },
    {
      "type": "range",
      "id": "top_space_mobile",
      "label": "t:global.top_space_mobile.label",
      "default": 35,
      "min": 0,
      "max": 100,
      "step": 5
    },
    {
      "type": "range",
      "id": "bottom_space_mobile",
      "label": "t:global.bottom_space_mobile.label",
      "default": 35,
      "min": 0,
      "max": 100,
      "step": 5
    }
  ],
  "presets": [
    {
      "name": "t:sections.recently-viewed-product.presets.name"
    }
  ]
}
{% endschema %}
