          "id": "link_url",
          "label": "t:sections.mulicolumn.blocks.settings.link_url.label",
          "info": "t:sections.mulicolumn.blocks.settings.link_url.info"
        },
        {
          "type": "checkbox",
          "id": "column_background",
          "label": "t:sections.mulicolumn.blocks.settings.column_background.label",
          "default": true
        },
        {
          "type": "header",
          "content": "t:global.header.color_section.label"
        },
        {
          "type": "color",
          "id": "column_background_color",
          "label": "t:sections.mulicolumn.blocks.settings.column_background_color.label",
          "default": "#F2F2F2"
        },
        {
          "type": "color",
          "id": "column_text_color",
          "label": "t:sections.mulicolumn.blocks.settings.column_text_color.label",
          "default": "#000000"
        },
        {
          "type": "color",
          "id": "column_link_color",
          "label": "t:sections.mulicolumn.blocks.settings.column_link_color.label",
          "default": "#2877FF"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.mulicolumn.presets.name",
      "blocks": [
        {
          "type": "column"
        },
        {
          "type": "column"
        },
        {
          "type": "column"
        }
      ]
    }
  ]
}
{% endschema %}
