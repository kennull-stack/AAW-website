<link rel="preload" as="style" href="{{ 'multicolumn.css' | asset_url }}">
{{ 'multicolumn.css' | asset_url | stylesheet_tag }}
<div class="section-container {{ section.settings.color_scheme }}-scheme {% if section.settings.make_section_rounded %}section-rounded{% endif %}">
    <div class="{{ settings.container_width }}">
        {% if section.settings.heading != blank %}

            {%- capture sectionhighlightPrefix -%}
            <strong class="highlight-text">
            {%- endcapture -%}

            {%- capture sectionhighlightSuffix -%}
            </strong>
            {%- endcapture -%}

            <div class="section-heading-box {{ section.settings.heading_alignment }}" {% if settings.enable_animation %}data-aos="fade-up" data-aos-duration="1000"{% endif %}>
                <{{ section.settings.seo_heading }} class="section-heading {{ section.settings.heading_size }}">
                    {{ section.settings.heading | replace: "<strong>", sectionhighlightPrefix | replace: "</strong>", sectionhighlightSuffix | replace: '++', '<br>' }}
                </{{ section.settings.seo_heading }}>
            </div>
        {% endif %}
        <div class="multicolumn-wrapper {% if section.settings.enable_swipe_mobile %} mobile-swipe{% endif %}">
            <div class="row">
                {% for block in section.blocks %}
                    {%liquid
                        if section.settings.multicolumn_image_size == 'landscape'
                            assign imageRatio = 75
                        elsif section.settings.multicolumn_image_size == 'square'
                            assign imageRatio = 100
                        elsif section.settings.multicolumn_image_size == 'portrait'
                            assign imageRatio = 125
                        else 
                            if block.settings.video != blank
                              assign imageRatio = 1 | divided_by:  block.settings.video.aspect_ratio | times: 100 | plus: 1 
                            elsif block.settings.image != blank 
                                assign imageRatio = 1 | divided_by: block.settings.image.aspect_ratio | times: 100 | plus: 1 
                            else  
                                assign imageRatio = 100 
                            endif 
                        endif 
                         if section.settings.columns_desktop == 2 
                          assign columnsValue = 'col-lg-6'
                         elsif section.settings.columns_desktop == 3
                          assign columnsValue = 'col-lg-4'
                         else
                          assign columnsValue = 'col-lg-3'
                         endif

                    -%}


                    {% assign aosDelay = forloop.index | times: 50 %}
                    <div class="col-12 col-sm-12 col-md-4 {{ columnsValue }}"  {% if settings.enable_animation %}data-aos="fade-up" data-aos-delay="{{aosDelay}}"{% endif %}>
                        <div id="block-{{ block.id }}" class="multicolumn-item {{ section.settings.layout_type }}-view {% if block.settings.column_background %} background-enabled{% endif %}" {{ block.shopify_attributes }}>
                          {% if block.settings.video != blank %}
                            <deferred-media class="media-box" style="--image-ratio:{{ imageRatio }}%">
                            <template style="display:none">
                              {{ 
                                block.settings.video | video_tag:  image_size: '1100x',
                                  class: 'multicolumn-video', 
                                  autoplay:true,
                                  loop:true,
                                  controls: false,
                                  muted:true
                              }} 
                         
                            </template>
                            <noscript>
                              <img
                                src="{{ block.settings.video.preview_image | img_url: '1100x' }}"
                                alt="{{ block.settings.video.preview_image.alt | default: shop.name | strip_html }}"
                                width="{{ block.settings.video.preview_image.width }}"
                                height="{{ block.settings.video.preview_image.height }}"
                              >
                    </noscript>
                  </deferred-media>
                          {% elsif block.settings.image != blank %}
                                <{% if block.settings.link_label == blank and block.settings.link_url != blank %}a href="{{ block.settings.link_url }}" {% else %}div{% endif %} class="multicolumn-img">
                                    <div class="media-box" style="--image-ratio:{{ imageRatio }}%">
                                        {% render 'image', image: block.settings.image %}
                                    </div>
                                </{% if block.settings.link_label == blank and block.settings.link_url != blank %}a{% else %}div{% endif %}>
                            {% endif %}
                            {% if block.settings.heading != blank or block.settings.description != blank or block.settings.link_label != blank %}
                            <div class="multicolumn-content">
                                {% if block.settings.heading != blank %}
                                    <h5 class="multicolumn-content-heading">{{ block.settings.heading }}</h5>
                                {% endif %}
                                {% if block.settings.description != blank %}
                                        <p class="multicolumn-content-description text-small">{{ block.settings.description | newline_to_br }}</p>
                                {% endif %}
                                {% if block.settings.link_url != blank and  block.settings.link_label != blank %}
                                    <a {% if block.settings.link_url != blank %}href="{{block.settings.link_url}}"{% endif %} class="multicolumn-content-link text-underline text-small">{{ block.settings.link_label }}</a>
                                {% endif %}
                            </div>
                            {% endif %}
                        </div>
                    </div>
                    
                {% endfor %}
            </div>
        </div>
    </div>
</div>
<style>
    #shopify-section-{{ section.id }} {
      {% if section.settings.make_section_rounded %}
        background:{{ section.settings.section_background }};
      {% endif %}
      --top-spacer:{{ section.settings.top_space_desktop }}px;
      --bottom-spacer:{{ section.settings.bottom_space_desktop }}px;
      --highlight-text: {{ section.settings.highlighted_color }};
    }
    {% for block in section.blocks %}
        #block-{{ block.id }}{
            --multicolumn-card-background: {{ block.settings.column_background_color }};
            --multicolumn-card-color: {{ block.settings.column_text_color }};
            --multicolumn-card-link-color: {{ block.settings.column_link_color }};
        }
    {% endfor %}
    @media only screen and (max-width:767px) {
        #shopify-section-{{ section.id }}{
          --top-spacer:{{ section.settings.top_space_mobile }}px;
          --bottom-spacer:{{ section.settings.bottom_space_mobile }}px;
        }
    }
    {% if section.settings.section_visibility == 'large' %}
        @media (max-width: 767px) {
            #shopify-section-{{ section.id }}{
                display: none !important;
            }
        }
        {% elsif section.settings.section_visibility == 'small' %}
        @media (min-width: 768px) {
            #shopify-section-{{ section.id }}{
            display: none !important;
            }
        }
    {% endif %}
</style>
{% schema %}
{
  "name": "t:sections.mulicolumn.name",
  "tag": "section",
  "class": "multicolumn",
  "disabled_on": {
    "groups": [
      "header",
      "footer"
    ]
  },
  "settings": [
    {
      "type": "select",
      "id": "section_visibility",
      "label": "t:global.common.section_visibility.label",
      "default": "always",
      "options": [
        {
          "label": "t:global.common.section_visibility.options.always",
          "value": "always"
        },
        {
          "label": "t:global.common.section_visibility.options.small",
          "value": "small"
        },
        {
          "label": "t:global.common.section_visibility.options.large",
          "value": "large"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "make_section_rounded",
      "label": "t:global.common.general_labels.make_section_rounded",
      "default": false
    },
    {
      "type": "select",
      "id": "multicolumn_image_size",
      "label": "t:global.common.image_ratio.label",
      "default": "square",
      "options": [
        {
          "value": "auto",
          "label": "t:global.common.image_ratio.options.auto"
        },
        {
          "value": "landscape",
          "label": "t:global.common.image_ratio.options.landscape"
        },
        {
          "value": "portrait",
          "label": "t:global.common.image_ratio.options.portrait"
        },
        {
          "value": "square",
          "label": "t:global.common.image_ratio.options.square"
        }
      ]
    },
    {
      "type": "select",
      "id": "layout_type",
      "label": "t:sections.mulicolumn.settings.layout_type.label",
      "default": "stacked",
      "options": [
        {
          "value": "inline",
          "label": "t:sections.mulicolumn.settings.layout_type.options.inline.label"
        },
        {
          "value": "inline-reverse",
          "label": "t:sections.mulicolumn.settings.layout_type.options.inline-reverse.label"
        },
        {
          "value": "stacked",
          "label": "t:sections.mulicolumn.settings.layout_type.options.stacked.label"
        },
        {
          "value": "stacked-reverse",
          "label": "t:sections.mulicolumn.settings.layout_type.options.stacked-reverse.label"
        }
      ]
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "t:global.common.columns_desktop.label",
      "default": 3,
      "min": 2,
      "max": 4,
      "step": 1
    },
    {
      "type": "checkbox",
      "id": "enable_swipe_mobile",
      "label": "t:global.common.swipe_mobile.label",
      "default": true
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "t:global.common.general_labels.heading",
      "info": "t:global.common.infos.heading.label",
      "default": "Multicolumn"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "t:global.common.general_labels.heading_size",
      "default": "h3",
      "options": [
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        },
        {
          "value": "h4",
          "label": "H4"
        },
        {
          "value": "h5",
          "label": "H5"
        },
        {
          "value": "h6",
          "label": "H6"
        }
      ]
    },
    {
      "type": "select",
      "id": "seo_heading",
      "label": "t:global.common.general_labels.heading_tag",
      "info": "t:global.common.infos.seo_heading.label",
      "default": "h3",
      "options": [
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        },
        {
          "value": "h4",
          "label": "H4"
        },
        {
          "value": "h5",
          "label": "H5"
        },
        {
          "value": "h6",
          "label": "H6"
        }
      ]
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "t:global.common.heading_alignment.label",
      "default": "text-center",
      "options": [
        {
          "label": "t:global.common.heading_alignment.options.left.label",
          "value": "text-left"
        },
        {
          "label": "t:global.common.heading_alignment.options.center.label",
          "value": "text-center"
        }
      ]
    },
    {
      "type": "paragraph",
      "content": "t:global.header.color_section.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "primary",
      "label": "t:global.header.color_scheme.label"
    },
    {
      "type": "color",
      "id": "section_background",
      "label": "t:global.common.section_background.label",
      "info": "t:global.common.section_background.info"
    },
    {
      "type": "color",
