<link rel="preload" as="style" href="{{ 'social-gallery.css' | asset_url }}">
{{ 'social-gallery.css' | asset_url | stylesheet_tag }}

<div class="section-container {{ section.settings.color_scheme }}-scheme {% if section.settings.make_section_rounded %}section-rounded{% endif %}">
    <div class="{{ settings.container_width }}">
        <div class="section-heading-box {% if section.settings.description != blank %} desc-enabled{% endif %} {{ section.settings.content_alignment }}" {% if settings.enable_animation %}data-aos="fade-up" data-aos-duration="1000"{% endif %}>
            {% if section.settings.heading != blank %}
            {%- capture sectionhighlightPrefix -%}
              <strong class="highlight-text">
            {%- endcapture -%}
            {%- capture sectionhighlightSuffix -%}
              </strong>
            {%- endcapture -%}
              <{{ section.settings.seo_heading }} class="section-heading {{ section.settings.heading_size }}">
                {{ section.settings.heading | replace: "<strong>", sectionhighlightPrefix | replace: "</strong>", sectionhighlightSuffix | replace: '++', '<br>' }}
              </{{ section.settings.seo_heading }}>
            {% endif %}
            {%- if section.settings.description != blank -%}
              <div class="section-description">
                {{ section.settings.description | newline_to_br }}
              </div>
            {%- endif -%}
        </div>
        {% if section.blocks.size>0 %}
          <div class="social-media-wrapper {% if section.settings.enable_swipe_mobile %} mobile-swipe{% endif %}">
            {% for block in section.blocks %}
              {% assign aosDelay = forloop.index | times: 50 %}
              <{% if block.settings.link != blank %}a href="{{ block.settings.link }}" aria-label="{{ section.settings.social_media_icon }}" {%else%}div{% endif %} class="social-media-item"  {% if settings.enable_animation %}data-aos="fade-up" data-aos-delay="{{ aosDelay }}"{% endif %}>
                  <div class="social-media-image">
                    {%- liquid
                      case section.settings.media_image_size
                        when 'landscape'
                        assign imageRatio = 75
                        when 'square'
                        assign imageRatio = 100
                        when 'portrait'
                        assign imageRatio = 125
                        when 'auto'
                          if block.settings.video != blank 
                            assign imageRatio = block.settings.video.aspect_ratio | times: 100 | plus: 1 
                          elsif block.settings.image != blank 
                            assign imageRatio =  block.settings.image.aspect_ratio | times: 100 | plus: 1 
                          else
                            assign imageRatio = 100
                          endif
                      endcase
                    %}
                      
                      <div class="media-box" style="--image-ratio:{{ imageRatio }}%">
                        {% if block.settings.video != blank %}
                          <deferred-media >
                            <template style="display:none">
                              {{ 
                                block.settings.video | video_tag:  image_size: '1100x',
                                  class: 'social-gallery-video', 
                                  autoplay:true,
                                  loop:true,
                                  controls: false,
                                  muted:true
                              }} 
                            </template>
                            <noscript>
                              <img
                                src="{{ block.settings.video.preview_image | image_url: '1100x' }}"
                                alt="{{ block.settings.video.preview_image.alt | default: shop.name | strip_html }}"
                                width="{{ block.settings.video.preview_image.width }}"
                                height="{{ block.settings.video.preview_image.height }}"
                              >
                            </noscript>
                          </deferred-media>
                          {% elsif block.settings.image != blank %}
                            {% render 'image', image: block.settings.image, class: 'media_image' %}
                          {% else%}
                            {{ 'detailed-apparel-1' | placeholder_svg_tag: 'placeholder-svg'}}
                        {% endif %}
                      </div>
                  </div>
                  {% if section.settings.social_media_icon != 'none' or block.settings.heading != blank  %}
                    <div class="social-media-content">
                        <div class="social-media-content-inner">
                          {% if section.settings.social_media_icon != 'none' %}
                              <span class="social-media-icon">
                                {% render 'social-icons',icon : section.settings.social_media_icon %}
                              </span>
                          {% endif %}
                            {% if block.settings.heading != blank %}
                              <span class="social-media-title">{{ block.settings.heading }}</span>
                            {% endif %}
                        </div>
                    </div>
                  {% endif  %}
              </{% if block.settings.link != blank %}a{%else%}div{% endif %}>
            {% endfor %}
          </div>
       {% endif %}
    </div>
</div>
<style>
    #shopify-section-{{ section.id }} {
      {% if section.settings.make_section_rounded %}
        background:{{ section.settings.section_background }};
      {% endif %}
      --column-count:{{ section.blocks.size }};
      --top-spacer:{{ section.settings.top_space_desktop }}px;
      --bottom-spacer:{{ section.settings.bottom_space_desktop }}px;
      --highlight-text: {{ section.settings.highlighted_color }};
      --overlay-background:{{ section.settings.overlay_background }};
      --overlay-opacity:{{ section.settings.overlay_opacity }};
      --overlay-color:{{ section.settings.overlay_color }};
    }
    @media only screen and (max-width:767px) {
        #shopify-section-{{ section.id }}{
          --top-spacer:{{ section.settings.top_space_mobile }}px;
          --bottom-spacer:{{ section.settings.bottom_space_mobile }}px;
        }
    }
    {% if section.settings.section_visibility == 'large' %}
        @media (max-width: 767px) {
            #shopify-section-{{ section.id }}{
                display: none !important;
            }
        }
    {% elsif section.settings.section_visibility == 'small' %}
        @media (min-width: 768px) {
            #shopify-section-{{ section.id }}{
            display: none !important;
            }
        }
    {% endif %}
</style>
