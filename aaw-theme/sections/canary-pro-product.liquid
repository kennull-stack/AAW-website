  <section class="cp-final">
    <div class="cp-wrap">
      <p class="cp-kicker">Canary Pro</p>
      <h2>Fourteen drivers, blue-fire faceplates, and a tuning made to stay vivid.</h2>
      <form class="cp-actions cp-actions--center" method="post" action="/cart/add">
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
        <input type="hidden" name="quantity" value="1">
        <button class="cp-btn" type="submit">Buy Canary Pro</button>
      </form>
    </div>
  </section>
</div>

