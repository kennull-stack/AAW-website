<script type="application/ld+json">
{
  "@context": "https://schema.org/",
  "@type": "Product",
  "@id": {{ canonical_url | append: "#product" | json }},
  "name": "AAW Canary Pro 14-Driver Isobaric Electrostatic In-Ear Monitor",
  "image": [
    {{ 'canary-pro-cable-player-instagram.jpg' | asset_url | prepend: 'https:' | json }},
    {{ 'canary-pro-faceplate-angle.jpg' | asset_url | prepend: 'https:' | json }},
    {{ 'canary-pro-exploded-serial.png' | asset_url | prepend: 'https:' | json }}
  ],
  "description": "Canary Pro is a 14-driver tri-hybrid in-ear monitor from Singapore-based Advanced AcousticWerkes. It combines quad electrostatic super tweeters, dual isobaric dynamic woofers, eight balanced armatures, a 5-way passive crossover, and Super-Low Flat Impedance (SLFI) to deliver consistent tuning across sources.",
  "sku": {{ product.selected_or_first_available_variant.sku | default: "CANARY-PRO" | json }},
  "mpn": "Canary Pro",
  "brand": {"@id": "https://www.aaw.me/#organization"},
  "designer": {
    "@type": "Person",
    "name": "Kevin Wang",
    "jobTitle": "Founder & Tuning Engineer",
    "description": "Founder and tuning engineer of Advanced AcousticWerkes, responsible for the acoustic design and tuning of AAW in-ear monitors.",
    "knowsAbout": ["in-ear monitor tuning", "hybrid IEM design", "balanced armature drivers", "electrostatic driver integration", "isobaric woofer design", "custom in-ear monitors", "universal in-ear monitors"],
    "worksFor": {"@id": "https://www.aaw.me/#organization"}
  },
  "category": "Universal In-Ear Monitor",
  "offers": {
    "@type": "Offer",
    "url": {{ canonical_url | json }},
    "priceCurrency": {{ cart.currency.iso_code | default: shop.currency | json }},
    "price": {{ product.selected_or_first_available_variant.price | money_without_currency | remove: ',' | json }},
    "availability": "https://schema.org/{% if product.selected_or_first_available_variant.available %}InStock{% else %}OutOfStock{% endif %}",
    "itemCondition": "https://schema.org/NewCondition",
    "seller": {"@id": "https://www.aaw.me/#organization"},
    "hasMerchantReturnPolicy": {
      "@type": "MerchantReturnPolicy",
      "url": "https://www.aaw.me/pages/shipping-return",
      "applicableCountry": "SG",
      "returnPolicyCategory": "https://schema.org/MerchantReturnFiniteReturnWindow",
      "merchantReturnDays": 7,
      "returnMethod": "https://schema.org/ReturnByMail",
      "returnFees": "https://schema.org/ReturnShippingFees"
