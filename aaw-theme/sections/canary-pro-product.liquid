  "additionalProperty": [
    {"@type": "PropertyValue", "name": "Driver Configuration", "value": "14-driver tri-hybrid: 2 dynamic woofers, 8 balanced armatures, 4 electrostatic super tweeters"},
    {"@type": "PropertyValue", "name": "Woofer System", "value": "Dual isobaric dynamic drivers"},
    {"@type": "PropertyValue", "name": "Crossover", "value": "5-way passive crossover"},
    {"@type": "PropertyValue", "name": "Impedance Design", "value": "Super-Low Flat Impedance (SLFI)"},
