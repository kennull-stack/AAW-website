<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What makes Canary Pro different from the original Canary?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Canary Pro keeps the hybrid Canary identity but rebuilds it around a 14-driver matrix: quad electrostatic super tweeters, dual isobaric dynamic woofers, eight balanced armatures, a 5-way passive crossover, and Super-Low Flat Impedance for consistent source pairing."
      }
    },
    {
      "@type": "Question",
      "name": "What is the driver configuration?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "2 isobaric dynamic woofers, 2 low-range BA, 2 mid-range BA, 4 mid-high BA, and 4 electrostatic super tweeters. The five driver groups are managed by a 5-way passive crossover."
      }
    },
    {
      "@type": "Question",
      "name": "What does SLFI do and why does it matter?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Super-Low Flat Impedance reshapes the balanced armature electrical load from inductive toward resistive, holding the monitor near 7 Ohm across the frequency range. This reduces tonal shifts when switching between sources with different output impedances."
      }
    },
    {
      "@type": "Question",
      "name": "What is the isobaric woofer system?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Two dynamic drivers are arranged in an isobaric (constant-pressure) configuration. This doubles the effective diaphragm area and improves low-end control without increasing the shell size."
      }
    },
    {
      "@type": "Question",
      "name": "Is Canary Pro suitable for stage monitoring?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Canary Pro is designed for critical listening and professional use. The custom-fit option provides additional isolation and stability for stage work. Final suitability depends on personal fit, isolation needs, and monitoring level."
      }
    },
    {
      "@type": "Question",
      "name": "What source is recommended for Canary Pro?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "With 106dB sensitivity and a flat 7 Ohm impedance, Canary Pro pairs well with most portable players, dongles, DAPs, and desktop amplifiers. A clean, low-output-impedance source is recommended for lowest noise floor."
      }
    },
    {
      "@type": "Question",
      "name": "What is the difference between universal and custom fit?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The universal model ships with SpinFit silicone tips, AAW foam tips, and assorted silicone tips for an immediate fit. Custom-fit monitors are shaped from ear impressions for a personalized seal. Both share the same 14-driver acoustic design."
      }
    },
    {
      "@type": "Question",
      "name": "What comes in the box?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Canary Pro includes a 48-inch Null Audio Lune cable with 4.4mm balanced termination, leather carry case, cleaning tool, owner's club card, SpinFit silicone tips, AAW foam tips, assorted silicone tips, and a 1-year limited warranty."
      }
    },
    {
      "@type": "Question",
      "name": "Does Canary Pro come with a warranty?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Canary Pro includes a 1-year limited warranty covering manufacturing defects under normal use. For support, contact AAW Singapore or the authorized dealer where you purchased it."
      }
    },
    {
      "@type": "Question",
      "name": "Where can I demo Canary Pro?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "In Singapore, you can audition Canary Pro at the AAW Office, Zeppelin & Co., JABEN, or AV One. Outside Singapore, AAW works with specialist audio stores across Hong Kong, Japan, China, South Korea, and Thailand. Use the store locator to find the closest listening point."
      }
    }
  ]
}
</script>

