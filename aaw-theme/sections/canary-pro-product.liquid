  <section class="cp-section cp-artwork">
    <div class="cp-wrap cp-artwork__grid">
      <figure>
        {% render 'aaw-responsive-asset-image', file: 'canary-pro-singapore-packaging.jpg', alt: 'Canary Pro illustrated packaging held in Singapore with Merlion, skyline, orchid, and canary identity artwork', width: '1440', height: '1440', loading: 'lazy' %}
