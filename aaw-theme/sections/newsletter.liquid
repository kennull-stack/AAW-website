
<link rel="preload" as="style" href="{{ 'newsletter.css' | asset_url }}">
{{ 'newsletter.css' | asset_url | stylesheet_tag }}
<div class="section-container {{ section.settings.color_scheme }}-scheme {% if section.settings.make_section_rounded %}section-rounded{% endif %}">
  {% if section.settings.newsletter_background and section.settings.background_image != blank %}
    <div class="newsletter-background" {% if settings.enable_animation %}data-aos="zoom-out" data-aos-delay="100"{% endif %}>
      {% render 'image', image: section.settings.background_image %}
    </div>
  {% endif %}
  <div class="{{ settings.container_width }}">
    <div class="newsletter-box content-{{ section.settings.content_postion }} {{ section.settings.content_alignment }}" {% if settings.enable_animation %}data-aos="fade-up" data-aos-delay="100"{% endif %}>
      {% if section.settings.heading != blank %}
        {%- capture sectionhighlightPrefix -%}
            <strong class="highlight-text">
            {%- endcapture -%}

            {%- capture sectionhighlightSuffix -%}
            </strong>
            {%- endcapture -%}

        <{{ section.settings.seo_heading }} class="{{ section.settings.heading_size }} newsletter-heading" >
          {{ section.settings.heading | replace: "<strong>", sectionhighlightPrefix | replace: "</strong>", sectionhighlightSuffix | replace: '++', '<br>' }}
        </{{ section.settings.seo_heading }}>
      {% endif %}
     
      {%- form 'customer', class: 'newsletter-form' -%}

      
        <input type="hidden" name="contact[tags]" value="newsletter">
        <div class="newsletter-form-box">
          <input
            id="Email-{{ section.id }}"
            type="email"
            name="contact[email]"
            class="form-control enter-email"
            value="{{ form.email }}"
            aria-required="true"
            autocorrect="off"
            autocapitalize="off"
            autocomplete="email"
            {% if form.errors %}
              autofocus
              aria-invalid="true"
              aria-describedby="Newsletter-error-{{ section.id }}"
            {% elsif form.posted_successfully? %}
              aria-describedby="Newsletter-success-{{ section.id }}"
            {% endif %}
            placeholder="{% if section.settings.placeholder != blank %}{{ section.settings.placeholder }}{% else %}{{ 'newsletter.label' | t }}{% endif %}"
            pattern="^([a-zA-Z0-9_\-\.]+)@((\[[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.)|(([a-zA-Z0-9\-]+\.)*[a-zA-Z]{2,}))$"
            required
          >
          <button type="submit" name="commit" id="Subscribe-{{ section.id }}" class="newsletter-btn arrow-btn" aria-label="Newsletter">
            {% comment %} <span>{{ section.settings['btn-text'] | default: 'Subscribe' }}</span> {% endcomment %}
            <svg class="arrow-btn-icon1" width="15" height="15" viewBox="0 0 15 15" fill="none">
                <path fill-rule="evenodd" clip-rule="evenodd" d="M7.07031 0L14.1414 7.07107L7.07031 14.1421L5.76824 12.8401L10.6166 7.99173L0.95721 7.9917L0.957199 6.15032L10.6166 6.15035L5.76827 1.30205L7.07031 0Z" fill="currentColor"></path>
            </svg>
            <svg class="arrow-btn-icon2" width="15" height="15" viewBox="0 0 15 15" fill="none">
              <path fill-rule="evenodd" clip-rule="evenodd" d="M7.07031 0L14.1414 7.07107L7.07031 14.1421L5.76824 12.8401L10.6166 7.99173L0.95721 7.9917L0.957199 6.15032L10.6166 6.15035L5.76827 1.30205L7.07031 0Z" fill="currentColor"></path>
          </svg>
          </button>
        </div>
        {%- if form.errors -%}
          <div class="error-message no-bg" id="Newsletter-error-{{ section.id }}" tabindex="-1">
            {{- form.errors.translated_fields.email | capitalize }}
            {{ form.errors.messages.email -}}
          </div>
        {%- endif -%}

        {%- if form.posted_successfully? -%}
          <p class="success-message no-bg" id="Newsletter-success-{{ section.id }}" tabindex="-1">
            {{- 'newsletter.success' | t -}}
          </p>
      
        {%- endif -%}
     
      {% endform %}
    </div>
  </div>
</div>
<style>
  #shopify-section-{{ section.id }}.shopify-section {
    {% if section.settings.make_section_rounded %}
      background:{{ section.settings.section_background }};
    {% endif %}
    --top-spacer:{{ section.settings.top_space_desktop }}px;
    --bottom-spacer:{{ section.settings.bottom_space_desktop }}px;
    --highlight-text: {{ section.settings.highlighted_color }};
    --overlay-background: {{ section.settings.image_overlay_color }};
    --overlay-opacity: {{ section.settings.image_overlay_opacity }};
  }
  @media only screen and (max-width:767px) {
    #shopify-section-{{ section.id }}.shopify-section{
      --top-spacer:{{ section.settings.top_space_mobile }}px;
      --bottom-spacer:{{ section.settings.bottom_space_mobile }}px;
    }
  }

  {% if section.settings.section_visibility == 'large' %}
    @media (max-width: 767px) {
      #shopify-section-{{ section.id }}{
        display: none !important;
      }
    }
  {% elsif section.settings.section_visibility == 'small' %}
    @media (min-width: 768px) {
      #shopify-section-{{ section.id }}{
        display: none !important;
      }
    }
  {% endif %}
</style>

{% schema %}
{
  "name": "t:sections.newsletter.name",
  "tag": "section",
  "disabled_on": {
    "groups": [
      "header",
      "footer"
    ]
  },
  "class": "newsletter",
  "settings": [
    {
      "type": "select",
      "id": "section_visibility",
      "label": "t:global.common.section_visibility.label",
      "default": "always",
      "options": [
        {
          "label": "t:global.common.section_visibility.options.always",
          "value": "always"
        },
        {
          "label": "t:global.common.section_visibility.options.small",
          "value": "small"
        },
        {
          "label": "t:global.common.section_visibility.options.large",
          "value": "large"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "make_section_rounded",
      "label": "t:global.common.general_labels.make_section_rounded",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "newsletter_background",
      "label": "t:sections.newsletter.settings.newsletter_background.label",
      "default": false
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "t:sections.newsletter.settings.background_image.label"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "t:global.common.general_labels.heading",
      "info": "t:global.common.infos.heading.label",
      "default": "Join our newsletter"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "t:global.common.general_labels.heading_size",
      "default": "h2",
      "options": [
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        },
        {
          "value": "h4",
          "label": "H4"
        },
        {
          "value": "h5",
          "label": "H5"
        },
        {
          "value": "h6",
          "label": "H6"
        }
      ]
    },
    {
      "type": "select",
      "id": "seo_heading",
      "label": "t:global.common.general_labels.heading_tag",
      "info": "t:global.common.infos.seo_heading.label",
      "default": "h2",
      "options": [
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        },
        {
          "value": "h4",
          "label": "H4"
        },
        {
          "value": "h5",
          "label": "H5"
        },
        {
          "value": "h6",
          "label": "H6"
        }
      ]
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "t:sections.newsletter.settings.placeholder.label"
    },
    {
      "type": "header",
      "content": "t:global.header.content_section.label"
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "t:sections.newsletter.settings.content_alignment.label",
      "default": "text-center",
      "options": [
        {
          "label": "t:global.common.alignments.left",
          "value": "text-left"
        },
        {
          "label": "t:global.common.alignments.center",
          "value": "text-center"
        },
        {
          "label": "t:global.common.alignments.right",
          "value": "text-right"
        }
      ]
    },
    {
      "type": "select",
      "id": "content_postion",
      "label": "t:sections.newsletter.settings.content_postion.label",
      "default": "center",
      "options": [
        {
          "value": "left",
          "label": "t:global.common.alignments.left"
        },
        {
          "value": "center",
          "label": "t:global.common.alignments.center"
        },
        {
          "value": "right",
          "label": "t:global.common.alignments.right"
        }
      ]
    },
    {
      "type": "header",
      "content": "t:global.header.color_section.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "tertiary",
      "label": "t:global.header.color_scheme.label"
    },
    {
      "type": "color",
      "id": "section_background",
      "label": "t:global.common.section_background.label",
      "info": "t:global.common.section_background.info"
    },
    {
      "type": "color",
      "id": "highlighted_color",
      "default": "#EFF341",
      "label": "t:global.common.general_labels.highlight_color"
    },
    {
      "type": "color",
      "id": "image_overlay_color",
      "default": "#000000",
      "label": "t:sections.newsletter.settings.image_overlay_color.label",
      "info": "It is applicable with the background image only."
    },
    {
      "type": "range",
      "id": "image_overlay_opacity",
      "label": "t:global.common.general_labels.opacity",
      "default": 0.5,
      "min": 0,
      "max": 1,
      "step": 0.1
    },
    {
      "type": "header",
      "content": "t:global.header.space_section.label"
    },
    {
      "type": "range",
      "id": "top_space_desktop",
      "label": "t:global.top_space_desktop.label",
      "default": 100,
      "min": 0,
      "max": 100,
      "step": 5
    },
    {
      "type": "range",
      "id": "bottom_space_desktop",
      "label": "t:global.bottom_space_desktop.label",
      "default": 100,
      "min": 0,
      "max": 100,
      "step": 5
    },
    {
      "type": "range",
      "id": "top_space_mobile",
      "label": "t:global.top_space_mobile.label",
      "default": 50,
      "min": 0,
      "max": 100,
      "step": 5
    },
    {
      "type": "range",
      "id": "bottom_space_mobile",
      "label": "t:global.bottom_space_mobile.label",
      "default": 50,
      "min": 0,
      "max": 100,
      "step": 5
    }
  ],
  "presets": [
    {
      "name": "t:sections.newsletter.presets.name"
    }
  ]
}
{% endschema %}
