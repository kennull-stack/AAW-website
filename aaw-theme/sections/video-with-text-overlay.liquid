<link rel="preload" as="style" href="{{ 'video-text-overlay.css' | asset_url }}">
{{ 'video-text-overlay.css' | asset_url | stylesheet_tag }}
<div class="section-container {{ section.settings.color_scheme }}-scheme {% if section.settings.make_section_rounded %}section-rounded{% endif %}">
  {%- capture sectionhighlightPrefix -%}
      <strong class="highlight-text">
  {%- endcapture -%}
  {%- capture sectionhighlightSuffix -%}
    </strong>
  {%- endcapture -%}  
  <div class="video-text-overlay-wrapper">
    <div class="video-text-overlay-media">
      {% if section.settings.video != blank or section.settings.video_url != blank  %}
        <deferred-media class="deferred-media autoplay-status-true" data-type="{{ section.settings.video_url.type }}">
          <template>
            {% if section.settings.video != blank %}
              <video
                class="videoBackgroundFile"
                autoplay muted loop playsinline
                data-autoplay="true"
                data-video-image-wrapper
              >
                <source
                  src="{% if section.settings.video.sources[0].url contains 'mp4' %}{{ section.settings.video.sources[0].url -}}{% else %}{{ section.settings.video.sources[1].url -}}{% endif %}"
                  type="video/mp4"
                >
              </video>
            {% elsif section.settings.video_url != blank %}
              {%- if section.settings.video_url.type == 'youtube' -%}
                <iframe
                  src="https://www.youtube.com/embed/{{ section.settings.video_url.id }}?autoplay=1&mute=1&loop=1&controls=0&rel=0&showinfo=0&enablejsapi=1&playlist={{ section.settings.video_url.id }}"
                  class="youtube_video"
                  allow="autoplay; encrypted-media"
                  allowfullscreen
                  data-autoplay="true"
                  title="youtube"
                ></iframe>
              {%- elsif section.settings.video_url.type == 'vimeo' -%}
                <iframe
                  src="https://player.vimeo.com/video/{{ section.settings.video_url.id }}?autoplay=1&loop=1&autopause=0&muted=1"
                  class="vimeo_video"
                  allow="autoplay; fullscreen encrypted-media"
                  data-autoplay="true"
                  allowfullscreen
                  title="vimeo"
                ></iframe>
              {%- endif -%}
            {% endif %}
          </template>
        </deferred-media>
      {% elsif section.settings.cover_image != blank  %}
        {% render 'image', image: section.settings.cover_image %}
      {% else %}
        {{ 'hero-apparel-3' | placeholder_svg_tag: 'placeholder-svg placeholder' }}
      {% endif %}
      <div class="video-text-overlay-media-overlay"></div>
    </div>
    {% if section.blocks.size>0 %}
      <div class="video-text-overlay-content container" data-text-overlay-content>
          <div class="video-text-overlay-content-inner  content-{{ section.settings.blocks_content_position }}">
            {% for block in section.blocks %}
              {% if  block.settings.heading  !=  blank or  block.settings.title_text != blank or block.settings.description != blank %}
              <div class="video-text-overlay-content-heading" data-text-overlay-inner >
                <div class="" data-animate="fade-up-large">
                {% if  block.settings.heading  !=  blank  %}
                  <{{ block.settings.seo_heading }} class="video-text-overlay-content-title {{ block.settings.heading_size }}">
                    {{ block.settings.heading | replace: "<strong>", sectionhighlightPrefix | replace: "</strong>", sectionhighlightSuffix | replace: '++', '<br>' }}
                  </{{ block.settings.seo_heading }}>
                {% endif %}
                {% if block.settings.title_text != blank %}
                <p class="video-text-overlay-content-subheading h4">{{  block.settings.title_text }}</p>
                {% endif %}
                {% if block.settings.description != blank %}
                  <p class="video-text-overlay-content-description">{{ block.settings.description  }}</p>
                {% endif %}
              </div>
              </div>
            {% endif %}
            {% endfor %}
          </div>
      </div>
    {% endif %}
  </div>
</div>
<style>
    #shopify-section-{{ section.id }}{
      {% if section.settings.make_section_rounded %}
        background:{{ section.settings.section_background }};
      {% endif %}
      --highlight-text: {{ section.settings.highlighted_color }};
      --overlay-color: {{  section.settings.overlay_background}};
      --overlay-opacity:{{ section.settings.overlay_opacity | divided_by: 100.0 }};
    }
   
    {% if section.settings.section_visibility == 'large' %}
      @media (max-width: 767px) {
        #shopify-section-{{ section.id }}{
          display: none !important;
        }
      }
    {% elsif section.settings.section_visibility == 'small' %}
      @media (min-width: 768px) {
        #shopify-section-{{ section.id }}{
          display: none !important;
        }
      }
    {% endif %}
  </style>
  {% schema %}
{
  "name": "t:sections.video_text_overlay.name",
  "tag": "section",
  "class": "video-text-overlay",
  "disabled_on": {
    "groups": [
      "header",
      "footer"
    ]
  },
  "settings": [
    {
      "type": "select",
      "id": "section_visibility",
      "label": "t:global.common.section_visibility.label",
      "default": "always",
      "options": [
        {
          "label": "t:global.common.section_visibility.options.always",
          "value": "always"
        },
        {
          "label": "t:global.common.section_visibility.options.small",
          "value": "small"
        },
        {
          "label": "t:global.common.section_visibility.options.large",
          "value": "large"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "make_section_rounded",
      "label": "t:global.common.general_labels.make_section_rounded",
      "default": false
    },
    {
      "type": "image_picker",
      "id": "cover_image",
      "label": "t:sections.video_text_overlay.settings.cover_image.label",
      "info": "t:sections.video_text_overlay.settings.cover_image.info"
    },
    {
      "type": "video_url",
      "id": "video_url",
      "label": "t:sections.video_text_overlay.settings.video_url.label",
      "default": "https://www.youtube.com/watch?v=_9VUPq3SxOc",
      "accept": [
        "youtube",
        "vimeo"
      ]
    },
    {
      "type": "video",
      "id": "video",
      "label": "t:sections.video_text_overlay.settings.video.label"
    },
    {
      "type":"select",
      "id":"blocks_content_position",
      "label":"t:sections.video_text_overlay.settings.blocks_content_position.label",
      "default":"center",
      "options": [
        {
          "label":"t:sections.video_text_overlay.settings.blocks_content_position.options.left.label",
          "value":"left"
        },
        {
          "label":"t:sections.video_text_overlay.settings.blocks_content_position.options.center.label",
          "value":"center"
        },
        {
          "label":"t:sections.video_text_overlay.settings.blocks_content_position.options.right.label",
          "value":"right"
        }
      ]
    },
    {
      "type": "header",
      "content": "t:global.header.color_section.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "secondary",
      "label": "t:global.header.color_scheme.label"
    },
    {
      "type": "color",
      "id": "section_background",
      "label": "t:global.common.section_background.label",
      "info": "t:global.common.section_background.info"
    },
    {
      "type": "color",
      "id": "highlighted_color",
      "default": "#EFF341",
      "label": "t:global.common.general_labels.highlight_color"
    },
    {
      "type": "color",
      "id": "overlay_background",
      "label": "t:global.common.general_labels.overlay",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "t:global.common.general_labels.overlay_opacity",
      "default": 0,
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%"
    }
  ],
  "blocks": [
   {
    "type":"text",
    "name":"t:global.common.general_labels.content",
    "settings": [
      {
        "type": "inline_richtext",
        "id": "heading",
        "default":"Heading here",
        "label": "t:global.common.general_labels.heading",
        "info": "t:global.common.infos.heading.label"
     
      },
      {
        "type": "select",
        "id": "heading_size",
        "label": "t:global.common.general_labels.heading_size",
        "default": "h2",
        "options": [
          {
            "value": "h1",
            "label": "H1"
          },
          {
            "value": "h2",
            "label": "H2"
          },
          {
            "value": "h3",
            "label": "H3"
          },
          {
            "value": "h4",
            "label": "H4"
          },
          {
            "value": "h5",
            "label": "H5"
          },
          {
            "value": "h6",
            "label": "H6"
          }
        ]
      },
      {
        "type": "select",
        "id": "seo_heading",
        "label": "t:global.common.general_labels.heading_tag",
        "info": "t:global.common.infos.seo_heading.label",
        "default": "h2",
        "options": [
          {
            "value": "h1",
            "label": "H1"
          },
          {
            "value": "h2",
            "label": "H2"
          },
          {
            "value": "h3",
            "label": "H3"
          },
          {
            "value": "h4",
            "label": "H4"
          },
          {
            "value": "h5",
            "label": "H5"
          },
          {
            "value": "h6",
            "label": "H6"
          }
        ]
      },
      {
        "type":"text",
        "id":"title_text",
        "label":"t:global.common.general_labels.subheading",
        "default":"Subheading here"
        
      },
      {
        "type":"textarea",
        "id":"description",
        "label":"t:global.common.general_labels.description",
        "default":"Add short description here"
        
      }
    ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.video_text_overlay.presets.name",
      "blocks":[
        {
          "type":"text"
        },
        {
          "type":"text"
        },
        {
          "type":"text"
        },
        {
          "type":"text"
        },
        {
          "type":"text"
        }
    ]
    }
  ]
}
{% endschema %}