{{ 'event-calender.css' | asset_url | stylesheet_tag }}
<div class="section-container {{ section.settings.color_scheme }}-scheme {% if section.settings.make_section_rounded %}section-rounded{% endif %}">
  <div class="{{ settings.container_width }}">
    {% if section.settings.heading != blank %}

      {%- capture sectionhighlightPrefix -%}
        <strong class="highlight-text">
      {%- endcapture -%}

      {%- capture sectionhighlightSuffix -%}
        </strong>
      {%- endcapture -%}

      <div class="section-heading-box {{ section.settings.heading_alignment }}" {% if settings.enable_animation %}data-aos="fade-up" data-aos-duration="1000"{% endif %}>
        <{{ section.settings.seo_heading }} class="section-heading {{ section.settings.heading_size }}">
          {{ section.settings.heading | replace: "<strong>", sectionhighlightPrefix | replace: "</strong>", sectionhighlightSuffix | replace: '++', '<br>' }}
        </{{ section.settings.seo_heading }}>
      </div>
    {% endif %}
    {% if section.blocks.size > 0 %}
      <div class="event-calender-wrapper">
        <div class="row">
          {% for block in section.blocks %}
            {% assign aosDelay = forloop.index | times: 100  %}
            {% if block.settings.image != blank
              or block.settings.date != blank
              or block.settings.title != empty
              or block.settings.description != empty
              or block.settings.time != empty
              or block.settings.link_text != blank
              and block.settings.link_url
            %}
              <div class="col-12 col-sm-12 col-md-4 col-lg-4" {% if settings.enable_animation %}data-aos="fade-up" data-aos-delay="{{aosDelay}}"{% endif %} {{ block.shopify_attributes }}>
                <div class="event-calender-item">
                  {% if block.settings.image != blank or block.settings.date != blank %}
                    <div class="event-calender-img-box{% if block.settings.image == blank %} no-img{% elsif block.settings.date == blank %} no-date{% endif %}">
                      {% if block.settings.date != blank %}
                        {%- liquid
                          assign day = block.settings.date | date: '%d'
                          assign month = block.settings.date | date: '%b'
                        -%}
                        <div class="event-calender-date">
                          <span class="event-calender-date-day heading-font h3">{{ day }}</span>
                          <span class="event-calender-date-month heading-font">{{ month }}</span>
                        </div>
                      {% endif %}

                      {%liquid
                        if section.settings.event_image_size == 'landscape'
                            assign imageRatio = 75
                        elsif section.settings.event_image_size == 'square'
                            assign imageRatio = 100
                        elsif section.settings.event_image_size == 'portrait'
                            assign imageRatio = 125
                        else 
                            if block.settings.image != blank 
                                assign imageRatio = 1 | divided_by: block.settings.image.aspect_ratio | times: 100 | plus: 1 
                            elsif collection.featured_image 
                                assign imageRatio = 1 | divided_by: collection.featured_image.aspect_ratio | times: 100 | plus: 1 
                            else  
                                assign imageRatio = 100 
                            endif 
                        endif 
                    -%}


                      {% if block.settings.image != blank %}
                        <div class="event-calender-img">
                          <div class="media-box" style="--image-ratio:{{ imageRatio }}%">
                            {%- render 'image', image: block.settings.image, sizes: '[500]' -%}
                          </div>
                        </div>
                      {% endif %}
                    </div>
                  {% endif %}
                  <div class="event-calender-content">
                    {%- if block.settings.title != empty -%}
                      <h5 class="event-calender-heading">{{ block.settings.title }}</h5>
                    {% endif %}
                    {%- if block.settings.description != empty -%}
                      <div class="event-calender-description rte">
                        {{ block.settings.description | replace: '<p></p>', '<br>' }}
                      </div>
                    {% endif %}
                    <ul class="event-calender-info-list">
                      {%- if block.settings.location != empty -%}
                        <li class="event-location">
                          {% capture location %}
                                <svg width="8" height="12" viewBox="0 0 8 12" fill="none">
                                  <path d="M4 0C1.78857 0 0 1.878 0 4.2C0 7.35 4 12 4 12C4 12 8 7.35 8 4.2C8 1.878 6.21143 0 4 0ZM4 5.7C3.21143 5.7 2.57143 5.028 2.57143 4.2C2.57143 3.372 3.21143 2.7 4 2.7C4.78857 2.7 5.42857 3.372 5.42857 4.2C5.42857 5.028 4.78857 5.7 4 5.7Z" fill="currentColor"/>
                                </svg>
                                {{ block.settings.location }}
                              {% endcapture %}
                          {% if block.settings.location_url %}
                            <a
                              href="{{ block.settings.location_url }}"
                              target="_blank"
                              class="event-location-child"
                            >
                              {{ location }}
                            </a>
                          {% else %}
                            <span class="event-location-child">
                              {{ location }}
                            </span>
                          {% endif %}
                        </li>
                      {% endif %}
                      {%- if block.settings.time != empty -%}
                        <li class="event-timing">
                          <span class="event-location-child">
                            <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
                              <path d="M6 12C9.31235 12 12 9.31235 12 6C12 2.68765 9.31235 0 6 0C2.68765 0 0 2.68765 0 6C0 9.31235 2.68765 12 6 12ZM5.30266 2.90557C5.30266 2.67312 5.49152 2.48426 5.72397 2.48426C5.95642 2.48426 6.14528 2.67312 6.14528 2.90557V6.08717L7.90315 7.4092C8.09201 7.55448 8.12107 7.81598 7.99031 8.00484C7.90315 8.12106 7.78692 8.17918 7.65617 8.17918C7.56901 8.17918 7.48184 8.15012 7.4092 8.09201L5.477 6.63923C5.3753 6.56659 5.30266 6.43583 5.30266 6.30508V2.90557Z" fill="currentColor"/>
                            </svg>
                            {{ block.settings.time }}
                          </span>
                        </li>
                      {% endif %}
                    </ul>
                    {%- if block.settings.link_text != blank and block.settings.link_url -%}
                      <a
                        href="{{ block.settings.link_url }}"
                        class="text-underline event-button "
                        aria-label="{{ block.settings.link_text }}"
                      >
                        {{ block.settings.link_text -}}
                      </a>
                    {%- endif -%}
                  </div>
                </div>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    {% endif %}
  </div>
</div>
<style>
  #shopify-section-{{ section.id }}.shopify-section {
      --top-spacer:{{ section.settings.top_space_desktop }}px;
      --bottom-spacer:{{ section.settings.bottom_space_desktop }}px;
      --highlight-text: {{ section.settings.highlighted_color }};
      {% if section.settings.make_section_rounded %}
        background:{{ section.settings.section_background }};
      {% endif %}
  }
  @media only screen and (max-width:767px) {
      #shopify-section-{{ section.id }}.shopify-section{
          --top-spacer:{{ section.settings.top_space_mobile }}px;
          --bottom-spacer:{{ section.settings.bottom_space_mobile }}px;
      }
  }
  {% if section.settings.section_visibility == 'large' %}
      @media (max-width: 767px) {
          #shopify-section-{{ section.id }}{
              display: none !important;
          }
      }
  {% elsif section.settings.section_visibility == 'small' %}
      @media (min-width: 768px) {
          #shopify-section-{{ section.id }}{
              display: none !important;
          }
      }
  {% endif %}
</style>
{% schema %}
{
  "name": "t:sections.event-calender.name",
  "tag": "section",
  "class": "event-calender",
  "disabled_on": {
    "groups": [
      "header",
      "footer"
    ]
  },
  "settings": [
    {
      "type": "select",
      "id": "section_visibility",
      "label": "t:global.common.section_visibility.label",
      "default": "always",
      "options": [
        {
          "label": "t:global.common.section_visibility.options.always",
          "value": "always"
        },
        {
          "label": "t:global.common.section_visibility.options.small",
          "value": "small"
        },
        {
          "label": "t:global.common.section_visibility.options.large",
          "value": "large"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "make_section_rounded",
      "label": "t:global.common.general_labels.make_section_rounded",
      "default": false
    },
    {
      "type": "select",
      "id": "event_image_size",
      "label": "t:sections.event-calender.settings.event_image_size.label",
      "default": "square",
      "options": [
        {
          "value": "auto",
          "label": "t:global.common.image_ratio.options.auto"
        },
        {
          "value": "landscape",
          "label": "t:global.common.image_ratio.options.landscape"
        },
        {
          "value": "portrait",
          "label": "t:global.common.image_ratio.options.portrait"
        },
        {
          "value": "square",
          "label": "t:global.common.image_ratio.options.square"
        }
      ]
    },
    {
      "type": "header",
      "content": "t:global.header.heading_section.label"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "Event calender",
      "label": "t:sections.featured-collections-list.settings.heading.label",
      "info": "t:global.common.infos.heading.label"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "t:global.common.general_labels.heading_size",
      "default": "h3",
      "options": [
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        },
        {
          "value": "h4",
          "label": "H4"
        },
        {
          "value": "h5",
          "label": "H5"
        },
        {
          "value": "h6",
          "label": "H6"
        }
      ]
    },
    {
      "type": "select",
      "id": "seo_heading",
      "label": "t:global.common.general_labels.heading_tag",
      "default": "h3",
      "info": "t:global.common.infos.seo_heading.label",
      "options": [
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        },
        {
          "value": "h4",
          "label": "H4"
        },
        {
          "value": "h5",
          "label": "H5"
        },
        {
          "value": "h6",
          "label": "H6"
        }
      ]
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "t:global.common.heading_alignment.label",
      "default": "text-center",
      "options": [
        {
          "label": "t:global.common.heading_alignment.options.left.label",
          "value": "text-left"
        },
        {
          "label": "t:global.common.heading_alignment.options.center.label",
          "value": "text-center"
        }
      ]
    },
    {
      "type": "header",
      "content": "t:global.header.color_section.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "primary",
      "label": "t:global.header.color_scheme.label"
    },
    {
      "type": "color",
      "id": "section_background",
      "label": "t:global.common.section_background.label",
      "info": "t:global.common.section_background.info"
    },
    {
      "type": "color",
      "id": "highlighted_color",
      "default": "#EFF341",
      "label": "t:global.common.general_labels.highlight_color"
    },
    {
      "type": "header",
      "content": "t:global.header.space_section.label"
    },
    {
      "type": "range",
      "id": "top_space_desktop",
      "label": "t:global.top_space_desktop.label",
      "default": 40,
      "min": 0,
      "max": 100,
      "step": 5
    },
    {
      "type": "range",
      "id": "bottom_space_desktop",
      "label": "t:global.bottom_space_desktop.label",
      "default": 40,
      "min": 0,
      "max": 100,
      "step": 5
    },
    {
      "type": "range",
      "id": "top_space_mobile",
      "label": "t:global.top_space_mobile.label",
      "default": 35,
      "min": 0,
      "max": 100,
      "step": 5
    },
    {
      "type": "range",
      "id": "bottom_space_mobile",
      "label": "t:global.bottom_space_mobile.label",
      "default": 35,
      "min": 0,
      "max": 100,
      "step": 5
    }
  ],
  "blocks": [
    {
      "type": "event",
      "name": "t:sections.event-calender.blocks.name",
      "settings": [
        {
          "id": "image",
          "type": "image_picker",
          "label": "t:global.common.general_labels.image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "t:global.common.general_labels.title",
          "default": "Event heading"
        },
        {
          "id": "description",
          "type": "richtext",
          "label": "t:global.common.general_labels.description",
          "default": "<p>Share information and details about this event.</p>"
        },
        {
          "id": "date",
          "type": "text",
          "label": "t:sections.event-calender.blocks.settings.date.label",
          "default": "10th December"
        },
        {
          "id": "time",
          "type": "text",
          "label": "t:sections.event-calender.blocks.settings.time.label",
          "default": "10.00pm - 12.00pm"
        },
        {
          "id": "location",
          "type": "text",
          "label": "t:sections.event-calender.blocks.settings.location.label",
          "default": "Event location"
        },
        {
          "id": "location_url",
          "type": "url",
          "label": "t:sections.event-calender.blocks.settings.location_url.label"
        },
        {
          "id": "link_text",
          "type": "text",
          "label": "t:sections.event-calender.blocks.settings.link_text.label",
          "default": "More info"
        },
        {
          "id": "link_url",
          "type": "url",
          "label": "t:sections.event-calender.blocks.settings.link_url.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.event-calender.presets.name",
      "blocks": [
        {
          "type": "event",
          "settings": {
            "date": "10th December",
            "time": "7PM - 11PM"
          }
        },
        {
          "type": "event",
          "settings": {
            "date": "20th November"
          }
        },
        {
          "type": "event",
          "settings": {
            "date": "Oct 29",
            "time": "8PM"
          }
        }
      ]
    }
  ]
}
{% endschema %}
