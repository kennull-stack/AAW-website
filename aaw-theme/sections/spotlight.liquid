<link rel="preload" as="style" href="{{ 'spotlight.css' | asset_url }}">
{{ 'spotlight.css' | asset_url | stylesheet_tag }}

<div class="section-container {{ section.settings.color_scheme }}-scheme {% if section.settings.make_section_rounded %}section-rounded{% endif %}">
    <div class="container">
    {% if section.settings.heading != blank %}
      {%- capture sectionhighlightPrefix -%}
        <strong class="highlight-text">
      {%- endcapture -%}

      {%- capture sectionhighlightSuffix -%}
        </strong>
      {%- endcapture -%}


      <div class="section-heading-box {{ section.settings.heading_alignment }}" {% if settings.enable_animation %}data-aos="fade-up" data-aos-duration="1000"{% endif %}>
        <{{ section.settings.seo_heading }} class="section-heading {{ section.settings.heading_size }}">
          {{ section.settings.heading | replace: "<strong>", sectionhighlightPrefix | replace: "</strong>", sectionhighlightSuffix | replace: '++', '<br>' }}
        </{{ section.settings.seo_heading }}>
      </div>
    {% endif %}
    {% if section.settings.section_fullwidth %}
    </div>
    {% endif %}
    <div class="spotlight-wrapper{% if section.settings.enable_swipe_mobile %} mobile-swipe{% endif %}">
      <div class="row">
        {% for block in section.blocks %}
          {% liquid
              assign aosDelay = forloop.index | times: 100  
              assign singleSpotStatus = false 
              if block.settings.hotspot_1 == true and  block.settings.hotspot_2 == false and block.settings.hotspot_3 == false 
                assign singleSpotStatus = true 
              elsif block.settings.hotspot_1 == false and  block.settings.hotspot_2 ==true and block.settings.hotspot_3 == false 
                assign singleSpotStatus = true 
              elsif block.settings.hotspot_1 == false and  block.settings.hotspot_2 ==false and block.settings.hotspot_3 == true 
                assign singleSpotStatus = true 
              endif 
          %}
          
          <div class="col-12{% if singleSpotStatus == true and section.settings.single_product_hover%} cursor-pointer single-spotlight-on {% endif %}{% if section.blocks.size == 1 %} col-md-12{% elsif section.blocks.size == 2 %} col-md-6{% else %} col-md-4{% endif %}" {% if settings.enable_animation %}data-aos="fade-up" data-aos-delay="{{aosDelay}}"{% endif %} {{ block.shopify_attributes }} {% if singleSpotStatus == true and section.settings.single_product_hover%} data-single-spot-item{% endif %}>
            <div id="spotlight-item-{{ block.id }}" class="spotlight-item{% if  block.settings.marquee_on_hover and block.settings.marquee %} marquee-on-hover{% endif %}">
              <div class="spotlight-img">
                {%- if block.settings.image != blank -%}
                  <div class="media-box" style="--image-ratio:{{ 1 | divided_by : block.settings.image.aspect_ratio | times: 100 | minus : 1 }}%" >
                  {%- render 'image' image: block.settings.image, class: 'spotlightSectionImage' -%}
                  </div>
                {%-else-%}
                    <div class="media-box no-product-image" style="--image-ratio:70%">
                    {{ 'collection-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
                    </div>
                {%- endif %}
              </div>
              {% if block.settings.marquee and block.settings.marquee_text != blank %}
                <div id="spotlight-marquee-{{ block.id }}" class="spotlight-marquee autoplay-infinite{% if block.settings.marquee_disable_mobile %} hidden d-md-flex{% endif %}">
                  <div class="spotlight-marquee-inner {{ block.settings.direction }}-direction" data-marque-node>
                    {% for i in (1..20) %}
                    <span class="spotlight-marquee-item">{{ block.settings.marquee_text }}</span>
                    {% endfor %}
                  </div>
                </div>
              {% endif %}
           
              {% for i in (1..3) %}
                {% liquid 
                  assign hotspotStatus = 'hotspot_' | append: forloop.index
                  assign hotspotProductStatus = 'product_' | append: forloop.index
                  assign hotspotVStatus = 'vertical_' | append: forloop.index
                  assign hotspotHStatus = 'horizontal_' | append: forloop.index
                %}
                {% if block.settings[hotspotStatus] == true %}
                  <div class="spotlight-product-item" data-spotlight-dot>
                    <div class="spotlight-product-inner-item hotspot-{{ forloop.index }} {% if block.settings[hotspotVStatus] > 80 %}bottom{% else %}top{% endif %} {% if block.settings[hotspotHStatus] > 45 %}left{% else %}right{% endif %}">
                      <button class="spotlight-dot {% if singleSpotStatus == true and section.settings.single_product_hover%} d-md-none d-block {% endif %}" {% if block.settings[hotspotProductStatus] != blank %} data-url="{{ block.settings[hotspotProductStatus].url }}" {% endif %} aria-label="spotlight" data-spotlight-item>
                          <span class="spotlight-dot-inner">
                            <svg viewBox="0 0 6 7" fill="none">
                              <path d="M2.25 0.847656H3.75V6.84766H2.25V0.847656Z" fill="currentColor"/>
                              <path d="M6.55655e-08 4.59766L0 3.09766L6 3.09766V4.59766L6.55655e-08 4.59766Z" fill="currentColor"/>
                            </svg>
                          </span> 
                      </button>  
                    </div>
                    {% if block.settings[hotspotProductStatus] != blank %}
                      {%- assign spotProduct = block.settings[hotspotProductStatus] -%}
                      <div class="spotlight-detail" data-spotlight-details>
                        <div class="spotlight-product-detail">
                          <a href="{{ spotProduct.url }}" class="spotlight-product-img">
                            {%- if spotProduct.featured_media != blank -%}
                              <div class="media-box" style="--image-ratio:100%">
                                  {%- render 'image' image: spotProduct.featured_media, class: 'spotlightSectionImage' -%}
                              </div>
                              {%- else -%}
                              <div class="media-box no-product-image" style="--image-ratio:100%">
                                
                              {{ 'product-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
                              </div>
                            {%- endif %}
                          </a>
                          <div class="spotlight-product-info">
                            <a href="{{ spotProduct.url }}" class="product-title {{ settings.font_type }}-font">{{ spotProduct.title }}</a>
                            <div class="product-pricing  {% if spotProduct.compare_at_price_min > spotProduct.price_min %} discount-price {% endif %}">
                              {%- assign price_min = spotProduct.price_min | money -%}
                              {%- if product.price_varies -%}
                                <span class="product-actual-price price-varies">{{ 'products.product.price.from_price_html' | t : price : price_min }}</span>
                                {%- else -%}
                                <span class="product-actual-price">{{ price_min }}</span>
                              {%- endif -%}
                              {%- if spotProduct.compare_at_price_min > spotProduct.price_min -%}
                                <span class="product-compare-price">{{ spotProduct.compare_at_price_min | money }}</span>
                              {%- endif -%}
                                
                              {%- if spotProduct.unit_price_measurement -%}
                                <span class="product-unit-price text-small">
                                {{ spotProduct.unit_price | money }} / {% if spotProduct.unit_price_measurement.reference_value != 1 %}{{ spotProduct.unit_price_measurement.reference_value }}{% endif %} {{ spotProduct.unit_price_measurement.reference_unit }}
                                </span>
                              {%- endif -%}
                            </div> 
                          </div>
                          <div class="spotlight-detail-close cursor-pointer {% if singleSpotStatus == true and section.settings.single_product_hover%} d-md-none d-block {% endif %}" data-spotlight-close>
                            <span class="arrow-btn small-arrow-btn">
                              <svg class="arrow-btn-icon1" x="0px" y="0px" viewBox="0 0 11.8 11.8" style="enable-background:new 0 0 11.8 11.8;" fill="currentColor">
                                <path d="M11.5,10.6L6.7,5.9l4.7-4.7c0.2-0.2,0.2-0.6,0-0.8c-0.1-0.1-0.3-0.2-0.4-0.2c0,0,0,0,0,0c-0.2,0-0.3,0.1-0.4,0.2L5.9,5.1
                                  L1.2,0.3c-0.2-0.2-0.6-0.2-0.8,0c-0.2,0.2-0.2,0.6,0,0.8l4.7,4.7l-4.7,4.7c-0.1,0.1-0.2,0.3-0.2,0.4c0,0.3,0.3,0.6,0.6,0.6
                                  c0.2,0,0.3-0.1,0.4-0.2l4.7-4.7l4.7,4.7c0.1,0.1,0.3,0.2,0.4,0.2s0.3-0.1,0.4-0.2C11.7,11.3,11.7,10.9,11.5,10.6z"></path>
                              </svg> 
                              <svg class="arrow-btn-icon2" x="0px" y="0px" viewBox="0 0 11.8 11.8" style="enable-background:new 0 0 11.8 11.8;" fill="currentColor">
                                <path d="M11.5,10.6L6.7,5.9l4.7-4.7c0.2-0.2,0.2-0.6,0-0.8c-0.1-0.1-0.3-0.2-0.4-0.2c0,0,0,0,0,0c-0.2,0-0.3,0.1-0.4,0.2L5.9,5.1
                                  L1.2,0.3c-0.2-0.2-0.6-0.2-0.8,0c-0.2,0.2-0.2,0.6,0,0.8l4.7,4.7l-4.7,4.7c-0.1,0.1-0.2,0.3-0.2,0.4c0,0.3,0.3,0.6,0.6,0.6
                                  c0.2,0,0.3-0.1,0.4-0.2l4.7-4.7l4.7,4.7c0.1,0.1,0.3,0.2,0.4,0.2s0.3-0.1,0.4-0.2C11.7,11.3,11.7,10.9,11.5,10.6z"></path>
                              </svg>                      
                            </span>
                          </div>
                        </div>
                      </div>
                      {% else %} 
                      <div class="spotlight-detail" data-spotlight-details>
                        <div class="spotlight-product-detail" >
                          <div class="spotlight-product-img">
                            <div class="media-box no-product-image" style="--image-ratio:100%">
                                {{ 'product-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
                            </div>
                          </div>
                          <div class="spotlight-product-info">
                              <p class="product-title {{ settings.font_type }}-font">{{ 'products.product.onboarding.title' | t }}</p>
                                <div class="product-pricing">
                                  <span class="product-actual-price">{{ 8800 | money }}</span>
                                </div> 
                          </div>
                          <div class="spotlight-detail-close cursor-pointer {% if singleSpotStatus == true and section.settings.single_product_hover%} d-md-none d-block {% endif %}" data-spotlight-close>
                            <span class="arrow-btn small-arrow-btn">
                              <svg class="arrow-btn-icon1" x="0px" y="0px" viewBox="0 0 11.8 11.8" style="enable-background:new 0 0 11.8 11.8;" fill="currentColor">
                                <path d="M11.5,10.6L6.7,5.9l4.7-4.7c0.2-0.2,0.2-0.6,0-0.8c-0.1-0.1-0.3-0.2-0.4-0.2c0,0,0,0,0,0c-0.2,0-0.3,0.1-0.4,0.2L5.9,5.1
                                  L1.2,0.3c-0.2-0.2-0.6-0.2-0.8,0c-0.2,0.2-0.2,0.6,0,0.8l4.7,4.7l-4.7,4.7c-0.1,0.1-0.2,0.3-0.2,0.4c0,0.3,0.3,0.6,0.6,0.6
                                  c0.2,0,0.3-0.1,0.4-0.2l4.7-4.7l4.7,4.7c0.1,0.1,0.3,0.2,0.4,0.2s0.3-0.1,0.4-0.2C11.7,11.3,11.7,10.9,11.5,10.6z"></path>
                              </svg> 
                              <svg class="arrow-btn-icon2" x="0px" y="0px" viewBox="0 0 11.8 11.8" style="enable-background:new 0 0 11.8 11.8;" fill="currentColor">
                                <path d="M11.5,10.6L6.7,5.9l4.7-4.7c0.2-0.2,0.2-0.6,0-0.8c-0.1-0.1-0.3-0.2-0.4-0.2c0,0,0,0,0,0c-0.2,0-0.3,0.1-0.4,0.2L5.9,5.1
                                  L1.2,0.3c-0.2-0.2-0.6-0.2-0.8,0c-0.2,0.2-0.2,0.6,0,0.8l4.7,4.7l-4.7,4.7c-0.1,0.1-0.2,0.3-0.2,0.4c0,0.3,0.3,0.6,0.6,0.6
                                  c0.2,0,0.3-0.1,0.4-0.2l4.7-4.7l4.7,4.7c0.1,0.1,0.3,0.2,0.4,0.2s0.3-0.1,0.4-0.2C11.7,11.3,11.7,10.9,11.5,10.6z"></path>
                              </svg>                      
                            </span>
                          </div>
                        </div>   
                      </div>  
                    {% endif %}
                    </div>  
                {% endif %}
              {% endfor %}  
        
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  {% if section.settings.section_fullwidth == false %}
    </div>
  {% endif %}
</div>
<style>
    #shopify-section-{{ section.id }}.shopify-section {
      {% if section.settings.make_section_rounded %}
        background:{{ section.settings.section_background }};
      {% endif %}
        --top-spacer:{{ section.settings.top_space_desktop }}px;
        --bottom-spacer:{{ section.settings.bottom_space_desktop }}px;
        --highlight-text: {{ section.settings.highlighted_color }};
    }
    @media only screen and (max-width:767px) {
        #shopify-section-{{ section.id }}.shopify-section{
            --top-spacer:{{ section.settings.top_space_mobile }}px;
            --bottom-spacer:{{ section.settings.bottom_space_mobile }}px;
        }
    }
    {% for block in section.blocks %}
        #spotlight-item-{{ block.id }} .hotspot-1{
        top:{{ block.settings.vertical_1 }}%;
        left:{{ block.settings.horizontal_1 }}%;
        --spot-color:{{ block.settings.spot_color_1 }};
				--spot-background-color:{{ block.settings.spot_color_background_1 }};
        --spot-color-light:{{ block.settings.spot_color_1 | color_modify : 'alpha' , 0.5 }};
        --spot-color-null:{{ block.settings.spot_color_1 | color_modify : 'alpha' , 0 }};
        }
        #spotlight-item-{{ block.id }} .hotspot-2{
        top:{{ block.settings.vertical_2 }}%;
        left:{{ block.settings.horizontal_2 }}%;
        --spot-color:{{ block.settings.spot_color_2 }};
				--spot-background-color:{{ block.settings.spot_color_background_2 }};
        --spot-color-light:{{ block.settings.spot_color_2 | color_modify : 'alpha' , 0.5 }};
        --spot-color-null:{{ block.settings.spot_color_2 | color_modify : 'alpha' , 0 }};
        }
        #spotlight-item-{{ block.id }} .hotspot-3{
        top:{{ block.settings.vertical_3 }}%;
        left:{{ block.settings.horizontal_3 }}%;
        --spot-color:{{ block.settings.spot_color_3 }};
				--spot-background-color:{{ block.settings.spot_color_background_3 }};
        --spot-color-light:{{ block.settings.spot_color_3 | color_modify : 'alpha' , 0.5 }};
        --spot-color-null:{{ block.settings.spot_color_3 | color_modify : 'alpha' , 0 }};
        }
        #spotlight-marquee-{{ block.id }}{
          --marquee-color:{{ block.settings.marquee_text_color }};
          --background: {{ block.settings.marquee_background.red }},{{ block.settings.marquee_background.green }},{{ block.settings.marquee_background.blue }};
          --opacity: {{ block.settings.marquee_background_opacity | divided_by: 100.0 }};
        }
    {% endfor %}  
    {% if section.settings.section_visibility == 'large' %}
      @media (max-width: 767px) {
        #shopify-section-{{ section.id }}{
          display: none !important;
        }
      }
    {% elsif section.settings.section_visibility == 'small' %}
      @media (min-width: 768px) {
        #shopify-section-{{ section.id }}{
          display: none !important;
        }
      }
    {% endif %}  
</style>
{% schema %}
{
  "name": "t:sections.spotlight.name",
  "class": "spotlight",
  "tag": "section",
  "disabled_on": {
    "groups": [
      "header",
      "footer"
    ]
  },
  "max_blocks": 3,
  "settings": [
    {
      "type": "select",
      "id": "section_visibility",
      "label": "t:global.common.section_visibility.label",
      "default": "always",
      "options": [
        {
          "label": "t:global.common.section_visibility.options.always",
          "value": "always"
        },
        {
          "label": "t:global.common.section_visibility.options.small",
          "value": "small"
        },
        {
          "label": "t:global.common.section_visibility.options.large",
          "value": "large"
        }
      ]
    },
    {
      "type": "checkbox",
      "id": "make_section_rounded",
      "label": "t:global.common.general_labels.make_section_rounded",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "section_fullwidth",
      "label": "t:sections.spotlight.settings.section_fullwidth.label",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "enable_swipe_mobile",
      "label": "t:global.common.swipe_mobile.label",
      "default": false
    },
    {
      "type":"checkbox",
      "id":"single_product_hover",
      "label":"Show single product on hover(desktop)",
      "default": true
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "Shop the look",
      "info": "t:global.common.infos.heading.label",
      "label": "t:global.common.general_labels.heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "t:global.common.general_labels.heading_size",
      "default": "h3",
      "options": [
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        },
        {
          "value": "h4",
          "label": "H4"
        },
        {
          "value": "h5",
          "label": "H5"
        },
        {
          "value": "h6",
          "label": "H6"
        }
      ]
    },
    {
      "type": "select",
      "id": "seo_heading",
      "label": "t:global.common.general_labels.heading_tag",
      "info": "t:global.common.infos.seo_heading.label",
      "default": "h3",
      "options": [
        {
          "value": "h1",
          "label": "H1"
        },
        {
          "value": "h2",
          "label": "H2"
        },
        {
          "value": "h3",
          "label": "H3"
        },
        {
          "value": "h4",
          "label": "H4"
        },
        {
          "value": "h5",
          "label": "H5"
        },
        {
          "value": "h6",
          "label": "H6"
        }
      ]
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "t:global.common.heading_alignment.label",
      "default": "text-center",
      "options": [
        {
          "value": "text-left",
          "label": "t:global.common.heading_alignment.options.left.label"
        },
        {
          "value": "text-center",
          "label": "t:global.common.heading_alignment.options.center.label"
        }
      ]
    },
    {
      "type": "header",
      "content": "t:global.header.color_section.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:global.header.color_scheme.label",
      "default": "primary"
    },
    {
      "type": "color",
      "id": "section_background",
      "label": "t:global.common.section_background.label",
      "info": "t:global.common.section_background.info"
    },
    {
      "type": "color",
      "id": "highlighted_color",
      "default": "#EFF341",
      "label": "t:global.common.general_labels.highlight_color"
    },
    {
      "type": "header",
      "content": "t:global.header.space_section.label"
    },
    {
      "type": "range",
      "id": "top_space_desktop",
      "label": "t:global.top_space_desktop.label",
      "default": 40,
      "min": 0,
      "max": 100,
      "step": 5
    },
    {
      "type": "range",
      "id": "bottom_space_desktop",
      "label": "t:global.bottom_space_desktop.label",
      "default": 40,
      "min": 0,
      "max": 100,
      "step": 5
    },
    {
      "type": "range",
      "id": "top_space_mobile",
      "label": "t:global.top_space_mobile.label",
      "default": 35,
      "min": 0,
      "max": 100,
      "step": 5
    },
    {
      "type": "range",
      "id": "bottom_space_mobile",
      "label": "t:global.bottom_space_mobile.label",
      "default": 35,
      "min": 0,
      "max": 100,
      "step": 5
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "t:sections.spotlight.blocks.spot.name",
      "settings": [
        {
          "type": "image_picker",
          "label": "t:sections.spotlight.blocks.spot.settings.image.label",
          "id": "image"
        },
        {
          "type": "header",
          "content": "t:global.header.marquee_section.label"
        },
        {
          "type": "checkbox",
          "id": "marquee",
          "label": "t:sections.spotlight.blocks.spot.settings.marquee_text.label",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "marquee_on_hover",
          "label": "t:sections.spotlight.blocks.spot.settings.marquee_on_hover.label",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "marquee_disable_mobile",
          "label": "t:sections.spotlight.blocks.spot.settings.marquee_disable_mobile.label",
          "default": false
        },
        {
          "type": "select",
          "id": "direction",
          "label": "t:global.common.marquee_direction.label",
          "options": [
            {
              "value": "rtl",
              "label": "t:global.common.marquee_direction.options.rtl"
            },
            {
              "value": "ltr",
              "label": "t:global.common.marquee_direction.options.ltr"
            }
          ],
          "default": "rtl"
        },
        {
          "type": "text",
          "id": "marquee_text",
          "label": "t:global.common.general_labels.text"
        },
        {
          "type": "color",
          "id": "marquee_text_color",
          "label": "t:sections.spotlight.blocks.spot.settings.marquee_text_color.label",
          "default": "#FFFFFF"
        },
        {
          "type": "color",
          "id": "marquee_background",
          "label": "t:sections.spotlight.blocks.spot.settings.marquee_background.label",
          "default": "#000000"
        },
        {
          "type": "range",
          "id": "marquee_background_opacity",
          "label": "t:global.common.general_labels.opacity",
          "default": 9,
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%"
        },
        {
          "type": "header",
          "content": "t:sections.spotlight.blocks.spot.settings.hotspot_header.content"
        },
        {
          "type": "checkbox",
          "id": "hotspot_1",
          "default": true,
          "label": "t:sections.spotlight.blocks.spot.settings.hotspot_checkbox.label"
        },
        {
