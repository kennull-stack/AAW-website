{% if  settings.enable_cartdrawer %}

  <cart-drawer
    class="side-drawer cart-side-drawer {{ settings.drawer_color_scheme }}-scheme{% if settings.enable_blur_effect %} background-blur{% endif %}{% if cart == empty %} is-empty{% endif %}"
    id="cart-side-drawer"
    data-cart-drawer
    side-drawer-body
  >
  <div id="CartDrawer" class="cart-drawer">
    <div
      class="close-fullwidth"
      data-sidedrawer-close
    ></div>
    <div class="side-drawer-panel">
      <div class="side-drawer-inner">
        {% if settings.cart_notification_bar == blank   %}
          <button class="drawer-close" data-sidedrawer-close aria-label="close">
            {% render 'theme-icons', theme_icon: 'drawer_close' %}
          </button>
       {% endif %}
        <div class="cart-drawer-content" data-cart-drawer-body>
  
          <div class="cart-drawer-notification" data-notification>
  
            {% if settings.cart_notification_bar != blank and cart.item_count > 0 %}
              <div class="cart-drawer-notification-content" data-notification-content>
                {{ settings.cart_notification_bar }}
              </div>
            {% endif %}
          </div>
         
  
          <div class="cart-drawer-content-header" data-cart-drawer-header>
  
            {% if settings.cart_notification_bar != blank   %}
              <button class="drawer-close" data-sidedrawer-close aria-label="close">
                {% render 'theme-icons', theme_icon: 'drawer_close' %}
              </button>
           {% endif %}
            <h4 class="cart-drawer-heading">{{ 'templates.cart.cart' | t }}</h4>
  
            {%- if settings.enable_shipping and settings.shipping_rate != blank and cart.item_count > 0 -%}
              {% liquid
                assign shippingRate = settings.shipping_rate | times: 100
                assign cartTotal = cart.total_price
                assign shippingPrice = shippingRate | minus: cartTotal
                if shippingPrice > 0
                  assign shippingPrice = shippingPrice | money
                  assign shippingMessage = settings.shipping_message | replace: '||amount||', shippingPrice
                else
                  assign shippingMessage = settings.shipping_success
                endif
  
                assign shippingPercentage = cartTotal | times: 100 | divided_by: shippingRate
                if shippingPercentage > 10 and shippingPercentage < 100
                  assign shippingPercentage = shippingPercentage | minus: 5
                elsif shippingPercentage > 100
                  assign shippingPercentage = 100
                endif
              %}
              <div class="cart-shipping-bar" data-free-shipping-container="" data-free-shipping-wrapper>
                <p data-free-shipping-text="" data-shipping-message>{{ shippingMessage }}</p>
                <div class="cart-shipping-bar-progress">
                  <div
                    class="cart-shipping-bar-progress-width"
                    role="progressbar"
                    aria-valuemin="0"
                    aria-valuemax="100"
                    data-width="{{ shippingPercentage }}%"
                    style="width:{{ shippingPercentage }}%"
                    data-shipping-bar
                  ></div>
                </div>
              </div>
            {%- endif -%}
          </div>
          <cart-drawer-items
            class="cart-drawer-content-body drawer__inner{% if cart == empty %} is-empty{% endif %}"
            data-section="ajax-cart"
           
          >
           {%- if cart == empty -%}
              <div class="empty-card">
                <span class="empty-card-icon">
                  {% comment %} <svg width="39" height="36" viewBox="0 0 39 36" fill="none">
