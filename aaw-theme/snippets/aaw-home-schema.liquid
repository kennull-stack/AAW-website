    {
      "@type": "FAQPage",
      "@id": {{ faq_id | json }},
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What does AAW specialize in?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Advanced AcousticWerkes specializes in in-ear monitors designed and built in Singapore. The range covers custom IEMs made from ear impressions, universal-fit monitors such as the Z Series, and long-term support for refits, cables, shells, sockets, and repair work."
          }
        },
        {
          "@type": "Question",
          "name": "What is the difference between universal and custom IEMs?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Universal IEMs use ear tips and can fit many listeners, which makes them easier to demo, share, and travel with. Custom IEMs are made from your ear impressions or approved digital scans, so they seal around your ears only and allow more freedom in shell shape, artwork, and fit tuning."
          }
        },
        {
          "@type": "Question",
          "name": "Do I need ear impressions for a CIEM?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. AAW needs physical impressions from an audiologist or an approved digital ear scan before building a custom in-ear monitor. Accurate impressions are critical because the acoustic seal affects bass, isolation, comfort, and whether the finished monitor can be worn for long sessions."
          }
        },
        {
          "@type": "Question",
          "name": "Can AAW help with refits or repairs?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. The Singapore office handles refit, warranty, repair, cable, socket, and shell service for AAW monitors. If you bought through an authorized dealer, that dealer is often the fastest first stop, but the work is still supported through AAW's service process."
          }
        },
        {
          "@type": "Question",
          "name": "Where can I audition or order AAW?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "In Singapore, listeners can start at the AAW office at 76 Playfair Rd, #01-03, or audition through Zeppelin & Co., JABEN, and AV One. Outside Singapore, AAW works with authorized specialist audio dealers; use the store locator or contact sales@acousticwerkes.com for the closest listening point."
          }
