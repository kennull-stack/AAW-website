{%- liquid
  assign z_series = collections['z-series']
  assign home_title = 'Advanced AcousticWerkes | Singapore Custom & Universal IEM Specialist'
  assign home_description = 'AAW designs and builds custom and universal in-ear monitors in Singapore since 2014. Audition the Z07, Z06, and Z05 AuAg at 76 Playfair Rd or four authorized dealers islandwide.'
  assign site_url = 'https://www.aaw.me'
  assign page_id = canonical_url | append: '#webpage'
  assign z_series_id = canonical_url | append: '#z-series'
  assign listening_paths_id = canonical_url | append: '#listening-paths'
  assign faq_id = canonical_url | append: '#faq'
  assign store_id = canonical_url | append: '#aaw-singapore-store'
  assign org_id = site_url | append: '/#organization'
  assign website_id = site_url | append: '/#website'
  assign kevin_wang_id = site_url | append: '/#kevin-wang'
-%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": ["WebPage", "HomePage"],
      "@id": {{ page_id | json }},
      "url": {{ canonical_url | json }},
      "name": {{ home_title | json }},
      "description": {{ home_description | strip_html | strip_newlines | json }},
      "isPartOf": {
        "@type": "WebSite",
        "@id": {{ website_id | json }}
      },
      "about": {
        "@type": "Organization",
        "@id": {{ org_id | json }}
      },
      "mainEntity": [
        { "@id": {{ site_url | append: '/products/z07-in-ear-monitor#product' | json }} },
        { "@id": {{ canonical_url | append: '#fitmorph' | json }} },
        { "@id": {{ listening_paths_id | json }} },
        { "@id": {{ z_series_id | json }} },
        { "@id": {{ store_id | json }} },
        { "@id": {{ faq_id | json }} },
        { "@id": {{ kevin_wang_id | json }} }
      ]
    },
    {
      "@type": "Organization",
      "@id": {{ org_id | json }},
      "name": "Advanced AcousticWerkes",
      "alternateName": "AAW",
      "url": {{ site_url | json }},
      "foundingDate": "2014",
      "founder": {
        "@id": {{ kevin_wang_id | json }}
      },
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "#01-03, 76 Playfair Rd",
        "addressLocality": "Singapore",
        "postalCode": "367996",
        "addressCountry": "SG"
      },
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "+65 8731 5476",
        "email": "sales@acousticwerkes.com",
        "contactType": "customer support",
        "areaServed": "SG"
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.74",
        "bestRating": "5",
        "worstRating": "1",
        "reviewCount": "335"
      }
    },
    {
      "@type": "Person",
      "@id": {{ kevin_wang_id | json }},
      "name": "Kevin Wang",
      "jobTitle": "Founder & Tuning Engineer",
      "worksFor": {
        "@id": {{ org_id | json }}
      },
      "knowsAbout": [
        "custom in-ear monitors",
        "universal in-ear monitors",
        "hybrid IEM tuning",
        "balanced armature drivers",
        "dynamic driver integration",
        "IEM acoustic design"
      ]
    },
    {
      "@type": "Product",
      "@id": {{ site_url | append: '/products/z07-in-ear-monitor#product' | json }},
      "name": "AAW Z07",
      "url": {{ site_url | append: '/products/z07-in-ear-monitor' | json }},
      "image": {{ 'z07-model-wearing-universal-fit-over-ear-cable.jpg' | asset_url | prepend: 'https:' | json }},
      "brand": {
        "@id": {{ org_id | json }}
      },
      "description": "AAW Z07 is a universal hybrid in-ear monitor with a tube-free acoustic core and FitMorph adaptive fit system.",
      "category": "Universal in-ear monitor",
      "additionalProperty": [
        {
          "@type": "PropertyValue",
          "name": "Fit system",
          "value": "FitMorph adaptive fit"
        },
        {
          "@type": "PropertyValue",
          "name": "Acoustic path",
          "value": "Tube-free hybrid core"
        }
      ]
    },
    {
      "@type": "Service",
      "@id": {{ canonical_url | append: '#fitmorph' | json }},
      "name": "FitMorph adaptive fit system",
      "provider": {
        "@id": {{ org_id | json }}
      },
      "serviceType": "In-ear monitor fit system",
      "description": "FitMorph lets AAW listeners change the outer fit of compatible monitors while keeping the acoustic core and tuning in place."
    },
    {
      "@type": "ItemList",
      "@id": {{ listening_paths_id | json }},
      "name": "AAW listening paths",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "item": {
            "@type": "Product",
            "name": "Z07 Hybrid In-Ear Monitor",
            "url": {{ site_url | append: '/products/z07-in-ear-monitor' | json }}
          }
        },
        {
          "@type": "ListItem",
          "position": 2,
          "item": {
            "@type": "Product",
            "name": "Z05 AuAg Launch Edition",
            "url": {{ site_url | append: '/products/z05-auag-launch-edition' | json }}
          }
        },
        {
          "@type": "ListItem",
          "position": 3,
          "item": {
            "@type": "Service",
            "name": "AAW Custom Monitor Builder",
            "url": {{ site_url | append: '/products/aaw-custom-builder' | json }}
          }
        }
      ]
    },
    {
      "@type": "ItemList",
      "@id": {{ z_series_id | json }},
      "name": "AAW Z Series",
      "url": {{ canonical_url | append: '#shopify-section-template--19986822496298__aaw_home_z_series_collection' | json }},
      "itemListElement": [
        {%- if z_series != blank -%}
          {%- for listed_product in z_series.products limit: 4 -%}
            {
              "@type": "ListItem",
              "position": {{ forloop.index }},
              "url": {{ site_url | append: listed_product.url | json }},
              "item": {
                "@type": "Product",
                "name": {{ listed_product.title | strip_html | json }},
                "url": {{ site_url | append: listed_product.url | json }}
                {%- if listed_product.featured_image != blank -%},
                "image": {{ listed_product.featured_image | image_url: width: 1200 | prepend: 'https:' | json }}
                {%- endif -%}
              }
            }{%- unless forloop.last -%},{%- endunless -%}
          {%- endfor -%}
        {%- endif -%}
      ]
    },
    {
      "@type": ["Store", "LocalBusiness"],
      "@id": {{ store_id | json }},
      "name": "AAW Singapore Office",
      "url": {{ canonical_url | json }},
      "telephone": "+65 8731 5476",
      "email": "sales@acousticwerkes.com",
      "hasMap": "https://www.google.com/maps/search/?api=1&query=76%20Playfair%20Rd%20Singapore%20367996",
      "areaServed": {
        "@type": "Country",
        "name": "Singapore"
      },
      "parentOrganization": {
        "@type": "Organization",
        "@id": {{ org_id | json }}
      },
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "#01-03, 76 Playfair Rd",
        "addressLocality": "Singapore",
        "postalCode": "367996",
        "addressCountry": "SG"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 1.3364791,
        "longitude": 103.8865741
      },
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday", "Wednesday", "Thursday", "Friday"],
          "opens": "10:00",
          "closes": "18:00"
        },
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Tuesday", "Saturday"],
          "description": "By appointment"
        }
      ]
    },
    {
      "@type": "LocalBusiness",
      "@id": {{ site_url | append: '/#dealer-zeppelin' | json }},
      "name": "Zeppelin & Co.",
      "telephone": "+65 9337 9655",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "1 Rochor Canal Rd, #02-78 Sim Lim Square",
        "addressLocality": "Singapore",
        "postalCode": "188504",
        "addressCountry": "SG"
      },
      "areaServed": {
        "@type": "Country",
        "name": "Singapore"
      },
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"],
          "opens": "11:30",
          "closes": "20:00"
        },
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": "Sunday",
          "opens": "12:00",
          "closes": "19:00"
        }
      ]
    },
    {
      "@type": "LocalBusiness",
      "@id": {{ site_url | append: '/#dealer-jaben' | json }},
      "name": "JABEN",
      "telephone": "+65 6337 0809",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "1 Coleman St, #01-25 The Adelphi",
        "addressLocality": "Singapore",
        "postalCode": "179803",
        "addressCountry": "SG"
      },
      "areaServed": {
        "@type": "Country",
        "name": "Singapore"
      },
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"],
          "opens": "12:00",
          "closes": "20:00"
        }
      ]
    },
    {
      "@type": "LocalBusiness",
      "@id": {{ site_url | append: '/#dealer-av-one' | json }},
      "name": "AV One",
      "telephone": "+65 6337 0080",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "1 Coleman St, The Adelphi",
        "addressLocality": "Singapore",
        "postalCode": "179803",
        "addressCountry": "SG"
      },
      "areaServed": {
        "@type": "Country",
        "name": "Singapore"
      },
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"],
          "opens": "11:00",
          "closes": "19:30"
        }
      ],
      "openingHours": "Monday-Saturday 11:00-19:30; public holidays 13:00-18:00"
    },
    {
      "@type": "FAQPage",
      "@id": {{ faq_id | json }},
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What does AAW specialize in?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "In-ear monitors. Custom and universal, designed and built in Singapore. We also handle refits, cables, and long-term service."
          }
        },
        {
          "@type": "Question",
          "name": "What is the difference between universal and custom IEMs?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Universal monitors come with ear tips and fit most ears. Custom monitors are built from impressions of your ears - better seal, more freedom in the design, and not really wearable by anyone else."
          }
        },
        {
          "@type": "Question",
          "name": "Do I need ear impressions for a CIEM?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, for any custom monitor. Either physical impressions taken by an audiologist or an approved digital ear scan. Good impressions are most of the battle - a bad seal can't be fixed by tuning."
          }
        },
        {
          "@type": "Question",
          "name": "Can AAW help with refits or repairs?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. The Singapore office handles refit, warranty, repair, and cable service directly. If you bought through a dealer, they're often the fastest first stop."
          }
        },
        {
          "@type": "Question",
          "name": "Where can I audition or order AAW?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "In Singapore: our office at 76 Playfair Rd, or Zeppelin & Co., JABEN, and AV One. Outside Singapore, the store locator lists authorised dealers."
          }
        }
      ]
    }
  ]
}
</script>
