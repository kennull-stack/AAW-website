    },
    {
      "@type": "Service",
      "@id": {{ canonical_url | append: '#fitmorph' | json }},
      "name": "FitMorph adaptive fit system",
      "provider": {
        "@id": {{ org_id | json }}
      },
      "serviceType": "In-ear monitor fit system",
      "description": "FitMorph lets AAW listeners change the outer fit of compatible monitors while keeping the acoustic core and tuning in place."
    },
    {
      "@type": "ItemList",
      "@id": {{ listening_paths_id | json }},
      "name": "AAW listening paths",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "item": {
            "@type": "Product",
            "name": "Z07 Hybrid In-Ear Monitor",
            "url": {{ site_url | append: '/products/z07-in-ear-monitor' | json }}
