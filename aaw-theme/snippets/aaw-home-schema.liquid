{%- liquid
  assign z_series = collections['z-series']
  assign home_title = 'Advanced AcousticWerkes | Singapore Custom & Universal IEM Specialist'
  assign home_description = 'Advanced AcousticWerkes (AAW) is a Singapore in-ear monitor specialist founded in 2014 by Kevin Wang, crafting custom and universal IEMs for musicians, engineers, and serious listeners.'
  assign site_url = 'https://www.aaw.me'
  assign page_id = canonical_url | append: '#webpage'
  assign z_series_id = canonical_url | append: '#z-series'
  assign listening_paths_id = canonical_url | append: '#listening-paths'
  assign faq_id = canonical_url | append: '#faq'
  assign store_id = canonical_url | append: '#aaw-singapore-store'
  assign org_id = site_url | append: '/#organization'
  assign website_id = site_url | append: '/#website'
  assign kevin_wang_id = site_url | append: '/#kevin-wang'
-%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": ["WebPage", "HomePage"],
      "@id": {{ page_id | json }},
      "url": {{ canonical_url | json }},
      "name": {{ home_title | json }},
      "description": {{ home_description | strip_html | strip_newlines | json }},
      "isPartOf": {
        "@type": "WebSite",
        "@id": {{ website_id | json }}
      },
      "about": {
        "@type": "Organization",
        "@id": {{ org_id | json }}
      },
      "mainEntity": [
        { "@id": {{ listening_paths_id | json }} },
        { "@id": {{ z_series_id | json }} },
        { "@id": {{ store_id | json }} },
        { "@id": {{ faq_id | json }} },
        { "@id": {{ kevin_wang_id | json }} }
      ]
    },
    {
      "@type": "Person",
      "@id": {{ kevin_wang_id | json }},
      "name": "Kevin Wang",
      "jobTitle": "Founder & Tuning Engineer",
      "worksFor": {
        "@id": {{ org_id | json }}
      },
      "knowsAbout": [
        "custom in-ear monitors",
        "universal in-ear monitors",
        "hybrid IEM tuning",
        "balanced armature drivers",
        "dynamic driver integration",
        "IEM acoustic design"
      ]
    },
    {
      "@type": "ItemList",
      "@id": {{ listening_paths_id | json }},
      "name": "AAW listening paths",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "item": {
            "@type": "Product",
            "name": "Z07 Hybrid In-Ear Monitor",
            "url": {{ site_url | append: '/products/z07-in-ear-monitor' | json }}
          }
        },
        {
          "@type": "ListItem",
          "position": 2,
          "item": {
            "@type": "Product",
            "name": "Z05 AuAg Launch Edition",
            "url": {{ site_url | append: '/products/z05-auag-launch-edition' | json }}
          }
        },
        {
          "@type": "ListItem",
          "position": 3,
          "item": {
            "@type": "Service",
            "name": "AAW Custom Monitor Builder",
            "url": {{ site_url | append: '/products/aaw-custom-builder' | json }}
          }
        }
      ]
    },
    {
      "@type": "ItemList",
      "@id": {{ z_series_id | json }},
      "name": "AAW Z Series",
      "url": {{ canonical_url | append: '#shopify-section-template--19986822496298__aaw_home_z_series_collection' | json }},
      "itemListElement": [
        {%- if z_series != blank -%}
          {%- for listed_product in z_series.products limit: 4 -%}
            {
              "@type": "ListItem",
              "position": {{ forloop.index }},
              "url": {{ site_url | append: listed_product.url | json }},
              "item": {
                "@type": "Product",
                "name": {{ listed_product.title | strip_html | json }},
                "url": {{ site_url | append: listed_product.url | json }}
                {%- if listed_product.featured_image != blank -%},
                "image": {{ listed_product.featured_image | image_url: width: 1200 | prepend: 'https:' | json }}
                {%- endif -%}
              }
            }{%- unless forloop.last -%},{%- endunless -%}
          {%- endfor -%}
        {%- endif -%}
      ]
    },
    {
      "@type": ["Store", "LocalBusiness"],
      "@id": {{ store_id | json }},
      "name": "AAW Singapore Office",
      "url": {{ canonical_url | json }},
      "telephone": "+65 8731 5476",
      "email": "sales@acousticwerkes.com",
      "hasMap": "https://www.google.com/maps/search/?api=1&query=76%20Playfair%20Rd%20Singapore%20367996",
      "areaServed": {
        "@type": "Country",
        "name": "Singapore"
      },
      "parentOrganization": {
        "@type": "Organization",
        "@id": {{ org_id | json }}
      },
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "#01-03, 76 Playfair Rd",
        "addressLocality": "Singapore",
        "postalCode": "367996",
        "addressCountry": "SG"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 1.3364791,
        "longitude": 103.8865741
      },
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday", "Wednesday", "Thursday", "Friday"],
          "opens": "10:00",
          "closes": "18:00"
        },
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Tuesday", "Saturday"],
          "description": "By appointment"
        }
      ]
    },
    {
      "@type": "FAQPage",
      "@id": {{ faq_id | json }},
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What does AAW specialize in?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "AAW designs and builds in-ear monitors in Singapore, including custom IEMs, universal monitors, hybrid driver designs, cables, refit work, and long-term service."
          }
        },
        {
          "@type": "Question",
          "name": "What is the difference between universal and custom IEMs?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Universal IEMs are ready to wear with ear tips and can be shared or resold more easily. Custom IEMs are built from ear impressions for a personal shell shape, stronger fit security, and more design freedom."
          }
        },
        {
          "@type": "Question",
          "name": "Do I need ear impressions for a CIEM?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. A custom in-ear monitor needs accurate ear impressions or approved digital ear scans. Good impressions help the shell seal, reduce pressure points, and lower the chance of refit work."
          }
        },
        {
          "@type": "Question",
          "name": "Can AAW help with refits or repairs?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. AAW supports refit, warranty, repair, cable, and service questions through the Singapore office and authorized dealers."
          }
        },
        {
          "@type": "Question",
          "name": "Where can I audition or order AAW?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Visit the AAW Office at 76 Playfair Road or an authorized listening room such as Zeppelin & Co., JABEN, and AV One. Outside Singapore, use the store locator for authorized dealers."
          }
        }
      ]
    }
  ]
}
</script>
