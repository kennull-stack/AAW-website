      "address": {
        "@type": "PostalAddress",
        "streetAddress": "#01-03, 76 Playfair Rd",
        "addressLocality": "Singapore",
        "postalCode": "367996",
        "addressCountry": "SG"
      },
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "+65 8731 5476",
        "email": "sales@acousticwerkes.com",
        "contactType": "customer support",
        "areaServed": "SG"
      }
    },
    {
      "@type": "Brand",
      "@id": {{ brand_id | json }},
