      "description": "AAW Z07 is a universal hybrid in-ear monitor with a tube-free acoustic core and FitMorph adaptive fit system.",
      "category": "Universal in-ear monitor",
      "additionalProperty": [
        {
          "@type": "PropertyValue",
          "name": "Fit system",
          "value": "FitMorph adaptive fit"
        },
        {
          "@type": "PropertyValue",
