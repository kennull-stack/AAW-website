    {
      "@type": "Product",
      "@id": {{ site_url | append: '/products/z07-in-ear-monitor#product' | json }},
      "name": "AAW Z07",
      "url": {{ site_url | append: '/products/z07-in-ear-monitor' | json }},
      "image": {{ 'z07-model-wearing-universal-fit-over-ear-cable.jpg' | asset_url | prepend: 'https:' | json }},
      "brand": {
        "@id": {{ org_id | json }}
