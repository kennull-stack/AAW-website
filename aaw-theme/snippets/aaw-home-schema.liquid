        "@type": "WebSite",
        "@id": {{ website_id | json }}
      },
      "about": {
        "@type": "Organization",
        "@id": {{ org_id | json }}
      },
      "mainEntity": [
        { "@id": {{ site_url | append: '/products/z07-in-ear-monitor#product' | json }} },
        { "@id": {{ canonical_url | append: '#fitmorph' | json }} },
        { "@id": {{ listening_paths_id | json }} },
        { "@id": {{ z_series_id | json }} },
        { "@id": {{ store_id | json }} },
        { "@id": {{ faq_id | json }} },
        { "@id": {{ kevin_wang_id | json }} },
        { "@id": {{ brand_id | json }} }
      ]
    },
    {
      "@type": "Organization",
      "@id": {{ org_id | json }},
      "name": "Advanced AcousticWerkes",
      "alternateName": "AAW",
      "url": {{ site_url | json }},
      "sameAs": [
        "https://www.facebook.com/acousticwerkes",
        "https://www.instagram.com/aaw_sg/"
      ],
      "foundingDate": "2014",
