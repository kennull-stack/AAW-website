{%- liquid
  assign z_series = collections['z-series']
  assign home_title = 'Advanced AcousticWerkes | Singapore IEM Specialist'
  assign home_description = 'AAW designs and builds custom and universal in-ear monitors in Singapore since 2014. Audition the Z07, Z06, and Z05 AuAg at 76 Playfair Rd or four authorized dealers islandwide.'
  assign site_url = 'https://www.aaw.me'
  assign page_id = canonical_url | append: '#webpage'
  assign z_series_id = canonical_url | append: '#z-series'
  assign listening_paths_id = canonical_url | append: '#listening-paths'
  assign faq_id = canonical_url | append: '#faq'
  assign store_id = canonical_url | append: '#aaw-singapore-store'
  assign org_id = site_url | append: '/#organization'
  assign brand_id = site_url | append: '/#brand'
  assign website_id = site_url | append: '/#website'
  assign kevin_wang_id = site_url | append: '/#kevin-wang'
  assign headfonics_nebula_id = site_url | append: '/#press-headfonics-nebula-one'
  assign headfonics_w900_id = site_url | append: '/#press-headfonics-w900'
  assign headfonics_canary_id = site_url | append: '/#press-headfonics-canary'
-%}
<script type="application/ld+json">
