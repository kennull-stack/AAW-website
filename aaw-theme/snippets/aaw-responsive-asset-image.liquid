{% liquid
  assign rendered_width = width | default: 1200 | plus: 0
  if rendered_width > 2000
    assign rendered_width = 2000
  elsif rendered_width < 1
    assign rendered_width = 1200
  endif

  assign rendered_src_size = rendered_width | append: 'x'
  assign rendered_widths = widths | default: '360,540,720,900,1200,1600,2000'
  if sizes != blank
    assign rendered_sizes = sizes
  elsif width != blank
    assign rendered_sizes = '(max-width: ' | append: width | append: 'px) 100vw, ' | append: width | append: 'px'
  else
    assign rendered_sizes = '100vw'
  endif
  assign rendered_loading = loading | default: 'lazy'
  assign rendered_decoding = decoding | default: 'async'
%}

{% if file != blank %}
  <img
    {% if class != blank %}class="{{ class }}"{% endif %}
    src="{{ file | asset_img_url: rendered_src_size }}"
    srcset="{% assign responsive_widths = rendered_widths | split: ',' %}{% for candidate_width in responsive_widths %}{% assign candidate_width = candidate_width | strip %}{% assign candidate_size = candidate_width | append: 'x' %}{{ file | asset_img_url: candidate_size }} {{ candidate_width }}w{% unless forloop.last %}, {% endunless %}{% endfor %}"
    sizes="{{ rendered_sizes }}"
    alt="{{ alt | default: '' | escape }}"
    {% if width != blank %}width="{{ width }}"{% endif %}
    {% if height != blank %}height="{{ height }}"{% endif %}
    loading="{{ rendered_loading }}"
    decoding="{{ rendered_decoding }}"
    {% if fetchpriority != blank %}fetchpriority="{{ fetchpriority }}"{% endif %}
    {% if style != blank %}style="{{ style }}"{% endif %}
  >
{% endif %}
