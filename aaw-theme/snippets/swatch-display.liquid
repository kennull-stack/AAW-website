{%- liquid
    assign swatch_value = null
    if presentation == 'swatch'
      if value.swatch.image
        assign image_url = value.swatch.image | image_url: width: 50
        assign swatch_value = '--swatch-img: url(' | append: image_url | append: ')'
        assign swatch_focal_point = value.swatch.image.presentation.focal_point
      elsif value.swatch.color
        assign swatch_value = '--swatch-color:rgb(' | append: value.swatch.color.rgb | append: ')'
      endif
    endif
   
  -%}
 
  {% if  presentation == 'swatch' and swatch_value != null %}
    <span class="filter-swatch-img  {% if value.swatch.image %}image{% endif %}{% if swatch_focal_point %} variant-image-focal{% endif %}"  style="{{ swatch_value }}; {% if swatch_focal_point %} --swatch-focal-point: {{ swatch_focal_point }};{% endif %}"></span>
 {% elsif presentation == 'image' %}
    <span class="filter-swatch-img">
      {%- if value.image -%}
      {{
        value.image
        | image_url: width: 300
        | image_tag: class: 'swatch_image', alt: value.alt
      }}
    {% endif %}
    </span>
  {% endif %}

  <span class="filter-swatch-text">{{ value.label | escape }}</span> 

  