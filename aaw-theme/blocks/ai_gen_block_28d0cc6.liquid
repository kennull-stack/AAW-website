{% doc %}
  @prompt
    i want a section with dark background, which takes in 3D file like .glb, customer can rotate and view the model, for the 3d model file, page width medium
    
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-model-viewer-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_desktop }}px 0;
  }

  .ai-model-viewer-container-{{ ai_gen_id }} {
    max-width: 800px;
    margin: 0 auto;
    width: {{ block.settings.desktop_width_percent }}%;
  }

  .ai-model-viewer-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: {{ block.settings.viewer_height }}px;
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
    background-color: {{ block.settings.viewer_background }};
  }

  .ai-model-viewer-element-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
  }

  .ai-model-viewer-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, {{ block.settings.viewer_background }} 0%, {{ block.settings.background_color }} 100%);
    position: relative;
  }

  .ai-model-viewer-placeholder-{{ ai_gen_id }} svg {
    width: 120px;
    height: 120px;
    opacity: 0.3;
    margin-bottom: 20px;
  }

  .ai-model-viewer-empty-text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: 16px;
    text-align: center;
    padding: 0 20px;
  }

  .ai-model-viewer-controls-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 12px;
    margin-top: 20px;
    flex-wrap: wrap;
  }

  .ai-model-viewer-button-{{ ai_gen_id }} {
    padding: 10px 20px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text }};
    border: 1px solid {{ block.settings.button_border }};
    border-radius: {{ block.settings.button_radius }}px;
    cursor: pointer;
    font-size: 14px;
    transition: all 0.3s ease;
  }

  .ai-model-viewer-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text }};
    border-color: {{ block.settings.button_hover_border }};
  }

  .ai-model-viewer-info-{{ ai_gen_id }} {
    text-align: center;
    margin-top: 16px;
    color: {{ block.settings.text_color }};
    font-size: 14px;
  }

  @media screen and (max-width: 749px) {
    .ai-model-viewer-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_mobile }}px 0;
    }

    .ai-model-viewer-container-{{ ai_gen_id }} {
      width: 95%;
    }

    .ai-model-viewer-wrapper-{{ ai_gen_id }} {
      height: {{ block.settings.viewer_height_mobile }}px;
    }

    .ai-model-viewer-controls-{{ ai_gen_id }} {
      gap: 8px;
    }

    .ai-model-viewer-button-{{ ai_gen_id }} {
      padding: 8px 16px;
      font-size: 13px;
    }
  }
{% endstyle %}

<model-viewer-block-{{ ai_gen_id }}
  class="ai-model-viewer-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-model-viewer-container-{{ ai_gen_id }}">
    <div class="ai-model-viewer-wrapper-{{ ai_gen_id }}">
      {% if block.settings.model_file %}
        <model-viewer
          class="ai-model-viewer-element-{{ ai_gen_id }}"
          src="{{ block.settings.model_file }}"
          alt="{{ block.settings.model_alt }}"
          camera-controls
          auto-rotate="{{ block.settings.auto_rotate }}"
          rotation-per-second="{{ block.settings.rotation_speed }}deg"
          {% if block.settings.enable_ar %}ar{% endif %}
          {% if block.settings.enable_zoom %}disable-zoom="false"{% else %}disable-zoom="true"{% endif %}
          loading="lazy"
        ></model-viewer>
      {% else %}
        <div class="ai-model-viewer-placeholder-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M12 2L2 7l10 5 10-5-10-5z"/>
            <path d="M2 17l10 5 10-5"/>
            <path d="M2 12l10 5 10-5"/>
          </svg>
          <div class="ai-model-viewer-empty-text-{{ ai_gen_id }}">
            Upload a 3D model file (.glb or .gltf) to get started
          </div>
        </div>
      {% endif %}
    </div>

    {% if block.settings.model_file %}
      <div class="ai-model-viewer-controls-{{ ai_gen_id }}">
        <button
          class="ai-model-viewer-button-{{ ai_gen_id }}"
          data-action="reset"
        >
          Reset View
        </button>
        {% if block.settings.enable_ar %}
          <button
            class="ai-model-viewer-button-{{ ai_gen_id }}"
            data-action="ar"
          >
            View in AR
          </button>
        {% endif %}
      </div>

      {% if block.settings.show_instructions %}
        <div class="ai-model-viewer-info-{{ ai_gen_id }}">
          {{ block.settings.instructions_text }}
        </div>
      {% endif %}
    {% endif %}
  </div>
</model-viewer-block-{{ ai_gen_id }}>

<script type="module">
  (function() {
    class ModelViewerBlock{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.loadModelViewerLibrary();
        this.setupControls();
      }

      loadModelViewerLibrary() {
        if (!customElements.get('model-viewer')) {
          const script = document.createElement('script');
          script.type = 'module';
          script.src = 'https://ajax.googleapis.com/ajax/libs/model-viewer/3.3.0/model-viewer.min.js';
          document.head.appendChild(script);
        }
      }

      setupControls() {
        const resetButton = this.querySelector('[data-action="reset"]');
        const arButton = this.querySelector('[data-action="ar"]');
        const modelViewer = this.querySelector('model-viewer');

        if (resetButton && modelViewer) {
          resetButton.addEventListener('click', () => {
            modelViewer.resetTurntableRotation();
            modelViewer.cameraOrbit = modelViewer.getCameraOrbit();
            modelViewer.fieldOfView = '45deg';
          });
        }

        if (arButton && modelViewer) {
          arButton.addEventListener('click', () => {
            modelViewer.activateAR();
          });
        }
      }
    }

    customElements.define('model-viewer-block-{{ ai_gen_id }}', ModelViewerBlock{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "3D model viewer",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "3D model"
    },
    {
      "type": "text",
      "id": "model_file",
      "label": "Model file URL",
      "info": "Upload your .glb or .gltf file to Files in Shopify admin, then paste the URL here"
    },
    {
      "type": "text",
      "id": "model_alt",
      "label": "Model description",
      "default": "3D model"
    },
    {
      "type": "header",
      "content": "Viewer settings"
    },
    {
      "type": "range",
      "id": "viewer_height",
      "label": "Viewer height (desktop)",
      "min": 300,
      "max": 800,
      "step": 50,
      "unit": "px",
      "default": 600
    },
    {
      "type": "range",
      "id": "viewer_height_mobile",
      "label": "Viewer height (mobile)",
      "min": 250,
      "max": 600,
      "step": 50,
      "unit": "px",
      "default": 400
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "checkbox",
      "id": "auto_rotate",
      "label": "Auto-rotate model",
      "default": true
    },
    {
      "type": "range",
      "id": "rotation_speed",
      "label": "Rotation speed",
      "min": 10,
      "max": 100,
      "step": 10,
      "unit": "°",
      "default": 30
    },
    {
      "type": "checkbox",
      "id": "enable_zoom",
      "label": "Enable zoom",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_ar",
      "label": "Enable AR view",
      "default": true,
      "info": "Allows viewing the model in augmented reality on supported devices"
    },
    {
      "type": "header",
      "content": "Instructions"
    },
    {
      "type": "checkbox",
      "id": "show_instructions",
      "label": "Show instructions",
      "default": true
    },
    {
      "type": "text",
      "id": "instructions_text",
      "label": "Instructions text",
      "default": "Drag to rotate • Scroll to zoom • Pinch to zoom on mobile"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section background",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "viewer_background",
      "label": "Viewer background",
      "default": "#2a2a2a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Button background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_text",
      "label": "Button text",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_border",
      "label": "Button border",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_background",
      "label": "Button hover background",
      "default": "#a60c0c"
    },
    {
      "type": "color",
      "id": "button_hover_text",
      "label": "Button hover text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_border",
      "label": "Button hover border",
      "default": "#a60c0c"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_desktop",
      "label": "Padding (desktop)",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_mobile",
      "label": "Padding (mobile)",
      "min": 0,
      "max": 80,
      "step": 10,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "button_radius",
      "label": "Button border radius",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 25
    }
  ],
  "presets": [
    {
      "name": "3D model viewer"
    }
  ]
}
{% endschema %}