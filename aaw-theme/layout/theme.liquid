<!doctype html>
  <html class="no-js" lang="{{ request.locale.iso_code }}">
    <head>
      <meta charset="utf-8">
      <meta http-equiv="X-UA-Compatible" content="IE=edge">
      <meta name="viewport" content="width=device-width,initial-scale=1">
      <meta name="theme-color" content="#F5F5F5">
      {% render 'meta-tags' %}
      <link rel="canonical" href="{{ canonical_url }}">
      {%- if request.page_type == 'product' or request.page_type == 'index' or request.page_type == 'collection' -%}
        {{ 'aaw-judgeme-reviews.css' | asset_url | stylesheet_tag }}
        <script src="{{ 'aaw-judgeme-reviews.js' | asset_url }}&aaw_reviews=photo-first-longest-alt-v4" defer></script>
      {%- endif -%}
      {%- if template.name == 'product' and product.handle == 'z05-auag-launch-edition' -%}
        <link rel="alternate" hreflang="en" href="https://www.aaw.me/products/z05-auag-launch-edition">
        <link rel="alternate" hreflang="zh-Hans" href="https://www.aaw.me/zh/products/z05-auag-launch-edition">
        <link rel="alternate" hreflang="zh-Hant" href="https://www.aaw.me/zh-tw/products/z05-auag-launch-edition">
        <link rel="alternate" hreflang="ja" href="https://www.aaw.me/ja/products/z05-auag-launch-edition">
        <link rel="alternate" hreflang="ko" href="https://www.aaw.me/ko/products/z05-auag-launch-edition">
        <link rel="alternate" hreflang="x-default" href="https://www.aaw.me/products/z05-auag-launch-edition">
        {{ 'z05-product.css' | asset_url | stylesheet_tag }}
      {%- elsif request.page_type == 'page' and page.handle == 'get-started' -%}
        {{ 'get-started.css' | asset_url | stylesheet_tag }}
      {%- elsif request.page_type == 'page' and page.handle == 'shipping-return' -%}
        {{ 'shipping-return.css' | asset_url | stylesheet_tag }}
      {%- elsif request.page_type == 'page' and page.handle == 'warranty-and-refit' -%}
        {{ 'warranty-and-refit.css' | asset_url | stylesheet_tag }}
      {%- elsif request.page_type == 'page' and page.handle == 'what-is-custom-in-ear-monitor' -%}
        {{ 'what-is-ciem.css' | asset_url | stylesheet_tag }}
      {%- elsif request.page_type == 'page' and page.handle == 'what-is-universal-in-ear-monitor' -%}
        {{ 'what-is-uiem.css' | asset_url | stylesheet_tag }}
      {%- elsif request.page_type == 'index' -%}
        <link rel="alternate" hreflang="en" href="https://www.aaw.me/">
        <link rel="alternate" hreflang="x-default" href="https://www.aaw.me/">
      {%- endif -%}
      <link rel="preconnect" href="https://cdn.shopify.com" crossorigin>
      {%- if settings.favicon != blank -%}
        <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
      {%- endif -%}

      {%- unless settings.type_header_font.system? and settings.type_body_font.system? -%}
        <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
      {%- endunless -%}
      <link rel="preload" as="style" href="{{ 'country-flags.css' | asset_url }}" onload="this.onload=null;this.rel='stylesheet'">
      <noscript>{{ 'country-flags.css' | asset_url | stylesheet_tag }}</noscript>

      {%- if request.page_type == 'index' -%}
        <link rel="preload" as="image" href="{{ 'z07-monitors-on-beige-marble.jpg' | asset_img_url: '700x' }}" media="(max-width: 767px)">
        <link rel="preload" as="image" href="{{ 'z07-model-wearing-universal-fit-over-ear-cable.jpg' | asset_img_url: '1600x' }}" imagesrcset="{{ 'z07-model-wearing-universal-fit-over-ear-cable.jpg' | asset_img_url: '1200x' }} 1200w, {{ 'z07-model-wearing-universal-fit-over-ear-cable.jpg' | asset_img_url: '1600x' }} 1600w, {{ 'z07-model-wearing-universal-fit-over-ear-cable.jpg' | asset_img_url: '2000x' }} 2000w" imagesizes="100vw" media="(min-width: 768px)">
      {%- elsif request.page_type == 'product' and product.handle == 'z05-auag-launch-edition' -%}
        <link rel="preload" as="image" href="{{ 'z05-auag-luxury-portrait-hero-optimized.jpg' | asset_img_url: '1024x' }}">
      {%- elsif request.page_type == 'product' and product.handle == 'z07-in-ear-monitor' -%}
        <link rel="preload" as="image" href="{{ 'z07-worn-in-ear-fitmorph-hero.jpg' | asset_img_url: '1600x' }}">
      {%- elsif request.page_type == 'product' and product.handle contains 'm20' -%}
        <link rel="preload" as="image" href="{{ 'm20-gallery-3.jpg' | asset_img_url: '1600x' }}">
      {%- endif -%}

      {%- if request.page_type == 'page' and page.handle == 'about-us' -%}
        <title>About Advanced AcousticWerkes | Singapore IEM Specialist Founded by Kevin Wang</title>
        <meta name="description" content="Advanced AcousticWerkes (AAW) is a Singapore in-ear monitor specialist founded in 2014 by Kevin Wang, known for custom IEMs, hybrid tuning, and the Z Series.">
        <script>
          (function () {
            if (window.location.pathname === '/pages/about-us' && !new URLSearchParams(window.location.search).has('view')) {
              window.location.replace('/pages/about-us?view=about-brand-v13');
            }
          })();
        </script>
      {%- elsif request.page_type == 'index' -%}
        <title>Advanced AcousticWerkes | Singapore IEM Specialist</title>
        <meta name="description" content="AAW designs custom and universal in-ear monitors from Singapore since 2014. Audition the Z07, Z06, and Z05 AuAg at 76 Playfair Rd or four authorized dealers islandwide.">
        <meta name="geo.region" content="SG">
        <meta name="geo.placename" content="Singapore">
        <meta name="geo.position" content="1.3364791;103.8865741">
        <meta name="ICBM" content="1.3364791, 103.8865741">
      {%- else -%}
        <title>
          {{ page_title }}
        </title>

        {% if page_description %}
          <meta name="description" content="{{ page_description | escape }}">
        {% endif %}
      {%- endif -%}
      {{ content_for_header }}
      {%- if request.page_type == 'index' -%}
        {%- render 'aaw-home-schema' -%}
      {%- endif -%}

      {%- render 'global-style-variables' -%}
      {%- render 'global-variables' -%}
    </head>
    <body class="{{ settings.other_layout }} button-hover-{{ settings.button_hover_effect }}{% if settings.enable_animation %} animation-on{% endif %}">
      <a class="unstyled-link skip-to-content-link button focus-inside{% if settings.enable_button_shadow %} button-shadow{% endif %}" href="#MainContent">
        {{ 'accessibility.skip_to_text' | t }}
      </a>
      <div class="body-main">
        {% sections 'header-group' %}
        <main id="MainContent" class="main-content focus-none" role="main" tabindex="-1" >
          {%- if request.page_type == 'page' and page.handle == 'about-us' -%}
            {% section 'aaw-about-brand-v13' %}
          {%- else -%}
            {{ content_for_layout }}
          {%- endif -%}
        </main>
        <div class="custom-footer-group">
        {% sections 'footer-group' %}
        </div>
        {% section 'mobile-dock' %}
      </div>
        {% render 'newsletter-popup' %}
        {% render 'cookies-popup' %}
        {% render 'age-verification' %}
        {% render 'search-drawer' %}
        {% section 'cart-drawer' %}
        {% render 'quick-view' %}
        {% render 'scroll-top' %}

        {% if settings.enable_shipping and settings.shipping_rate != blank %}
          <div id="mini-cart-shipping"  data-minicart-shipping {% if settings.enable_shipping and settings.shipping_rate != blank %}  data-shipping-rate="{{ settings.shipping_rate | times: 100 }}" data-shippin-text="{{ settings.shipping_text }}"{% endif %}>
          </div>
        {% endif %}
        {% if settings.enable_animation %}
          <script>
            document.addEventListener("DOMContentLoaded",function(){
              AOS.init({
                startEvent: 'DOMContentLoaded',
                offset: 100,
                once: true,
              });
            });
          </script>
        {% endif %}
      <script>
        document.documentElement.className = document.documentElement.className.replace('no-js', 'js');
        if (Shopify.designMode) {
          document.documentElement.classList.add('shopify-design-mode');
        }
    window.theme = window.theme || {};
    window.shopUrl = '{{ request.origin }}';
    window.routes = {
      shop_url: '{{ request.origin }}',
      root_url: '{{ routes.root_url }}',
      cart_url: '{{ routes.cart_url }}',
      cart_add_url: '{{ routes.cart_add_url }}',
      cart_change_url: '{{ routes.cart_change_url }}',
      cart_update_url: '{{ routes.cart_update_url }}',
      search_url: '{{ routes.search_url }}',
      predictive_search_url: '{{ routes.predictive_search_url }}',
    };

    theme.settings = {
      moneyFormat: '{{ shop.money_format }}',
      moneyWithCurrencyFormat: '{{ shop.money_with_currency_format }}',
      currencyCodeEnabled: '{{ shop.enabled_currencies }}',
    };

    window.cartStrings = {
      error: `{{ 'sections.cart.cart_error' | t }}`,
      quantityError: `{{ 'sections.cart.cart_quantity_error_html' | t: quantity: '[quantity]' }}`,
    };

    window.variantStrings = {
      preOrder: `{{ 'products.product.preorder' | t }}`,
      addToCart: `{{ 'products.product.add_to_cart' | t }}`,
      soldOut: `{{ 'products.product.sold_out' | t }}`,
      unavailable: `{{ 'products.product.unavailable' | t }}`,
      unavailable_with_option: `{{ 'products.product.value_unavailable' | t: option_value: '[value]' }}`,
    };

      </script>

    </body>
  </html>
